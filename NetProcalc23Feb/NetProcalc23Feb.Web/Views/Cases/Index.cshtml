@model IEnumerable<NetProcalc23Feb.Domain.Entities.Case>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Cases</h2>
  <a class="btn btn-primary" href="/Cases/Create">New Case</a>
</div>
<table class="table table-striped">
  <thead><tr><th>Case #</th><th>Date</th><th>Obligor</th><th>Obligee</th><th></th></tr></thead>
  <tbody>
  @foreach (var c in Model)
  {
      <tr>
        <td>@c.CaseId</td>
        <td>@c.Date</td>
        <td>@c.Obligor</td>
        <td>@c.Obligee</td>
        <td><a class="btn btn-sm btn-outline-secondary" href="/Cases/Edit/@c.Id">Edit</a></td>
      </tr>
  }
  </tbody>
</table>
