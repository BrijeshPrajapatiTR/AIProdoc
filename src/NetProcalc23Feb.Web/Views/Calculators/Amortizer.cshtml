@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<h4>Obligation Amortizer</h4>
<form method="post" class="row g-2">
  <div class="col-md-3"><label>Principal</label><input name="principal" class="form-control" type="number" step="0.01"></div>
  <div class="col-md-3"><label>Annual Interest %</label><input name="annualRate" class="form-control" type="number" step="0.01"></div>
  <div class="col-md-3"><label>Months</label><input name="months" class="form-control" type="number"></div>
  <div class="col-md-3 align-self-end"><button class="btn btn-primary">Compute</button></div>
</form>
@if(ViewBag.Payment != null){ <div class="alert alert-info mt-3">Monthly Payment: @ViewBag.Payment</div> }
