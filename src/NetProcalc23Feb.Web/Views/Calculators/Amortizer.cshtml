<h2>Obligation Amortizer</h2>
<form method="post" class="row g-3">
  <div class="col-md-3"><label class="form-label">Principal</label><input name="principal" type="number" step="0.01" class="form-control" value="@ViewBag.Principal" /></div>
  <div class="col-md-3"><label class="form-label">Annual Rate (%)</label><input name="rateAnnual" type="number" step="0.01" class="form-control" value="@ViewBag.Rate" /></div>
  <div class="col-md-3"><label class="form-label">Terms / Year</label><input name="termsPerYear" type="number" class="form-control" value="@ViewBag.TPY" /></div>
  <div class="col-md-3"><label class="form-label">Years</label><input name="years" type="number" class="form-control" value="@ViewBag.Years" /></div>
  <div class="col-12"><button class="btn btn-primary">Compute</button></div>
</form>
@if (ViewBag.Payment != null){<div class="alert alert-info mt-3">Payment per term: <strong>@ViewBag.Payment</strong></div>}
