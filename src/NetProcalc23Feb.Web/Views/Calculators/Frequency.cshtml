@{ Layout = "~/Views/Shared/_Layout.cshtml"; }
<h4>Calculate Semi-monthly / Biweekly / Weekly Amounts</h4>
<form method="post" class="row g-2">
  <div class="col-md-3"><label>Amount</label><input name="amount" class="form-control" type="number" step="0.01"></div>
  <div class="col-md-3"><label>From</label>
    <select name="from" class="form-select">
      <option value="1">Monthly</option><option value="2">SemiMonthly</option><option value="3">BiWeekly</option><option value="4">Weekly</option>
    </select>
  </div>
  <div class="col-md-3"><label>To</label>
    <select name="to" class="form-select">
      <option value="1">Monthly</option><option value="2">SemiMonthly</option><option value="3">BiWeekly</option><option value="4">Weekly</option>
    </select>
  </div>
  <div class="col-md-3 align-self-end"><button class="btn btn-primary">Convert</button></div>
</form>
@if(ViewBag.Result != null){ <div class="alert alert-info mt-3">Result: @ViewBag.Result</div> }
