<h2>Child Support (General / Adjustment)</h2>
<form method="post" action="/Calculators/ChildSupport" class="row g-3">
  <div class="col-md-4"><label class="form-label">Obligor Monthly Income</label><input name="obligorMonthlyIncome" type="number" step="0.01" class="form-control" /></div>
  <div class="col-md-4"><label class="form-label">Obligee Monthly Income</label><input name="obligeeMonthlyIncome" type="number" step="0.01" class="form-control" /></div>
  <div class="col-md-4"><label class="form-label">Baseline %</label><input name="baselinePercent" type="number" step="0.01" class="form-control" value="20" /></div>
  <div class="col-12"><button class="btn btn-primary">Calculate</button></div>
</form>
