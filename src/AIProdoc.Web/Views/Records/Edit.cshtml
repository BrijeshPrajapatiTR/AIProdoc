@model Record
@{
    ViewData["Title"] = "Edit Record";
}
<h2>Edit</h2>
<form method="post">
  <input type="hidden" asp-for="Id" />
  <div class="mb-3"><label class="form-label">Name</label><input asp-for="Name" class="form-control" /></div>
  <div class="mb-3"><label class="form-label">Description</label><textarea asp-for="Description" class="form-control"></textarea></div>
  <div class="mb-3"><label class="form-label">Amount</label><input asp-for="Amount" class="form-control" /></div>
  <div class="mb-3"><label class="form-label">Date</label><input asp-for="Date" type="date" class="form-control" /></div>
  <div asp-validation-summary="All" class="text-danger"></div>
  <button class="btn btn-primary" type="submit">Save</button>
  <a class="btn btn-secondary" href="/Records">Cancel</a>
</form>
