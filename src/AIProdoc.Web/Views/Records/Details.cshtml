@model Record
@{
    ViewData["Title"] = "Record Details";
}
<h2>Details</h2>
<dl class="row">
  <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
  <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
  <dt class="col-sm-3">Amount</dt><dd class="col-sm-9">@Model.Amount.ToString("C")</dd>
  <dt class="col-sm-3">Date</dt><dd class="col-sm-9">@Model.Date.ToShortDateString()</dd>
</dl>
<a class="btn btn-secondary" href="/Records">Back</a>
