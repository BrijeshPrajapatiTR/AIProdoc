%CheckedAssignValue DEPEND %CheckedAssigns DEFAULT TIMES 0

%CheckedHides DEPEND %Control MULTI LONG TIMES 0

%CheckedControl DEPEND %CheckedHides DEFAULT TIMES 0

%CheckedControlAction DEPEND %CheckedHides DEFAULT TIMES 2
WHEN  ('')TIMES 0
WHEN  ('?LINE1')TIMES 0

%UncheckedAssigns DEPEND %Control MULTI LONG TIMES 0

%UncheckedAssignVariable DEPEND %UncheckedAssigns FIELD TIMES 0

%UncheckedAssignValue DEPEND %UncheckedAssigns DEFAULT TIMES 0

%UnCheckedHides DEPEND %Control MULTI LONG TIMES 0

%UnCheckedControl DEPEND %UnCheckedHides DEFAULT TIMES 0

%UnCheckedControlAction DEPEND %UnCheckedHides DEFAULT TIMES 2
WHEN  ('')TIMES 0
WHEN  ('?LINE1')TIMES 0

%Parameters DEFAULT  ('')
[EMBED]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?OkButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
GLO:IsAnyFullReportSelected = 0
If ?ChkFullReportChild{PROP:Checked}
  RetVal = BOR(RetVal, 0000001b)
  GLO:IsAnyFullReportSelected = 1
END
If ?ChkFullReportMedical{PROP:Checked}
  RetVal = BOR(RetVal, 0000010b)
  GLO:IsAnyFullReportSelected = 1
END
If ?ChkFullReportDental{PROP:Checked}
  RetVal = BOR(RetVal, 0000100b)
  GLO:IsAnyFullReportSelected = 1
END
If ?ChkSummaryChild{PROP:Checked}
  RetVal = BOR(RetVal, 0001000b)
END
If ?ChkSummaryMedical{PROP:Checked}
  RetVal = BOR(RetVal, 0010000b)
END
If ?ChkSummaryDental{PROP:Checked}
  RetVal = BOR(RetVal, 0100000b)
END

If RetVal <= 0
  MESSAGE('Please select report(s)')
ELSE
  POST(EVENT:CloseWindow)
END
[END]
[END]
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 1
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[WINDOW]
SelectionWindow WINDOW('Print Selection'),AT(,,207,142),FONT('MS Sans Serif',8,,FONT:regular), |
          GRAY
          PROMPT('Summary'),AT(43,23),USE(?PROMPT1:2),FONT('Microsoft Sans Serif',,,FONT:bold), |
            #ORDINAL(1)
          CHECK('Child Support'),AT(30,47),USE(?ChkSummaryChild),#ORDINAL(2)
          CHECK('Medical Support'),AT(30,60),USE(?ChkSummaryMedical),#ORDINAL(3)
          CHECK('Dental Support'),AT(30,74),USE(?ChkSummaryDental),#ORDINAL(4)
          LINE,AT(108,18,0,66),USE(?LINE1),COLOR(COLOR:Black),#ORDINAL(5)
          PROMPT('Full Report'),AT(131,23),USE(?PROMPT1),FONT('Microsoft Sans Serif',,,FONT:bold), |
            #ORDINAL(6)
          CHECK('Child Support'),AT(123,47),USE(?ChkFullReportChild),#ORDINAL(7)
          CHECK('Medical Support'),AT(123,61),USE(?ChkFullReportMedical),#ORDINAL(8)
          CHECK('Dental Support'),AT(123,74),USE(?ChkFullReportDental),#ORDINAL(9)
          BUTTON('&OK'),AT(92,116,47,14),USE(?OkButton),LEFT,ICON('WAOk.ico'),DEFAULT,#ORDINAL(10)
          BUTTON('&Cancel'),AT(145,116,47,14),USE(?CancelButton),LEFT,ICON('WACancel.ico'), |
            STD(STD:Close),#ORDINAL(11)
        END

[END]
