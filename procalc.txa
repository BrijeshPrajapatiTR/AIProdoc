EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?Cancel'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF MESSAGE('Cancel the saving data operation?','Cancel Request',ICON:QUESTION,|
            BUTTON:YES+BUTTON:NO,BUTTON:YES) = BUTTON:YES
  POST(EVENT:CLOSEWINDOW)
END
[END]
[END]
[END]
EMBED %WindowEventHandling
[INSTANCES]
WHEN 'Timer'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  !IF ExportCompleted
  !  POST(EVENT:CloseWindow)
  !ELSIF DeleteCompleted
  !  DO ExportRecords
  !ELSE
  !  DO DeleteExisting
  !END

  IF ExportCompleted
    POST(EVENT:CloseWindow)
  ELSIF DeleteCompleted
    IF ~LOC:ExpFamilyDone
      LOC:VOLUME_ID=GLO:VOLUME_ID
      DO ExportRecordsFAM
    ELSIF ~LOC:ExpAdopDone
      LOC:VOLUME_ID='TXADOPT'
      DO ExportRecordsADOP
    END
  ELSE
    IF ~LOC:DelFamilyDone
      LOC:VOLUME_ID=GLO:VOLUME_ID
      DO DeleteExistingFAM
    ELSIF ~LOC:DelAdopDone
      LOC:VOLUME_ID='TXADOPT'
      DO DeleteExistingADOP
    END
  END
[END]
[END]
EMBED %ProcedureInitialize
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!FIRST ADD ALL TOKENS TO BE REMOVED IN THE QUEUE
FREE(DeletedTokensQue)
DTQ:OBJ_ID='PX096'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX098'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='AX005'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='AX010'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='AX020'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX060'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX062'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX064'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX066'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='AX015'
ADD(DeletedTokensQue)
!@Vedant FB28901
!  DTQ:OBJ_ID='A0091'
!  ADD(DeletedTokensQue)
!@Vedant
DTQ:OBJ_ID='PX068'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX070'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX072'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX074'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX076'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX051'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX052'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX053'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX054'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX055'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX056'
ADD(DeletedTokensQue)
DTQ:OBJ_ID='PX057'
ADD(DeletedTokensQue)
!Ma - Fogbugz case 14024, added new token A0054V 6/18/07
DTQ:OBJ_ID='A0054'
ADD(DeletedTokensQue)
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 1
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[WINDOW]
window  WINDOW('Saving Data To ProDoc'),AT(,,182,87),DOUBLE,CENTER,CURSOR(CURSOR:None),GRAY, |
          TIMER(1)
          SHEET,AT(7,6,169,59),USE(?Sheet1),WIZARD,#ORIG(?Sheet1),#ORDINAL(1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1),#ORDINAL(2)
              STRING('Please wait ...'),AT(21,18),USE(?String3),#ORIG(?String3),#ORDINAL(3)
              PROGRESS,AT(52,40,78,14),USE(LOC:Progress),RANGE(0,100),#ORIG(?Progress1),#ORDINAL(4)
            END
          END
          BUTTON('&Cancel'),AT(65,70,45,14),USE(?Cancel),LEFT,ICON('cancel.ico'),HIDE,#ORIG(?Button1), |
            #ORDINAL(5)
        END

[END]
