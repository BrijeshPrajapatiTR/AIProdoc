window  WINDOW('Delinquent Support Calculator'),AT(,,379,255),FONT('MS Sans Serif',8,,FONT:regular, |
          CHARSET:ANSI),DOUBLE,CENTER,ICON('prowin.ico'),GRAY,MDI,HLP('~Delinquent_Obli' & |
          'gations_Form'),SYSTEM
          SHEET,AT(3,8,374,217),USE(?CurrentTab),#ORIG(CurrentTab),#ORDINAL(1)
            TAB('&Names'),USE(?NamesTab),#ORDINAL(2)
              CHECK('SUIT filed on or after 9/1/2021'),AT(83,50),USE(GLO:FiledAfterSep1Delinquency), |
                HIDE,TRN,#ORDINAL(3)
              PROMPT('Obligo&r:'),AT(51,87),USE(?CAS:PETITIONER:Prompt),#LINK(?GLO:Obligor), |
                #ORIG(?CAS:PETITIONER:Prompt),#ORDINAL(4)
              ENTRY(@s80),AT(83,84,246,12),USE(GLO:Obligor),#LINK(?CAS:PETITIONER:Prompt), |
                #ORIG(CAS:PETITIONER),#ORDINAL(5)
              PROMPT('Obli&gee:'),AT(51,132),USE(?CAS:RESPONDENT:Prompt),#LINK(?GLO:Obligee), |
                #ORIG(?CAS:RESPONDENT:Prompt),#ORDINAL(6)
              ENTRY(@s80),AT(83,130,245,12),USE(GLO:Obligee),#LINK(?CAS:RESPONDENT:Prompt), |
                #ORIG(CAS:RESPONDENT),#ORDINAL(7)
            END
            TAB('O&bligations'),USE(?ObligationsTab),#ORDINAL(8)
              LIST,AT(9,28,207,172),USE(?QOBLIGATE),VSCROLL,ALRT(InsertKey),ALRT(DeleteKey), |
                ALRT(EnterKey),ALRT(MouseLeft2),FORMAT('45R|M~Date~C(0)@d2@42R|M~Amount' & |
                '~C(0)@n-10.2@48C|~Frequency~@s12@90C|~Type~@s20@'),FROM(QObligate),VCR,#FIELDS(QOB:ODate, |
                QOB:OAmount,QOB:Frequency,QOB:ObligateTypeDisplayText),#ORIG(?List2),#ORDINAL(9)
              GROUP('Quick Entry'),AT(233,25,137,175),USE(?Group3),BOXED,#ORIG(?Group3),#ORDINAL(10)
                PROMPT('Use these buttons to create/update multiple support obligations' & |
                  '.  All entries created will have the same amount and frequency.  Aft' & |
                  'er creation, individual entries can be modified.'),AT(238,39,131,88),USE(?Prompt13), |
                  #ORIG(?Prompt13),#ORDINAL(11)
                BUTTON('Change &Multiple Obligations'),AT(250,178,104,15),USE(?ChangeRange), |
                  TIP('make changes within the specified range of records'),#ORIG(?Button16), |
                  #ORDINAL(12)
                BUTTON('&Add Multiple Obligations'),AT(250,159,104,15),USE(?RangeObligate), |
                  TIP('insert the specified range of records'),#ORIG(?Button10),#ORDINAL(13)
              END
              BUTTON('Ne&w'),AT(9,204,48,15),USE(?InsertObligation),LEFT,ICON('5insert.ico'), |
                TIP('insert a new record'),#ORIG(?Button11),#ORDINAL(14)
              BUTTON('&Update'),AT(57,204,48,15),USE(?ChangeObligation),LEFT,ICON('5edit.ico'), |
                TIP('change the highlighted record'),#ORIG(?Button10),#ORDINAL(15)
              BUTTON('&Delete'),AT(109,204,48,15),USE(?DeleteObligation),LEFT,ICON('5delete.ico'), |
                TIP('delete the highlighted record'),#ORIG(?Button13),#ORDINAL(16)
            END
            TAB('Pa&yments'),USE(?PaymentsTab),#ORDINAL(17)
              LIST,AT(9,28,147,172),USE(?QPAYMENT),VSCROLL,ALRT(InsertKey),ALRT(EnterKey), |
                ALRT(DeleteKey),ALRT(MouseLeft2),FORMAT('45L|~Date~L(10)@d2@42L|~Amount' & |
                '~L(10)@n-10.2@'),FROM(QPayments),VCR,#FIELDS(QPA:PDate,QPA:PAmount),#ORIG(?List2), |
                #ORDINAL(18)
              GROUP('Quick Entry'),AT(197,25,168,175),USE(?Group4),BOXED,#ORIG(?Group4),#ORDINAL(19)
                PROMPT('Use these buttons to create/update multiple payments.  All entr' & |
                  'ies created will have the same amount.  After creation, individual e' & |
                  'ntries can be modified.'),AT(209,39,149,88),USE(?Prompt14),#ORIG(?Prompt14), |
                  #ORDINAL(20)
                BUTTON('&Add Multiple Payments'),AT(229,159,104,15),USE(?PaymentRangeButton), |
                  TIP('insert the specified range of records'),#ORIG(?Button14),#ORDINAL(21)
                BUTTON('Change &Multiple Payments'),AT(229,178,104,15),USE(?ButtonRangeChange), |
                  TIP('make changes within the specified range of records'),#ORIG(?Button16), |
                  #ORDINAL(22)
              END
              BUTTON('Ne&w'),AT(9,204,48,15),USE(?InsertPayment),LEFT,ICON('5insert.ico'), |
                TIP('insert a new record'),#ORIG(?Button10),#ORDINAL(23)
              BUTTON('&Update'),AT(57,204,48,15),USE(?ChangePayment),LEFT,ICON('5edit.ico'), |
                TIP('change the highlighted record'),#ORIG(?Button11),#ORDINAL(24)
              BUTTON('&Delete'),AT(109,204,48,15),USE(?DeletePayment),LEFT,ICON('5delete.ico'), |
                TIP('delete the highlighted record'),#ORIG(?Button13),#ORDINAL(25)
            END
            TAB('&Judgment'),USE(?Tab5),#ORIG(?Tab5),#ORDINAL(26)
              SHEET,AT(10,46,355,154),USE(JudgmentSupportTabSelected),#ORDINAL(27)
                TAB('&Child Support'),USE(?JudgmentChildSupport),#ORDINAL(28)
                END
                TAB('&Medical Support'),USE(?JudgmentMedicalSupport),#ORDINAL(29)
                END
                TAB('Dental &Support'),USE(?JudgmentDentalSupport),#ORDINAL(30)
                END
              END
              STRING('(Note - compound interest is compounded annually)'),AT(90,30),USE(?String7), |
                #ORIG(?String7),#ORDINAL(31)
              ENTRY(@d2<50B),AT(153,70,60,12),USE(NAM:ConfirmedDate),#ORIG(CAS:ConfirmedDate), |
                #ORDINAL(32)
              PROMPT('&Date rendered:'),AT(95,71),USE(?Prompt4),#ORIG(?Prompt4),#ORDINAL(33)
              BUTTON,AT(219,69,15,14),USE(?Calendar),ICON('smcal.ico'),FLAT,SKIP,#ORIG(?Calendar), |
                #SEQ(2),#ORDINAL(34)
              STRING(' (mm/dd/yyyy)'),AT(235,71),USE(?String6),#ORIG(?String6),#ORDINAL(35)
              GROUP('Arrears'),AT(21,89,169,92),USE(?Group1),BOXED,#ORIG(?Group1),#ORDINAL(36)
                PROMPT('&Amount of judgment:'),AT(46,108),USE(?Prompt3),#ORIG(?Prompt3),#ORDINAL(37)
                ENTRY(@n13.2),AT(117,106,60,12),USE(NAM:ConfirmedPrincipal),#ORIG(CAS:ConfirmedAmount), |
                  #ORDINAL(38)
                PROMPT('&Interest rate:'),AT(46,124),USE(?Prompt5),#ORIG(?Prompt5),#ORDINAL(39)
                ENTRY(@n6.2),AT(117,124,60,12),USE(NAM:ConfirmedInterestRate),#ORIG(CAS:ConfirmedInterestRate), |
                  #ORDINAL(40)
                OPTION('Interest &Type:'),AT(29,151,153,26),USE(NAM:InterestType),BOXED,#ORIG(?Option1), |
                  #ORDINAL(41)
                  RADIO('Simple'),AT(53,162),USE(?SimpleButton),VALUE('SIMPLE'),#ORIG(?Option1:Radio1), |
                    #ORDINAL(42)
                  RADIO('Compound'),AT(105,162),USE(?CompoundButton),VALUE('COMPOUND'),#ORIG(?Option1:Radio2), |
                    #ORDINAL(43)
                END
              END
              GROUP('Attorney''s Fees and Costs'),AT(199,89,155,92),USE(?Group2),BOXED,#ORIG(?Group2), |
                #ORDINAL(44)
                PROMPT('Am&ount of judgment:'),AT(213,108),USE(?Prompt11),#ORIG(?Prompt11), |
                  #ORDINAL(45)
                ENTRY(@n13.2),AT(282,108,60,12),USE(ATT:AttyFeescosts),#ORIG(ATT:ConfimedAttyFees), |
                  #ORDINAL(46)
                PROMPT('Interest &rate:'),AT(213,124),USE(?Prompt12),#ORIG(?Prompt12),#ORDINAL(47)
                ENTRY(@n6.2),AT(282,124,60,12),USE(ATT:InterestRate),#ORIG(ATT:ConfirmedInterestRate), |
                  #ORDINAL(48)
                OPTION('Interest T&ype'),AT(206,151,130,25),USE(ATT:InterestType),BOXED,#ORIG(?Option2), |
                  #ORDINAL(49)
                  RADIO('Simple'),AT(229,162),USE(?Option2:Radio1),VALUE('SIMPLE'),#ORIG(?Option2:Radio1), |
                    #ORDINAL(50)
                  RADIO('Compound'),AT(281,162),USE(?Option2:Radio2),VALUE('COMPOUND'),#ORIG(?Option2:Radio2), |
                    #ORDINAL(51)
                END
              END
            END
            TAB('D&ebit'),USE(?Tab6),#ORIG(?Tab6),#ORDINAL(52)
              SHEET,AT(53,82,273,124),USE(DebitSupportTabSelected),IMM,#ORDINAL(53)
                TAB('&Child Support'),USE(?DebitChildSupport),#ORDINAL(54)
                END
                TAB('&Medical Support'),USE(?DebitMedicalSupport),#ORDINAL(55)
                END
                TAB('Dental &Support'),USE(?DebitDentalSupport),#ORDINAL(56)
                END
              END
              STRING('This Debit is used for the special case where the AG''s office ga' & |
                'rnished an amount in'),AT(53,33),USE(?String1),#ORIG(?String1),#ORDINAL(57)
              STRING('excess of the amount authorized by law and then, subsequently, de' & |
                'bits the excess'),AT(53,44),USE(?String2),#ORIG(?String2),#ORDINAL(58)
              STRING('payment and sends a refund to the obligor. Enter the date and the' & |
                ' amounts that should'),AT(53,54),USE(?String4),#ORIG(?String4),#ORDINAL(59)
              STRING('be debited to each portion of the obligation.'),AT(53,65),USE(?String5), |
                #ORIG(?String5),#ORDINAL(60)
              PROMPT('&Date:'),AT(73,118),USE(?Prompt7),#ORIG(?Prompt7),#ORDINAL(61)
              ENTRY(@d2<50b),AT(153,118,47,12),USE(EXT:DebitDate),#ORIG(LOC:CreditDate),#ORDINAL(62)
              BUTTON,AT(205,115,15,14),USE(?Calendar:2),ICON('smcal.ico'),FLAT,SKIP,#ORIG(?Calendar), |
                #SEQ(4),#ORDINAL(63)
              STRING('(mm/dd/yyyy)'),AT(221,118),USE(?String8),#ORIG(?String8),#ORDINAL(64)
              PROMPT('Unconfirmed oblig&ation:'),AT(73,137),USE(?Prompt6),#ORIG(?Prompt6), |
                #ORDINAL(65)
              ENTRY(@n-11.2),AT(153,134,47,12),USE(EXT:DebitUobl),#ORIG(EXT:DebitUobl),#ORDINAL(66)
              PROMPT('Unconfirmed &interest:'),AT(73,153),USE(?Prompt10),#ORIG(?Prompt10), |
                #ORDINAL(67)
              ENTRY(@n-11.2),AT(153,150,47,12),USE(EXT:DebitUint),#ORIG(EXT:DebitUint),#ORDINAL(68)
              PROMPT('Confi&rmed obligation:'),AT(73,169),USE(?Prompt9),#ORIG(?Prompt9),#ORDINAL(69)
              ENTRY(@n-11.2),AT(153,166,47,12),USE(EXT:DebitCobl),#ORIG(EXT:DebitCobl),#ORDINAL(70)
              PROMPT('Confirmed in&terest:'),AT(73,185),USE(?Prompt8),#ORIG(?Prompt8),#ORDINAL(71)
              ENTRY(@n-11.2),AT(153,182,47,12),USE(EXT:DebitCint),#ORIG(EXT:DebitCint),#ORDINAL(72)
            END
          END
          BUTTON('&Save and Close'),AT(260,231,60,19),USE(?OK),LEFT,ICON('ok.ico'),DEFAULT, |
            TIP('save all information and quit this program'),#ORIG(?OK),#ORDINAL(73)
          BUTTON('&Cancel'),AT(323,231,52,19),USE(?Cancel),LEFT,ICON('cancel.ico'),TIP('quit this ' & |
            'program without saving information'),#ORIG(?Cancel),#ORDINAL(74)
          BUTTON('  &Help'),AT(2,231,48,19),USE(?Help),LEFT,ICON(ICON:Help),STD(STD:Help), |
            TIP('display help'),#ORDINAL(75)
          BUTTON('&Print'),AT(52,231,48,19),USE(?PrintButton),LEFT,ICON('5printme.ico'),TIP('print report'), |
            #ORIG(?Button17),#ORDINAL(76)
          BUTTON('C&lipboard'),AT(102,231,58,19),USE(?ClipboardButton),LEFT,ICON(ICON:Paste), |
            TIP('copy obligations owed and payments to clipboard'),#ORIG(?Button13),#ORDINAL(77)
          BUTTON('Sa&ve and Continue'),AT(197,231,60,19),USE(?SaveAndContinueButton),LEFT, |
            ICON('save.ico'),TIP('save all information and continue with this program'),#ORIG(?Button18), |
            #ORDINAL(78)
        END

