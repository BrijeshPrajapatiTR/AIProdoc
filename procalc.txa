[WINDOW]
QuickWindow WINDOW('Obligations'),AT(,,237,153),FONT('MS Sans Serif',8,,FONT:regular),DOUBLE, |
          CENTER,GRAY,IMM,HLP('~Obligations_Form'),SYSTEM
          SHEET,AT(5,2,227,130),USE(?Sheet1),SPREAD,#ORIG(?Sheet1),#ORDINAL(1)
            TAB('Obligation'),USE(?Tab1),FONT(,,,FONT:bold,CHARSET:ANSI),#ORIG(?Tab1),#ORDINAL(2)
              OPTION('&Obligation Types'),AT(12,17,215,36),USE(QOB:Type),FONT('MS Sans Serif', |
                8,,FONT:regular),BOXED,#ORIG(QOB:Frequency),#ORDINAL(14)
                RADIO('Child Support'),AT(19,33,55,10),USE(?Option1:ChildSupport),VALUE('Child'), |
                  #ORIG(?Option1:Monthly),#ORDINAL(15)
                RADIO('Medical Support'),AT(87,33,71,10),USE(?Option1:MedicalSupport),VALUE('Medical'), |
                  #ORIG(?Option1:semimonthly),#ORDINAL(16)
                RADIO('Dental Support'),AT(162,33,60,10),USE(?Option1:DentalSupport),VALUE('Dental'), |
                  #ORIG(?Option1:weekly),#ORDINAL(17)
              END
              PROMPT('Date:'),AT(17,60),USE(?OBL:DATE:Prompt),#LINK(?QOB:ODate),#ORIG(?OBL:DATE:Prompt), |
                #ORDINAL(3)
              ENTRY(@d2<50b),AT(53,58,53,12),USE(QOB:ODate),REQ,#LINK(?OBL:DATE:Prompt),#ORIG(OBL:DATE), |
                #ORDINAL(4)
              STRING('(mm/dd/yyyy)'),AT(125,60),USE(?String2),#ORIG(?String2),#ORDINAL(5)
              PROMPT('Amount:'),AT(17,76),USE(?OBL:AMOUNT:Prompt),#LINK(?QOB:OAmount),#ORIG(?OBL:AMOUNT:Prompt), |
                #ORDINAL(6)
              ENTRY(@n-10.2),AT(53,74,53,12),USE(QOB:OAmount),REQ,#LINK(?OBL:AMOUNT:Prompt), |
                #ORIG(OBL:AMOUNT),#ORDINAL(7)
              BUTTON,AT(109,58,15,14),USE(?Calendar),ICON('smcal.ico'),FLAT,SKIP,#ORIG(?Calendar), |
                #SEQ(4),#ORDINAL(8)
              OPTION('&Frequency Options'),AT(12,92,215,36),USE(QOB:Frequency),BOXED,#ORIG(Option1), |
                #ORDINAL(9)
                RADIO('Monthly'),AT(17,110,43),USE(?Option1:Monthly),VALUE('Monthly'),#ORIG(?Option1:Radio1), |
                  #ORDINAL(10)
                RADIO('Semi-monthly'),AT(64,110,61),USE(?Option1:semimonthly),VALUE('Semi-monthly'), |
                  #ORIG(?Option1:Radio2),#ORDINAL(11)
                RADIO('Weekly'),AT(128,110),USE(?Option1:weekly),VALUE('Weekly'),#ORIG(?Option1:Radio3), |
                  #ORDINAL(12)
                RADIO('Bi-weekly'),AT(174,110,51),USE(?Option1:biweekly),VALUE('Bi-weekly'), |
                  #ORIG(?Option1:Radio4),#ORDINAL(13)
              END
            END
          END
          BUTTON('&OK'),AT(130,135,50,15),USE(?OK),LEFT,ICON('ok.ico'),DEFAULT,#ORIG(?Button5), |
            #ORDINAL(19)
          BUTTON('&Cancel'),AT(183,135,50,15),USE(?Cancel),LEFT,ICON('cancel.ico'),#ORIG(?Cancel), |
            #SEQ(3),#ORDINAL(20)
          BUTTON('&Repeat'),AT(78,135,50,15),USE(?MultiAddButton),LEFT,ICON('RETRY.ICO'),#ORIG(?Button4), |
            #ORDINAL(21)
          BUTTON('&Help'),AT(5,135,50,15),USE(?Help),LEFT,ICON(ICON:Help),STD(STD:Help),#ORDINAL(22)
        END

[END]
