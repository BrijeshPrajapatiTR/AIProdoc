%Parameters DEFAULT  ('')
[EMBED]
EMBED %AfterWindowOpening
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF OriginalRequest = InsertRecord
  QOB:ODATE = ''
  QOB:OAMOUNT = ''
  ?OK{PROP:DEFAULT} = FALSE
  ?MultiAddButton{PROP:DEFAULT} = TRUE
  QOB:Frequency='Monthly'
!   @Parth - FB28903
  QOB:Type = 'Child'
  
!   @Parth 
ELSE
  ?OK{PROP:DEFAULT} = TRUE
  DISABLE(?MultiAddButton)
.
[END]
EMBED %WindowEventHandling
[INSTANCES]
WHEN 'CloseWindow'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF MultiAdd
!  SaveAmount = OBL:AMOUNT
!  DO PrimeFields
!  IF LocalResponse = RequestCancelled
!    DO ProcedureReturn
!  END
!  OBL:AMOUNT = SaveAmount
!  LocalResponse = RequestCancelled
!  MultiAdd = FALSE
!  POST(EVENT:OPENWINDOW)
!  CYCLE
!END
[END]
[END]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?MultiAddButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF ~QOB:ODATE
  MESSAGE('You must enter a date for the obligation.',,ICON:EXCLAMATION,|
          BUTTON:OK,BUTTON:OK)
  SELECT(?QOB:ODATE)
  CYCLE
END

IF ~QOB:OAMOUNT
  MESSAGE('You must enter an amount for the obligation.',,ICON:EXCLAMATION,|
          BUTTON:OK,BUTTON:OK)
  SELECT(?QOB:OAMOUNT)
  CYCLE
END


IF QOB:OAMOUNT < 0
  MESSAGE('The obligation amount cannot be negative',,ICON:EXCLAMATION,|
          BUTTON:OK,BUTTON:OK)
  SELECT(?QOB:OAMOUNT)
  CYCLE
.

!-----MA ADDED CODE TO DO NOT ALLOW ADDING DUPLICATE DATE   7/25/01
LOC:DATE=QOB:ODATE
LOC:AMOUNT=QOB:OAmount
LOC:Frequency=QOB:Frequency    !MA ADDED  2/15/02
IF OriginalRequest = ChangeRecord
  DUP#=0
  P#=POINTER(QObligate)
  LOOP I#=1 TO RECORDS(QObligate)
    GET(QObligate,I#)
    IF ERRORCODE() THEN BREAK.
    IF QOB:ODATE<>LOC:DATE THEN CYCLE.
    IF QOB:ODATE=LOC:DATE AND P#=I# THEN CYCLE.
    MESSAGE('Every obligation should have different date.','Duplicate Date')
    DUP#=1
    BREAK
  END
  GET(QObligate,P#)     !SHOULDN'T CARE THIS BECAUSE FOR ChangeRecord REQUEST THE ?MultiAddButton WAS DISABLE
  SELECT(?QOB:ODATE)
  IF DUP# THEN CYCLE.
ELSIF OriginalRequest = InsertRecord
  GET(QObligate,QOB:ODATE)
  IF ~ERRORCODE()
    MESSAGE('Every obligation should have different date.','Duplicate Date')
    QOB:ODATE=LOC:DATE
    QOB:OAmount=LOC:AMOUNT
    QOB:Frequency=LOC:Frequency    !MA ADDED  2/15/02
    SELECT(?QOB:ODATE)
    CYCLE
  END
END
!---------------------------------------

DO UpdateRecord
GLO:UpdateObligate = TRUE
QOB:ODATE = ''
SELECT(?QOB:ODate)
[END]
[END]
[END]
EMBED %ControlPostEventHandling
[INSTANCES]
WHEN '?OK'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF ~QOB:ODATE
  MESSAGE('You must enter a date for the obligation.',,ICON:EXCLAMATION,|
          BUTTON:OK,BUTTON:OK)
  SELECT(?QOB:ODATE)
  CYCLE
END

IF ~QOB:OAMOUNT
  MESSAGE('You must enter an amount for the obligation.',,ICON:EXCLAMATION,|
          BUTTON:OK,BUTTON:OK)
  SELECT(?QOB:OAMOUNT)
  CYCLE
END


IF QOB:OAMOUNT < 0
  MESSAGE('The obligation amount cannot be negative',,ICON:EXCLAMATION,|
          BUTTON:OK,BUTTON:OK)
  SELECT(?QOB:OAMOUNT)
  CYCLE
.
!-----MA ADDED CODE TO DO NOT ALLOW ADDING DUPLICATE DATE   7/25/01
LOC:DATE=QOB:ODATE
LOC:AMOUNT=QOB:OAmount
LOC:Frequency=QOB:Frequency    !MA ADDED  2/15/02
!@Parth - FB28903
LOC:Type=QOB:Type
!@Parth
IF OriginalRequest = ChangeRecord
  DUP#=0
  P#=POINTER(QObligate)
  LOOP I#=1 TO RECORDS(QObligate)
    GET(QObligate,I#)
    IF ERRORCODE() THEN BREAK.
    IF QOB:ODATE<>LOC:DATE THEN CYCLE.
    !@Parth - FB28903
    IF LOC:Type <> QOB:Type THEN CYCLE.
    !@Parth
    IF QOB:ODATE=LOC:DATE AND P#=I# THEN CYCLE.
    MESSAGE('Every obligation must have a different date. This obligation '|
          & 'cannot be saved for this date.','Duplicate Date')
    DUP#=1
    BREAK
  END
  GET(QObligate,P#)
  QOB:ODATE=LOC:DATE
  QOB:OAmount=LOC:AMOUNT
  QOB:Frequency=LOC:Frequency    !MA ADDED  2/15/02
  !@Parth - FB28903
  QOB:Type = LOC:Type
  CASE UPPER(QOB:Type)
  OF 'CHILD'
    QOB:TypeSort = SupportType:Children
  OF 'MEDICAL'
    QOB:TypeSort = SupportType:Medical
  OF 'DENTAL'
    QOB:TypeSort = SupportType:Dental
  END
  !@Parth
  IF DUP#
    SELECT(?QOB:ODATE)
    CYCLE
  END
ELSIF OriginalRequest = InsertRecord
!@Parth - FB28903
!  GET(QObligate,QOB:ODATE)
  GET(QObligate,QOB:ODATE,QOB:Type)
 !@Parth
  IF ~ERRORCODE()
    MESSAGE('Every obligation must have a different date. This obligation '|
          & 'cannot be saved for this date.','Duplicate Date')
    QOB:ODATE=LOC:DATE
    QOB:OAmount=LOC:AMOUNT
    QOB:Frequency=LOC:Frequency    !MA ADDED  2/15/02
    !@Parth - FB28903
    QOB:Type = LOC:Type
    CASE UPPER(QOB:Type)
    OF 'CHILD'
      QOB:TypeSort = SupportType:Children
    OF 'MEDICAL'
      QOB:TypeSort = SupportType:Medical
    OF 'DENTAL'
      QOB:TypeSort = SupportType:Dental
    END
    !@Parth
    SELECT(?QOB:ODATE)
    CYCLE
  END
END
!---------------------------------------
DO UpdateRecord
GLO:UpdateObligate = TRUE
LocalResponse = RequestCompleted
[GROUP]
PRIORITY 4000
INSTANCE 2
[END]
[END]
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!------------------------------
UpdateRecord     ROUTINE
!------------------------------
! @Parth - FB28903 
  CASE UPPER(QOB:Type)
  OF 'CHILD'
    QOB:ObligateTypeDisplayText = 'Child Support'
  OF 'MEDICAL'
    QOB:ObligateTypeDisplayText = 'Medical Support'
  OF 'DENTAL'
    QOB:ObligateTypeDisplayText = 'Dental Support'
  END
! @Parth 

  IF OriginalRequest = InsertRecord
    QOB:OCaseID = CAS:CAS_ID
    ADD(QOBLIGATE,QOB:ODATE)
  ELSIF OriginalRequest = ChangeRecord
    PUT(QOBLIGATE)
  END

  IF ~ERRORCODE()
    GLO:UpdateObligate = TRUE
  END
[END]
EMBED %DataSectionBeforeWindow
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
LOC:DATE       LONG
LOC:Amount     DECIMAL(7,2)
LOC:Frequency  STRING(12)
LOC:Type          like(QOB:Type)
[END]
[END]
