%Parameters DEFAULT  ('')
[EMBED]
EMBED %AfterWindowOpening
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF OriginalRequest = InsertRecord
  QPA:PDATE = ''
  QPA:PAMOUNT = ''
  ?OK{PROP:DEFAULT} = FALSE
  ?MultiAddButton{PROP:DEFAULT} = TRUE
ELSE
  ?OK{PROP:DEFAULT} = TRUE
  DISABLE(?MultiAddButton)
.
[END]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?Ok'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF ~QPA:PDATE
  MESSAGE('The payment date cannot be blank.',,ICON:EXCLAMATION,|
          BUTTON:OK,BUTTON:OK)
  SELECT(?QPA:PDATE)
  CYCLE
END

IF ~QPA:PAMOUNT
  MESSAGE('The payment amount cannot be 0.00.',,ICON:EXCLAMATION,|
          BUTTON:OK,BUTTON:OK)
  SELECT(?QPA:PAMOUNT)
  CYCLE
END

IF QPA:PAMOUNT < 0
  MESSAGE('The payment amount cannot be negative',,ICON:EXCLAMATION,|
          BUTTON:OK,BUTTON:OK)
  SELECT(?QPA:PAMOUNT)
  CYCLE
.
[END]
[END]
WHEN '?MultiAddButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF ~QPA:PDATE
  SELECT(?QPA:PDATE)
  CYCLE
END

IF ~QPA:PAMOUNT
  SELECT(?QPA:PAMOUNT)
  CYCLE
END

DO UpDateRecord

GLO:UpdatePayments = TRUE

QPA:PDATE = ''

SELECT(?QPA:PDATE)
[END]
[END]
[END]
EMBED %ControlPostEventHandling
[INSTANCES]
WHEN '?OK'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
DO UpDateRecord
GLO:UpdatePayments = TRUE
[GROUP]
PRIORITY 4000
INSTANCE 4
[END]
[END]
WHEN '?Cancel'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
LocalResponse = RequestCancelled
[GROUP]
PRIORITY 4000
INSTANCE 5
[END]
[END]
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!------------------------------
UpdateRecord     ROUTINE
!------------------------------

  IF OriginalRequest = InsertRecord
    QPA:PCaseID = CAS:CAS_ID
    ADD(QPAYMENTS,QPA:PDATE)
  ELSIF OriginalRequest = ChangeRecord
    PUT(QPAYMENTS)
  END

  IF ~ERRORCODE()
    GLO:UpdatePayments = TRUE
  END
[END]
[END]
