[WINDOW]
window  WINDOW('Enter A Range Of Obligations'),AT(,,347,188),FONT('MS Sans Serif',8,,FONT:regular), |
          DOUBLE,CENTER,GRAY,HLP('~Range_Insert_Form')
          SHEET,AT(7,4,333,158),USE(?Sheet1),WIZARD,#ORIG(?Sheet1),#ORDINAL(1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1),#ORDINAL(2)
              GROUP('&Inclusive Dates'),AT(15,13,99,57),USE(?Group1),BOXED,#ORIG(?Group1), |
                #ORDINAL(3)
                STRING('(mm/dd/yyyy)'),AT(47,24),USE(?String3),#ORIG(?String3),#ORDINAL(4)
                BUTTON,AT(94,33,15,14),USE(?Calendar),ICON('smcal.ico'),FLAT,SKIP,#ORIG(?Calendar), |
                  #SEQ(3),#ORDINAL(5)
                PROMPT('&From:'),AT(21,37),USE(?Prompt5),#ORIG(?Prompt5),#ORDINAL(6)
                ENTRY(@d2<50B),AT(46,35,45,12),USE(FromDate),#ORIG(FromDate),#ORDINAL(7)
                PROMPT('&To:'),AT(22,55),USE(?Prompt6),#ORIG(?Prompt6),#ORDINAL(8)
                ENTRY(@d2<50B),AT(46,53,45,12),USE(ToDate),REQ,#ORIG(ToDate),#ORDINAL(9)
                BUTTON,AT(94,51,15,14),USE(?Calendar:2),ICON('smcal.ico'),FLAT,SKIP,#ORIG(?Calendar), |
                  #SEQ(4),#ORDINAL(10)
              END
              OPTION('&Obligation Types'),AT(120,13,210,26),USE(ObligationType),FONT(,8),BOXED, |
                #ORIG(PaymentOption),#ORDINAL(11)
                RADIO('Child Support'),AT(130,24,57,10),USE(?Option1:ChildSupport),VALUE('Child'), |
                  #ORIG(?Option1:Monthly),#ORDINAL(12)
                RADIO('Medical Support'),AT(191,24,67,10),USE(?Option1:MedicalSupport),VALUE('Medical'), |
                  #ORIG(?Option1:weekly),#ORDINAL(13)
                RADIO('Dental Support'),AT(261,24,61,10),USE(?Option1:DentalSupport),VALUE('Dental'), |
                  #ORIG(?Option1:biweekly),#ORDINAL(14)
              END
              OPTION('&Payment Options'),AT(120,44,210,26),USE(PaymentOption),BOXED,#ORIG(Option1), |
                #ORDINAL(15)
                RADIO('Monthly'),AT(130,55,40),USE(?Option1:Monthly),VALUE('A'),#ORIG(?Option1:Radio1), |
                  #ORDINAL(16)
                RADIO('Semi-monthly'),AT(174,55,56),USE(?Option1:semimonthly),VALUE('B'),#ORIG(?Option1:Radio2), |
                  #ORDINAL(17)
                RADIO('Weekly'),AT(234,55),USE(?Option1:weekly),VALUE('C'),#ORIG(?Option1:Radio3), |
                  #ORDINAL(18)
                RADIO('Bi-weekly'),AT(282,55,41),USE(?Option1:biweekly),VALUE('D'),#ORIG(?Option1:Radio4), |
                  #ORDINAL(19)
              END
              PROMPT('&Amount of each obligation:'),AT(75,79),USE(?Prompt1),#ORIG(?Prompt1), |
                #ORDINAL(20)
              ENTRY(@n-10.2),AT(200,77,46,12),USE(ObligationAmount),#ORIG(ObligationAmount), |
                #ORDINAL(21)
              PROMPT('&Day of month first payment is due:'),AT(75,96),USE(?PromptFirstDay), |
                #ORIG(?Prompt2),#ORDINAL(22)
              SPIN(@n3),AT(200,94,25,12),USE(FirstDay),RANGE(1,28),STEP(1),REQ,#ORIG(?Spin1), |
                #ORDINAL(23)
              CHECK('&Last day of the month'),AT(233,95),USE(MonthlyLastDay),VALUE('1','0'), |
                #ORIG(MonthlyLastDay),#ORDINAL(24)
              PROMPT('Day of &month second payment is due:'),AT(75,114),USE(?PromptSecondDay), |
                DISABLE,#ORIG(?Prompt4),#ORDINAL(25)
              SPIN(@n3),AT(200,112,25,12),USE(SecondDay),DISABLE,RANGE(1,30),STEP(1),#ORIG(?Spin2), |
                #ORDINAL(26)
              CHECK('La&st day of the month'),AT(233,113),USE(SemiMonthlyLastDay),DISABLE, |
                #ORIG(SemiMonthlyLastDay),#ORDINAL(27)
              PROMPT('Day of &week payments are due:'),AT(75,130),USE(?PromptDayOfWeek),DISABLE, |
                #ORIG(?Prompt3),#ORDINAL(28)
              LIST,AT(200,128,61,12),USE(DayOfWeek),VSCROLL,DISABLE,DROP(7),FORMAT('36L@s9@'), |
                FROM('Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday'),#FIELDS(DayOfWeek), |
                #ORIG(?List1),#ORDINAL(29)
            END
          END
          BUTTON('&OK'),AT(237,170,50,15),USE(?OkButton),LEFT,ICON('ok.ico'),DEFAULT,#ORDINAL(30)
          BUTTON('&Cancel'),AT(290,170,50,15),USE(?CancelButton),LEFT,ICON('cancel.ico'),#ORDINAL(31)
          BUTTON('&Help'),AT(7,170,50,15),USE(?Help),LEFT,ICON(ICON:Help),STD(STD:Help),#ORIG(?Button3), |
            #ORDINAL(32)
        END

[END]
