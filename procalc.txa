!This is a flag so the 1st time uint is called in 2000
! any credit balance in delbalbefore is moved over to DelBalAfter
FirstTimeIn2000     byte(0)


QCOUNTER            LONG
FirstDelinquent     LONG
!TotalObligations     LONG
PaymentCounter      LONG
ObligateCounter     LONG
CurrentRecord       LONG
RejectRecord        LONG
LocalRequest        LONG
LocalResponse       LONG
WindowOpened        LONG
RecordsToProcess    LONG
RecordsProcessed    LONG
RecordsPerCycle     LONG
RecordsThisCycle    LONG
PercentProgress     BYTE
RecordStatus        BYTE
