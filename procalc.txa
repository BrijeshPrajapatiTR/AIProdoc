[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
IF KEYCODE() = MOUSELEFT2
  POST(EVENT:ACCEPTED,?ChangePayment)
  CYCLE
.
IF ~RECORDS(QPayments)
  DISABLE(?ChangePayment)
  DISABLE(?DeletePayment)
  !DISABLE(?ChangeRange)
  DISABLE(?ButtonRangeChange)
  SELECT(?InsertPayment)
ELSE
  ENABLE(?ChangePayment)
  ENABLE(?DeletePayment)
  !ENABLE(?ChangeRange)
  ENABLE(?ButtonRangeChange)
END
