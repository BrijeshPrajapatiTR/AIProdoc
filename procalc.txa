EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!----------------------------
BuildExport           ROUTINE
!----------------------------
  CLEAR(ExportQueue)
  FREE(ExportQueue)
  SaveChildrenInCourt = ChildrenInCourt
  SaveTotalChildren   = TotalChildren
  QCounter = 0
  ChildrenInCourt += 1
  TotalChildren   += 1
  Loop
    ChildrenInCourt -= 1
    TotalChildren -= 1
    If ChildrenInCourt < 1 THEN BREAK.
    SHOWMESSAGE=FALSE   !MA ADDED TO AVOID DISPLAYING WARNING MESSAGE TWO TIMES  2/6/02
    DontShowMsg=TRUE
    DO CalculateNet
    QCounter += 1
    ExportQueue:ExpMonthly = ChildMonthly
    ExportQueue:ExpSemiMonthly = ChildSemiMonthly
    ExportQueue:ExpWeekly = ChildWeekly
    ExportQueue:ExpBiWeekly = ChildBiWeekly
    ADD(ExportQueue)
  END
  ChildrenInCourt = SaveChildrenInCourt
  TotalChildren = SaveTotalChildren
  DontShowMsg=FALSE
  DO Recalc
  DISPLAY()

!----------------------------
Recalc           ROUTINE
!----------------------------
  !DontShowMsg=FALSE
  DO CalculateNet

!------------------------
CalculateNet     ROUTINE
!------------------------
  IF TotalChildren < ChildrenInCourt
    ChildMonthly = ''
    ChildSemiMonthly = ''
    ChildWeekly = ''
    ChildBiWeekly = ''
    UNHIDE(?Message4)
    EXIT
  ELSE
   HIDE(?Message4)
  .

  DO CalcTax

  NetMonthlyIncome = NetResources               !This amount is being
                                                ! preserved so it can be
                                                ! printed on the printout

  NetResources += NonTaxableMonthly
  NetResources -= UnionDues
  NetResources -= HealthInsurance
  NetResources -= Adjustment                    !This is the 154.123 adjust.
  NetResources -= StateIncomeTax

  IF ~InitCalc

  !The NetResources is Real data type and if it's 6000 then NetResources > 6000.00 will return true so use different way
  ! to detect the condition MA 11/17/06

  !Ma - Fogbugz case 14024, based on the "Suit was filed on or after 9/1/2007" checkbox, the ceiling on net resources is
  ! different so need to show different message 6/18/07

  !Ma - Fogbugz case 19568, removed the Glo:IsOnAfter090107 and only calculate for netresource 7500.00 9/26/08
  !RGR - FBZ# 25153, Noe NetResource > $9200.00
    !if Glo:IsOnAfter090107
      !RGR - FBZ# 25153, netresource now $8550.00
      !rRealForComparison = round(NetResources - 7500, 0.01)
      rRealForComparison = round(NetResources - 9200, 0.01)
      IF rRealForComparison > 0
        IF ~ALREADYSHOWN
          IF SHOWMESSAGE
            !RGR - FBZ# 25153, NetResource now calculates on $8550.00
            !Message('Note - section 154.125 states that the guidelines are specific' |
            !  & 'ally designed for situations in which obligor''s net resources' |
            !  & ' are $7,500.00 or less.  In this case, Net Resources are $' |
            !  & CLIP(LEFT(FORMAT(NetResources,@N12.2))) & '.  Section 154.062 covers how to compute net' |
            !  & ' resources and Section 154.126 explains how to calculate support' |
            !  & ' when net resources are greater than $7,500.00.',,ICON:EXCLAMATION,BUTTON:OK,BUTTON:OK)
            Message('Note - section 154.125 states that the guidelines are specific' |
              & 'ally designed for situations in which obligor''s net resources' |
              & ' are $9,200.00 or less.  In this case, Net Resources are $' |
              & CLIP(LEFT(FORMAT(NetResources,@N12.2))) & '.  Section 154.062 covers how to compute net' |
              & ' resources and Section 154.126 explains how to calculate support' |
              & ' when net resources are greater than $9,200.00.',,ICON:EXCLAMATION,BUTTON:OK,BUTTON:OK)
              ALREADYSHOWN=TRUE
          ELSE
            SHOWMESSAGE=TRUE
          END
        END
      ELSE
        ALREADYSHOWN=FALSE
      END
!    else
!      rRealForComparison = round(NetResources - 6000, 0.01)
!      !IF NetResources > 6000.00
!      IF rRealForComparison > 0
!        IF ~ALREADYSHOWN
!          IF SHOWMESSAGE
!            Message('Note - section 154.125 states that the guidelines are specific' |
!              & 'ally designed for situations in which obligor''s net resources' |
!              & ' are $6,000.00 or less.  In this case, Net Resources are $' |
!              & CLIP(LEFT(FORMAT(NetResources,@N12.2))) & '.  Section 154.062 covers how to compute net' |
!              & ' resources and Section 154.126 explains how to calculate support' |
!              & ' when net resources are greater than $6,000.00.',,ICON:EXCLAMATION,BUTTON:OK,BUTTON:OK)
!              ALREADYSHOWN=TRUE
!          ELSE
!            SHOWMESSAGE=TRUE
!          END
!        END
!      ELSE
!        ALREADYSHOWN=FALSE
!      END
!    end
  ELSE
    InitCalc=FALSE
    ALREADYSHOWN=FALSE
  END

  AltNetResources = NetResources !Save this for doing alternative calculations
                                 ! in the report
  DO CalculateObligation

!-------------------------------
CalculateObligation   ROUTINE
!-------------------------------
  HIDE(?Message5)
  HIDE(?Message6)
  !@Vedant FB28901
  !IF GLO:FiledAfterSep1 = TRUE AND NetResources < 1000
   IF NetResources < 1000 !Case 1601337
      CASE TotalChildren
    OF 1
      ChildMonthly = NetResources * .15
    OF 2
      ChildMonthly = NetResources * .20
    OF 3
      ChildMonthly = NetResources * .25
    OF 4
      ChildMonthly = NetResources * .30
    ELSE
      ChildMonthly = NetResources * .35
    END
  ELSE
     CASE TotalChildren
    OF 1
      ChildMonthly = NetResources * .20
    OF 2
      ChildMonthly = NetResources * .25
    OF 3
      ChildMonthly = NetResources * .30
    OF 4
      ChildMonthly = NetResources * .35
    ELSE
      ChildMonthly = NetResources * .40
    END
  END
 !@Vedant
              !!!!!This was changed in June 2000 because if disablity income was higher than
              ! the obligation it was not showing as a negative amount.  It was displaying
              ! an incorrect obligation

  ChildMonthly = Round(ChildMonthly, 0.01)   !TO BE SAME AS PDA MA 12/20/05

  !MA CHANGED FOLLOWING CODE BECAUSE OF NEW LAW
  TotalBenefits=DisabilityIncome+SocialSecurityBenefits
  IF TotalBenefits                         !If the child is receiving disabilty income
    !If TotalBenefits < ChildMonthly
    rRealForComparison = TotalBenefits
    !Ma - Fogbugz case 12822, replace "<" with "<=" and do not show message 12/11/2007
    If rRealForComparison <= ChildMonthly   !If disablity income is less than obligation
      ChildMonthly -= TotalBenefits        ! credit that to obligor's obligation ( Sec.
      ChildSemiMonthly = ChildMonthly/2    ! 154.132 effective September 1, 1999
      ChildWeekly = (ChildMonthly * 12)/52

      ChildWeekly = Round(ChildWeekly, 0.01) !TO BE SAME AS PDA MA 12/20/05

      ChildBiWeekly = ChildWeekly * 2
      BenefitsGTMonthly=0
    ELSE                                   !But if disablity income exceeds obligation set all obligations to 0
      !If TotalBenefits > ChildMonthly AND ~LOC:Print1 AND ~DontShowMsg   !If disablity income is less than obligation
      If rRealForComparison > ChildMonthly AND ~LOC:Print1 AND ~DontShowMsg   !If disablity income is less than obligation
        !MESSAGE('NOTE! - The amount of monthly benefits child(ren) received exceeds the amount of the support obligation.')
        DontShowMsg=TRUE
      END
      !Ma - Fogbugz case 12822, code below should be done after "If" and message statements 12/11/2007
      ChildMonthly     = 0                 
      ChildSemiMonthly = 0
      ChildWeekly      = 0
      ChildBiWeekly    = 0
      BenefitsGTMonthly=1
    END
  ELSE         !If not receiving disablity income
    ChildSemiMonthly = ChildMonthly/2
    ChildWeekly = (ChildMonthly * 12)/52

    ChildWeekly = Round(ChildWeekly, 0.01) !TO BE SAME AS PDA MA 12/20/05

    ChildBiWeekly = ChildWeekly * 2
    BenefitsGTMonthly=0
  END

  IF ChildrenInCourt > 5
      UNHIDE(?Message5)
      UNHIDE(?Message6)
  END

  HouseholdCredit = 0            !initialize this to 0 !!!!!!THIS LINE ADDED FOR 1997.1


  NetBeforeCredit = NetResources                     !This was added for 2001 because the report was
                                                     ! changed to show the credit for children in multiple
                                                     ! households as an adjustment to net resources.  No calculations
                                                     ! were changed.  This value is just calculated and displayed
                                                     ! and the NetResources is displayed as "Adjusted Net Resources"

  IF TotalChildren > ChildrenInCourt
    DO HouseholdAdjustment
  END
 
!---------------------------
HouseholdAdjustment   ROUTINE
!----------------------------
  !MA CHANGED FOLLOWING CODE TO MATCH NEW LAW   6/12/01
  IF ~BenefitsGTMonthly
    IF TotalBenefits                        !If the child is receiving disabilty income
      ChildMonthly += TotalBenefits         ! take the adjustment back out before
    END                                     ! calculating the adjustment

    HouseholdCredit = (ChildMonthly/TotalChildren) * (TotalChildren - ChildrenInCourt)

    NetResources -= HouseholdCredit
    !@Vedant FB28901
    !IF GLO:FiledAfterSep1 = TRUE AND NetResources < 1000 
    IF NetResources < 1000 !Case 1601337
      CASE ChildrenInCourt
    OF 1
      ChildMonthly = NetResources * .15
    OF 2
      ChildMonthly = NetResources * .20
    OF 3
      ChildMonthly = NetResources * .25
    OF 4
      ChildMonthly = NetResources * .30
    ELSE
      ChildMonthly = NetResources * .35
    END
  ELSE
     CASE ChildrenInCourt
    OF 1
      ChildMonthly = NetResources * .20
    OF 2
      ChildMonthly = NetResources * .25
    OF 3
      ChildMonthly = NetResources * .30
    OF 4
      ChildMonthly = NetResources * .35
    ELSE
      ChildMonthly = NetResources * .40
    END
  END
  !@Vedant
    ChildMonthly = Round(ChildMonthly, 0.01)   !TO BE SAME AS PDA MA 12/20/05

    !EACH CASE ABOVE USES SAME CODE SO PUT IT BELOW
    !IF TotalBenefits<ChildMonthly             !If the child is receiving disabilty income
    rRealForComparison = TotalBenefits
    !Ma - Fogbugz case 12822, replace "<" with "<=" and do not show message 12/11/2007
    IF rRealForComparison <= ChildMonthly         !If the child is receiving disabilty income
      ChildMonthly -= TotalBenefits            ! credit that to obligor's obligation ( Sec.
                                               ! 154.132 effective September 1, 1999
      ChildSemiMonthly = ChildMonthly/2
      ChildWeekly = (ChildMonthly * 12)/52

      ChildWeekly = Round(ChildWeekly, 0.01) !TO BE SAME AS PDA MA 12/20/05

      ChildBiWeekly = ChildWeekly * 2
    ELSE
      !If TotalBenefits > ChildMonthly AND ~LOC:Print1 AND ~DontShowMsg   !If disablity income is less than obligation
      If rRealForComparison > ChildMonthly AND ~LOC:Print1 AND ~DontShowMsg   !If disablity income is less than obligation
        !MESSAGE('NOTE! - The amount of monthly benefits child(ren) received exceeds the amount of the support obligation.')
        DontShowMsg=TRUE
      END
      !Ma - Fogbugz case 12822, code below should be done after "If" and message statements 12/11/2007
      ChildMonthly     = 0                     ! set all obligations to 0
      ChildSemiMonthly = 0
      ChildWeekly      = 0
      ChildBiWeekly    = 0
    END
  END

!---------------------------
CalcTax   ROUTINE
!---------------------------
    !MA CHANGED THIS ROUTINE TO CALCULATE NETRESOURCE WITH CALLING A PROCEDURE, AND TAX CHART
    ! IS STORED IN A MODULE QUEUE WHICH WAS PRE-LOADED. 
    !NOTE: THIS ROUTINE IS FOR BOTH EMPLOYED AND SELFEMPLOYED
  !IF GrossMonthlyIncome >= 0 AND GrossMonthlyIncome < 15000.00
  !FB - 28710 - @parth changed this condition because Steve not able to get the correct result for $15000 due to this condition.
  IF GrossMonthlyIncome >= 0 AND GrossMonthlyIncome <= 15000.00
    !Locate record in NumQ using a binary search.
    LocateNumQ(GrossMonthlyIncome)  
    GETAVERAGENUM()

  ELSIF GrossMonthlyIncome => 15000.00
    NQ:ID=15000.00
    GET(NUMQ,NQ:ID)
    GETAVERAGENUM()

  END

!END OF ROUTINES
[END]
