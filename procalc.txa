EMBED %LocalProcedures
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END

ReplaceStringCL.ReplaceString   PROCEDURE(long FEQ, REPORT reportname, string ObligationType)
CODE
  Self.stringcl.str(reportname$FEQ{PROP:Text})
!TODO: Create generic routine which will pass both the string along with stringcl object 
  Self.stringcl.replace('{{SUPPORTTYPE}', CLIP(UPPER(ObligationType)))
  Self.stringcl.replace('{{supporttype}', CLIP(LOWER(ObligationType)))
  Self.stringcl.replace('SUPPORTTYPE', CLIP(UPPER(ObligationType)))
  reportname$FEQ{PROP:Text} = Self.stringcl.str()
  
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END

ReplaceStringCL.Construct   PROCEDURE()
CODE
  Self.stringcl &= New(StringClType)
[END]
