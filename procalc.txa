AttyfeesIntPay        PROCEDURE(string ObligationType, long ObligationCount = -1)
AttyfeescostsInt      PROCEDURE(string ObligationType, long ObligationCount = -1)
PayAttyfeescosts      PROCEDURE(string ObligationType, long ObligationCount = -1)
CompoundInterestAtty  PROCEDURE(long ObligationCount = -1)
PayConfirmedObl       PROCEDURE(string ObligationType, long ObligationCount = -1)
PayDelinquentObl      Procedure(string ObligationType, long ObligationCount = -1)                   
PayCurrentOblBack30   Procedure(String ObligationType, long ObligationCount = -1)
