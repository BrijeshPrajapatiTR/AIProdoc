[MODULE]
[COMMON]
FROM Clarion GENERATED
MODIFIED '2021/06/17' '17:37:56'
[PROCEDURE]
NAME SetGlobals
PROTOTYPE '(string cmdline)'
PARAMETERS '(string cmdline)'
NOEXPORT
[COMMON]
DESCRIPTION 'setup file name variables instead of settings in Main'
FROM Clarion Source
MODIFIED '2021/08/04' '19:09:48'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
COMMANDPAR           STRING(256)
startpos             long
endpos               long
dummy                long
cInfoServerCmd       cstring(80)
loc:asmcaseid        long,auto
!pathcl               pathcltype
!cpath                cstring(256)

Reg                  BGRegistryClass
KEYSTR1              CSTRING(256)
KEYSTR2              CSTRING(32)
KEYVALUE             CSTRING(256)


UserDir              STRING(255)
pathcl               pathcltype

DllParseCl           DllParseClType
bRetValue            BYTE                                  !
bCitrixFlag          BYTE                                  !
szProdocRoot         CSTRING(255)                          !
szProdocUserDir      CSTRING(255)                          !
szProdocEXEPath      CSTRING(255)                          !
sFilePath            STRING(255)
[END]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  DO ResetGlobalVars

    cmdline=upper(cmdline)
    startpos=instring('A=',cmdline,1,1)
    if startpos then
      startpos+=2
      endpos=instring(' ',cmdline,1,startpos)
      if ~endpos then endpos=len(clip(cmdline)) else endpos-=1.
      if numeric(cmdline[startpos : endpos]) then
        glo:InfoServerAddress= cmdline[startpos : endpos]
      end
    end

    startpos=instring('X=',cmdline,1,1)   !GET CALLER'S PROCEDURE(BRW:CLIENTS) ADDRESS
    if startpos then
      startpos+=2
      endpos=instring(' ',cmdline,1,startpos)
      if ~endpos then endpos=len(clip(cmdline)) else endpos-=1.
      if numeric(cmdline[startpos : endpos]) then
        GLO:CallerProcAdd= cmdline[startpos : endpos]
      end
    end

  szProdocUserDir = ''
  sFilePath = ''
  bRetValue          = false
  bRetvalue = DllParseCl.init()
  if ~bRetvalue
    bRetValue = DllParseCl.StartSetup(szProdocRoot, szProdocUserDir, |
               szProdocEXEPath, Glo:StaffId, GLO:CALLER, glo:citrixFlag, |
               GLO:VOLUME_ID, CMDLine, g_lInterfacePointer, sFilePath)
  end
  DllParseCl.kill()

  glo:filepath = szProdocRoot
  GLO:ProDocDirectory = glo:filepath   !set both global variables for the entire program
  !-------------------------------------------------

!--------------------------
ResetGlobalVars  ROUTINE
!--------------------------
!BECAUSE WHEN PRODOC CALLS PROCALC DLL, THE DLL'S FUNCTION IS TREATED AS A PROCEDURE INSIDE
! PRODOC APPLICATION, SO THE GLOBAL VARIABLES WILL NOT BE CLEARED WHEN USER EXIT DLL FUNCTIN
! AND THAT WILL MAKE EFFECTS BETWEEN EACH CALLING. WE NEED MANUALLY CLEAR ALL THESE VARIABLES.
  GLO:Filepath=''
  CLEAR(GLO:WHOCALL)
  CLEAR(GLO:NEWCASE)
  CLEAR(GLO:NOCASE)
  CLEAR(GLO:CalcDate)
