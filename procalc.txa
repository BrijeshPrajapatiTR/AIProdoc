[EMBED]
EMBED %AfterWindowOpening
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  DO SetupDelete
[END]
EMBED %DataSectionBeforeWindow
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
MAX_LOOP_LEVEL       EQUATE(8)         !max nesting level for L code loops
ELEMENT              USHORT,AUTO
INPTR                BYTE,  AUTO
KClass               long
KString              CSTRING(260)
KValue               CSTRING(260)
KElement             CSTRING(260)
regclass             bgregistryclass

DeletedTokensQue     QUEUE,PRE(DTQ)
OBJ_ID                 LIKE(ANS:OBJ_ID)
                     END

LOC:VOLUME_ID        LIKE(ANS:VOLUME_ID)
LOC:DelFamilyDone    BYTE(0)
LOC:DelAdopDone      BYTE(0)
LOC:ExpFamilyDone    BYTE(0)
LOC:ExpAdopDone      BYTE(0)
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!-----------------------
SetupDelete      ROUTINE
!-----------------------
  DeleteCOUNTER = RECORDS(DeletedTokensQue)
  STREAM(ANSWERS)
  QCOUNTER = 1

!--------------------------
DeleteExistingFAM   ROUTINE          !Delete existing data IN ANSWERS.TPS FOR TXFAM VOLUME
!--------------------------
  LOOP 5 TIMES
    GET(DeletedTokensQue,QCOUNTER)
    IF ERRORCODE() OR QCOUNTER>RECORDS(DeletedTokensQue)
      LOC:DelFamilyDone = TRUE
      QCOUNTER=1       !WELL DONE FOR TXFAM BUT ALSO NEED TO BE DONE FOR TXADOPT SO RESET COUNTER
      BREAK
    END
    ANS:CAS_ID = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:OBJ_ID = DTQ:OBJ_ID
    ANS:SCOPE = 'V'
    CLEAR(ANS:INDEXSTRING,-1)
    SET(ANS:kScope,ANS:kScope)
    LOOP
      NEXT(ANSWERS)
      IF ERRORCODE() OR ANS:SCOPE <> 'V' OR ANS:CAS_ID<>GLO:CAS_ID |
                     OR ANS:VOLUME_ID<>LOC:VOLUME_ID OR ANS:OBJ_ID<>DTQ:OBJ_ID
        BREAK
      END
      DELETE(ANSWERS)
    END
    LOC:Progress = ((QCOUNTER)/(DeleteCOUNTER*2)) * 100
    QCOUNTER += 1
    DISPLAY()
  END


!----------------------------
DeleteExistingADOP   ROUTINE         !Delete existing data IN ANSWERS.TPS FOR TXADOPT VOLUME
!----------------------------
  LOOP 5 TIMES
    GET(DeletedTokensQue,QCOUNTER)
    IF ERRORCODE() OR QCOUNTER>RECORDS(DeletedTokensQue)
      LOC:DelAdopDone = TRUE
      DeleteCompleted = TRUE          !COMPLETELY FINISH DELETION THEN PREPARE EXPORT
      DO SetupExport
      BREAK
    END
    ANS:CAS_ID = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:OBJ_ID = DTQ:OBJ_ID
    ANS:SCOPE = 'V'
    CLEAR(ANS:INDEXSTRING,-1)
    SET(ANS:kScope,ANS:kScope)
    LOOP
      NEXT(ANSWERS)
      IF ERRORCODE() OR ANS:SCOPE <> 'V' OR ANS:CAS_ID<>GLO:CAS_ID |
                     OR ANS:VOLUME_ID<>LOC:VOLUME_ID OR ANS:OBJ_ID<>DTQ:OBJ_ID
        BREAK
      END
      DELETE(ANSWERS)
    END
    LOC:Progress = ((DeleteCOUNTER+QCOUNTER)/(DeleteCOUNTER*2)) * 100
    QCOUNTER += 1
    DISPLAY()
  END


!-----------------------------
SetupExport      ROUTINE
!-----------------------------
  FLUSH(ANSWERS)
  ?STRING3{PROP:TEXT} = '                     Saving data to ProDoc'
  STREAM(ANSWERS)
  MaxLoop = ChildrenInCourt    !THE NUMBER DIMENSION TOKENS' INDEX BASED ON IS ChildrenInCourt NOT TotalChildren
  QCOUNTER = 0


!-----------------------------
ExportRecordsFAM     ROUTINE
!-----------------------------
  LOOP 5 TIMES
    QCOUNTER += 1
    IF QCOUNTER > MaxLoop
      LOC:ExpFamilyDone = TRUE
      QCOUNTER=0
      BREAK
    .
    LOC:Progress = (QCOUNTER/(Maxloop*2)) * 100
    DISPLAY()
    GET(ExportQueue,QCOUNTER)
    IF ERRORCODE() THEN BREAK.

    ANS:CAS_ID = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:SCOPE  = 'V'
    CLEAR(ANS:INDEXSTRING,-1)
    ANS:INDEXES[1]  = SwapUshortBytes(QCOUNTER)
    ANS:ANSWER      = LEFT(FORMAT(ExportQueue:ExpMonthly,@N_9.2))
    ANS:OBJ_ID      = 'PX051'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(ExportQueue:ExpSemiMonthly,@N_9.2))
    ANS:OBJ_ID      = 'PX052'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(ExportQueue:ExpWeekly,@N_9.2))
    ANS:OBJ_ID      = 'PX053'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(ExportQueue:ExpBiWeekly,@N_9.2))
    ANS:OBJ_ID      = 'PX054'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

  END

  IF LOC:ExpFamilyDone
    CLEAR(ANS:INDEXES)
    ANS:ANSWER      = LEFT(FORMAT(NetResources,@N_10.2))
    ANS:OBJ_ID      = 'PX055'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    !@Vedant FB28901
!    CASE GLO:FiledAfterSep1
!    OF 1
!      ANS:ANSWER='Y'
!    OF 0
!      ANS:ANSWER='N'
!    END
!    ANS:OBJ_ID      = 'A0091'
!    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
!    ADD(ANSWERS)
    !@Vedant   
    ANS:ANSWER      = LEFT(FORMAT(GLO:FEDERALTAX,@N_10.2))    !MA ADDED FOLLOWING TWO RECORD
    ANS:OBJ_ID      = 'PX056'                                 ! TO EXPORT TO ANSWERS.TPS BECAUSE
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))                   ! IN THE CHILD SUPPORT OBLIGATION
    ADD(ANSWERS)                                              ! REPORT WE ALSO PRINT OUT THESE TWO
    ANS:ANSWER      = LEFT(FORMAT(GLO:FICASSTAX,@N_10.2))     ! NUMBER     1/16/02
    ANS:OBJ_ID      = 'PX057'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = GLO:Obligor
    ANS:OBJ_ID      = 'PX096'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = GLO:Obligee
    ANS:OBJ_ID      = 'PX098'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = GLO:ObligorParty
    ANS:OBJ_ID      = 'AX020'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    CASE SelfEmployed
    OF 1
      ANS:ANSWER='Y'
    OF 0
      ANS:ANSWER='N'
    END
    ANS:OBJ_ID      = 'AX015'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    !Ma - Fogbugz case 14024, added a new token and need to save answer for it 6/18/17
    !Ma - Fogbugz case 19568, removed the Glo:IsOnAfter090107 so don't save answer to A0054V 9/26/08
!    CASE Glo:IsOnAfter090107
!    OF 1
!      ANS:ANSWER='Y'
!    OF 0
!      ANS:ANSWER='N'
!    END
!    ANS:OBJ_ID      = 'A0054'
!    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
!    ADD(ANSWERS)

    ANS:ANSWER      = TotalChildren
    ANS:OBJ_ID      = 'AX005'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = ChildrenInCourt
    ANS:OBJ_ID      = 'AX010'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(HealthInsurance,@N_10.2))
    ANS:OBJ_ID      = 'PX060'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(UnionDues,@N_10.2))
    ANS:OBJ_ID      = 'PX062'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(StateIncomeTax,@N_10.2))
    ANS:OBJ_ID      = 'PX064'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(GrossMonthlyIncome,@N_10.2))
    ANS:OBJ_ID      = 'PX066'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(NonTaxableMonthly,@N_10.2))
    ANS:OBJ_ID      = 'PX068'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(DisabilityIncome,@N_10.2))
    ANS:OBJ_ID      = 'PX070'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(SocialSecurityBenefits,@N_10.2))
    ANS:OBJ_ID      = 'PX072'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(Adjustment,@N_10.2))
    ANS:OBJ_ID      = 'PX074'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = Explanation
    ANS:OBJ_ID      = 'PX076'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

  END


!-----------------------------
ExportRecordsADOP     ROUTINE
!-----------------------------
  LOOP 5 TIMES
    QCOUNTER += 1
    IF QCOUNTER > MaxLoop
      LOC:ExpAdopDone=TRUE
      ExportCompleted = TRUE
      CAS:CAS_ID=GLO:CAS_ID
      SET(CAS:kCAS_ID,CAS:kCAS_ID)
      NEXT(CASES)
      IF ~ERRORCODE() AND CAS:CAS_ID=GLO:CAS_ID AND ~CAS:VOLUME_ID
        CAS:VOLUME_ID=GLO:VOLUME_ID      !SAVE VOLUME_ID TO CASES.TPS BECAUSE IF IT'S NEW CASE
        PUT(CASES)                       ! THEN THE CAS:VOLUME_ID IS BLANK
      END
      BREAK
    .
    LOC:Progress = ((Maxloop+QCOUNTER)/(Maxloop*2)) * 100
    DISPLAY()
    GET(ExportQueue,QCOUNTER)
    IF ERRORCODE() THEN BREAK.


    ANS:CAS_ID = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:SCOPE  = 'V'
    CLEAR(ANS:INDEXSTRING,-1)
    ANS:INDEXES[1]  = SwapUshortBytes(QCOUNTER)
    ANS:ANSWER      = LEFT(FORMAT(ExportQueue:ExpMonthly,@N_9.2))
    ANS:OBJ_ID      = 'PX051'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(ExportQueue:ExpSemiMonthly,@N_9.2))
    ANS:OBJ_ID      = 'PX052'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(ExportQueue:ExpWeekly,@N_9.2))
    ANS:OBJ_ID      = 'PX053'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(ExportQueue:ExpBiWeekly,@N_9.2))
    ANS:OBJ_ID      = 'PX054'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
  END

  IF LOC:ExpAdopDone
    CLEAR(ANS:INDEXES)
    ANS:ANSWER      = LEFT(FORMAT(NetResources,@N_10.2))
    ANS:OBJ_ID      = 'PX055'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(GLO:FEDERALTAX,@N_10.2))    !MA ADDED FOLLOWING TWO RECORD
    ANS:OBJ_ID      = 'PX056'                                 ! TO EXPORT TO ANSWERS.TPS BECAUSE
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))                   ! IN THE CHILD SUPPORT OBLIGATION
    ADD(ANSWERS)                                              ! REPORT WE ALSO PRINT OUT THESE TWO
    ANS:ANSWER      = LEFT(FORMAT(GLO:FICASSTAX,@N_10.2))     ! NUMBER     1/16/02
    ANS:OBJ_ID      = 'PX057'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = GLO:Obligor
    ANS:OBJ_ID      = 'PX096'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = GLO:Obligee
    ANS:OBJ_ID      = 'PX098'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = GLO:ObligorParty
    ANS:OBJ_ID      = 'AX020'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    CASE SelfEmployed
    OF 1
      ANS:ANSWER='Y'
    OF 0
      ANS:ANSWER='N'
    END
    ANS:OBJ_ID      = 'AX015'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
        
    !@Vedant FB28901
!     CASE GLO:FiledAfterSep1
!     OF 1
!       ANS:ANSWER='Y'
!     OF 0
!       ANS:ANSWER='N'
!     END
!     ANS:OBJ_ID      = 'A0091'
!     ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
!     ADD(ANSWERS)
    !@Vedant

    ANS:ANSWER      = TotalChildren
    ANS:OBJ_ID      = 'AX005'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = ChildrenInCourt
    ANS:OBJ_ID      = 'AX010'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(HealthInsurance,@N_10.2))
    ANS:OBJ_ID      = 'PX060'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(UnionDues,@N_10.2))
    ANS:OBJ_ID      = 'PX062'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(StateIncomeTax,@N_10.2))
    ANS:OBJ_ID      = 'PX064'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(GrossMonthlyIncome,@N_10.2))
    ANS:OBJ_ID      = 'PX066'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(NonTaxableMonthly,@N_10.2))
    ANS:OBJ_ID      = 'PX068'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(DisabilityIncome,@N_10.2))
    ANS:OBJ_ID      = 'PX070'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(SocialSecurityBenefits,@N_10.2))
    ANS:OBJ_ID      = 'PX072'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = LEFT(FORMAT(Adjustment,@N_10.2))
    ANS:OBJ_ID      = 'PX074'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    ANS:ANSWER      = Explanation
    ANS:OBJ_ID      = 'PX076'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    FLUSH(ANSWERS)
    POST(EVENT:CloseWindow)
  END

[END]
