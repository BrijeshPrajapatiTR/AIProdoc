[MODULE]
[COMMON]
FROM Clarion GENERATED
MODIFIED '2021/06/17' '17:37:56'
[PROCEDURE]
NAME CallInfoServer
PROTOTYPE '(*cstring pInfoNeeded,*long param1, *long param2),long'
PARAMETERS '(*cstring pInfoNeeded,*long param1, *long param2)'
NOEXPORT
[COMMON]
FROM Clarion Source
MODIFIED '2021/06/17' '17:37:56'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
CALLDLLCL CALLDLLCLTYPE
result long(3)  !init to fail - 0=no error 3=error
[END]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  IF ~pInfoNeeded or ~glo:infoserveraddress then return 3.
  if ~Calldllcl.init('',0) then
    CALLDLLCL.ADDADDRESS('INFOSERVER',GLO:INFOSERVERADDRESS)
    result=CallDllcl.Call_p3('INFOSERVER',address(pInfoNeeded),address(param1),address(param2))
  end
  calldllcl.kill()
  return result
[END]
[END]
