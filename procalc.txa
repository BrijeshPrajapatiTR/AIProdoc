[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
FLUSH(ANSWERS)   !just to make sure STREAM isn't accidentally left in effect
[END]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?Cancel'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF MESSAGE('Cancel the saving data operation?','Cancel Request',ICON:QUESTION,|
            BUTTON:YES+BUTTON:NO,BUTTON:YES) = BUTTON:YES
  bRetVal = true
  POST(EVENT:CLOSEWINDOW)
END
[END]
[END]
[END]
EMBED %WindowEventHandling
[INSTANCES]
WHEN 'Timer'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  IF ExportCompleted
    POST(EVENT:CloseWindow)
  ELSIF DeleteCompleted
    IF ~LOC:ExpFamilyDone
      LOC:VOLUME_ID=GLO:VOLUME_ID
      !@Parth - FB28903
!            DO ExportRecordsFAM  
!            STOP('before DO ExportRecordsFAMAfterSep1')
      DO ExportRecordsFAMAfterSep1
!            STOP('LOC:ExpFamilyDone: ' & LOC:ExpFamilyDone)
      !@Parth  
    ELSIF ~LOC:ExpAdopDone
      LOC:VOLUME_ID='TXADOPT'
!            DO ExportRecordsADOP
      DO ExportRecordsFAMAfterSep1
    ELSIF LOC:ExpAdopDone
      ExportCompleted = TRUE
      CAS:CAS_ID=GLO:CAS_ID
      SET(CAS:kCAS_ID,CAS:kCAS_ID)
      NEXT(CASES)
      IF ~ERRORCODE() AND CAS:CAS_ID=GLO:CAS_ID AND ~CAS:VOLUME_ID
        CAS:VOLUME_ID=GLO:VOLUME_ID      !SAVE VOLUME_ID TO CASES.TPS BECAUSE IF IT'S NEW CASE
        PUT(CASES)                       ! THEN THE CAS:VOLUME_ID IS BLANK
      END
    END
  ELSE
    IF ~LOC:DelFamilyDone
      LOC:VOLUME_ID=GLO:VOLUME_ID
      DO DeleteExistingFAM
    ELSIF ~LOC:DelAdopDone
      LOC:VOLUME_ID='TXADOPT'
      0{PROP:TEXT} = eTitle & ' - For Adoptions'
      DO DeleteExistingADOP
    END
  END
[END]
