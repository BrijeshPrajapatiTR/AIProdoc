ProcessPayment        PROCEDURE(BYTE After2010)
PayCurrentOblBefore   PROCEDURE(STRING ObligationType, long ObligationCount = -1, BYTE lookBack30 = FALSE)
PayCurrentOblAfter    PROCEDURE(STRING ObligationType, LONG loc:month, LONG loc:year, LONG Glo:Calcdate, long ObligationCount = -1)
