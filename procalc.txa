!@Parth
[SOURCE]
PROPERTY:BEGIN
PRIORITY 3600
PROPERTY:END
!@Parth - FB28903 ResetReport         ROUTINE 
ResetReport         ROUTINE
  DebugCl.Send('Resetting report: ' & CurrentObligationType)
  ENDPAGE(REPORT)
  SummaryPrinted = FALSE
  SWITCH = 1
!  CLEARPAGES()
  LOOP I#=1 TO RECORDS(PrintPreviewQueue)
    GET(PrintPreviewQueue,I#)
    IF ERRORCODE() THEN BREAK.
    DebugCl.Send('prINTPREVIEWQUEUE.PRINTPREVIEWIMAGE: ' & prINTPREVIEWQUEUE.PRINTPREVIEWIMAGE)
    SETCLIPBOARD(prINTPREVIEWQUEUE.PRINTPREVIEWIMAGE)
    if addpage(prINTPREVIEWQUEUE.PRINTPREVIEWIMAGE, 2)  then
      message('There was a problem sending one page to the printer. This is sometimes caused by too little disk space or too many temporary files.','Print Problem')
    end
  END
  Free(PrintPreviewQueue)
  DebugCl.Send('Before Closing Report')
  CLOSE(REPORT)
  DebugCl.Send('Before calling Open report routine')
  ReportWasOpened = FALSE
  Do OpenReportRoutine
[SOURCE]
PROPERTY:BEGIN
PRIORITY 3600
PROPERTY:END
ProcessNextReport   ROUTINE
  CASE UPPER(CurrentObligationType)
  OF 'CHILD'
    IF BAND(filtervalues,FilterObligationMedical)
      CurrentObligationType = 'MEDICAL'
    ELSIF BAND(filtervalues,FilterObligationDental)
      CurrentObligationType = 'DENTAL'  
    END                 
  OF 'MEDICAL'
    IF BAND(filtervalues,FilterObligationDental)
      CurrentObligationType = 'DENTAL'  
    END 
  OF 'DENTAL'
    PFQ:Done:1 = TRUE
    LocalResponse = RequestCompleted 
  END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 3600
PROPERTY:END
PrintUnconfirmedObligations ROUTINE
  
  MESSAGE1 = '                                PAYMENT    '|
    & '       UNCONFIRMED                                CONFIRMED                    ATTORNEY''S FEES & COSTS'
  MESSAGE2 = 'DATE                     ALLOCATED      '|
    & ' OBLIGATION    INTEREST           OBLIGATION    INTEREST       OBLIGATION     INTEREST'
  
  MESSAGE3 = 'PAYMENT HISTORY - HOW PAYMENTS WERE APPLIED'
  
  ENDPAGE(REPORT)
  
  QCOUNTER = 0
  LOOP
    QCOUNTER += 1
    GET(ReportQueue,QCOUNTER)
    IF ERRORCODE() THEN BREAK.
  !     @Parth - FB28903
  !TODO: Need to add obligation type
  !     @Parth 
    IF RPQ:ObligationType <> CurrentObligationType THEN CYCLE.
    IF RPQ:TYPE <> 'P'THEN CYCLE. !!1997.3 (added "D")
    IF ~RPQ:AplUobl AND ~RPQ:AplCobl AND ~RPQ:AplUint AND ~RPQ:AplCint
      MESSAGE4 = 'CREDIT'
    ELSE
      MESSAGE4 = ''
    .
  
    PRINT(RPT:PaymentsDetail)
  .
  !TODO: Remove last page of report 
  MESSAGE1 = ' '
  MESSAGE2 = '              DATE              AMOUNT          REMAINING BALANCE'
  
  MESSAGE3 = ' UNCONFIRMED OBLIGATIONS - REMAINING BALANCES'
  MESSAGE4 = ''
  ENDPAGE(REPORT)
  
  QCOUNTER = 0
  LOOP
    QCOUNTER += 1
    GET(ReportQueue,QCOUNTER)
    IF ERRORCODE() THEN BREAK.
  !     @Parth - FB28903
  !TODO: CAe stmt with OBl type 
    If UPPER(RPQ:ObligationType) <> CurrentObligationType
      CYCLE
    END
    
    
  !     @Parth  
    IF ~(RPQ:TYPE = 'O' or (RPQ:Type='D' and RPQ:DebitUobl<>0))  THEN CYCLE.
    IF ~RPQ:AmountO OR RPQ:dummybyte <> 0 THEN CYCLE.

    PRINT(RPT:ObligationsDetail)
  .
  MESSAGE3 = ''
[END]
EMBED %BeforeOpeningReport
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
CASE SWITCH
OF 1
  IF ~ReportWasOpened
    DebugCL.Send('Before OPEN(Report1)')
    OPEN(report1)
    ReportWasOpened=True
  END
  IF PRINTER{PROPPRINT:Copies} <> report1{PROPPRINT:Copies}
    report1{PROPPRINT:Copies} = PRINTER{PROPPRINT:Copies}
  END
  CollateCopies = report1{PROPPRINT:Copies}
  IF report1{PROPPRINT:COLLATE}=True
    report1{PROPPRINT:Copies} = 1
  END
  DebugCL.Send('Delinquent Text Report Preview: ' & PrintPreviewQueue2.PrintPreviewImage2)    
  report1{Prop:Preview} =PrintPreviewQueue2.PrintPreviewImage2
!    @Parth - FB28903
  Do UpdateReport
!   @Parth 
OF 2
DebugCL.Send('Before Opening Report, ReportWasOpened: ' & ReportWasOpened)
[END]
EMBED %AfterPrintPreview
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
***

!Call the ABC print preview
ELSE
IF CPCSPgOfPgOption = True
  AssgnPgOfPg(PrintPreviewQueue)
END
report{PROPPRINT:COPIES}=CollateCopies
LOOP i#=1 TO RECORDS(PRINTPREVIEWQUEUE)
  get(printpreviewqueue,i#)
  IF ERRORCODE() THEN BREAK.
  IF ADDPAGE(pRINTPREVIEWQUEUE.PRINTPREVIEWIMAGE,2) THEN
    mESSAGE('4. There was an error sending a page to your printer. One page may not print. Sometimes this is caused by too many temporary files and/or too little disk space.','Printing Problem')
  end
end
Printer{PROPPRINT:COPIES}=CollateCopies
SHOWANDPRINT(1,1,0,Printer{07B28H}) !show print preview, prompt for printer, print then delete the wmfs
GLOBALRESPONSE=REQUESTCANCELLED
[END]
EMBED %BeforeClosingReport
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
***
      ! End of "After: Nothing To Print Msg"
    ELSE
      IF CPCSPgOfPgOption = True
        AssgnPgOfPg(PrintPreviewQueue)
      END
      LOOP i#=1 TO RECORDS(PRINTPREVIEWQUEUE)
        get(printpreviewqueue,i#)
        IF ERRORCODE() THEN BREAK.
        IF ADDPAGE(pRINTPREVIEWQUEUE.PRINTPREVIEWIMAGE,2) THEN
          mESSAGE('1. There was an error sending a page to your printer. One page may not print. Sometimes this is caused by too many temporary files and/or too little disk space.','Printing Problem')
        end
      end
      Printer{PROPPRINT:COPIES}=CollateCopies
      SHOWANDPRINT(0,1,0,Printer{07B28H}) !dont show print preview, dont prompt for printer, print then delete the wmfs

    END
  ELSIF ~ReportWasOpened
    MESSAGE(CPCS:NthgToPrntText,CPCS:NthgToPrntTitle,ICON:Exclamation)
  END
ELSE
  FREE(PrintPreviewQueue)
END
!***MCY***

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
IF PreviewReq
  CLOSE(ProgressWindow)
  IF (LocalResponse = RequestCompleted AND KEYCODE()<>EscKey) OR PartialPreviewReq=True
    ENDPAGE(report)
    IF ~RECORDS(PrintPreviewQueue)
      IF PRINTSUMMARY      !ONLY PRINT SUMMARY
        Printer{PROPPRINT:COPIES}=CollateCopies
        SHOWANDPRINT(1,1,0,Printer{07B28H}) !show print preview, prompt for printer, print then delete the wmfs
        !SHOWANDPRINT(1,1,0,Printer{PropPrint:device}) !show print preview, prompt for printer, print then delete the wmfs
        GLOBALRESPONSE=REQUESTCANCELLED
      ELSE
        MESSAGE(CPCS:NthgToPrvwText,CPCS:NthgToPrvwTitle,ICON:Exclamation)
      END
    ELSE
      IF CPCSPgOfPgOption = True
        AssgnPgOfPg(PrintPreviewQueue)
      END
      report{PROPPRINT:COPIES}=CollateCopies
      LOOP i#=1 TO RECORDS(PRINTPREVIEWQUEUE)
        get(printpreviewqueue,i#)
        IF ERRORCODE() THEN BREAK.
        IF ADDPAGE(pRINTPREVIEWQUEUE.PRINTPREVIEWIMAGE,2) THEN
          mESSAGE('2. There was an error sending a page to your printer. One page may not print. Sometimes this is caused by too many temporary files and/or too little disk space.','Printing Problem')
        end
      end
      Printer{PROPPRINT:COPIES}=CollateCopies
      SHOWANDPRINT(1,1,0,Printer{07B28H}) !show print preview, prompt for printer, print then delete the wmfs
      GLOBALRESPONSE=REQUESTCANCELLED
      IF GlobalResponse = RequestCompleted
        PSAV::Copies = PRINTER{PROPPRINT:Copies}
        PRINTER{PROPPRINT:Copies} = report{PROPPRINT:Copies}
        HandleCopies(PrintPreviewQueue,report{PROPPRINT:Copies})
        report{PROP:FlushPreview} = True
        PRINTER{PROPPRINT:Copies} = PSAV::Copies
      END
    END
    LocalResponse = GlobalResponse
  ELSIF ~ReportWasOpened
    MESSAGE(CPCS:NthgToPrvwText,CPCS:NthgToPrvwTitle,ICON:Exclamation)
  END
ELSIF KEYCODE()<>EscKey
  IF (ReportWasOpened AND report{PROPPRINT:Copies} > 1 AND ~(Supported(PROPPRINT:Copies)=True)) OR |
     (ReportWasOpened AND (AsciiOutputReq OR report{PROPPRINT:Collate} = True OR CPCSPgOfPgOption = True OR CPCSPageScanOption = True OR EmailOutputReq))
    ENDPAGE(report)
    IF ~RECORDS(PrintPreviewQueue)
      IF PRINTSUMMARY      !ONLY PRINT SUMMARY
        Printer{PROPPRINT:COPIES}=CollateCopies
        SHOWANDPRINT(0,1,0,Printer{07B28H}) !show print preview, prompt for printer, print then delete the wmfs
        !SHOWANDPRINT(1,1,0,Printer{PropPrint:device}) !show print preview, prompt for printer, print then delete the wmfs
        GLOBALRESPONSE=REQUESTCANCELLED
      ELSE
        MESSAGE(CPCS:NthgToPrvwText,CPCS:NthgToPrvwTitle,ICON:Exclamation)
      END
    ELSE
      IF CPCSPgOfPgOption = True
        AssgnPgOfPg(PrintPreviewQueue)
      END
      LOOP i#=1 TO RECORDS(PRINTPREVIEWQUEUE)
        get(printpreviewqueue,i#)
        IF ERRORCODE() THEN BREAK.
        IF ADDPAGE(pRINTPREVIEWQUEUE.PRINTPREVIEWIMAGE,2) THEN
          mESSAGE('3. There was an error sending a page to your printer. One page may not print. Sometimes this is caused by too many temporary files and/or too little disk space.','Printing Problem')
        end
      end
      Printer{PROPPRINT:COPIES}=CollateCopies
      SHOWANDPRINT(0,1,0,Printer{07B28H}) !dont show print preview, dont prompt for printer, print then delete the wmfs
    END
  ELSIF ~ReportWasOpened
    MESSAGE(CPCS:NthgToPrntText,CPCS:NthgToPrntTitle,ICON:Exclamation)
  END
ELSE
  FREE(PrintPreviewQueue)
END

[END]
EMBED %DeclarationSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 3500
PROPERTY:END
PRINTSUMMARY        BYTE(0)
LOC:DATE            LONG
