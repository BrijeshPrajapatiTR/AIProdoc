PROPERTY:END
GetWindowRect(?PrintButton{PROP:HANDLE},WinRECT)
!?PrintButton{prop:color} = Color:btnShadow
!@Parth - FB28903
!        POPUP('~Child Support|-|Full Report|Summary|-|~Medical Support|-|Full Report|Summary|-|~Dental Support|-|Full Report|Summary')
!  CASE POPUP('Full report|Summary',WinRECT.Left, WinRECT.bottom)
!  OF 1
!    DelinquentReport(FullReport)
!  OF 2
!    DelinquentReport(SummaryReport)
