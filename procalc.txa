PRIORITY 50
PROPERTY:END
Util.IsDummyRow     FUNCTION(string ObligationType)
CODE
    QOB:Type = ObligationType
    GET(QOBLIGATE,QOB:Type)
    IF ERRORCODE() THEN 
      RETURN (TRUE)
    ELSE
      RETURN (FALSE)
    END

