  !Loop backwards through reportqueue
  ! looking for the last obligation
  LOOP QCOUNTER = MaxLoop TO 1 BY -1
    GET(ReportQueue,QCounter)
    IF ERRORCODE() THEN BREAK.
    IF CLIP(UPPER(RPQ:ObligationType)) <> 'DENTAL' THEN CYCLE.
    IF RPQ:Type = 'O' AND RPQ:AmountO > 0
