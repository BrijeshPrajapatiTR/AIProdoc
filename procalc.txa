EMBED %BeforeTurnQuickScanOff
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  ENDPAGE(REPORT)
  


    DebugCL.Send('GLO:IsAnyFullReportSelected: ' & GLO:IsAnyFullReportSelected)
    IF GLO:IsAnyFullReportSelected = 1 
      OPEN(PaymentHistoryReport)
      
      
      
      IF PRINTER{PROPPRINT:Copies} <> PaymentHistoryReport{PROPPRINT:Copies}
        PaymentHistoryReport{PROPPRINT:Copies} = PRINTER{PROPPRINT:Copies}
      END
      CollateCopies = PaymentHistoryReport{PROPPRINT:Copies}
      IF PaymentHistoryReport{PROPPRINT:COLLATE}=True
        PaymentHistoryReport{PROPPRINT:Copies} = 1
      END
        
      PaymentHistoryReport{Prop:Preview} = PrintPreviewQueuePay.PrintPreviewImagePay
      DebugCL.Send('PH Preview: ' & PrintPreviewQueuePay.PrintPreviewImagePay)  
      
      DebugCL.Send('PH Landscape: ' & PaymentHistoryReport{PROP:Landscape})
      IF PaymentHistoryReport{PROPPRINT:Landscape}=True
          PaymentHistoryReport{PROP:Landscape} = TRUE
      END
      DebugCL.Send('PH Landscape after: ' & PaymentHistoryReport{PROP:Landscape})
      QCOUNTER = 0
      LOOP
        !  !TODO: Order of C M D will not work and we need to fix that 
        QCOUNTER += 1
        GET(ReportQueue,QCOUNTER)
        IF ERRORCODE() THEN BREAK.
        If UPPER(RPQ:Type) <> 'P' OR RPQ:dummybyte = 1 THEN CYCLE.
        !If RPQ:dummybyte <> 0 THEN CYCLE.
        
        CASE UPPER(RPQ:ObligationType)
        OF 'CHILD'
          LOC:PaymentClassification = 'Child Support'
        OF 'MEDICAL'
          LOC:PaymentClassification = 'Medical'
        OF 'DENTAL'
          LOC:PaymentClassification = 'Dental'
        END
        If CLIP(RPQ:ObligationType) = ''
          PRINT(PayRPT:PaymentHistoryTotalDetail)
        ELSE
          PRINT(PayRPT:PaymentHistoryDetail)
        END
      END
      
      ENDPAGE(PaymentHistoryReport)
    END
    IF CPCSPgOfPgOption = True
      AssgnPgOfPg(PrintPreviewQueuePay)
    END
  PaymentHistoryReport{PROPPRINT:COPIES}=CollateCopies 
  !DebugCL.Send('Before PaymentHistoryReport{PROPPRINT:Landscape}: ' & PaymentHistoryReport{PROPPRINT:Landscape})
!    PaymentHistoryReport{PROP:} = PROPPRINT:Landscape
  !DebugCL.Send('After PaymentHistoryReport{PROPPRINT:Landscape}: ' & PaymentHistoryReport{PROPPRINT:Landscape})
    LOOP I#=1 TO RECORDS(PrintPreviewQueuePay)
      GET(PrintPreviewQueuePay,I#)
      IF ERRORCODE() THEN BREAK.
      !if addpage(PrintPreviewQueuePay.PRINTPREVIEWIMAGEPay, 1)  then
      if addpage(PrintPreviewQueuePay.PRINTPREVIEWIMAGEPay, 2)  then
        DebugCl.Send('PaymentHistoryReport: PRINT ISSUE')
        message('There was a problem sending one page to the printer. This is sometimes caused by too little disk space or too many temporary files.','Print Problem')
      end
    END
    DebugCl.Send('PaymentHistoryReport: before  free PrintPreviewQueue2')
    Free(PrintPreviewQueuePay)
    DebugCl.Send('PaymentHistoryReport: All reports completed ')
            
    CLOSE(PaymentHistoryReport)
[END]
[END]
