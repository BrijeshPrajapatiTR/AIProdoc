[WINDOW]
window  WINDOW('Calculation Date'),AT(,,207,76),FONT('MS Sans Serif',8,,FONT:regular),DOUBLE, |
          CENTER,GRAY,HLP('~Calculation_Date_Form')
          SHEET,AT(5,4,196,48),USE(?Sheet1),WIZARD,#ORIG(?Sheet1),#ORDINAL(1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1),#ORDINAL(2)
              PROMPT('&Date to calculate interest through:'),AT(13,21),USE(?Prompt1),#ORIG(?Prompt1), |
                #ORDINAL(3)
              ENTRY(@D2<50B),AT(126,19,45,12),USE(GLO:CalcDate),#ORIG(CalcDate),#ORDINAL(4)
              BUTTON,AT(174,17,15,14),USE(?Calendar),ICON('smcal.ico'),FLAT,SKIP,#ORIG(?Calendar), |
                #SEQ(3),#ORDINAL(5)
              STRING('(mm/dd/yyyy)'),AT(127,33),USE(?String2),#ORIG(?String2),#ORDINAL(6)
            END
          END
          BUTTON('&Help'),AT(4,59,50,15),USE(?Help),LEFT,ICON(ICON:Help),STD(STD:Help),#ORIG(?Button3), |
            #ORDINAL(7)
          BUTTON('&OK'),AT(98,59,50,15),USE(?OkButton),LEFT,ICON('OK.ICO'),DEFAULT,#ORDINAL(8)
          BUTTON('&Cancel'),AT(151,59,50,15),USE(?CancelButton),LEFT,ICON('cancel.ico'),#ORDINAL(9)
        END

[END]
