EMBED %AfterWindowOpening
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
  !Replace token XXXX with year
  szTempString = ?String2{prop:text}
  x# = instring('XXX', szTempString, 1, 1)
  if x#
    szTempString[x# : x# + 3] = sVersionYear
    ?String2{prop:text} = szTempString
  end

[END]
