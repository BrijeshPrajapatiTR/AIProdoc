%Parameters DEFAULT  ('')
[EMBED]
EMBED %DataSectionBeforeWindow
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
Licensecl            LicenseclType
LOC:OKBUTTON         BYTE(0)
LOC:SaveUobl         DECIMAL(8,2)
LOC:SaveUint         DECIMAL(8,2)
LOC:SaveCobl         DECIMAL(8,2)
LOC:SaveCint         DECIMAL(8,2)
LOC:SaveDate         LONG
LOC:SaveFlag         BYTE
QCOUNTER             LONG

LOC:NEWRECORD        BYTE(0)
ABSTRACTQ            QUEUE,PRE(AQ)    !MA ADDED   2/15/02
ID                     LONG
NUMBEROFOBL            LONG
FIRSTAMOUNT            DECIMAL(9,2)
LASTAMOUNT             DECIMAL(9,2)
FIRSTDATE              LONG
LASTDATE               LONG
FREQUENCY              STRING(12)
TYPE                   STRING(1)
                     END
FIRSTOPEN            BYTE(TRUE)
MAKEGUESS            BYTE(FALSE)
!AS FB Case 20475. Uses PDOptions:DBVersionRequired global variable defined procalc.dct which stores version number.
LOC:Filever          EQUATE(PDOptions:DBVersionRequired)

LOCALCL        CLASS
GetCaseDesc      PROCEDURE()
GetContactName   PROCEDURE()
               END

sFullName   STRING(60)
sCaseDesc   LIKE(CAS:DESCRIPTION)
[END]
EMBED %ProcedureInitialize
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!system{prop:messageHook} = address(messageBox)
clear(lErr)
IAppMutex &= NewMutex(eTXDEL_Mutex,, lErr)
if lErr = ERROR_ALREADY_EXISTS
  !STOP('BEFORE SHOWING MESSAGE')
  message(eTXDEL_IsRunning, eTXDEL_IsRunningTitle , ICON:Exclamation)
  DO PROCEDURERETURN
end

GLO:NOCASE = FALSE
GLO:NEWCASE = FALSE
GLO:CAS_ID = 0
GLO:CON_ID = 0

!Fogbugz case 10793, call SetGlobals() before checking license and if caller is cscjs then force to use ProCalc.chm as help
! file since the CSCJS does not have it's own help file (The registration PowerPack window has a help button) MA 12/11/06
SetGlobals(cmdline)
IF GLO:CALLER = eCallerIsCSCJS
  HELP('PROCALC.HLP')
  IF Licensecl.init('TX', 0, ,eProCalcHelp)   !THE SECOND PARAMETER 1 MEANS SHOWING TREE AND 0 MEANS NO TREE
    DO PROCEDURERETURN
  END
ELSE
  IF Licensecl.init('TX',0) 
    DO PROCEDURERETURN
  END
END
IF Licensecl.CheckLicense('ProCalc.dll')  !CHECK THE LICENSE FOR ADDIN BEING STARTED
  Licensecl.Kill()
  DO PROCEDURERETURN
END
Licensecl.Kill()
!SetGlobals(cmdline)
!CHECK FILE VERSION(FILEVER.TPS) BECAUSE OF PROCALC IS LEGACY APP SO IT CAN'T USE THE CLASS
! DENNIS CREATED
IF ~EXISTS(CLIP(FIFilever))
  CREATE(Filever)
  IF ERRORCODE()
    MESSAGE(CLIP(ERROR()) & ' creating filever.tps file.')
    DO PROCEDURERETURN
  ELSE
    OPEN(Filever,22H)
    IF ERRORCODE()
      MESSAGE(CLIP(ERROR()) & ' opening filever.tps file.')
      DO PROCEDURERETURN
    END
    FILEV:FILEVERSION=LOC:FILEVER
    FILEV:PRODUCT='PROCALC'
    ADD(Filever)
    IF ERRORCODE()
      MESSAGE(CLIP(ERROR()) & ' writing filever.tps file.')
      CLOSE(Filever)
      DO PROCEDURERETURN
    END
  END
ELSE
  OPEN(Filever,22H)
  IF ERRORCODE()
    MESSAGE(CLIP(ERROR()) & ' opening filever.tps file.')
    DO PROCEDURERETURN
  END
  IF RECORDS(Filever)
    SET(Filever)
    NEXT(Filever)
    IF ERRORCODE()
      MESSAGE(CLIP(ERROR()) & ' reading filever.tps file.')
      CLOSE(Filever)
      DO PROCEDURERETURN
    END
    IF FILEV:FILEVERSION>LOC:FILEVER
      MESSAGE('A version of '&CLIP(FILEV:PRODUCT) & ' that requires a newer data file version '|
            & 'has  been used, this version of PROCALC cannot continue.<13><10><13><10>'|
            & '      Please contact technical support for assistance.','Incorrect File Version',|
            ICON:EXCLAMATION,BUTTON:OK)
      CLOSE(Filever)
      DO PROCEDURERETURN
    ELSIF FILEV:FILEVERSION<LOC:FILEVER
      FILEV:FILEVERSION=LOC:FILEVER
      FILEV:PRODUCT='PROCALC'
      PUT(Filever)
      IF ERRORCODE()
        MESSAGE(CLIP(ERROR()) & ' writing filever.tps file.')
        CLOSE(Filever)
        DO PROCEDURERETURN
      END
    END
  ELSE
    FILEV:FILEVERSION=LOC:FILEVER
    FILEV:PRODUCT='PROCALC'
    ADD(Filever)
    IF ERRORCODE()
      MESSAGE(CLIP(ERROR()) & ' writing filever.tps file.')
      CLOSE(Filever)
      DO PROCEDURERETURN
    END
  END
END
CLOSE(Filever)

  ! @Parth - FB28903 - NotDoneWindow
!      If UPPER(COMMAND('BETA')) <> 'Y'
!        OPEN(NotDoneWindow)
!        ACCEPT
!        END
!        GlobalResponse = RequestCancelled
!        
!        if ~IAppMutex &= null  
!          IAppMutex.Kill()
!          IAppMutex &= null
!        end
!        clear(GLO:DelinquentCalcThread)
!        
!        RETURN
!      END
  !   @Parth 
  
IF GLO:CALLER <> eCallerIsCSCJS   !GLO:CALLER=1 - ProDoc, GLO:CALLER=2 - SOS, GLO:CALLER=3 - CSCJS
  !NEW CODE TO CALL BACK CASE SELECTION WINDOW IN PROWIN
  rIProwinLink &= (g_lInterfacePointer)
  !Ma - Fogbugz case 10891, pass the third parameter to allow not use case 4/12/07
  if rIProwinLink.GetClientCase(GLO:CAS_ID, GLO:CON_ID, GLO:NOCASE) <> RequestCompleted
    GlobalResponse = RequestCancelled
    CLEAR(GLO:DelinquentCalcThread)
    DO PROCEDURERETURN
  END
  HELP('PROCALC.HLP')
  !Ma - Fogbugz case 10891, if glo:nocase is true do not load answers 4/12/07
  !MESSAGE('1.1')
  NAM:ConfirmedInterestRate = 0
  GLO:ConfIntRate = 0
  if ~GLO:NOCASE
  LoadAnswersDelin()           !LOAD QOBLIGATE, QPAYMENTS AND OTHER DATA
  IF RECORDS(QObligate)
    GET(QObligate,1)
    IF ~QOB:Frequency
      DO GetOblFrequency       !MA ADDED THIS ROUTINE TO GET THE FREQUENCY OF OBLIGATION BY PARSING QOBLIGATE  2/15/02
      GLO:UpdateObligate=TRUE  !IF MADE GUESS THEN FORCE TO UPDATE WHEN USER CLICK OK BUTTON
      MAKEGUESS=TRUE
    END
  END
    IF GLO:NEWCASE
      !MESSAGE('1.2')
    NAM:ConfirmedInterestRate = 0    !USER WANT SET DEFAULT VALUE TO 0.0 FOR NEW CASE 4/22/02
    GLO:ConfIntRate = 0
  END
  end
  SYSTEM{PROP:Icon} = '~PROWIN.ICO'

  OMIT('***MCY***')
  GLO:CAS_ID = SelectOneConCas()
  IF GLOBALRESPONSE=REQUESTCOMPLETED
    IF ~GLO:NOCASE
      LoadAnswersDelin()           !LOAD QOBLIGATE, QPAYMENTS AND OTHER DATA
      IF RECORDS(QObligate)
        GET(QObligate,1)
        IF ~QOB:Frequency
          DO GetOblFrequency       !MA ADDED THIS ROUTINE TO GET THE FREQUENCY OF OBLIGATION BY PARSING QOBLIGATE  2/15/02
          GLO:UpdateObligate=TRUE  !IF MADE GUESS THEN FORCE TO UPDATE WHEN USER CLICK OK BUTTON
          MAKEGUESS=TRUE
        END
      END
      IF GLO:NEWCASE
        !MESSAGE('1.3')
        NAM:ConfirmedInterestRate = 0    !USER WANT SET DEFAULT VALUE TO 0.0 FOR NEW CASE 4/22/02
        GLO:ConfIntRate = 0
      END
    ELSE
      !MESSAGE('1.4')
      NAM:ConfirmedInterestRate = 0
      GLO:ConfIntRate = 0
    END
  ELSE
    GlobalResponse = RequestCancelled
    DO PROCEDURERETURN
  END
  !***MCY***
ELSE    !RIGHT NOW WE ONLY HAVE THREE KIND OF CALLER: 1-PROWIN,2-SOS,3-CSCJS(FOR JUDGES SPECIAL)
  GLO:WHOCALL=2       !THIS HAS TO BE SET TO 2 WHICH MEANS CHILD BEING CALLING PROCEDURE IN PARENT
                      ! WHEN PARENT ITSELF CALLS THE PROCEDURE IT WILL PASS 1
  DUMMY#=CallClientsCases(GLO:CAS_ID,GLO:WHOCALL)
  IF DUMMY#=3         !DIDN'T GET PROCEDURE ADDRESS
    MESSAGE('Calling procedure failed.')
    DO PROCEDURERETURN
  END
  IF GLO:CAS_ID=-1    !USER CLICKS ON CLOSE BUTTON TO EXIT
    DO PROCEDURERETURN
  ELSIF GLO:CAS_ID=0  !USER CLICKS ON DON'T USE CASE BUTTON
    GLO:NOCASE=TRUE
    !MESSAGE('1.5')
    NAM:ConfirmedInterestRate = 0
    GLO:ConfIntRate = 0
  ELSIF GLO:CAS_ID>0  !USER CLICKS ON SELECT BUTTON TO PICK UP A CASE
    !GLO:VOLUME_ID='TXFAM'   !DEFAULT TO FAMILY LAW
    GLO:NOCASE=FALSE
    LoadAnswersDelin()           !LOAD QOBLIGATE, QPAYMENTS AND OTHER DATA
    IF RECORDS(QObligate)
      GET(QObligate,1)
      IF ~QOB:Frequency
        DO GetOblFrequency       !MA ADDED THIS ROUTINE TO GET THE FREQUENCY OF OBLIGATION BY PARSING QOBLIGATE  2/15/02
        GLO:UpdateObligate=TRUE  !IF MADE GUESS THEN FORCE TO UPDATE WHEN USER CLICK OK BUTTON
        MAKEGUESS=TRUE
      END
    END
    IF GLO:NEWCASE
      !MESSAGE('1.6')
      NAM:ConfirmedInterestRate = 0    !USER WANT SET DEFAULT VALUE TO 0.0 FOR NEW CASE 4/22/02
      GLO:ConfIntRate = 0
    END
  ELSE                !OTHERWISE CALLING IS FAILED
    !MESSAGE('Calling procedure failed.')
    CLEAR(GLO:DelinquentCalcThread)
    DO PROCEDURERETURN
  END
  HELP('PROCALC.HLP')
  SYSTEM{PROP:Icon} = '~PROCALC.ICO'
END
  GLO:DelinquentCalcThread=Thread()
  SORT(QObligate, +QOB:ODate, +QOB:TypeSort)

!Ma - Fogbugz case 15992, initialize dirty flags when open Delinquent Calculator window 12/11/07
GLO:UpdatePayments = FALSE
GLO:UpdateObligate = FALSE
GLO:DelinquentCalcThread = Thread()
SaveOriginalValues()
[END]
EMBED %WindowEventHandling
[INSTANCES]
WHEN 'OpenWindow'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
IF GLO:NOCASE
  DISABLE(?OK)
  DISABLE(?SaveAndContinueButton)
END
!@Parth - FB28903
EXTDebitSave = EXTDebit
Do UpdateAfterSep1
!@Parth
[END]
WHEN 'CloseWindow'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!warn them on the way out to check the frequency one time if
! we made a guess.
!if firstopen and makeguess
!  IF window{PROP:ICONIZE}=TRUE
!    window{PROP:ICONIZE}=FALSE
!  END
!  do showfreqwarning !sets firstopen to false if showed the warning
!  if ~FirstOpen then
!    select(?Qobligate,1) !put focus on what they should check
!    cycle !let them do it.
!  end
!end

IF ~GLO:NOCASE AND ~LOC:OKBUTTON
  IF window{PROP:ICONIZE}=TRUE
    window{PROP:ICONIZE}=FALSE
  END
  !CASE MESSAGE('Are you sure you want to exit without saving information?','Confirm',|
  CASE MESSAGE('Canceling will cause you to lose any information you have|entered since '|
             & 'the last save. Do you still want to Cancel?','Caution',|
                ICON:EXCLAMATION,BUTTON:YES+BUTTON:NO,BUTTON:NO)
  OF BUTTON:NO
    CYCLE
  END
END

[END]
[END]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?QOBLIGATE'
[INSTANCES]
WHEN 'AlertKey'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
DO ObligateAlerts
[END]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
IF KEYCODE() = MOUSELEFT2
  POST(EVENT:ACCEPTED,?ChangeObligation)
  CYCLE
.
IF ~RECORDS(QObligate)
  DISABLE(?ChangeObligation)
  DISABLE(?DeleteObligation)
  DISABLE(?ChangeRange)
  SELECT(?InsertObligation)
ELSE
  ENABLE(?ChangeObligation)
  ENABLE(?DeleteObligation)
  ENABLE(?ChangeRange)
END
[END]
[END]
