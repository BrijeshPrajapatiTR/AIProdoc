%LookupAssign DEPEND %Control MULTI LONG TIMES 0

%MoreTarget DEPEND %LookupAssign FIELD TIMES 0

%MoreField DEPEND %LookupAssign DEFAULT TIMES 0

%Parameters DEFAULT  ('')
[EMBED]
EMBED %ProcedureInitialize
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF OBLIGATE::Used = 0
!  CheckOpen(OBLIGATE,1)
!END
!BIND(OBL:RECORD)
!OBLIGATE::Used += 1

PaymentOption = 'A'
FirstDay = 1
! @Parth - FB28903
  ObligationType = 'Child'
!  @Parth 
[END]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?FromDate'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?FromDate{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?ToDate'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?ToDate{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?Option1:Monthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptFirstDay,?MonthlyLastDay)
DISABLE(?PromptSecondDay,?DayOfWeek)
IF MonthlyLastDay
  DISABLE(?PromptFirstDay)
  DISABLE(?FirstDay)
END
DISPLAY()
[END]
[END]
WHEN '?Option1:semimonthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?MonthlyLastDay)
DISPLAY()
[END]
[END]
WHEN '?Option1:weekly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISPLAY()
[END]
[END]
WHEN '?Option1:biweekly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
[END]
[END]
WHEN '?OkButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
UPDATE
IF ~FromDate
  SELECT(?FromDate)
  CYCLE
END

IF ~ToDate
  SELECT(?ToDate)
  CYCLE
END

IF ~ObligationAmount
  SELECT(?ObligationAmount)
  CYCLE
END

CASE PaymentOption
OF 'A'
  IF ~FirstDay
    SELECT(?FirstDay)
    CYCLE
  END
OF 'B'
  IF ~FirstDay
    SELECT(?FirstDay)
    CYCLE
  END
  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    CYCLE
  END
OF 'C'
OROF 'D'
  IF ~DayOfWeek
    SELECT(?DayOfWeek)
    CYCLE
  END
END

!-----MA ADDED CODE TO MAKE SURE ANY DATE WITHIN THE RANGE IS NOT DUPLICATE WITH EXISTED DATES  7/25/01
CASE PaymentOption
OF 'A'
  LOC:DUP=0
  DO CheckDupDateMonthly
  IF LOC:DUP
    MESSAGE('Some of the dates within the range you entered already exist in obligations list. '|
          & 'Every obligation must have a different date. No new obligations were inserted.',|
            'Duplicate Date')
    SELECT(?FromDate)
    CYCLE
  END
OF 'B'
  LOC:DUP=0
  DO CheckDupDateSemiMonthly
  IF LOC:DUP
    MESSAGE('Some of the dates within the range you entered already exist in obligations list. '|
          & 'Every obligation must have a different date. No new obligations were inserted.',|
            'Duplicate Date')
    SELECT(?FromDate)
    CYCLE
  END
OF 'C'
  LOC:DUP=0
  DO CheckDupDateWeekly
  IF LOC:DUP
    MESSAGE('Some of the dates within the range you entered already exist in obligations list. '|
          & 'Every obligation must have a different date. No new obligations were inserted.',|
            'Duplicate Date')
    SELECT(?FromDate)
    CYCLE
  END
OF 'D'
  LOC:DUP=0
  DO CheckDupDateBiWeekly
  IF LOC:DUP
    MESSAGE('Some of the dates within the range you entered already exist in obligations list. '|
          & 'Every obligation must have a different date. No new obligations were inserted.',|
            'Duplicate Date')
    SELECT(?FromDate)
    CYCLE
  END
END
!----------------------------------------------------------------------------

DISABLE(?CancelButton)
SETCURSOR(CURSOR:WAIT)
DO CallUpdate
SETCURSOR()
[GROUP]
PRIORITY 4000
INSTANCE 2
[END]
[END]
[END]
EMBED %ControlPostEventHandling
[INSTANCES]
WHEN '?FromDate'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF KEYCODE() = TabKey AND ~FromDate
!  SELECT(?FromDate)
!  CYCLE
!.
[END]
[END]
WHEN '?ToDate'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF KEYCODE() = TabKey AND ~ToDate
!  SELECT(?ToDate)
!  CYCLE
!END
[END]
[END]
WHEN '?CancelButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[GROUP]
PRIORITY 4000
INSTANCE 1
[END]
[END]
WHEN '?MonthlyLastDay'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF MonthlyLastDay
  Disable(?FirstDay)
  DISABLE(?PromptFirstDay)
ELSE
  ENABLE(?PromptFirstDay,?FirstDay)
.
[END]
[END]
WHEN '?SemiMonthlyLastDay'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF SemiMonthlyLastDay
  Disable(?SecondDay)
ELSE
  ENABLE(?PromptSecondDay,?SecondDay)
.
[END]
[END]
WHEN '?Calendar:2'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
SELECT(?ToDate)
[END]
[END]
WHEN '?Calendar'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
SELECT(?FromDate)
[END]
[END]
[END]
EMBED %EndOfProcedure
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  SORT(QOBLIGATE,QOB:ODATE)
  !OBLIGATE::Used -= 1
  !IF OBLIGATE::Used = 0 THEN CLOSE(OBLIGATE).
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!-----------------------------------
CallUpdate      ROUTINE
!-----------------------------------
! @Parth - FB28903 
  CASE UPPER(QOB:Type)
  OF 'CHILD'
    QOB:ObligateTypeDisplayText = 'Child Support'
  OF 'MEDICAL'
    QOB:ObligateTypeDisplayText = 'Medical Support'
  OF 'DENTAL'
    QOB:ObligateTypeDisplayText = 'Dental Support'
  END
! @Parth 
  
  CASE PaymentOption
  OF 'A'                        !Monthly
    QOB:Frequency='Monthly'     !MA ADDED  2/15/02
    DO Monthly
  OF 'B'                        !Semimonthly
    QOB:Frequency='Semi-monthly'!MA ADDED  2/15/02
    DO SemiMonthly
  OF 'C'                        !Weekly
    QOB:Frequency='Weekly'      !MA ADDED  2/15/02
    DO Weekly
  OF 'D'                        !Biweekly
    QOB:Frequency='Bi-weekly'   !MA ADDED  2/15/02
    DO BiWeekly
  END

!-----------------------------------
Monthly      ROUTINE
!-----------------------------------

  IF MonthlyLastDay                         !If payment is to be made on last day of month
    FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                             ! subtract 1 day to get the
                                                             ! last day of month

  ELSIF DAY(FromDate) > FirstDay   !If from date is after the day of month for payment
    FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !set for next month
  ELSE                                        !otherwise set due date equal to the
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))  !day of month selected
  .
  LocalResponse = RequestCompleted

  QOB:ODATE = FirstDate
  LOOP
    DO AddRecords
    IF MonthlyLastDay  !If payment on last day of month then set for 1st day of second
      QOB:ODATE =  (DATE(MONTH(QOB:ODATE)+2,1,YEAR(QOB:ODATE)))-1   !month the subtract 1 to
                                                                    !get last day of next month
    ELSE
      QOB:ODATE =  DATE(MONTH(QOB:ODATE)+1,FirstDay,YEAR(QOB:ODATE))
    .
    IF QOB:ODATE > ToDate THEN BREAK.
  .

!-----------------------------------
SemiMonthly      ROUTINE
!-----------------------------------
  DATA
M     LONG
  CODE
  IF ~FirstDaY
    SELECT(?FirstDay)
    EXIT
  END

  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    EXIT
  END

  IF DAY(FromDate) > FirstDay !If from date is greater than day of month for first obligation
    IF SemiMonthlyLastDay                         !If payment is to be made on last day of month
      FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                               ! subtract 1 day to get the
                                                               ! last day of month
      DayFlag = 1           !DayFlag will be set to keep track of which obligation of the month we are doing
                            !  it's set in reverse from here because the addrecord is done in the loop below
                            !  and then the flag is reset.  This starts it out correctly

    ELSE   !If second obligation day is not the last day of month
      IF DAY(FromDate) > SecondDay !If past first and second obligation dates then start over with
        FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !the first obligation date next month
        DayFlag = 2
      ELSE                         !Otherwise set for the second obligation day
        !FirstDate = DATE(MONTH(FromDate)+1,SecondDay,YEAR(FromDate)) !Set first payment for day of
        FirstDate = DATE(MONTH(FromDate),SecondDay,YEAR(FromDate)) !Set first payment for day of   !MA CHANGED 1/15/02
        DayFlag = 1                                                  !month for second obligation
      END!OF handling second day
    END!END OF SEMIMONTHLYLASTDAY IF STATEMENT

  ELSE                             !If from date is less than set first obligation date
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))!start obligation then
    DayFlag = 2
  .

  LocalResponse = RequestCompleted
  QOB:ODATE = FirstDate
  M=MONTH(QOB:ODATE)
  LOOP
    DO AddRecords
    IF DayFlag = 1
      QOB:ODATE =  DATE(MONTH(QOB:ODATE)+1,FirstDay,YEAR(QOB:ODATE))
      DayFlag = 2
      M=MONTH(QOB:ODATE)
    ELSE
      IF SemiMonthlyLastDay  !If payment on last day of month then set for 1st day of second
        QOB:ODATE =  (DATE(MONTH(QOB:ODATE)+1,1,YEAR(QOB:ODATE)))-1   !month the subtract 1 to
      ELSE                                                            !get last day of next month
        QOB:ODATE =  DATE(MONTH(QOB:ODATE),SecondDay,YEAR(QOB:ODATE))
        IF MONTH(QOB:ODATE)>M !FIX THE BUG WHEN SECOND DAY IS 30TH ON FEBRUARY THE MARCH 30TH WAS SKIPPED
          QOB:ODATE =  (DATE(M+1,1,YEAR(QOB:ODATE)))-1
        END
      END !OF IF MonthlyLastDay
      DayFlag = 1
    .
    IF QOB:ODATE > ToDate THEN BREAK.
  .


!-----------------------------------
Weekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE
 .

  LocalResponse = RequestCompleted

  QOB:ODATE = FirstDate
  LOOP
    DO AddRecords
    QOB:ODATE += 7
    IF QOB:ODATE > ToDate THEN BREAK.
  .

!-----------------------------------
BiWeekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE
 .

  LocalResponse = RequestCompleted

  QOB:ODATE = FirstDate
  LOOP
    DO AddRecords
    QOB:ODATE += 14
    IF QOB:ODATE > ToDate THEN BREAK.
  .


!-----------------------------------
AddRecords      ROUTINE
!-----------------------------------
  QOB:OCaseID = CAS:CAS_ID
  QOB:OAMOUNT = ObligationAmount
  ADD(QOBLIGATE,QOB:ODATE)
  IF ERRORCODE()
      MESSAGE('Unable to add an obligation for ' & FORMAT(QOB:ODATE,@D1) |
         & '!',,ICON:EXCLAMATION,BUTTON:OK,BUTTON:OK)
  ELSE
    GLO:UpdateObligate = TRUE
  .


!-------------------------------
CheckDupDateMonthly     ROUTINE        !MA CREATED     7/25/01
!-------------------------------
  FREE(MonthlyQ)

  IF MonthlyLastDay                         !If payment is to be made on last day of month
    FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                             ! subtract 1 day to get the
                                                             ! last day of month

  ELSIF DAY(FromDate) > FirstDay   !If from date is after the day of month for payment
    FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !set for next month
  ELSE                                        !otherwise set due date equal to the
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))  !day of month selected
  .

  MTQ:DATE = FirstDate
  LOOP
    ADD(MonthlyQ)
    IF MonthlyLastDay  !If payment on last day of month then set for 1st day of second
      MTQ:DATE =  (DATE(MONTH(MTQ:DATE)+2,1,YEAR(MTQ:DATE)))-1   !month the subtract 1 to
                                                                    !get last day of next month
    ELSE
      MTQ:DATE =  DATE(MONTH(MTQ:DATE)+1,FirstDay,YEAR(MTQ:DATE))
    .
    IF MTQ:DATE > ToDate THEN BREAK.
  .
  LOC:DUP=0
  LOOP I#=1 TO RECORDS(MONTHLYQ)
    GET(MONTHLYQ,I#)
    IF ERRORCODE() THEN BREAK.
    QOB:ODATE=MTQ:DATE
    !@Parth - FB28903
    QOB:Type = ObligationType
!    GET(QOBLIGATE,QOB:ODATE)
    GET(QOBLIGATE,QOB:ODATE,QOB:Type)
    !@Parth
    IF ~ERRORCODE()
      LOC:DUP=1
      EXIT
    END
  END

!-----------------------------------
CheckDupDateSemiMonthly     ROUTINE        !MA CREATED     7/25/01
!-----------------------------------
  FREE(SemiMonthlyQ)

  IF ~FirstDaY
    SELECT(?FirstDay)
    EXIT
  END
  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    EXIT
  END
  IF DAY(FromDate) > FirstDay !If from date is greater than day of month for first obligation
    IF SemiMonthlyLastDay                         !If payment is to be made on last day of month
      FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                               ! subtract 1 day to get the
                                                               ! last day of month
      DayFlag = 1           !DayFlag will be set to keep track of which obligation of the month we are doing
                            !  it's set in reverse from here because the addrecord is done in the loop below
                            !  and then the flag is reset.  This starts it out correctly

    ELSE   !If second obligation day is not the last day of month
      IF DAY(FromDate) > SecondDay !If past first and second obligation dates then start over with
        FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !the first obligation date next month
        DayFlag = 2
      ELSE                         !Otherwise set for the second obligation day
        FirstDate = DATE(MONTH(FromDate)+1,SecondDay,YEAR(FromDate)) !Set first payment for day of
        DayFlag = 1                                                  !month for second obligation
      END!OF handling second day
    END!END OF SEMIMONTHLYLASTDAY IF STATEMENT
  ELSE                                        !If from date is less than set first obligation date
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))!start obligation then
    DayFlag = 2
  .
  SMQ:DATE = FirstDate
  LOOP
    ADD(SemiMonthlyQ)
    IF DayFlag = 1
      SMQ:DATE =  DATE(MONTH(SMQ:DATE)+1,FirstDay,YEAR(SMQ:DATE))
      DayFlag = 2
    ELSE
      IF SemiMonthlyLastDay  !If payment on last day of month then set for 1st day of second
        SMQ:DATE =  (DATE(MONTH(SMQ:DATE)+1,1,YEAR(SMQ:DATE)))-1   !month the subtract 1 to
      ELSE                                                            !get last day of next month
        SMQ:DATE =  DATE(MONTH(SMQ:DATE),SecondDay,YEAR(SMQ:DATE))
      END !OF IF MonthlyLastDay
      DayFlag = 1
    .
    IF SMQ:DATE > ToDate THEN BREAK.
  .
  LOC:DUP=0
  LOOP I#=1 TO RECORDS(SemiMonthlyQ)
    GET(SemiMonthlyQ,I#)
    IF ERRORCODE() THEN BREAK.
    QOB:ODATE=SMQ:DATE
    !@Parth - FB28903
    QOB:Type = ObligationType
!    GET(QOBLIGATE,QOB:ODATE)
    GET(QOBLIGATE,QOB:ODATE,QOB:Type)
    !@Parth
    IF ~ERRORCODE()
      LOC:DUP=1
      EXIT
    END
  END

!-----------------------------------
CheckDupDateWeekly        ROUTINE        !MA CREATED     7/25/01
!-----------------------------------
  FREE(WeeklyQ)

  CASE DayOfWeek
  OF 'Sunday'
    DayNumber = 0
  OF 'Monday'
    DayNumber = 1
  OF 'Tuesday'
    DayNumber = 2
  OF 'Wednesday'
    DayNumber = 3
  OF 'Thursday'
    DayNumber = 4
  OF 'Friday'
    DayNumber = 5
  OF 'Saturday'
    DayNumber = 6
  END
  EnteredDay = FromDate % 7
  IF EnteredDay = DayNumber
      FirstDate = FromDate
  ELSIF EnteredDay < DayNumber
      FirstDate = FromDate + (DayNumber - EnteredDay)
  ELSE
!     FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE
  .
   WKQ:DATE = FirstDate
  LOOP
    ADD(WeeklyQ)
    WKQ:DATE += 7
    IF WKQ:DATE > ToDate THEN BREAK.
  .
  LOC:DUP=0
  LOOP I#=1 TO RECORDS(WeeklyQ)
    GET(WeeklyQ,I#)
    IF ERRORCODE() THEN BREAK.
    QOB:ODATE=WKQ:DATE
   !@Parth - FB28903
    QOB:Type = ObligationType
!    GET(QOBLIGATE,QOB:ODATE)
    GET(QOBLIGATE,QOB:ODATE,QOB:Type)
    !@Parth
    IF ~ERRORCODE()
      LOC:DUP=1
      EXIT
    END
  END

!-----------------------------------
CheckDupDateBiWeekly        ROUTINE        !MA CREATED     7/25/01
!-----------------------------------
  FREE(BiWeeklyQ)
  DebugCL.DumpQ(QObligate,'QObligate Queue-----')
  CASE DayOfWeek
  OF 'Sunday'
    DayNumber = 0
  OF 'Monday'
    DayNumber = 1
  OF 'Tuesday'
    DayNumber = 2
  OF 'Wednesday'
    DayNumber = 3
  OF 'Thursday'
    DayNumber = 4
  OF 'Friday'
    DayNumber = 5
  OF 'Saturday'
    DayNumber = 6
  END
  DebugCL.Send('DayNumber: ' & DayNumber)
  DebugCL.Send('FromDate: ' & FromDate & ' -- ' & format(FromDate, @d2))
  EnteredDay = FromDate % 7
  DebugCL.Send('EnteredDay: ' & EnteredDay)
  IF EnteredDay = DayNumber
      FirstDate = FromDate
  ELSIF EnteredDay < DayNumber
      FirstDate = FromDate + (DayNumber - EnteredDay)
  ELSE
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)
  .
  DebugCL.Send('FirstDate: ' & FirstDate & ' -- ' & format(FirstDate, @d2)) 
  BWQ:DATE = FirstDate
  LOOP
    ADD(BiWeeklyQ)
    BWQ:DATE += 14
    IF BWQ:DATE > ToDate THEN BREAK.
  .
  DebugCL.Send('ToDate: ' & ToDate & ' -- ' & format(ToDate, @d2))
  DebugCL.DumpQ(BiWeeklyQ,'BiWeekly Queue-----')
  LOC:DUP=0
  LOOP I#=1 TO RECORDS(BiWeeklyQ)
    DebugCL.Send('I#: ' & I#)
    GET(BiWeeklyQ,I#)
    IF ERRORCODE()
      !DebugCL.Send('I#: ' & I#)
      BREAK
    END
    QOB:ODATE=BWQ:DATE
    DebugCL.Send('I#: ' & BWQ:DATE & ' -- ' & format(BWQ:DATE, @d2))
    !@Parth - FB28903
    QOB:Type = ObligationType
!    GET(QOBLIGATE,QOB:ODATE)
    GET(QOBLIGATE,QOB:ODATE,QOB:Type)
    !@Parth
    IF ~ERRORCODE()
      LOC:DUP=1
      DebugCL.Send('LOC:DUP: ' & LOC:DUP)
      EXIT
    END
  END

[END]
EMBED %DataSectionBeforeWindow
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!MA ADDED TO BE USED TO CHECK OUT DUPLICATE DATE  7/25/01
MonthlyQ       QUEUE,PRE(MTQ)
DATE            LONG
               END
SemiMonthlyQ   QUEUE,PRE(SMQ)
DATE            LONG
               END
WEEKLYQ        QUEUE,PRE(WKQ)
DATE            LONG
               END
BiWEEKLYQ      QUEUE,PRE(BWQ)
DATE            LONG
               END
LOC:DUP        BYTE(0)
[END]
[END]
