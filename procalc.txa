WHEN '?Calendar'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
NAM:ConfirmedDate=Calendar2.SelectedDate
DISPLAY(?NAM:ConfirmedDate)
IF Calendar2.Response = RequestCompleted
  GLO:ConfirmedLastDate = NAM:ConfirmedDate
  GLO:JudgementDate=NAM:ConfirmedDate    !SAVE DATE TO ANOTHER GLOBALE VAR BECAUSE GLO:ConfirmedLastDate
  IF NAM:ConfirmedDate=0     !IF USER CLEAR THE DATE ENTRY THEN WE SHOULD CLEAR RATE ENTRY  4/22/02
    !MESSAGE('1.8')
    NAM:ConfirmedInterestRate=0.00
    NAM:ConfirmedPrincipal=0
  END
!  IF NAM:ConfirmedDate<DATE(9,1,2001)      ! WILL BE CHANGED IN ProcessPayment PROCEDURE
!    ATT:Attyfeescosts=0
!    ATT:InterestRate=0
!    DISABLE(?Group2)
!  ELSE
!    ENABLE(?Group2)
!!    ATT:InterestType='COMPOUND'
!  END
  Do RestoreJudgmentSupportTab
  CASE (JudgmentSupportTabSelected)
  OF 1
    !MESSAGE('Calendar Child: NAMChild:ConfirmedInterestRate: ' & NAMChild:ConfirmedInterestRate)
    IF NAMChild:ConfirmedDate<DATE(9,1,2001)      ! WILL BE CHANGED IN ProcessPayment PROCEDURE
      ATTChild:Attyfeescosts=0
      ATTChild:InterestRate=0
      DISABLE(?Group2)
    ELSE
      ENABLE(?Group2)
!  ATT:InterestType='COMPOUND'
    END
    IF NAMChild:ConfirmedDate<DATE(9,1,1987)
      NAMChild:InterestType='SIMPLE'
    END
    IF NAMChild:ConfirmedDate>=DATE(9,1,1987) AND NAMChild:ConfirmedDate<=DATE(8,31,1993)
      NAMChild:InterestType='COMPOUND'
    END
    IF NAMChild:ConfirmedDate>=DATE(9,1,1993) AND NAMChild:ConfirmedDate<DATE(1,1,2002) AND FOCUS()<>?OK
      NAMChild:InterestType='SIMPLE'
      NAMChild:ConfirmedInterestRate=0.12
    END
    IF NAMChild:ConfirmedDate>=DATE(1,1,2002) AND FOCUS()<>?OK  !BECAUSE WHEN USER CLICK OK BUTTON
      NAMChild:InterestType='SIMPLE'                            ! THIS EVENT STILL HAPPENS AND WILL
      NAMChild:ConfirmedInterestRate=0.06                       ! CHANGE THE RATE BACK TO DEFAULT AND
      ATTChild:InterestType='COMPOUND'
    END
  OF 2
    !MESSAGE('Calendar Medical NAMMedical:ConfirmedInterestRate: ' & NAMMedical:ConfirmedInterestRate)
    IF NAMMedical:ConfirmedDate<DATE(9,1,2001)      ! WILL BE CHANGED IN ProcessPayment PROCEDURE
      ATTMedical:Attyfeescosts=0
      ATTMedical:InterestRate=0
      DISABLE(?Group2)
    ELSE
      ENABLE(?Group2)
!  ATT:InterestType='COMPOUND'
    END
    IF NAMMedical:ConfirmedDate<DATE(9,1,1987)
      NAMMedical:InterestType='SIMPLE'
    END
    IF NAMMedical:ConfirmedDate>=DATE(9,1,1987) AND NAMMedical:ConfirmedDate<=DATE(8,31,1993)
      NAMMedical:InterestType='COMPOUND'
    END
    IF NAMMedical:ConfirmedDate>=DATE(9,1,1993) AND NAMMedical:ConfirmedDate<DATE(1,1,2002) AND FOCUS()<>?OK
      NAMMedical:InterestType='SIMPLE'
      NAMMedical:ConfirmedInterestRate=0.12
    END
    IF NAMMedical:ConfirmedDate>=DATE(1,1,2002) AND FOCUS()<>?OK  !BECAUSE WHEN USER CLICK OK BUTTON
      NAMMedical:InterestType='SIMPLE'                            ! THIS EVENT STILL HAPPENS AND WILL
      NAMMedical:ConfirmedInterestRate=0.06                       ! CHANGE THE RATE BACK TO DEFAULT AND
      ATTMedical:InterestType='COMPOUND'
    END
  OF 3
    IF NAMDental:ConfirmedDate<DATE(9,1,2001)      ! WILL BE CHANGED IN ProcessPayment PROCEDURE
      ATTDental:Attyfeescosts=0
      ATTDental:InterestRate=0
      DISABLE(?Group2)
    ELSE
      ENABLE(?Group2)
!  ATT:InterestType='COMPOUND'
    END
    IF NAMDental:ConfirmedDate<DATE(9,1,1987)
      NAMDental:InterestType='SIMPLE'
    END
    IF NAMDental:ConfirmedDate>=DATE(9,1,1987) AND NAMDental:ConfirmedDate<=DATE(8,31,1993)
      NAMDental:InterestType='COMPOUND'
    END
    IF NAMDental:ConfirmedDate>=DATE(9,1,1993) AND NAMDental:ConfirmedDate<DATE(1,1,2002) AND FOCUS()<>?OK
      NAMDental:InterestType='SIMPLE'
      NAMDental:ConfirmedInterestRate=0.12
    END
    IF NAMDental:ConfirmedDate>=DATE(1,1,2002) AND FOCUS()<>?OK  !BECAUSE WHEN USER CLICK OK BUTTON
      NAMDental:InterestType='SIMPLE'                            ! THIS EVENT STILL HAPPENS AND WILL
      NAMDental:ConfirmedInterestRate=0.06                       ! CHANGE THE RATE BACK TO DEFAULT AND
      ATTDental:InterestType='COMPOUND'
    END
  END
!  IF NAM:ConfirmedDate<DATE(9,1,1987)
!    NAM:InterestType='SIMPLE'
!  END
!  IF NAM:ConfirmedDate>=DATE(9,1,1987) AND NAM:ConfirmedDate<=DATE(8,31,1993)
!    NAM:InterestType='COMPOUND'
!  END
!  IF NAM:ConfirmedDate>=DATE(9,1,1993) AND NAM:ConfirmedDate<DATE(1,1,2002) AND FOCUS()<>?OK
!    NAM:InterestType='SIMPLE'
!    NAM:ConfirmedInterestRate=0.12
!  END
!  IF NAM:ConfirmedDate>=DATE(1,1,2002) AND FOCUS()<>?OK  !BECAUSE WHEN USER CLICK OK BUTTON
!    NAM:InterestType='SIMPLE'                            ! THIS EVENT STILL HAPPENS AND WILL
!    NAM:ConfirmedInterestRate=0.06                       ! CHANGE THE RATE BACK TO DEFAULT AND
!    ATT:InterestType='COMPOUND'
!  END                                                    ! USER COULDN'T SAVE NEW RATE  1/31/02 MA
  Do SaveJudgmentSupportTab !Nikita - TODO
  DISPLAY()
END
!Do RestoreJudgmentSupportTab !Nikita - TODO
[END]
[END]
