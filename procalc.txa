  ANS:ANSWER      = LEFT(FORMAT(RPQ:AplCint,@N-_11.2))
  ANS:OBJ_ID      = 'PX313'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = RPQ:DebitMessage
  ANS:OBJ_ID      = 'PX314'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

    !MA ADDED FOLLOWING CODE TO SAVE ATTORNEY'S FEES AND COSTS   7/05/01
  ANS:ANSWER      = LEFT(FORMAT(RPQ:Attyfeescosts,@N-_10.2))
  ANS:OBJ_ID      = 'PX349'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AttyfeescostsInt,@N-_10.2))
  ANS:OBJ_ID      = 'PX350'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  IF RPQ:TYPE='O'            
    ANS:ANSWER      = LEFT(RPQ:Frequency)    !THIS IS NEW TOKEN FOR FREQUENCY ONLY SAVE FOR OBL
    ANS:OBJ_ID      = 'AX300'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
  END
! @Parth 
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!@Parth - FB28903 - ExportRecordsFAMAfterSep1Dental ROUTINE
ExportRecordsFAMAfterSep1Dental ROUTINE
  
  If (RPQ:Type = 'P' OR RPQ:Type = 'F') AND UPPER(CLIP(RPQ:ObligationType)) <> 'DENTAL'
    EXIT
  END
      
  ANS:CAS_ID = GLO:CAS_ID
  ANS:VOLUME_ID = LOC:VOLUME_ID
  ANS:SCOPE  = 'V'
  CLEAR(ANS:INDEXSTRING,-1)
  ! @Parth - FB28903 
!    ANS:INDEXES[1]  = SwapUshortBytes(QCOUNTER)
  KCOUNTERDental += 1
  IF RPQ:Type = 'O' AND RPQ:dummybyte = 0
    KCOUNTERObligationsDental += 1
  END
  ANS:INDEXES[1]  = SwapUshortBytes(KCOUNTERDental)
  ! @Parth 
  ANS:ANSWER      = LEFT(FORMAT(RPQ:DATE,@D01))
  ANS:OBJ_ID      = 'PX401'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)
            
  ANS:ANSWER      = RPQ:Type
  ANS:OBJ_ID      = 'PX402'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)
!  DebugCL.Send('SAVE Dental RPQ:Type: ' & RPQ:TYPE)

  IF RPQ:TYPE = 'D'                                     !For DEBITS, the amount applied
    RPQ:AplUobl = RPQ:DebitUobl                         ! to each category is not stored in
    RPQ:AplCobl = RPQ:DebitCobl                         ! reportque so need to set it up here
    RPQ:AplUint = RPQ:DebitUint
    RPQ:AplCint = RPQ:DebitCint
    RPQ:AmountP = 0-(RPQ:DebitUobl+RPQ:DebitCobl+RPQ:DebitUint+RPQ:DebitCint)
    RPQ:AmountO = 0.00
  END

    !Ma - Fogbugz 18886, the pictures used to save decimal amount is too small which causes "######.##" so changed all
    ! "@N-_9.2" pictures to "@N-_10.2" and then changed the PX006V picture from "@N-_10.2" to "@N-11.2"  7/31/08
  ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountO,@N-_11.2))
  ANS:OBJ_ID      = 'PX403'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:UnpaidBalance,@N-_11.2))
  ANS:OBJ_ID      = 'PX404'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountP,@N-_11.2))
  IF RPQ:TYPE = 'D'
    ANS:Answer = 0.00
  END
  ANS:OBJ_ID      = 'PX405'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)
  
!  ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountP,@N-_11.2))
!  ANS:OBJ_ID      = 'PX455'
!  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
!  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:Uobl,@N-_11.2))
  ANS:OBJ_ID      = 'PX406'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:Cobl,@N-_11.2))
  ANS:OBJ_ID      = 'PX407'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:Uint,@N-_11.2))
  ANS:OBJ_ID      = 'PX408'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:Cint,@N-_11.2))
  ANS:OBJ_ID      = 'PX409'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AplUobl,@N-_11.2))
  ANS:OBJ_ID      = 'PX410'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AplCobl,@N-_11.2))
  ANS:OBJ_ID      = 'PX411'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AplUint,@N-_11.2))
  ANS:OBJ_ID      = 'PX412'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AplCint,@N-_11.2))
  ANS:OBJ_ID      = 'PX413'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = RPQ:DebitMessage
  ANS:OBJ_ID      = 'PX414'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

    !MA ADDED FOLLOWING CODE TO SAVE ATTORNEY'S FEES AND COSTS   7/05/01
  ANS:ANSWER      = LEFT(FORMAT(RPQ:Attyfeescosts,@N-_10.2))
  ANS:OBJ_ID      = 'PX449'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AttyfeescostsInt,@N-_10.2))
  ANS:OBJ_ID      = 'PX450'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  IF RPQ:TYPE='O'            
    ANS:ANSWER      = LEFT(RPQ:Frequency)    !THIS IS NEW TOKEN FOR FREQUENCY ONLY SAVE FOR OBL
    ANS:OBJ_ID      = 'AX400'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
  END
! @Parth
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!ExportFinishOutFAM  ROUTINE
!-------------------------------
ExportFinishOutFAM    ROUTINE
!-------------------------------
  DATA
KCOUNTER      LONG
  CODE
    !CHECK TO SEE IF GLO:CALCDATE IS GREAT THAN THE LAST DATE IN QOBLIGATE OR LAST DATE IN QPAYMENTS
    ! IF NOT THEN WE NEED TO SAVE REST OF THE RECORDS HAVE NOT BEEN SAVED IN QOBLIGATE AND QPAYMENTS
    KCOUNTER=QCOUNTER
    IF RECORDS(QObligate)
      ANS:CAS_ID = GLO:CAS_ID
      DebugCL.Send('Saving FinishOUT OBligate FAM routine: ' & LOC:VOLUME_ID)
      ANS:VOLUME_ID = LOC:VOLUME_ID
      ANS:SCOPE  = 'V'
      CLEAR(ANS:INDEXSTRING,-1)
      LOOP I#=1 TO RECORDS(QOBLIGATE)
        GET(QOBLIGATE,I#)
        IF ERRORCODE() THEN BREAK.
        DebugCL.Send('QOB:ODATE: ' & FORMAT(QOB:ODATE,@D2) & ', GLO:CalcDate: ' & FORMAT(GLO:CalcDate,@D2) & ', QOB:Type: ' & QOB:Type)
        IF QOB:ODATE<=GLO:CalcDate THEN CYCLE.
!       @Parth - FB28903
        DebugCL.Send('Inside obl GLO Calc IF')
        ANS:INDEXES[1]  = SwapUshortBytes(KCOUNTER)

        ANS:ANSWER      = LEFT(FORMAT(QOB:ODATE,@D01))
        ANS:OBJ_ID      = 'PX001'
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)
      
        ANS:ANSWER      = 'O'
        ANS:OBJ_ID      = 'PX002'
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)

        ANS:ANSWER      = LEFT(FORMAT(QOB:OAmount,@N-_11.2))
        ANS:OBJ_ID      = 'PX003'
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)

        ANS:ANSWER      = LEFT(QOB:Frequency)
        ANS:OBJ_ID      = 'AX100'
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)
        DebugCL.Send('ExportFinishOutFAM QOB:Type: ' & QOB:Type)
        CASE UPPER(QOB:Type)
        OF 'CHILD'
          DO ExportFinishOutFAMAfterSep1ObligateChild
        OF 'MEDICAL'
          DO ExportFinishOutFAMAfterSep1ObligateMedical
        OF 'DENTAL'
          Do ExportFinishOutFAMAfterSep1ObligateDental
        END
!       @Parth 
        KCOUNTER+=1
      END
    END
    
    !   @Parth - FB28903 
    ANS:ANSWER      = ''
    DebugCL.Send('ExportFinishOutFAM KCOUNTERObligationsChild: ' & KCOUNTERObligationsChild)
    DebugCL.Send('ExportFinishOutFAM KCOUNTERObligationsMedical ' & KCOUNTERObligationsMedical)
    DebugCL.Send('ExportFinishOutFAM KCOUNTERObligationsDental: ' & KCOUNTERObligationsDental)
      IF KCOUNTERObligationsChild >= 1 THEN ANS:Answer = '1' .
      IF KCOUNTERObligationsMedical >= 1 THEN ANS:Answer = LEFT(CLIP(ANS:Answer) & ' 2') .
      IF KCOUNTERObligationsDental >= 1 THEN ANS:Answer = LEFT(CLIP(ANS:Answer) & ' 3') .
      ANS:OBJ_ID      = 'AX102'
      ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
      ADD(ANSWERS)
    
      IF KCOUNTERObligationsChild >= 1 
        ANS:Answer = '1 - Child Support'
        ANS:OBJ_ID      = 'AX102'
        ANS:Indexes[1]  = SwapUshortBytes(1) !256
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)
      END
    
      IF KCOUNTERObligationsMedical >= 1 
        ANS:Answer = '2 - Medical Support'
        ANS:OBJ_ID      = 'AX102'
        ANS:Indexes[1] = SwapUshortBytes(2) !512
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)
      END
    
      IF KCOUNTERObligationsDental >= 1 
        ANS:Answer = '3 - Dental Support'
        ANS:OBJ_ID      = 'AX102'
        ANS:Indexes[1]  = SwapUshortBytes(3) !768
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)
      END
!   @Parth 
    
    DebugCL.Send('RECORDS(QPayments): ' & RECORDS(QPayments))
    IF RECORDS(QPayments)
      ANS:CAS_ID = GLO:CAS_ID
      ANS:VOLUME_ID = LOC:VOLUME_ID
      ANS:SCOPE  = 'V'
      CLEAR(ANS:INDEXSTRING,-1)
      DebugCL.DumpQ(QPayments,'Payment Queue')
      LOOP I#=1 TO RECORDS(QPayments)
!        DebugCL.Send('I#: ' & I#)
        GET(QPayments,I#)
        IF ERRORCODE() THEN BREAK.
        DebugCL.Send('I#: ' & I# & ', QPA:Date: ' & FORMAT(QPA:PDATE,@D01) & ', QPA:Pamount: ' & FORMAT(QPA:PAmount,@N-_11.2))
        DebugCL.Send('GLO:CalcDate: ' & FORMAT(GLO:CalcDate,@D01) & ',KCOUNTER: ' & KCOUNTER )
        IF QPA:PDATE<=GLO:CalcDate THEN CYCLE.
!TODO: Create separate routine for C, M, D 
        !       @Parth - FB28903
         DebugCL.Send('GLO:CalcDate: ' & FORMAT(GLO:CalcDate,@D01) & ', I#: ' & I#)
        ANS:INDEXES[1]  = SwapUshortBytes(I#)

        ANS:ANSWER      = LEFT(FORMAT(QPA:PDATE,@D01))
        ANS:OBJ_ID      = 'PX001'
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)
      
        ANS:ANSWER      = 'P'
        ANS:OBJ_ID      = 'PX002'
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)

        ANS:ANSWER      = LEFT(FORMAT(QPA:PAmount,@N-_11.2))
        ANS:OBJ_ID      = 'PX005'
        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
        ADD(ANSWERS)
        
!        CASE CLIP(UPPER(RPQ:ObligationType))
!        OF 'CHILD'
!          ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountP,@N-_11.2))
!          ANS:OBJ_ID      = 'PX255'
!        OF 'MEDICAL'
!          ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountP,@N-_11.2))
!          ANS:OBJ_ID      = 'PX355'
!        OF 'DENTAL'
!          ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountP,@N-_11.2))
!          ANS:OBJ_ID      = 'PX455'
!        END
!        ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountP,@N-_11.2))
!        ANS:OBJ_ID      = 'PX255'
!        ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
!        ADD(ANSWERS)
        
        DO ExportFinishOutFAMAfterSep1PaymentChild
        DO ExportFinishOutFAMAfterSep1PaymentMedical
        DO ExportFinishOutFAMAfterSep1PaymentDental
!       @Parth
        KCOUNTER+=1
!       TODO: END 
      END
    END
    !After exporting the records from ReportQueue and rest of recors in QObligate & QPayments
    ! this exports the totals SO IT'S NOT DIMENSION
    !TODO: Create 3 separate routine for C, M, D also include code below for PX025,26 and 27 loop
 !       @Parth - FB28903
!    DebugCL.Send('Before Child judgment save')
    DO ExportFinishOutFAMAfterSep1TotalsChild
!    DebugCL.Send('Before Medical judgment save')
    DO ExportFinishOutFAMAfterSep1TotalsMedical
!    DebugCL.Send('Before Dental judgment save')
    Do ExportFinishOutFAMAfterSep1TotalsDental
!       @Parth
!       TODO: END
    ANS:ANSWER      = GLO:Obligor
    ANS:OBJ_ID      = 'PX096'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = GLO:Obligee
    ANS:OBJ_ID      = 'PX098'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    !@Parth - FB28903
    ANS:ANSWER      ='Y'
    ANS:OBJ_ID      = 'A0092'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
    !@Parth 
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!@Parth - FB28903 ExportFinishOutFAMAfterSep1ObligateChild    ROUTINE
ExportFinishOutFAMAfterSep1ObligateChild    ROUTINE
  
  KCOUNTERChild += 1
  KCOUNTERObligationsChild += 1
  DebugCL.Send('KCOUNTERObligationsChild: ' & KCOUNTERObligationsChild)
  
  ANS:INDEXES[1]  = SwapUshortBytes(KCOUNTERChild)

  ANS:ANSWER      = LEFT(FORMAT(QOB:ODATE,@D01))
  ANS:OBJ_ID      = 'PX201'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)
      
  ANS:ANSWER      = 'O'
  ANS:OBJ_ID      = 'PX202'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(QOB:OAmount,@N-_11.2))
  ANS:OBJ_ID      = 'PX203'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(QOB:Frequency)
  ANS:OBJ_ID      = 'AX200'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)
!@Parth
