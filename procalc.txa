LOC:TotalUnconfirmed      DECIMAL(9,2)
LOC:PayConfirmedO         DECIMAL(9,2)
LOC:PayUnconfirmedO       DECIMAL(9,2)
LOC:PayConfirmedI         DECIMAL(9,2)
LOC:PayUnconfirmedI       DECIMAL(9,2)
LOC:TotalPaymentsApplied  DECIMAL(9,2)
LOC:TotalPaymentsMade     DECIMAL(9,2)
LOC:TotalRemaining        DECIMAL(9,2)
LOC:PayAttyfeescosts      DECIMAL(9,2)
LOC:PayAttyfeescostsInt   DECIMAL(9,2)
LOC:AttyfeescostsBalance  DECIMAL(9,2)
LOC:AttyfeescostsIntBalance   DECIMAL(9,2)
LOC:UnconfirmedPrincipalBalance   DECIMAL(9,2)
LOC:UnconfirmedPrincipalBalanceBefore DECIMAL(9,2)
LOC:UnconfirmedInterestBalance    DECIMAL(9,2)
LOC:ConfirmedPrincipalBalance DECIMAL(9,2)
LOC:ConfirmedInterestBalance  DECIMAL(8,2)
LOC:TotalObligations      DECIMAL(8,2)
LOC:DelBalBefore          DECIMAL(8,2)
LOC:DelBalAfter           DECIMAL(8,2)
LOC:ConfirmedLastDate     LONG
LOC:UnConfirmedLastDate   LONG
LOC:ConfIntRate           DECIMAL(6,2)
LOC:DateRendered          LONG
LOC:LastCompoundDate      LONG                                  !
LOC:CompoundBalance       DECIMAL(8,2)                          !
LOC:SaveCompoundBalance   DECIMAL(8,2)                       !
LOC:LastCompoundDateAtty  LONG
LOC:CompoundBalanceAtty   DECIMAL(8,2)
LOC:DailyRate           DECIMAL(10,5)
LOC:Days                  LONG
LOC:calcInterest            Decimal(8,2)
LOC:NewInterest     Decimal(8,2)

LOC:InterestType string(10)
!Debit Tab
LOC:EXT:DebitDate       LONG
LOC:EXT:DebitUobl   DECIMAL(8,2)
LOC:EXT:DebitUint   DECIMAL(8,2)
LOC:EXT:DebitCobl   DECIMAL(8,2)
LOC:EXT:DebitCint   DECIMAL(8,2)


AnnuallyCompound    STRING(18)
SAVEDATE            LONG
SAVEDAMOUNTO        DECIMAL(9,2)
COUNTPAYMENT        DECIMAL(9,2)
[END]
EMBED %PrePrintFromQueue
[INSTANCES]
WHEN '1'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!MA ADDED FOLLOWING CODE TO PRINT OBLIGATION AND PAYMENTS IN SAME DAY TOGETHER(SAME LINE) 8/22/02 
!@Parth - FB28903
!  DebugCL.Send('QQQ123')
If UPPER(RPQ:ObligationType) <> UPPER(CurrentObligationType)
  EXIT
END
!  IF RPQ:dummybyte <> 0 THEN EXIT.
!  IF RPQ:Type = 'P' AND RPQ:AmountP <= 0 THEN EXIT.
IF (RPQ:Type = 'O' OR RPQ:Type = 'P'  OR RPQ:Type = 'D' ) AND RPQ:IsDummyProcess = 1
  EXIT
END
  !@Parth
SAVEDATE=RPQ:DATE
SavedAmountO=RPQ:AMOUNTO
CountPayment=RPQ:AMOUNTP
!  DebugCL.Send('QQQ RPQ:ObligationType: ' & RPQ:ObligationType & ', CurrentObligationType: ' & CurrentObligationType)

IF RPQ:TYPE='O'
  DebugCL.Send('QQQ RPQ:ObligationType: ' & RPQ:ObligationType & ', RPQ:Type: ' & RPQ:Type & ', RPQ:dummyByte: ' & RPQ:dummybyte )
  LOOP
    IF RECORDS(ReportQueue)<QueNdx:1+1
      BREAK
    END
    GET(ReportQueue,QueNdx:1+1)
      !TODO: Show the proper payment applied to the obligation
    IF SAVEDATE=RPQ:DATE AND RPQ:TYPE='P' AND CLIP(RPQ:ObligationType) <> ''
      COUNTPAYMENT+=RPQ:AMOUNTP
      QueNdx:1+=1
    ELSE
      GET(ReportQueue,QueNdx:1)
      BREAK
    END
  END
  RPQ:AmountO=SavedAmountO
  RPQ:AmountP=CountPayment
END
[END]
[END]
EMBED %AfterEndPage
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
IF ~RECORDS(PrintPreviewQueue)
  IF PRINTSUMMARY      !ONLY PRINT SUMMARY
    Printer{PROPPRINT:COPIES}=CollateCopies
    SHOWANDPRINT(1,1,0,Printer{07B28H}) !show print preview, prompt for printer, print then delete the wmfs
    !SHOWANDPRINT(1,1,0,Printer{PropPrint:device}) !show print preview, prompt for printer, print then delete the wmfs
    GLOBALRESPONSE=REQUESTCANCELLED
  ELSE
    MESSAGE(CPCS:NthgToPrvwText,CPCS:NthgToPrvwTitle,ICON:Exclamation)
  END
