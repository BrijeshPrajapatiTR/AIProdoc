!For print report, always popup the GetCalcDate window
GetCalcDate(1)
IF GlobalResponse <> RequestCompleted
  RETURN
.

ProcessPayments
!Ma - Fogbugz case 15992, after processPayments reset the dirty flags 12/11/07
GLO:UpdatePayments = FALSE
GLO:UpdateObligate = FALSE
SaveOriginalValues()


!  DO TOTALS


LOC:ACTION = PrintObligations
ObligateCounter = 0
PayCounter = 0
ApplyCounter = 0

!IF GLO:ConfirmedPrincipalBalance
  DebugCL.Send('NAMChild:InterestType: ' & NAMChild:InterestType)
!      IF NAM:InterestType
!        InterestType = NAM:InterestType
!      ELSE
!        InterestType = 'N/A'
!    .! .
!MA ADDED  6/27/01
  IF GLO:JudgementDate>=DATE(9,1,200101)
!      IF ATT:InterestType
!        LOC:AttyInterestType=ATT:InterestType
!      ELSE
!        LOC:AttyInterestType='N/A'
!      END
    LOC:DATE=GLO:DateRendered
  ELSE
    LOC:AttyInterestType='N/A'
    LOC:DATE=0
  END

