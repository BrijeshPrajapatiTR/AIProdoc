EMBED %ProcedureInitialize
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF PAYMENTS::Used = 0
!  CheckOpen(PAYMENTS,1)
!END
!BIND(PAY:RECORD)
!PAYMENTS::Used += 1


!  IF OBLIGATE::Used = 0
!    CheckOpen(OBLIGATE,1)
!  END
!  BIND(OBL:RECORD)
!  OBLIGATE::Used += 1

PaymentOption = 'A'
FirstDay = 1
[END]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?FromDate'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?FromDate{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?ToDate'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?ToDate{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?Option1:Monthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!ENABLE(?PromptFirstDay,?FirstDay)
!DISABLE(?PromptSecondDay,?DayOfWeek)
ENABLE(?PromptFirstDay,?MonthlyLastDay)
DISABLE(?PromptSecondDay,?DayOfWeek)
IF MonthlyLastDay
  DISABLE(?PromptFirstDay)
  DISABLE(?FirstDay)
END
DISPLAY()
[END]
[END]
WHEN '?Option1:semimonthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!ENABLE(?PromptFirstDay,?SecondDay)
!DISABLE(?PromptDayOfWeek,?DayOfWeek)
ENABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?MonthlyLastDay)
DISPLAY()
[END]
[END]
WHEN '?Option1:weekly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!ENABLE(?PromptDayOfWeek,?DayOfWeek)
!DISABLE(?PromptFirstDay,?SecondDay)
ENABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISPLAY()
[END]
[END]
WHEN '?Option1:biweekly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!ENABLE(?PromptDayOfWeek,?DayOfWeek)
!DISABLE(?PromptFirstDay,?SecondDay)
ENABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
[END]
[END]
WHEN '?OkButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
UPDATE
IF ~FromDate
  SELECT(?FromDate)
  CYCLE
END

IF ~ToDate
  SELECT(?ToDate)
  CYCLE
END

IF ~PaymentAmount
  SELECT(?PaymentAmount)
  CYCLE
END

CASE PaymentOption
OF 'A'
  IF ~FirstDay
    SELECT(?FirstDay)
    CYCLE
  END
OF 'B'
  IF ~FirstDay
    SELECT(?FirstDay)
    CYCLE
  END
  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    CYCLE
  END
OF 'C'
OROF 'D'
  IF ~DayOfWeek
    SELECT(?DayOfWeek)
    CYCLE
  END
END

DISABLE(?CancelButton)
SETCURSOR(CURSOR:WAIT)
DO CallUpdate
SETCURSOR()
[GROUP]
PRIORITY 4000
INSTANCE 2
[END]
[END]
[END]
EMBED %ControlPostEventHandling
[INSTANCES]
WHEN '?FromDate'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF KEYCODE() = TabKey AND ~FromDate
!  SELECT(?FromDate)
!  CYCLE
!.
[END]
[END]
WHEN '?ToDate'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF KEYCODE() = TabKey AND ~ToDate
!  SELECT(?ToDate)
!  CYCLE
!END
[END]
[END]
WHEN '?CancelButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[GROUP]
PRIORITY 4000
INSTANCE 1
[END]
[END]
WHEN '?SemiMonthlyLastDay'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF SemiMonthlyLastDay
  Disable(?SecondDay)
ELSE
  ENABLE(?PromptSecondDay,?SecondDay)
.
[END]
[END]
WHEN '?MonthlyLastDay'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF MonthlyLastDay
  Disable(?FirstDay)
  DISABLE(?PromptFirstDay)
ELSE
  ENABLE(?PromptFirstDay,?FirstDay)
.
[END]
[END]
WHEN '?Calendar:2'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
SELECT(?ToDate)
[END]
[END]
WHEN '?Calendar'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
SELECT(?FromDate)
[END]
[END]
[END]
EMBED %EndOfProcedure
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  SORT(QPAYMENTS,QPA:PDATE)
  !PAYMENTS::Used -= 1
  !IF PAYMENTS::Used = 0 THEN CLOSE(PAYMENTS).

 !SORT(QOBLIGATE,QOB:ODATE)
 !OBLIGATE::Used -= 1
 !IF OBLIGATE::Used = 0 THEN CLOSE(OBLIGATE).
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!-----------------------------------
CallUpdate      ROUTINE
!-----------------------------------
  CASE PaymentOption
  OF 'A'                        !Monthly
    DO Monthly
  OF 'B'                        !Semimonthly
    DO SemiMonthly
  OF 'C'                        !Weekly
    DO Weekly
  OF 'D'                        !Biweekly
    DO BiWeekly
  END

!-----------------------------------
Monthly      ROUTINE
!-----------------------------------
! @Parth - FB28919 - MonthlyLastday issue. Soln: Added only IF MonthlyLastDay condition to existing IF condition to resolve  
  IF MonthlyLastDay                         !If payment is to be made on last day of month
    FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                             ! subtract 1 day to get the
                                                             ! last day of month
!@Parth
  ELSIF DAY(FromDate) > FirstDay   !If from date is greater than
    FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate))
  ELSE                                        !If from date is less than
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))
  .
  LocalResponse = RequestCompleted

  QPA:PDATE = FirstDate
  LOOP
    DO AddRecords
    IF MonthlyLastDay  !If payment on last day of month then set for 1st day of second
      QPA:PDATE =  (DATE(MONTH(QPA:PDATE)+2,1,YEAR(QPA:PDATE)))-1   !month the subtract 1 to
                                                                    !get last day of next month
    ELSE
      QPA:PDATE =  DATE(MONTH(QPA:PDATE)+1,FirstDay,YEAR(QPA:PDATE))
    .
    IF QPA:PDATE > ToDate THEN BREAK.
  .

!-----------------------------------
SemiMonthly      ROUTINE
!-----------------------------------
  DATA
M      LONG
  CODE
 OMIT('***MCY***')   !USE NEW CODE BELOW TO ALLOW USER TO SPECIFY USING LAST DAY 6/15/05
 IF ~FirstDaY
   SELECT(?FirstDay)
   EXIT
 END

 IF ~SecondDay
   SELECT(?SecondDay)
   EXIT
 END

 IF DAY(FromDate) > FirstDay   !If from date is greater than
   IF DAY(FromDate) > SecondDay      !MA CHANGED HERE   1/15/02
     FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate))
     DayFlag = 2
   ELSE
     FirstDate = DATE(MONTH(FromDate),SecondDay,YEAR(FromDate))
     DayFlag = 1
   END
   !FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate))
 ELSE                                        !If from date is less than
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))
    DayFlag = 2                     !DayFlag will be set to keep track of
                                    ! whether we are doing the first payment
 END                                ! of the month or the second
 LocalResponse = RequestCompleted

  QPA:PDATE = FirstDate
  LOOP
    DO AddRecords
    IF DayFlag = 1
      QPA:PDATE =  DATE(MONTH(QPA:PDATE)+1,FirstDay,YEAR(QPA:PDATE))
      DayFlag = 2
    ELSE
      QPA:PDATE =  DATE(MONTH(QPA:PDATE),SecondDay,YEAR(QPA:PDATE))
      DayFlag = 1
    .
    IF QPA:PDATE > ToDate THEN BREAK.
  .
  !***MCY***

  IF ~FirstDaY
    SELECT(?FirstDay)
    EXIT
  END

  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    EXIT
  END

  IF DAY(FromDate) > FirstDay !If from date is greater than day of month for first payment
    IF SemiMonthlyLastDay                         !If payment is to be made on last day of month
      FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                               ! subtract 1 day to get the
                                                               ! last day of month
      DayFlag = 1           !DayFlag will be set to keep track of which payment of the month we are doing
                            !  it's set in reverse from here because the addrecord is done in the loop below
                            !  and then the flag is reset.  This starts it out correctly

    ELSE   !If second payment day is not the last day of month
      IF DAY(FromDate) > SecondDay !If past first and second payment dates then start over with
        FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !the first payment date next month
        DayFlag = 2
      ELSE                         !Otherwise set for the second payment day
        !FirstDate = DATE(MONTH(FromDate)+1,SecondDay,YEAR(FromDate)) !Set first payment for day of
        FirstDate = DATE(MONTH(FromDate),SecondDay,YEAR(FromDate)) !Set first payment for day of   !MA CHANGED 1/15/02
        DayFlag = 1                                                  !month for second payment
      END!OF handling second day
    END!END OF SEMIMONTHLYLASTDAY IF STATEMENT
  ELSE                             !If from date is less than set first payment date
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))!start payment then
    DayFlag = 2
  .

  LocalResponse = RequestCompleted
  QPA:PDATE = FirstDate
  M=MONTH(QPA:PDATE)
  LOOP
    DO AddRecords
    IF DayFlag = 1
      QPA:PDATE =  DATE(MONTH(QPA:PDATE)+1,FirstDay,YEAR(QPA:PDATE))
      DayFlag = 2
      M=MONTH(QPA:PDATE)
    ELSE
      IF SemiMonthlyLastDay  !If payment on last day of month then set for 1st day of second
        QPA:PDATE =  (DATE(MONTH(QPA:PDATE)+1,1,YEAR(QPA:PDATE)))-1   !month the subtract 1 to
      ELSE                                                            !get last day of next month
        QPA:PDATE =  DATE(MONTH(QPA:PDATE),SecondDay,YEAR(QPA:PDATE))
        IF MONTH(QPA:PDATE)>M !FIX THE BUG WHEN SECOND DAY IS 30TH ON FEBRUARY THE MARCH 30TH WAS SKIPPED
          QPA:PDATE =  (DATE(M+1,1,YEAR(QPA:PDATE)))-1
        END
      END !OF IF MonthlyLastDay
      DayFlag = 1
    .
    IF QPA:PDATE > ToDate THEN BREAK.
  .


!-----------------------------------
Weekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE
 .

  LocalResponse = RequestCompleted

  QPA:PDATE = FirstDate
  LOOP
    DO AddRecords
    QPA:PDATE += 7
    IF QPA:PDATE > ToDate THEN BREAK.
  .

!-----------------------------------
BiWeekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE
 .

  LocalResponse = RequestCompleted

  QPA:PDATE = FirstDate
  LOOP
    DO AddRecords
    QPA:PDATE += 14
    IF QPA:PDATE > ToDate THEN BREAK.
  .


!-----------------------------------
AddRecords      ROUTINE
!-----------------------------------
  QPA:PCaseID = CAS:CAS_ID
  QPA:PAMOUNT = PaymentAmount
  ADD(QPAYMENTS,QPA:PDATE)
  IF ERRORCODE()
      MESSAGE('Unable to add a payment for ' & FORMAT(QPA:PDATE,@D1) |
         & '!',,ICON:EXCLAMATION,BUTTON:OK,BUTTON:OK)
  ELSE
    GLO:UpdatePayments = TRUE
  .

[END]
