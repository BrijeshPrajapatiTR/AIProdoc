[MODULE]
[COMMON]
FROM Clarion GENERATED
MODIFIED '2021/06/17' '17:37:56'
[PROCEDURE]
NAME LoadAnswersDelin
NOEXPORT
[COMMON]
DESCRIPTION 'new, load answers from answers.tps to queue, group and global variables'
FROM Clarion Source
MODIFIED '2022/02/17' '18:07:26'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  FREE(QObligate)
  FREE(QPayments)
  CLEAR(QObligate)
  CLEAR(QPayments)
  IF ANSWERS::Used=0
    CheckOpen(ANSWERS,1)   !NOT ABC VERSION APP SO CAN'T USE ABC CLASS TO OPEN FILE
  END
  ANSWERS::Used+=1
  ANS:CAS_ID=GLO:CAS_ID
  CLEAR(ANS:VOLUME_ID,-1)
  CLEAR(ANS:OBJ_ID,-1)
  CLEAR(ANS:SCOPE,-1)
  CLEAR(ANS:Indexstring,-1)
  SET(ANS:kScope,ANS:kScope)     !GO TO THE FIRST RECORD OF THE SELECTED CASE
  NEXT(ANSWERS)
  IF ERRORCODE() OR ANS:CAS_ID<>GLO:CAS_ID
    GLO:NEWCASE=TRUE
    DO PROCEDURERETURN
  END
  ANS:CAS_ID=GLO:CAS_ID
  ANS:VOLUME_ID=GLO:VOLUME_ID
  CLEAR(ANS:OBJ_ID,-1)
  CLEAR(ANS:SCOPE,-1)
  CLEAR(ANS:Indexstring,-1)
  SET(ANS:kScope,ANS:kScope)
  NEXT(ANSWERS)
  IF ~ERRORCODE() AND ANS:CAS_ID=GLO:CAS_ID AND ANS:VOLUME_ID=GLO:VOLUME_ID
    LOC:VOLUME_ID=GLO:VOLUME_ID      !ANSWERS AGAINST TXFAM VOLUME EXIST
  ELSE
    ANS:CAS_ID=GLO:CAS_ID
    ANS:VOLUME_ID='TXADOPT'
    CLEAR(ANS:OBJ_ID,-1)
    CLEAR(ANS:SCOPE,-1)
    CLEAR(ANS:Indexstring,-1)
    SET(ANS:kScope,ANS:kScope)
    NEXT(ANSWERS)
    IF ~ERRORCODE() AND ANS:CAS_ID=GLO:CAS_ID AND ANS:VOLUME_ID='TXADOPT'
      LOC:VOLUME_ID='TXADOPT'        !ANSWERS AGAINST TXFAM VOLUME EXIST
    ELSE
      DO PROCEDURERETURN
    END
  END

    Do LoadPayments
    Do LoadEverythingBUTPaymentsChild
    Do LoadEverythingBUTPaymentsMedical
    Do LoadEverythingBUTPaymentsDental
    
  CLEAR(QObligate)
  CLEAR(QPayments)
  !NOW FINISH TO LOAD ANSWERS FOR DIMENSION CODES AND BEGIN TO LOAD NON-DIMENSION CODES' ANSWERS
  !CONFIRMED(JUDGMENT) ANSWERS
  CLEAR(ANS:INDEXSTRING,-1)
  ANS:INDEXES[1]=0
  ANS:OBJ_ID='PX015'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    CASE LEN(CLIP(LEFT(ANS:ANSWER)))
    OF 7
      GLO:CalcDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D1)
    OF 8
      GLO:CalcDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D01)
    OF 9
    OROF 10
      GLO:CalcDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D2)
    END
  END
  ANS:OBJ_ID='PX096'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    GLO:Obligor=LEFT(ANS:ANSWER)
  END
  ANS:OBJ_ID='PX098'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    GLO:Obligee=LEFT(ANS:ANSWER)
  END
  !@Parth FB8903
   ANS:OBJ_ID = 'A0092'
   GLO:FiledAfterSep1Delinquency  = 1  
  !@Parth
!  ANS:OBJ_ID='PX039'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    CASE LEN(CLIP(LEFT(ANS:ANSWER)))
!    OF 7
!      NAM:ConfirmedDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D1)
!    OF 8
!      NAM:ConfirmedDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D01)
!    OF 9
!    OROF 10
!      NAM:ConfirmedDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D2)
!    END
!  END
!  ANS:OBJ_ID='PX038'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    NAM:ConfirmedPrincipal=DEFORMAT(CLIP(ANS:ANSWER))
!  END
!  ANS:OBJ_ID='PX036'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    NAM:ConfirmedInterestRate=DEFORMAT(CLIP(ANS:ANSWER))
!  END
!  ANS:OBJ_ID='PX037'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    NAM:InterestType=LEFT(ANS:ANSWER)
!  END
!  ANS:OBJ_ID='PX028'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    ATT:Attyfeescosts=DEFORMAT(CLIP(ANS:ANSWER))
!  END
!  ANS:OBJ_ID='PX031'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    ATT:InterestRate=DEFORMAT(CLIP(ANS:ANSWER))
!  END
!  ANS:OBJ_ID='PX032'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    ATT:InterestType=LEFT(ANS:ANSWER)
!  END
    Do LoadJudgmentChild
    Do LoadJudgmentMedical
    Do LoadJudgmentDental
    
!  !DEBIT ANSWERS
!  ANS:OBJ_ID='PX040'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    CASE LEN(CLIP(LEFT(ANS:ANSWER)))
!    OF 7
!      EXT:DebitDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D1)
!    OF 8
!      EXT:DebitDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D01)
!    OF 9
!    OROF 10
!      EXT:DebitDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D2)
!    END
!  END
!  ANS:OBJ_ID='PX041'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    EXT:DebitUObl=DEFORMAT(CLIP(ANS:ANSWER))
!  END
!  ANS:OBJ_ID='PX042'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    EXT:DebitUInt=DEFORMAT(CLIP(ANS:ANSWER))
!  END
!  ANS:OBJ_ID='PX043'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    EXT:DebitCObl=DEFORMAT(CLIP(ANS:ANSWER))
!  END
!  ANS:OBJ_ID='PX044'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    EXT:DebitCInt=DEFORMAT(CLIP(ANS:ANSWER))
!  END
    
    Do LoadDebitChild
    Do LoadDebitMedical
    Do LoadDebitDental
    
  DO PROCEDURERETURN


!-------------------------
PROCEDURERETURN  ROUTINE
!-------------------------
  ANSWERS::Used -= 1
  IF ANSWERS::Used = 0 THEN CLOSE(ANSWERS).
  RETURN
[END]
EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
COUNTER        LONG
LOC:STRING     STRING(40)
LOC:VOLUME_ID  LIKE(ANS:VOLUME_ID)
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 3500
PROPERTY:END
LoadPayments        ROUTINE
!  DebugCL.DumpQ(QPayments,'Start Queue Payment Details')
  COUNTER=0
  CLEAR(ANS:RECORD)
  LOOP
    COUNTER+=1      !INCREASE INDEXS[1] FOR OBLIGATIONS AND PAYMENTS DIMENSION CODE
    ANS:CAS_ID    = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:SCOPE='V'
    ANS:OBJ_ID= 'PX002'
    CLEAR(ANS:INDEXSTRING,-1)
    ANS:INDEXES[1]=SwapUshortBytes(COUNTER)
!    DebugCL.Send('ANS:INDEXES[1]: ' & ANS:INDEXES[1] & ', COUNTER: ' & COUNTER)
    GET(ANSWERS,ANS:kScope)
    IF ERRORCODE()
      BREAK     !IF DIDN'T FIND ANY OBLIGATTION OR PAYMENT THEN BREAK AND LOAD OTHER NON-DIMENSION CODES
    END
!    DebugCL.Send('UPPER(CLIP(ANS:ANSWER): ' & UPPER(CLIP(ANS:ANSWER)))
    CASE UPPER(CLIP(ANS:ANSWER))
    OF 'P'
      ANS:OBJ_ID='PX001'
!      DebugCL.Send('2..ANS:OBJ_ID: ' & ANS:OBJ_ID & ', COUNTER: ' & COUNTER)
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        CASE LEN(CLIP(LEFT(ANS:ANSWER)))
        OF 7
          QPA:PDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D1)
        OF 8
          QPA:PDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D01)
        OF 9
        OROF 10
          QPA:PDate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D2)
        END
      END
        
      ANS:OBJ_ID='PX005'
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        QPA:PAmount=DEFORMAT(CLIP(ANS:ANSWER))
      END
      QPA:PCaseID=GLO:CAS_ID
      IF QPA:PAmount
        ADD(QPayments)
      END
    END
  END
!  DebugCL.DumpQ(QPayments,'End Queue Payment Details')
[SOURCE]
PROPERTY:BEGIN
PRIORITY 3500
PROPERTY:END
LoadEverythingBUTPaymentsChild        ROUTINE
  COUNTER=0
  CLEAR(ANS:RECORD)
  LOOP
    COUNTER+=1      !INCREASE INDEXS[1] FOR OBLIGATIONS AND PAYMENTS DIMENSION CODE
    ANS:CAS_ID    = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:SCOPE='V'
    ANS:OBJ_ID= 'PX202'
    CLEAR(ANS:INDEXSTRING,-1)
    ANS:INDEXES[1]=SwapUshortBytes(COUNTER)
    GET(ANSWERS,ANS:kScope)
    IF ERRORCODE()
      BREAK     !IF DIDN'T FIND ANY OBLIGATTION OR PAYMENT THEN BREAK AND LOAD OTHER NON-DIMENSION CODES
    END
    CASE UPPER(CLIP(ANS:ANSWER))
    OF 'O'
      ANS:OBJ_ID='PX201'
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        CASE LEN(CLIP(LEFT(ANS:ANSWER)))
        OF 7
          QOB:ODate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D1)
        OF 8
          QOB:ODate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D01)
        OF 9
        OROF 10
          QOB:ODate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D2)
        END
      END
        
      ANS:OBJ_ID='PX203'
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        QOB:OAmount=DEFORMAT(CLIP(ANS:ANSWER))
      END
      ANS:OBJ_ID='AX200'
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        QOB:Frequency=LEFT(ANS:ANSWER)
      ELSE
        QOB:Frequency=''
      END
      
      QOB:OCaseID=GLO:CAS_ID
      IF QOB:OAmount
        QOB:Type = 'Child'
        QOB:TypeSort = SupportType:Children
        QOB:ObligateTypeDisplayText = 'Child Support'
        ADD(QObligate)
      END
    END
  END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 3500
PROPERTY:END
LoadEverythingBUTPaymentsMedical    ROUTINE
  COUNTER=0
