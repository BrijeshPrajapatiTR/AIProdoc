              STRING(@n3),AT(2188,10),USE(NumKids),TRN,#ORIG(?String159),#ORDINAL(200)
              STRING(@n$-11.2),AT(3969,10),USE(ExpSemiMonthly),RIGHT(12),#ORIG(ExpSemiMonthly), |
                #ORDINAL(201)
