[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 1
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[ADDITION]
NAME Clarion CloseCurrentWindow
[INSTANCE]
INSTANCE 2
[CALLS]
PrintAmortize
[WINDOW]
window  WINDOW('Obligation Amortizer'),AT(,,377,204),FONT('MS Sans Serif',8,,FONT:regular), |
          DOUBLE,CENTER,ICON('prowin.ico'),GRAY,MDI,HLP('~Range_Payment_Form')
          SHEET,AT(4,1,367,181),USE(?Sheet1),WIZARD,#ORIG(?Sheet1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1)
              STRING('This window is used to calculate how long it will take to pay off' & |
                ' an obligation. The calculation is based'),AT(17,6),USE(?String4),#ORIG(?String4)
              STRING('on the simple interest rate you enter below. Simply fill-in the b' & |
                'lanks and click on "C'),AT(17,17),USE(?String5),#ORIG(?String5)
              STRING('lculate". You can'),AT(278,17),USE(?String11),#ORIG(?String11)
              STRING('a'),AT(274,17),USE(?String15),FONT(,,,FONT:underline),#ORIG(?String15)
              STRING('print an amortization schedule by clicking on "'),AT(17,29),USE(?String6), |
                #ORIG(?String6)
              STRING('P'),AT(162,29),USE(?String12),FONT(,,,FONT:underline),#ORIG(?String12)
              STRING('rint".'),AT(167,29),USE(?String13),#ORIG(?String13)
              PROMPT('Calc&ulate interest from (mm/dd/yyyy):'),AT(17,47),USE(?Prompt7),#ORIG(?Prompt7)
              ENTRY(@d2<50B),AT(137,45,54,12),USE(FromDate),REQ,#ORIG(FromDate)
              PROMPT('&Total obligation:'),AT(200,47,52,10),USE(?Prompt5),#ORIG(?Prompt5)
              ENTRY(@n-11.2),AT(255,45,60,12),USE(TotalObligation),#ORIG(TotalObligation)
              STRING('%'),AT(290,65),USE(?String14),FONT(,10,,FONT:bold),#ORIG(?String14)
              PROMPT('Amou&nt of each payment:'),AT(17,66),USE(?Prompt1),#ORIG(?Prompt1)
              ENTRY(@n-13.2),AT(137,64,54,12),USE(PaymentAmount),#ORIG(ObligationAmount)
              PROMPT('&Interest rate:'),AT(201,66),USE(?Prompt8),#ORIG(?Prompt8)
              SPIN(@n6.2),AT(255,64,34,12),USE(GLO:IntRate),RANGE(0.25,100),STEP(0.25),#ORIG(?Spin3)
              PROMPT('Pa&yment options:'),AT(29,87),USE(?Prompt6),#ORIG(?Prompt6)
              OPTION,AT(88,81,214,17),USE(PaymentOption),BOXED,#ORIG(Option1)
                RADIO('Monthly'),AT(98,87),USE(?Option1:Monthly),VALUE('A'),#ORIG(?Option1:Radio1)
                RADIO('Semi-monthly'),AT(142,87),USE(?Option1:semimonthly),VALUE('B'),#ORIG(?Option1:Radio2)
                RADIO('Weekly'),AT(202,87),USE(?Option1:weekly),VALUE('C'),#ORIG(?Option1:Radio3)
                RADIO('Bi-weekly'),AT(250,87),USE(?Option1:biweekly),VALUE('D'),#ORIG(?Option1:Radio4)
              END
              PANEL,AT(15,80,347,78),USE(?Panel1),#ORIG(?Panel1)
              PROMPT('&Day of month first payment is due:'),AT(61,104),USE(?PromptFirstDay), |
                #ORIG(?Prompt2)
              SPIN(@n3),AT(185,102,25,12),USE(FirstDay),RANGE(1,28),STEP(1),REQ,#ORIG(?Spin1)
              CHECK('&Last day of the month'),AT(218,103,,11),USE(MonthlyLastDay),#ORIG(MonthlyLastDay)
              PROMPT('Day of &month second payment is due:'),AT(61,123),USE(?PromptSecondDay), |
                DISABLE,#ORIG(?Prompt4)
              SPIN(@n3),AT(185,121,25,12),USE(SecondDay),DISABLE,RANGE(1,30),STEP(1),#ORIG(?Spin2)
              CHECK('La&st day of the month'),AT(218,122,,11),USE(SemiMonthlyLastDay),DISABLE, |
                VALUE('1','0'),#ORIG(SemiMonthlyLastDay)
              PROMPT('Day of &week payments are due:'),AT(61,141),USE(?PromptDayOfWeek),DISABLE, |
                #ORIG(?Prompt3)
              LIST,AT(185,139,61,12),USE(DayOfWeek),VSCROLL,DISABLE,DROP(7),FORMAT('36L@s9@'), |
                FROM('Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday'),#FIELDS(DayOfWeek), |
                #ORIG(?List1)
              STRING('Total payments:'),AT(9,167),USE(?String7),FONT(,,,FONT:bold),#ORIG(?String7)
              STRING(@n5),AT(72,167),USE(TotalPayments),FONT(,,,FONT:underline),#ORIG(?String10)
              STRING('Date of last payment:'),AT(96,167),USE(?String9),FONT(,,,FONT:bold), |
                #ORIG(?String9)
              STRING(@d1),AT(179,167),USE(DateLastPayment),FONT(,,,FONT:underline),#ORIG(?String10)
              STRING('Amount of last payment:'),AT(225,167),USE(?String8),FONT(,,,FONT:bold), |
                #ORIG(?String8)
              STRING(@n$11.2),AT(319,167),USE(AmountLastPayment),FONT(,,,FONT:underline),#ORIG(?String10)
            END
          END
          BUTTON('&Help'),AT(4,185,50,15),USE(?Button4),LEFT,ICON(ICON:Help),STD(STD:Help), |
            TIP('display help'),#ORIG(?Button4)
          BUTTON('C&alculate'),AT(139,185,57,15),USE(?CalculateButton),LEFT,ICON('Calc.ico'), |
            #ORIG(?Button4)
          BUTTON('&Print'),AT(200,185,50,15),USE(?PrintButton),LEFT,ICON('5printme.ico'),#ORIG(?Button3)
          BUTTON('&Close'),AT(321,185,50,15),USE(?CloseButton),LEFT,ICON('5exit.ico'),DEFAULT
        END

[END]
