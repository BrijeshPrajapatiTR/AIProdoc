[PROCEDURE]
NAME LoadAnswersObl
NOEXPORT
[COMMON]
DESCRIPTION 'new procedure, load data from answers.tps'
FROM Clarion Source
MODIFIED '2022/07/05' '14:29:43'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  IF ANSWERS::Used=0
    CheckOpen(ANSWERS,1)   !NOT ABC VERSION APP SO CAN'T USE ABC CLASS TO OPEN FILE
  END
  ANSWERS::Used+=1
  ANS:CAS_ID=GLO:CAS_ID
  CLEAR(ANS:VOLUME_ID,-1)
  CLEAR(ANS:OBJ_ID,-1)
  CLEAR(ANS:SCOPE,-1)
  CLEAR(ANS:Indexstring,-1)
  SET(ANS:kScope,ANS:kScope)     !GO TO THE FIRST RECORD OF THE SELECTED CASE
  NEXT(ANSWERS)
  IF ERRORCODE() OR ANS:CAS_ID<>GLO:CAS_ID
    GLO:NEWCASE=TRUE
    DO PROCEDURERETURN
  END
  ANS:CAS_ID=GLO:CAS_ID
  ANS:VOLUME_ID=GLO:VOLUME_ID
  CLEAR(ANS:OBJ_ID,-1)
  CLEAR(ANS:SCOPE,-1)
  CLEAR(ANS:Indexstring,-1)
  SET(ANS:kScope,ANS:kScope)
  NEXT(ANSWERS)
  IF ~ERRORCODE() AND ANS:CAS_ID=GLO:CAS_ID AND ANS:VOLUME_ID=GLO:VOLUME_ID
    LOC:VOLUME_ID=GLO:VOLUME_ID  !ANSWERS AGAINST TXFAM VOLUME EXIST
  ELSE
    ANS:CAS_ID=GLO:CAS_ID
    ANS:VOLUME_ID='TXADOPT'
    CLEAR(ANS:OBJ_ID,-1)
    CLEAR(ANS:SCOPE,-1)
    CLEAR(ANS:Indexstring,-1)
    SET(ANS:kScope,ANS:kScope)
    NEXT(ANSWERS)
    IF ~ERRORCODE() AND ANS:CAS_ID=GLO:CAS_ID AND ANS:VOLUME_ID='TXADOPT'
      LOC:VOLUME_ID='TXADOPT'    !ANSWERS AGAINST TXFAM VOLUME EXIST
    ELSE
      DO PROCEDURERETURN
    END
  END

  !ONLY LOAD FIRST SET OF RESULT SAVED AND THOSE DATA CAN BE SHOWN ON WINDOW BEING OPENED
  !-----BETH SAID DON'T LOAD THE ANSWERS FOR FOLLOWING TOKENS  1/28/03---------
  ANS:CAS_ID = GLO:CAS_ID
  ANS:VOLUME_ID = LOC:VOLUME_ID
  ANS:SCOPE  = 'V'
  CLEAR(ANS:INDEXSTRING,-1)
  ANS:INDEXES[1]  = SwapUshortBytes(1)
  ANS:OBJ_ID      = 'PX051'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    ChildMonthly=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID      = 'PX052'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    ChildSemiMonthly=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID      = 'PX053'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    ChildWeekly=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID      = 'PX054'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    ChildBiWeekly=DEFORMAT(CLIP(ANS:ANSWER))
  END
  !---------------------------------------------------------------------------------

  ANS:CAS_ID    = GLO:CAS_ID
  ANS:VOLUME_ID = LOC:VOLUME_ID
  ANS:SCOPE='V'
  CLEAR(ANS:INDEXSTRING,-1)
  CLEAR(ANS:INDEXES[1])
  ANS:OBJ_ID= 'PX096'            !OBLIGOR
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    GLO:OBLIGOR=LEFT(ANS:ANSWER)
  END
  ANS:OBJ_ID= 'PX098'            !OBLIGEE
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    GLO:OBLIGEE=LEFT(ANS:ANSWER)
  END
  ANS:OBJ_ID='AX020'               !OBLIGOR PARTY(PETITIONER/RESPONDENT)
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    GLO:ObligorParty=LEFT(ANS:ANSWER)
  END
  !-----FOLLOWING CODE WERE ADDED BY 1/23/03 BASED ON BETH COMMENT-----
  IF ~GLO:OBLIGEE
    SAVEDVOLUME_ID=ANS:VOLUME_ID
    SAVEDSCOPE=ANS:SCOPE
    CASE GLO:ObligorParty
    OF 1
      ANS:OBJ_ID='P1308'
      ANS:INDEXES[1]=256
      ANS:VOLUME_ID=''
      ANS:SCOPE='G'
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        GLO:OBLIGEE=LEFT(ANS:ANSWER)
      END
    OF 2
      ANS:OBJ_ID='P1208'
      ANS:INDEXES[1]=256
      ANS:VOLUME_ID=''
      ANS:SCOPE='G'
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        GLO:OBLIGEE=LEFT(ANS:ANSWER)
      END
    END
    ANS:SCOPE=SAVEDSCOPE
    ANS:VOLUME_ID=SAVEDVOLUME_ID
    CLEAR(ANS:Indexstring,-1)
  END
  !--------------------------------------------------------

  ANS:OBJ_ID= 'AX005'            !NUMBER OF TOTAL CHILDREN
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    TotalChildren=LEFT(ANS:ANSWER)
  END
  ANS:OBJ_ID= 'AX010'            !NUMBER OF CHILDREN BEFORE THE COURT
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    ChildrenInCourt=ANS:ANSWER
  ELSE
    !-----FOLLOWING CODE WERE ADDED BY 1/23/03 BASED ON BETH COMMENT-----
    ANS:OBJ_ID= 'A1500'          !IF NO ANSWER THEN TRY A1500V   1/23/03
    GET(ANSWERS,ANS:kScope)
    IF ~ERRORCODE()
      ChildrenInCourt=ANS:ANSWER
    END
  END
  !---------------------------------------------------------------------

  ANS:OBJ_ID= 'PX060'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    HealthInsurance=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID= 'PX062'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    UnionDues=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID= 'PX064'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    StateIncomeTax=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID= 'PX066'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    GrossMonthlyIncome=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID= 'AX015'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    CASE UPPER(CLIP(LEFT(ANS:ANSWER)))
    OF 'Y'
      SelfEmployed=1
    OF 'N'
      SelfEmployed=0
    END
  END
        
 !@Vedant FB28901
!  ANS:OBJ_ID= 'A0091'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    CASE UPPER(CLIP(LEFT(ANS:ANSWER)))
!    OF 'Y'
!      GLO:FiledAfterSep1=1
!    OF 'N'
!      GLO:FiledAfterSep1=0
!    END
!  END
 !@Vedant
        
  !Ma - Fogbugz case 14024, load answer for the new token
  !Ma - Fogbugz case 19568, removed the Glo:IsOnAfter090107 so don't read answer from A0054V 9/26/08
!  ANS:OBJ_ID= 'A0054'
!  GET(ANSWERS,ANS:kScope)
!  IF ~ERRORCODE()
!    CASE UPPER(CLIP(LEFT(ANS:ANSWER)))
!    OF 'Y'
!      Glo:IsOnAfter090107 = 1
!    OF 'N'
!      Glo:IsOnAfter090107 = 0
!    END
!  END

  ANS:OBJ_ID= 'PX068'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    NontaxableMonthly=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID= 'PX070'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    DisabilityIncome=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID= 'PX072'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    SocialSecurityBenefits=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID= 'PX074'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    Adjustment=DEFORMAT(CLIP(ANS:ANSWER))
  END
  ANS:OBJ_ID= 'PX076'
  GET(ANSWERS,ANS:kScope)
  IF ~ERRORCODE()
    Explanation=ANS:ANSWER
  END
  DO PROCEDURERETURN


!-------------------------
PROCEDURERETURN  ROUTINE
!-------------------------
  ANSWERS::Used -= 1
  IF ANSWERS::Used = 0 THEN CLOSE(ANSWERS).
  RETURN
[END]
EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
LOC:VOLUME_ID  LIKE(ANS:VOLUME_ID)
SAVEDVOLUME_ID LIKE(ANS:VOLUME_ID)
SAVEDSCOPE     LIKE(ANS:SCOPE)
[END]
[END]
