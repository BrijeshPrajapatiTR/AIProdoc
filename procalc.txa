WHEN  ('?Help') ('')
WHEN  ('?OkButton') ('')

%ButtonThreadReturnValueAssignment DEPEND %Control FIELD TIMES 3
WHEN  ('?CancelButton') ()
WHEN  ('?Help') ()
WHEN  ('?OkButton') ()

%PreLookupProcedureParameters DEPEND %Control DEFAULT TIMES 3
WHEN  ('?FirstDay') ('')
WHEN  ('?ObligationAmount') ('')
WHEN  ('?SecondDay') ('')

%PostLookupProcedureParameters DEPEND %Control DEFAULT TIMES 3
WHEN  ('?FirstDay') ('')
WHEN  ('?ObligationAmount') ('')
WHEN  ('?SecondDay') ('')

%LookupAssign DEPEND %Control MULTI LONG TIMES 0

%MoreTarget DEPEND %LookupAssign FIELD TIMES 0

%MoreField DEPEND %LookupAssign DEFAULT TIMES 0

%Parameters DEFAULT  ('')
[EMBED]
EMBED %ProcedureInitialize
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF OBLIGATE::Used = 0
!  CheckOpen(OBLIGATE,1)
!END
!BIND(OBL:RECORD)
!OBLIGATE::Used += 1

PaymentOption = 'A'
FirstDay = 1
! @Parth - FB28903
  ObligationType = 'Child'
!   @Parth 
[END]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?FromDate'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?FromDate{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?ToDate'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?ToDate{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?Option1:Monthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptFirstDay,?MonthlyLastDay)
DISABLE(?PromptSecondDay,?DayOfWeek)
IF MonthlyLastDay
  DISABLE(?PromptFirstDay)
  DISABLE(?FirstDay)
END
DISPLAY()
[END]
[END]
WHEN '?Option1:semimonthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?MonthlyLastDay)
DISPLAY()
[END]
[END]
WHEN '?Option1:weekly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISPLAY()
[END]
[END]
WHEN '?Option1:biweekly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
[END]
[END]
WHEN '?OkButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
UPDATE
IF ~FromDate
  SELECT(?FromDate)
  CYCLE
END

IF ~ToDate
  SELECT(?ToDate)
  CYCLE
END

IF ~ObligationAmount
  SELECT(?ObligationAmount)
  CYCLE
END
CASE PaymentOption
OF 'A'
  IF ~FirstDay
    SELECT(?FirstDay)
    CYCLE
  END
OF 'B'
  IF ~FirstDay
    SELECT(?FirstDay)
    CYCLE
  END
  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    CYCLE
  END
OF 'C'
OROF 'D'
  IF ~DayOfWeek
    SELECT(?DayOfWeek)
    CYCLE
  END
END

IF FromDate>ToDate
  MESSAGE('The From Date shouldn''t be greater than the To Date.')
  SELECT(?FromDate)
  CYCLE
END
POINTER#=POINTER(QOBLIGATE)
GET(QOBLIGATE,RECORDS(QOBLIGATE))
IF ToDate>QOB:ODATE
  DUMMY#=MESSAGE('The To Date you entered is greater than the last date in the obligations range and '|
        & 'the exceeded range will be inserted. Do you want to continue?','Warning',ICON:QUESTION,BUTTON:YES+BUTTON:NO,BUTTON:YES)
  IF DUMMY#=BUTTON:NO
    SELECT(?ToDate)
    CYCLE
  END
END

DISABLE(?CancelButton)
SETCURSOR(CURSOR:WAIT)
DO DeleteExistedDates
DO CallUpdate
SETCURSOR()
[GROUP]
PRIORITY 4000
INSTANCE 2
[END]
[END]
[END]
EMBED %ControlPostEventHandling
[INSTANCES]
WHEN '?FromDate'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
GET(ChangeFromQ,CHOICE(?FromDate))
!IF KEYCODE() = TabKey AND ~FromDate
!  SELECT(?FromDate)
!  CYCLE
!.
!@Parth - FB28903
ObligationType = CFQ:Type
!@Parth
IF CFQ:DATE
  CASE CLIP(CFQ:Frequency)
  OF 'Monthly'                  !Monthly
    PaymentOption='A'
    ENABLE(?PromptFirstDay,?MonthlyLastDay)
    DISABLE(?PromptSecondDay,?DayOfWeek)
    IF MonthlyLastDay
      DISABLE(?PromptFirstDay)
      DISABLE(?FirstDay)
    END
  OF 'Semi-monthly'             !Semimonthly
    PaymentOption='B'
    ENABLE(?PromptFirstDay,?SemiMonthlyLastDay)
    DISABLE(?PromptDayOfWeek,?DayOfWeek)
    DISABLE(?MonthlyLastDay)
  OF 'Weekly'                   !Weekly
    PaymentOption='C'
    ENABLE(?PromptDayOfWeek,?DayOfWeek)
    DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
  OF 'Bi-weekly'                !Biweekly
    PaymentOption='D'
    ENABLE(?PromptDayOfWeek,?DayOfWeek)
    DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
  END
END
DISPLAY()
[END]
[END]
WHEN '?ToDate'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF KEYCODE() = TabKey AND ~ToDate
!  SELECT(?ToDate)
!  CYCLE
!END
[END]
[END]
WHEN '?CancelButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[GROUP]
PRIORITY 4000
INSTANCE 1
[END]
[END]
WHEN '?MonthlyLastDay'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF MonthlyLastDay
  Disable(?FirstDay)
  DISABLE(?PromptFirstDay)
ELSE
  ENABLE(?PromptFirstDay,?FirstDay)
.
[END]
[END]
WHEN '?SemiMonthlyLastDay'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF SemiMonthlyLastDay
  Disable(?SecondDay)
ELSE
  ENABLE(?PromptSecondDay,?SecondDay)
.
[END]
[END]
[END]
EMBED %EndOfProcedure
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  SORT(QOBLIGATE,QOB:ODATE)
  !OBLIGATE::Used -= 1
  !IF OBLIGATE::Used = 0 THEN CLOSE(OBLIGATE).
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!-----------------------------------
CallUpdate      ROUTINE
!-----------------------------------
  CASE PaymentOption
  OF 'A'                        !Monthly
    QOB:Frequency='Monthly'     !MA ADDED  2/15/02
    DO Monthly
  OF 'B'                        !Semimonthly
    QOB:Frequency='Semi-monthly'!MA ADDED  2/15/02
    DO SemiMonthly
  OF 'C'                        !Weekly
    QOB:Frequency='Weekly'      !MA ADDED  2/15/02
    DO Weekly
  OF 'D'                        !Biweekly
    QOB:Frequency='Bi-weekly'   !MA ADDED  2/15/02
    DO BiWeekly
  END

!-----------------------------------
Monthly      ROUTINE
!-----------------------------------

  IF MonthlyLastDay                         !If payment is to be made on last day of month
    FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                             ! subtract 1 day to get the
                                                             ! last day of month

  ELSIF DAY(FromDate) > FirstDay   !If from date is after the day of month for payment
    FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !set for next month
  ELSE                                        !otherwise set due date equal to the
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))  !day of month selected
  .
  LocalResponse = RequestCompleted

  QOB:ODATE = FirstDate
  LOOP
    DO AddRecords
    IF MonthlyLastDay  !If payment on last day of month then set for 1st day of second
      QOB:ODATE =  (DATE(MONTH(QOB:ODATE)+2,1,YEAR(QOB:ODATE)))-1   !month the subtract 1 to
                                                                    !get last day of next month
    ELSE
      QOB:ODATE =  DATE(MONTH(QOB:ODATE)+1,FirstDay,YEAR(QOB:ODATE))
    .
    IF QOB:ODATE > ToDate THEN BREAK.
  .

!-----------------------------------
SemiMonthly      ROUTINE
!-----------------------------------
  DATA
M     LONG
  CODE
  IF ~FirstDaY
    SELECT(?FirstDay)
    EXIT
  END

  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    EXIT
  END

  IF DAY(FromDate) > FirstDay !If from date is greater than day of month for first obligation
    IF SemiMonthlyLastDay                         !If payment is to be made on last day of month
      FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                               ! subtract 1 day to get the
                                                               ! last day of month
      DayFlag = 1           !DayFlag will be set to keep track of which obligation of the month we are doing
                            !  it's set in reverse from here because the addrecord is done in the loop below
                            !  and then the flag is reset.  This starts it out correctly

    ELSE   !If second obligation day is not the last day of month
      IF DAY(FromDate) > SecondDay !If past first and second obligation dates then start over with
        FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !the first obligation date next month
        DayFlag = 2
      ELSE                         !Otherwise set for the second obligation day
        !FirstDate = DATE(MONTH(FromDate)+1,SecondDay,YEAR(FromDate)) !Set first payment for day of
        FirstDate = DATE(MONTH(FromDate),SecondDay,YEAR(FromDate)) !Set first payment for day of   !MA CHANGED 1/15/02
        DayFlag = 1                                                  !month for second obligation
      END!OF handling second day
    END!END OF SEMIMONTHLYLASTDAY IF STATEMENT

  ELSE                             !If from date is less than set first obligation date
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))!start obligation then
    DayFlag = 2
  .

  LocalResponse = RequestCompleted
  QOB:ODATE = FirstDate
  M=MONTH(QOB:ODATE)
  LOOP
    DO AddRecords
    IF DayFlag = 1
      QOB:ODATE =  DATE(MONTH(QOB:ODATE)+1,FirstDay,YEAR(QOB:ODATE))
      DayFlag = 2
      M=MONTH(QOB:ODATE)
    ELSE
      IF SemiMonthlyLastDay  !If payment on last day of month then set for 1st day of second
        QOB:ODATE =  (DATE(MONTH(QOB:ODATE)+1,1,YEAR(QOB:ODATE)))-1   !month the subtract 1 to
      ELSE                                                            !get last day of next month
        QOB:ODATE =  DATE(MONTH(QOB:ODATE),SecondDay,YEAR(QOB:ODATE))
        IF MONTH(QOB:ODATE)>M !FIX THE BUG WHEN SECOND DAY IS 30TH ON FEBRUARY THE MARCH 30TH WAS SKIPPED
          QOB:ODATE =  (DATE(M+1,1,YEAR(QOB:ODATE)))-1
        END
      END !OF IF MonthlyLastDay
      DayFlag = 1
    .
    IF QOB:ODATE > ToDate THEN BREAK.
  .


!-----------------------------------
Weekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE
 .

  LocalResponse = RequestCompleted

  QOB:ODATE = FirstDate
  LOOP
    DO AddRecords
    QOB:ODATE += 7
    IF QOB:ODATE > ToDate THEN BREAK.
  .

!-----------------------------------
BiWeekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE
 .

  LocalResponse = RequestCompleted

  QOB:ODATE = FirstDate
  LOOP
    DO AddRecords
    QOB:ODATE += 14
    IF QOB:ODATE > ToDate THEN BREAK.
  .


!-----------------------------------
AddRecords      ROUTINE
!-----------------------------------
  QOB:OCaseID = CAS:CAS_ID
  QOB:OAMOUNT = ObligationAmount
! @Parth - FB28903 
  QOB:Type = ObligationType
!  ADD(QOBLIGATE,QOB:ODATE)
  ADD(QOBLIGATE,QOB:ODATE,QOB:Type)
! @Parth 
  IF ERRORCODE()
      MESSAGE('Unable to add an obligation for ' & FORMAT(QOB:ODATE,@D1) |
         & '!',,ICON:EXCLAMATION,BUTTON:OK,BUTTON:OK)
  ELSE
    GLO:UpdateObligate = TRUE
  .

!----------------------------
DeleteExistedDates  ROUTINE    !MA CREATED TO BE USED TO CHANGE A RANGE OF OBL
!----------------------------
  LOOP I#=RECORDS(QOBLIGATE) TO 1 BY -1
    GET(QOBLIGATE,I#)
    IF ERRORCODE() THEN BREAK.
    IF QOB:ODATE<FROMDATE THEN BREAK.
!   @Parth - FB28903
    IF QOB:Type <> ObligationType THEN CYCLE.
!   @Parth 
    IF QOB:ODATE>=FROMDATE AND QOB:ODATE<=TODATE
      DELETE(QOBLIGATE)
    END
  END
[END]
EMBED %BeforeWindowOpening
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
POINTER#=POINTER(QOBLIGATE)
FREE(CHANGEFROMQ)
FREE(CHANGETOQ)
! @Parth - FB28903
LOC:Type = QOB:Type
! @Parth 
LOOP I#=1 TO RECORDS(QOBLIGATE)
  GET(QOBLIGATE,I#)
  IF ERRORCODE() THEN BREAK.
  CFQ:DATE=QOB:ODATE
  CFQ:Frequency=QOB:Frequency
!   @Parth - FB28903
  CFQ:Type = QOB:Type
!    GET(ChangeFromQ, CFQ:DATE)
!    IF ERRORCODE()
!      ADD(CHANGEFROMQ)
!    END
  ADD(CHANGEFROMQ)
!   @Parth 
  CTQ:DATE=QOB:ODATE
  !   @Parth - FB28903
    GET(ChangeToQ, CTQ:DATE)
    IF ERRORCODE()
      ADD(ChangeToQ)
    END
!    ADD(CHANGETOQ)
  !@Parth
END
GET(QOBLIGATE,POINTER#)
[END]
EMBED %DataSectionBeforeWindow
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!@Parth - FB28903
LOC:Type          LIKE(QOB:Type)
!@Parth
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 3
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[ADDITION]
NAME Clarion CloseCurrentWindow
[INSTANCE]
INSTANCE 1
[INSTANCE]
INSTANCE 2
[WINDOW]
window  WINDOW('Change A Range Of Obligations'),AT(,,347,188),FONT('MS Sans Serif',8,,FONT:regular), |
          DOUBLE,CENTER,GRAY,HLP('~Range_Insert_Form')
          SHEET,AT(7,6,331,157),USE(?Sheet1),WIZARD,#ORIG(?Sheet1),#ORDINAL(1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1),#ORDINAL(2)
              GROUP('Choose A Range Of Date'),AT(15,14,107,57),USE(?Group1),BOXED,#ORIG(?Group1), |
                #ORDINAL(3)
                PROMPT('&From:'),AT(23,38),USE(?Prompt5),#ORIG(?Prompt5),#ORDINAL(4)
                LIST,AT(45,36,69,12),USE(FromDate),VSCROLL,DROP(10,85),FORMAT('43L~DATE~@' & |
                  'D2@28L~Type~@s7@'),FROM(ChangeFromQ),#FIELDS(CFQ:DATE,CFQ:Type),#ORIG(?List2), |
                  #ORDINAL(5)
                PROMPT('&To:'),AT(23,56),USE(?Prompt6),#ORIG(?Prompt6),#ORDINAL(6)
                COMBO(@d2<50B),AT(45,54,69,12),USE(ToDate),VSCROLL,DROP(10),FORMAT('56L~DATE~@D2@'), |
                  FROM(ChangeToQ),#FIELDS(CTQ:DATE),#ORIG(?Combo1),#ORDINAL(7)
              END
              OPTION('&Obligation Types'),AT(127,12,202,26),USE(ObligationType),FONT(,8),BOXED, |
                #ORIG(ObligationType),#ORDINAL(23)
                RADIO('Child Support'),AT(136,22,57,10),USE(?Option1:ChildSupport),VALUE('Child'), |
                  #ORIG(?Option1:ChildSupport),#ORDINAL(24)
                RADIO('Medical Support'),AT(195,22,67,10),USE(?Option1:MedicalSupport),VALUE('Medical'), |
                  #ORIG(?Option1:MedicalSupport),#ORDINAL(25)
                RADIO('Dental Support'),AT(266,22,60,10),USE(?Option1:DentalSupport),VALUE('Dental'), |
                  #ORIG(?Option1:DentalSupport),#ORDINAL(26)
              END
              OPTION('&Payment Options'),AT(127,41,201,28),USE(PaymentOption),BOXED,#ORIG(Option1), |
                #ORDINAL(8)
                RADIO('Monthly'),AT(136,54,39),USE(?Option1:Monthly),VALUE('A'),#ORIG(?Option1:Radio1), |
                  #ORDINAL(9)
                RADIO('Semi-monthly'),AT(178,54,54),USE(?Option1:semimonthly),VALUE('B'),#ORIG(?Option1:Radio2), |
                  #ORDINAL(10)
                RADIO('Weekly'),AT(236,54,38),USE(?Option1:weekly),VALUE('C'),#ORIG(?Option1:Radio3), |
                  #ORDINAL(11)
                RADIO('Bi-weekly'),AT(278,54,45),USE(?Option1:biweekly),VALUE('D'),#ORIG(?Option1:Radio4), |
                  #ORDINAL(12)
              END
              PROMPT('&Amount of each obligation:'),AT(74,80),USE(?Prompt1),#ORIG(?Prompt1), |
                #ORDINAL(13)
              ENTRY(@n-10.2),AT(200,78,46,12),USE(ObligationAmount),#ORIG(ObligationAmount), |
                #ORDINAL(14)
              PROMPT('&Day of month first payment is due:'),AT(74,98),USE(?PromptFirstDay), |
                #ORIG(?Prompt2),#ORDINAL(15)
              SPIN(@n3),AT(200,96,25,12),USE(FirstDay),RANGE(1,28),STEP(1),REQ,#ORIG(?Spin1), |
                #ORDINAL(16)
              CHECK('&Last day of the month'),AT(233,97),USE(MonthlyLastDay),#ORIG(MonthlyLastDay), |
                #ORDINAL(17)
              PROMPT('Day of &month second payment is due:'),AT(74,118),USE(?PromptSecondDay), |
                DISABLE,#ORIG(?Prompt4),#ORDINAL(18)
              SPIN(@n3),AT(200,116,25,12),USE(SecondDay),DISABLE,RANGE(1,30),STEP(1),#ORIG(?Spin2), |
                #ORDINAL(19)
              CHECK('La&st day of the month'),AT(233,117),USE(SemiMonthlyLastDay),DISABLE, |
                #ORIG(SemiMonthlyLastDay),#ORDINAL(20)
              PROMPT('Day of &week payments are due:'),AT(74,136),USE(?PromptDayOfWeek),DISABLE, |
                #ORIG(?Prompt3),#ORDINAL(21)
              LIST,AT(200,134,61,12),USE(DayOfWeek),VSCROLL,DISABLE,DROP(7),FORMAT('36L@s9@'), |
                FROM('Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday'),#FIELDS(DayOfWeek), |
                #ORIG(?List1),#ORDINAL(22)
            END
          END
          BUTTON('&OK'),AT(236,169,50,15),USE(?OkButton),LEFT,ICON('ok.ico'),DEFAULT,#ORDINAL(27)
          BUTTON('&Cancel'),AT(289,169,50,15),USE(?CancelButton),LEFT,ICON('cancel.ico'),#ORDINAL(28)
          BUTTON('&Help'),AT(7,169,50,15),USE(?Help),LEFT,ICON(ICON:Help),STD(STD:Help),#ORIG(?Button3), |
            #ORDINAL(29)
        END

[END]
[MODULE]
[COMMON]
FROM Clarion GENERATED
MODIFIED '2021/06/17' '17:37:56'
[PROCEDURE]
NAME GetInfo
PROTOTYPE '(long lpcstr,*long pAddr,*long pSize),long,PASCAL,NAME(''GETINFO'')'
PARAMETERS '(long lpcstr,*long pAddr,*long pSize)'
[COMMON]
DESCRIPTION 'called by ProDoc to detect if thread is running'
FROM Clarion Source
MODIFIED '2021/06/17' '17:37:56'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
cInput cstring(256)
[END]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  if ~lpcstr then return 3.
  lstrcpy(address(cinput),lpcstr)
  case upper(cinput)
  of 'CALCULATESUPPORT'
    paddr=glo:Calculatesupportthread
  of 'BROWSECASES'
    paddr=glo:BrowseCasesThread
  of 'DELINQUENTCALC'
    paddr=glo:DelinquentCalcThread
  OF 'BREAKDOWNOBLIGATION'
    paddr=glo:BreakDownObligationThread
  of 'AMORTIZEOBLIGATION'
    paddr=glo:AMORTIZEOBLIGATIONThread
  else
    return 3
  end
  return 0
[END]
[END]
