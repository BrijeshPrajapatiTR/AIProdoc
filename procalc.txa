EMBED %HandCodeEventOpnWin
[DEFINITION]
[GROUP]
PRIORITY 4000
INSTANCE 1
[SOURCE]
PROPERTY:BEGIN
PRIORITY 8500
PROPERTY:END
SWITCH=1
RecordsToProcess = RECORDS(ReportQueue) * 3
DebugCL.Send('filtervalues: ' & filtervalues)
DebugCL.Send('BAND(filtervalues,FilterObligationChild + FilterObligationChildSummary): ' & BAND(filtervalues,FilterObligationChild + FilterObligationChildSummary))
IF BAND(filtervalues,FilterObligationChild + FilterObligationChildSummary)
  CurrentObligationType = 'CHILD'
ELSIF BAND(filtervalues,FilterObligationMedical + FilterObligationMedicalSummary)
  CurrentObligationType = 'MEDICAL'
ELSIF BAND(filtervalues,FilterObligationDental + FilterObligationDentalSummary)
  CurrentObligationType = 'DENTAL'  
END

[END]
EMBED %HandCodeEventTimer
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF ~SummaryPrinted
!         @Parth - FB28903
!       TODO: Check the Support Type amd assign the proper obligation type
DebugCl.Send('INSIDE ~SummaryPrinted')
Case UPPER(CurrentObligationType)
OF 'CHILD'
  NAMConfirmedObl = NAMConfirmedOblChildSupport
  ATTYFees = ATTYFeesChildSupport
OF 'MEDICAL'
  NAMConfirmedObl = NAMConfirmedOblMedicalSupport
  ATTYFees = ATTYFeesMedicalSupport
OF 'DENTAL'
  NAMConfirmedObl = NAMConfirmedOblDentalSupport
  ATTYFees = ATTYFeesDentalSupport
END
DebugCl.Send('outside ~SummaryPrinted')
!       @Parth 
PRINT(RPT:SummaryDetail)
PRINTSUMMARY=1     !MAKE SURE TO BE ABLE TO PRINT SUMMARY ONLY
!          TODO: replace 715 cond with if (child and band () summary check for child)
  !TODO: OR (MEdical and band () summary check for medical) OR Dental for the same
!          IF PAR:TYPE = SummaryReport
!          DebugCl.Send('CurrentObligationType: ' & CurrentObligationType)
!          DebugCl.Send('BAND(filtervalues,0001000b): '& BAND(filtervalues,0001000b))
!          DebugCl.Send('~BAND(filtervalues,0000001b)): ' &(~BAND(filtervalues,0000001b))))
!          DebugCl.Send('BXOR(FilterValues, 0001000b): ' & BXOR(FilterValues, 0001000b))
!          DebugCl.Send('BOR(FilterValues,0010010b): ' & BOR(FilterValues,0010010b))
  
IF (UPPER(CurrentObligationType) = 'CHILD' AND BAND(filtervalues,FilterObligationChildSummary) AND ~BAND(filtervalues,FilterObligationChild)) |
  OR (UPPER(CurrentObligationType) = 'MEDICAL' AND BAND(filtervalues,FilterObligationMedicalSummary) AND ~BAND(filtervalues,FilterObligationMedical)) |
  OR (UPPER(CurrentObligationType) = 'DENTAL' AND BAND(filtervalues,FilterObligationDentalSummary) AND ~BAND(filtervalues,FilterObligationDental))
  DebugCl.Send('INSIDE Big IF - Before CurrentObligationType: ' & CurrentObligationType & ', FilterValues: ' & FilterValues)
  CASE UPPER(CurrentObligationType)
  OF 'CHILD'
    FilterValues = BXOR(FilterValues, FilterObligationChildSummary)
    DebugCl.Send('FilterValues: ' & FilterValues)
    IF BAND(FilterValues,FilterObligationMedical + FilterObligationMedicalSummary)
      CurrentObligationType = 'MEDICAL'
    ELSIF BAND(filtervalues,FilterObligationDental + FilterObligationDentalSummary)
      CurrentObligationType = 'DENTAL'  
    END  
  OF 'MEDICAL'
    FilterValues = BXOR(FilterValues, FilterObligationMedicalSummary)
    IF BAND(FilterValues,FilterObligationDental + FilterObligationDentalSummary)
      CurrentObligationType = 'DENTAL'  
    END
  OF 'DENTAL'
    FilterValues = BXOR(FilterValues, FilterObligationDentalSummary)
  END
  DebugCL.Send('After CurrentObligationType: ' & CurrentObligationType & ', FilterValues: ' & FilterValues)
  If FilterValues = 0
    PFQ:Done:1 = TRUE
    LocalResponse = RequestCompleted 
      
    LOOP I#=1 TO RECORDS(PrintPreviewQueue2)
      GET(PrintPreviewQueue2,I#)
      IF ERRORCODE() THEN BREAK.
      if addpage(prINTPREVIEWQUEUE2.PRINTPREVIEWIMAGE2, 1)  then
        message('There was a problem sending one page to the printer. This is sometimes caused by too little disk space or too many temporary files.','Print Problem')
      end
    END
    DebugCl.Send('before  free PrintPreviewQueue2')
    Free(PrintPreviewQueue2)
    DebugCl.Send('All reports completed ')
!              ReportWasOpened=false
!              DebugCl.Send('before  Close report 1')
!              close(report1)
!              DebugCl.Send('before  SWITCH 2')
!              SWITCH=2
!              DebugCl.Send('before  OpenReportRoutine')
!              DO OpenReportRoutine
      
    BREAK
  END
    
  DebugCl.Send('Outside big if')
!            LocalResponse=RequestCompleted
!            clearpages()
  DebugCl.Send('before  PrintPreviewQueue2 loop')
  LOOP I#=1 TO RECORDS(PrintPreviewQueue2)
    GET(PrintPreviewQueue2,I#)
    IF ERRORCODE() THEN BREAK.
    if addpage(prINTPREVIEWQUEUE2.PRINTPREVIEWIMAGE2, 1)  then
      message('There was a problem sending one page to the printer. This is sometimes caused by too little disk space or too many temporary files.','Print Problem')
    end
  END
  DebugCl.Send('before  free PrintPreviewQueue2')
  Free(PrintPreviewQueue2)
  DebugCl.Send('before  ReportWasOpened false')
  ReportWasOpened=false
!!!
    
    
!            if SWITCH = 1
!              DebugCl.Send('before  Close report 1')
  close(report1)
!            ELSE
!              DebugCl.Send('before  Close report')
!              CLOSE(REPORT)
!            END
!            DebugCl.Send('before  SWITCH 2')
!            SWITCH=2
  DebugCl.Send('before  OpenReportRoutine')
!            ENDPAGE(report1)
  DO OpenReportRoutine
  DebugCl.Send('after  OpenReportRoutine')
!            SummaryPrinted = TRUE
  CYCLE
!            Break
ELSE
  PRINT(RPT:ExplainDetail)
  PRINT(RPT:ExplainDetail2)
  MESSAGE1 = '                      OBLIGATION       PAYMENT        UNCONFIRMED BALANCES       CONFIRMED BALANCES        ATTORNEY''S FEES & COSTS'
  MESSAGE2 = 'DATE               AMOUNT          ALLOCATED       OBLIGATION          INTEREST      OBLIGATION         INTEREST      OBLIGATION          INTEREST'
  SummaryPrinted = TRUE
    
    
  DebugCl.Send('ELSE Before Case Stmt FilterValues :' & FilterValues)
  CASE UPPER(CurrentObligationType)
  OF 'CHILD'
    IF BAND(FilterValues,FilterObligationChildSummary)
      FilterValues = BXOR(FilterValues, FilterObligationChildSummary)
    END
    DebugCl.Send('ELSE CHILD FilterValues :' & FilterValues)
  OF 'MEDICAL'
    IF BAND(FilterValues,FilterObligationMedicalSummary)
      FilterValues = BXOR(FilterValues, FilterObligationMedicalSummary)
    END
    DebugCl.Send('ELSE MEDICAL FilterValues :' & FilterValues)
  OF 'DENTAL'
    IF BAND(FilterValues,FilterObligationDentalSummary)
      FilterValues = BXOR(FilterValues, FilterObligationDentalSummary)
    END
    DebugCl.Send('ELSE DENTAL FilterValues :' & FilterValues)
  END

  DebugCl.Send('ELSE after case stmt FilterValues :' & FilterValues)
END
!          clearpages()
LOOP I#=1 TO RECORDS(PrintPreviewQueue2)
  GET(PrintPreviewQueue2,I#)
  IF ERRORCODE() THEN BREAK.
  if addpage(prINTPREVIEWQUEUE2.PRINTPREVIEWIMAGE2, 1)  then
    message('There was a problem sending one page to the printer. This is sometimes caused by too little disk space or too many temporary files.','Print Problem')
  end
END
DebugCl.Send('before PrintPreviewQueue2- @@ ')
Free(PrintPreviewQueue2)
DebugCl.Send('before SWITCH: @@')
if SWITCH = 1
  DebugCl.Send('before  Close report 1')
  close(report1)
ELSE
  DebugCl.Send('before  Close report')
  CLOSE(REPORT)
END
SWITCH=2
DebugCl.Send('before ReportWasOpened: @@')
ReportWasOpened=false
DebugCl.Send('before Close report1: @@')
!          close(report1)
DebugCl.Send('before OpenReportRoutine:@@ ' & CurrentObligationType)
DO OpenReportRoutine
report{Prop:NextPageNo}=I#
  !IF I#>0
  !  LOOP J#=1 TO I#-1
  !    Print(RPT:FAKE)    !THESE FOUR LINES OF STATEMENT JUST CREATE CORRECT START PAGE No.
  !  END                  ! FOR SECOND REPORT BECAUSE FIRST REPORT HAS PRINT OUT 3 PAGES
  !  FREE(PRINTPREVIEWQUEUE)
  !END
END
!        STOP('bEFORE LOOP 25 TIMES')
LOOP 25 TIMES
QueNdx:1 += 1
GET(ReportQueue,QueNdx:1)
DO DisplayProgress
DO PrintFromQueue:1
  
 ! @Parth - FB28903
If QueNdx:1 >= RECORDS(ReportQueue)
  DebugCL.Send('before case stmt FilterValues: ' & FilterValues)
  DebugCl.Send('In QUENDX, CurrentObligationType: ' & CurrentObligationType)
  Do PrintUnconfirmedObligations
  CASE UPPER(CurrentObligationType)
  OF 'CHILD'
    FilterValues = BXOR(FilterValues, FilterObligationChild)
    IF BAND(filtervalues,FilterObligationMedical + FilterObligationMedicalSummary)
      CurrentObligationType = 'MEDICAL'
    ELSIF BAND(filtervalues,FilterObligationDental + FilterObligationDentalSummary)
      CurrentObligationType = 'DENTAL'  
    END  
    DO ResetReport
  OF 'MEDICAL'
    FilterValues = BXOR(FilterValues, FilterObligationMedical)
    IF BAND(filtervalues,FilterObligationDental + FilterObligationDentalSummary)
      CurrentObligationType = 'DENTAL'  
    END
    DO ResetReport
  OF 'DENTAL'
    FilterValues = BXOR(FilterValues, FilterObligationDental)
    PFQ:Done:1 = TRUE
    LocalResponse = RequestCompleted 
    DO ResetReport
  END
  DebugCL.Send('After Case stmt FilterValues: ' & FilterValues)
  QueNdx:1 = 0
  If FilterValues = 0
    PFQ:Done:1 = TRUE
    LocalResponse = RequestCompleted 
    BREAK
  END
  BREAK
END
! @Parth
END
IF PFQ:Done:1
BREAK
END

OMIT ('**Parth')
