[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
IF NAM:ConfirmedPrincipal     !MA ADDED  6/27/01
  IF ~NAM:ConfirmedDate
    MESSAGE('You must enter the date rendered for the judgment.')
    SELECT(?NAM:ConfirmedDate)
    CYCLE
  END
END
IF ~LEN(CLIP(GLO:OBLIGOR))
  MESSAGE('You must enter the OBLIGOR before saving data.')
  SELECT(?GLO:Obligor)
  CYCLE
END
IF ~LEN(CLIP(GLO:OBLIGEE))
