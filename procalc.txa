%Parameters DEFAULT  ('')
[EMBED]
EMBED %ProcedureInitialize
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
PaymentOption = 'A'
FirstDay = 1
[END]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?FromDate'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?FromDate{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?ToDate'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?ToDate{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?Option1:Monthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptFirstDay,?MonthlyLastDay)
DISABLE(?PromptSecondDay,?DayOfWeek)
IF MonthlyLastDay
  DISABLE(?PromptFirstDay)
  DISABLE(?FirstDay)
END
DISPLAY()
[END]
[END]
WHEN '?Option1:semimonthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?MonthlyLastDay)
DISPLAY()
[END]
[END]
WHEN '?Option1:weekly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISPLAY()
[END]
[END]
WHEN '?Option1:biweekly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
[END]
[END]
WHEN '?OkButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
UPDATE
IF ~FromDate
  SELECT(?FromDate)
  CYCLE
END

IF ~ToDate
  SELECT(?ToDate)
  CYCLE
END

IF ~PaymentAmount
  SELECT(?PaymentAmount)
  CYCLE
END
CASE PaymentOption
OF 'A'
  IF ~FirstDay
    SELECT(?FirstDay)
    CYCLE
  END
OF 'B'
  IF ~FirstDay
    SELECT(?FirstDay)
    CYCLE
  END
  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    CYCLE
  END
OF 'C'
OROF 'D'
  IF ~DayOfWeek
    SELECT(?DayOfWeek)
    CYCLE
  END
END

IF FromDate>ToDate
  MESSAGE('The From Date shouldn''t be greater than the To Date.')
  SELECT(?FromDate)
  CYCLE
END
POINTER#=POINTER(QPAYMENTS)
GET(QPAYMENTS,RECORDS(QPAYMENTS))
IF ToDate>QPA:PDATE
  DUMMY#=MESSAGE('The To Date you entered is greater than the last date in the payments range and '|
        & 'the exceeded range will be inserted. Do you want to continue?','Warning',ICON:QUESTION,BUTTON:YES+BUTTON:NO,BUTTON:YES)
  IF DUMMY#=BUTTON:NO
    SELECT(?ToDate)
    CYCLE
  END
END

DISABLE(?CancelButton)
SETCURSOR(CURSOR:WAIT)
DO DeleteExistedDates
DO CallUpdate
SETCURSOR()
[GROUP]
PRIORITY 4000
INSTANCE 2
[END]
[END]
[END]
EMBED %ControlPostEventHandling
[INSTANCES]
WHEN '?FromDate'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
GET(ChangeFromQ,CHOICE(?FromDate))
!IF KEYCODE() = TabKey AND ~FromDate
!  SELECT(?FromDate)
!  CYCLE
!.
IF CFQ:DATE
  CASE CLIP(CFQ:Frequency)
  OF 'Monthly'                  !Monthly
    PaymentOption='A'
    ENABLE(?PromptFirstDay,?MonthlyLastDay)
    DISABLE(?PromptSecondDay,?DayOfWeek)
    IF MonthlyLastDay
      DISABLE(?PromptFirstDay)
      DISABLE(?FirstDay)
    END
  OF 'Semi-monthly'             !Semimonthly
    PaymentOption='B'
    ENABLE(?PromptFirstDay,?SemiMonthlyLastDay)
    DISABLE(?PromptDayOfWeek,?DayOfWeek)
    DISABLE(?MonthlyLastDay)
  OF 'Weekly'                   !Weekly
    PaymentOption='C'
    ENABLE(?PromptDayOfWeek,?DayOfWeek)
    DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
  OF 'Bi-weekly'                !Biweekly
    PaymentOption='D'
    ENABLE(?PromptDayOfWeek,?DayOfWeek)
    DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
  END
END
DISPLAY()
[END]
[END]
WHEN '?ToDate'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!IF KEYCODE() = TabKey AND ~ToDate
!  SELECT(?ToDate)
!  CYCLE
!END
[END]
[END]
WHEN '?CancelButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[GROUP]
PRIORITY 4000
INSTANCE 1
[END]
[END]
WHEN '?MonthlyLastDay'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF MonthlyLastDay
  Disable(?FirstDay)
  DISABLE(?PromptFirstDay)
ELSE
  ENABLE(?PromptFirstDay,?FirstDay)
.
[END]
[END]
WHEN '?SemiMonthlyLastDay'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF SemiMonthlyLastDay
  Disable(?SecondDay)
ELSE
  ENABLE(?PromptSecondDay,?SecondDay)
.
[END]
[END]
[END]
EMBED %EndOfProcedure
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  SORT(QPAYMENTS,QPA:PDATE)
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!-----------------------------------
CallUpdate      ROUTINE
!-----------------------------------
  CASE PaymentOption
  OF 'A'                        !Monthly
    DO Monthly
  OF 'B'                        !Semimonthly
    DO SemiMonthly
  OF 'C'                        !Weekly
    DO Weekly
  OF 'D'                        !Biweekly
    DO BiWeekly
  END

!-----------------------------------
Monthly      ROUTINE
!-----------------------------------

  IF MonthlyLastDay                         !If payment is to be made on last day of month
    FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                             ! subtract 1 day to get the
                                                             ! last day of month

  ELSIF DAY(FromDate) > FirstDay   !If from date is after the day of month for payment
    FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !set for next month
  ELSE                                        !otherwise set due date equal to the
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))  !day of month selected
  .
  LocalResponse = RequestCompleted

  QPA:PDATE = FirstDate
  LOOP
    DO AddRecords
    IF MonthlyLastDay  !If payment on last day of month then set for 1st day of second
      QPA:PDATE =  (DATE(MONTH(QPA:PDATE)+2,1,YEAR(QPA:PDATE)))-1   !month the subtract 1 to
                                                                    !get last day of next month
    ELSE
      QPA:PDATE =  DATE(MONTH(QPA:PDATE)+1,FirstDay,YEAR(QPA:PDATE))
    .
    IF QPA:PDATE > ToDate THEN BREAK.
  .

!-----------------------------------
SemiMonthly      ROUTINE
!-----------------------------------
  DATA
M     LONG
  CODE
  IF ~FirstDaY
    SELECT(?FirstDay)
    EXIT
  END

  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    EXIT
  END

  IF DAY(FromDate) > FirstDay !If from date is greater than day of month for first payment
    IF SemiMonthlyLastDay                         !If payment is to be made on last day of month
      FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                               ! subtract 1 day to get the
                                                               ! last day of month
      DayFlag = 1           !DayFlag will be set to keep track of which payment of the month we are doing
                            !  it's set in reverse from here because the addrecord is done in the loop below
                            !  and then the flag is reset.  This starts it out correctly

    ELSE   !If second payment day is not the last day of month
      IF DAY(FromDate) > SecondDay !If past first and second payment dates then start over with
        FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !the first payment date next month
        DayFlag = 2
      ELSE                         !Otherwise set for the second payment day as first payment day
        !FirstDate = DATE(MONTH(FromDate)+1,SecondDay,YEAR(FromDate))
        FirstDate = DATE(MONTH(FromDate),SecondDay,YEAR(FromDate))
        DayFlag = 1
      END!OF handling second day
    END!END OF SEMIMONTHLYLASTDAY IF STATEMENT

  ELSE                             !If from date is less than set first payment date
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))!start payment on the FirstDay
    DayFlag = 2
  .

  LocalResponse = RequestCompleted
  QPA:PDATE = FirstDate
  M=MONTH(QPA:PDATE)
  LOOP
    DO AddRecords
    IF DayFlag = 1
      QPA:PDATE =  DATE(MONTH(QPA:PDATE)+1,FirstDay,YEAR(QPA:PDATE))
      DayFlag = 2
      M=MONTH(QPA:PDATE)
    ELSE
      IF SemiMonthlyLastDay  !If payment on last day of month then set for 1st day of second
        QPA:PDATE =  (DATE(MONTH(QPA:PDATE)+1,1,YEAR(QPA:PDATE)))-1   !month the subtract 1 to
      ELSE                                                            !get last day of next month
        QPA:PDATE =  DATE(MONTH(QPA:PDATE),SecondDay,YEAR(QPA:PDATE))
        IF MONTH(QPA:PDATE)>M !FIX THE BUG WHEN SECOND DAY IS 30TH ON FEBRUARY THE MARCH 30TH WAS SKIPPED
          QPA:PDATE =  (DATE(M+1,1,YEAR(QPA:PDATE)))-1
        END
      END !OF IF MonthlyLastDay
      DayFlag = 1
    .
    IF QPA:PDATE > ToDate THEN BREAK.
  .


!-----------------------------------
Weekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE
 .

  LocalResponse = RequestCompleted

  QPA:PDATE = FirstDate
  LOOP
    DO AddRecords
    QPA:PDATE += 7
    IF QPA:PDATE > ToDate THEN BREAK.
  .

!-----------------------------------
BiWeekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE
 .

  LocalResponse = RequestCompleted

  QPA:PDATE = FirstDate
  LOOP
    DO AddRecords
    QPA:PDATE += 14
    IF QPA:PDATE > ToDate THEN BREAK.
  .


!-----------------------------------
AddRecords      ROUTINE
!-----------------------------------
  QPA:PCaseID = CAS:CAS_ID
  QPA:PAmount = PaymentAmount
  ADD(QPayments,QPA:PDATE)
  IF ERRORCODE()
      MESSAGE('Unable to add an payment for ' & FORMAT(QPA:PDATE,@D1) |
         & '!',,ICON:EXCLAMATION,BUTTON:OK,BUTTON:OK)
  ELSE
    GLO:UpdatePayments = TRUE
  .

!----------------------------
DeleteExistedDates  ROUTINE    !MA CREATED TO BE USED TO CHANGE A RANGE OF PAYMENTS
!----------------------------
  LOOP I#=RECORDS(QPAYMENTS) TO 1 BY -1
    GET(QPAYMENTS,I#)
    IF ERRORCODE() THEN BREAK.
    IF QPA:PDATE<FROMDATE THEN BREAK.
    IF QPA:PDATE>=FROMDATE AND QPA:PDATE<=TODATE
      DELETE(QPAYMENTS)
    END
  END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!----------------------------------
GetPaymentsFrequency    ROUTINE
!----------------------------------
!MA CREATED THIS ROUTINE TO GET THE FREQUENCY OF PAYMENTS BY PARSING PAYMENTS' DATE  10/28/02
  IF ~RECORDS(ChangeFromQ)
    EXIT
  END
  IF RECORDS(ChangeFromQ)=1
    GET(ChangeFromQ,1)
    CFQ:FREQUENCY='Monthly'     !IF ONLY 1 RECORD EXISTS THEN IT'S MONTHLY PAYMENT
    PUT(ChangeFromQ)
    EXIT
  END
  FREE(ABSTRACTQ)
  CLEAR(ABSTRACTQ)
  MONTH#=0
  YEAR#=0
  GROUP#=0
  LOOP I#=1 TO RECORDS(ChangeFromQ)     !FIRST MARK UP GROUPS
    GET(ChangeFromQ,I#)
    IF ERRORCODE() THEN BREAK.
    IF I#=1
      MONTH#=MONTH(CFQ:Date)
      YEAR#=YEAR(CFQ:Date)
      GROUP#+=1
      CFQ:GROUP=GROUP#
      PUT(ChangeFromQ)
      CYCLE
    END
    IF MONTH(CFQ:DATE)=MONTH# AND YEAR(CFQ:DATE)=YEAR#
      CFQ:GROUP=GROUP#
    ELSE
      GROUP#+=1
      MONTH#=MONTH(CFQ:Date)
      YEAR#=YEAR(CFQ:Date)
      CFQ:GROUP=GROUP#
    END
    PUT(ChangeFromQ)
  END
  I#=1
  GET(ChangeFromQ,1)
  LOOP                !THEN GENERATE THE ABSTRACTION OF THE PAYMENTS LIST INTO ABSTRACTQ
    GROUP#=CFQ:GROUP
    C#=0
    FIRSTAMOUNT#=CFQ:AMOUNT
    LASTAMOUNT#=CFQ:AMOUNT
    FIRSTDATE#=CFQ:DATE
    LASTDATE#=CFQ:DATE
    LOOP J#=I# TO RECORDS(ChangeFromQ)
      GET(ChangeFromQ,J#)
      IF ERRORCODE() THEN BREAK.
      IF GROUP#=CFQ:GROUP
        C#+=1
        LASTAMOUNT#=CFQ:AMOUNT
        LASTDATE#=CFQ:DATE
      ELSE
        BREAK
      END
    END
    CLEAR(ABSTRACTQ)
    AQ:ID=GROUP#
    AQ:FIRSTAMOUNT=FIRSTAMOUNT#
    AQ:LASTAMOUNT=LASTAMOUNT#
    AQ:FIRSTDATE=FIRSTDATE#
    AQ:LASTDATE=LASTDATE#
    AQ:NUMBEROFOBL=C#
    ADD(ABSTRACTQ)
    CASE C#
    OF 1        !IF IT'S 1 THEN THERE MAY BE 4 CHANCES OF 'WEEKLY','BI-WEEKLY','SEMI-MONTHLY' AND 'MONTHLY'
      IF J#+1>=RECORDS(ChangeFromQ)
        DATE#=CFQ:DATE
        GET(ChangeFromQ,J#+1)
        IF CFQ:DATE-DATE#=7 AND CFQ:AMOUNT=AQ:LASTAMOUNT     !WEEKLY
          AQ:TYPE='C'
          PUT(ABSTRACTQ)
        ELSIF CFQ:DATE-DATE#=14 AND CFQ:AMOUNT=AQ:LASTAMOUNT !BI-WEEKLY
          AQ:TYPE='D'
          PUT(ABSTRACTQ)
        END
        GET(ChangeFromQ,J#)
      END
    OF 2        !IF IT'S 2 THEN SEE IF IT'S WEEKLY OR BI-WEEKLY
      GET(ChangeFromQ,J#-1)
      DATE#=CFQ:DATE
      DAY1#=DAY(CFQ:DATE)
      GET(ChangeFromQ,J#-2)
      DAY2#=DAY(CFQ:DATE)
      IF DATE#-CFQ:DATE=7     !IT'S WEEKLY
        AQ:TYPE='C'
        PUT(ABSTRACTQ)
      ELSIF DATE#-CFQ:DATE=14
        IF J#+1<=RECORDS(ChangeFromQ)
          GET(ChangeFromQ,J#)
          DAY3#=DAY(CFQ:DATE)
          GET(ChangeFromQ,J#+1)
          IF DAY2#=DAY3# AND DAY1#=DAY(CFQ:DATE)
            AQ:TYPE=''
          ELSE
            AQ:TYPE='D'        !Bi-weekly
          END
          PUT(ABSTRACTQ)
        END
      END
      GET(ChangeFromQ,J#)
    OF 3
      !IF IT'S THREE THEN MAY BE BI-WEEKLY OR WEEKLY DEPENDING ON NEXT GROUP
    END
    IF J#>RECORDS(ChangeFromQ)
      BREAK
    END
    I#=J#
  END

  LOOP I#=1 TO RECORDS(ABSTRACTQ)    !THEN TRY TO GUESS THE FREQUENCY BASED ON THE ABSTRACTQ
    GET(ABSTRACTQ,I#)
    IF ERRORCODE() THEN BREAK.
    CASE AQ:NUMBEROFOBL
    OF 4                             !Weekly
    OROF 5
      AQ:FREQUENCY='Weekly'
      PUT(ABSTRACTQ)
    OF 3
      IF AQ:TYPE='C'
        AQ:FREQUENCY='Weekly'        !Weekly
        PUT(ABSTRACTQ)
      ELSIF AQ:TYPE='D'
        AQ:FREQUENCY='Bi-weekly'     !Bi-weekly
        PUT(ABSTRACTQ)
      ELSE
        LASTAMOUNT#=AQ:LASTAMOUNT
        FIRSTAMOUNT#=AQ:FIRSTAMOUNT
        IF I#+1<=RECORDS(ABSTRACTQ)
          GET(ABSTRACTQ,I#+1)
          IF AQ:NUMBEROFOBL=4 AND LASTAMOUNT#=AQ:FIRSTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Weekly'    !Weekly
          ELSE
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Bi-weekly' !Bi-weekly
          END
        ELSE
          GET(ABSTRACTQ,I#-1)
          IF AQ:NUMBEROFOBL=4 AND FIRSTAMOUNT#=AQ:LASTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Weekly'    !Weekly
          ELSE
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Bi-weekly' !Bi-weekly
          END
        END
        PUT(ABSTRACTQ)
      END
    OF 2
      IF AQ:TYPE='C'
        AQ:Frequency='Weekly'        !Weekly
      ELSIF AQ:TYPE='D'
        AQ:Frequency='Bi-weekly'     !Bi-weekly
      ELSE
        AQ:Frequency='Semi-monthly'  !Semi-monthly
      END
      PUT(ABSTRACTQ)
    OF 1
      LASTAMOUNT#=AQ:LASTAMOUNT
      FIRSTAMOUNT#=AQ:FIRSTAMOUNT
      LASTDATE#=AQ:LASTDATE
      FIRSTDATE#=AQ:FIRSTDATE
      IF AQ:TYPE='C'
        AQ:Frequency='Weekly'
        PUT(ABSTRACTQ)
      ELSIF AQ:TYPE='D'
        AQ:Frequency='Bi-weekly'
        PUT(ABSTRACTQ)
      ELSE
        IF I#+1<=RECORDS(ABSTRACTQ)
          GET(ABSTRACTQ,I#+1)
          IF AQ:NUMBEROFOBL=2 AND LASTAMOUNT#=AQ:FIRSTAMOUNT AND AQ:FIRSTDATE-LASTDATE#<30
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Semi-monthly' !Semi-monthly
          ELSE
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Monthly'      !Monthly
          END
        ELSE       !IF IT'S LAST ONE THEN SEE BACKWARD
          GET(ABSTRACTQ,I#-1)
          IF AQ:NUMBEROFOBL=4 AND FIRSTAMOUNT#=AQ:LASTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Weekly'       !Weekly
          ELSIF AQ:NUMBEROFOBL=3 AND FIRSTAMOUNT#=AQ:LASTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Bi-weekly'    !Bi-weekly
          ELSIF AQ:NUMBEROFOBL=2 AND FIRSTAMOUNT#=AQ:LASTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Semi-monthly' !Semi-monthly
          ELSE
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Monthly'      !Monthly
          END
        END
        PUT(ABSTRACTQ)
      END
    END
  END
  LOOP I#=1 TO RECORDS(ChangeFromQ)     !NOW WRITE BACK FREQUENCY TO ChangeddFromQ
    GET(ChangeFromQ,I#)
    IF ERRORCODE() THEN BREAK.
    AQ:ID=CFQ:GROUP
    GET(ABSTRACTQ,AQ:ID)
    IF ~ERRORCODE()
      CFQ:FREQUENCY=AQ:FREQUENCY
    ELSE
      CFQ:FREQUENCY=''
    END
    PUT(ChangeFromQ)
  END
[END]
EMBED %DataSectionBeforeWindow
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
ABSTRACTQ            QUEUE,PRE(AQ)
ID                     LONG
NUMBEROFOBL            LONG
FIRSTAMOUNT            DECIMAL(9,2)
LASTAMOUNT             DECIMAL(9,2)
FIRSTDATE              LONG
LASTDATE               LONG
FREQUENCY              STRING(12)
TYPE                   STRING(1)
                     END
[END]
EMBED %BeforeWindowOpening
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
POINTER#=POINTER(QPAYMENTS)
FREE(CHANGEFROMQ)
FREE(CHANGETOQ)
LOOP I#=1 TO RECORDS(QPAYMENTS)
  GET(QPAYMENTS,I#)
  IF ERRORCODE() THEN BREAK.
  CFQ:DATE=QPA:PDATE
  CFQ:AMOUNT=QPA:PAMOUNT
  ADD(CHANGEFROMQ)
  CTQ:DATE=QPA:PDATE
  ADD(CHANGETOQ)
END
GET(QPAYMENTS,POINTER#)
DO GetPaymentsFrequency
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 3
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[ADDITION]
NAME Clarion CloseCurrentWindow
[INSTANCE]
INSTANCE 1
[INSTANCE]
INSTANCE 2
[WINDOW]
window  WINDOW('Change A Range Of Payments'),AT(,,347,188),FONT('MS Sans Serif',8,,FONT:regular), |
          DOUBLE,CENTER,GRAY,HLP('~Range_Insert_Form')
          SHEET,AT(7,5,331,160),USE(?Sheet1),WIZARD,#ORIG(?Sheet1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1)
              GROUP('Choose A Range Of Date'),AT(17,14,107,57),USE(?Group1),BOXED,#ORIG(?Group1)
                PROMPT('&From:'),AT(24,35),USE(?Prompt5),#ORIG(?Prompt5)
                LIST,AT(46,33,69,12),USE(FromDate),VSCROLL,DROP(10),FORMAT('56L~DATE~@D2@'), |
                  FROM(ChangeFromQ),#FIELDS(CFQ:DATE),#ORIG(?List2)
                PROMPT('&To:'),AT(24,55),USE(?Prompt6),#ORIG(?Prompt6)
                COMBO(@d2<50B),AT(46,53,69,12),USE(ToDate),VSCROLL,DROP(10),FORMAT('56L~DATE~@D2@'), |
                  FROM(ChangeToQ),#FIELDS(CTQ:DATE),#ORIG(?Combo1)
              END
              OPTION('&Payment Options'),AT(129,14,201,58),USE(PaymentOption),BOXED,#ORIG(Option1)
                RADIO('Monthly'),AT(139,40),USE(?Option1:Monthly),VALUE('A'),#ORIG(?Option1:Radio1)
                RADIO('Semi-monthly'),AT(181,40),USE(?Option1:semimonthly),VALUE('B'),#ORIG(?Option1:Radio2)
                RADIO('Weekly'),AT(239,40),USE(?Option1:weekly),VALUE('C'),#ORIG(?Option1:Radio3)
                RADIO('Bi-weekly'),AT(281,40),USE(?Option1:biweekly),VALUE('D'),#ORIG(?Option1:Radio4)
              END
              PROMPT('&Amount of each payment:'),AT(74,79),USE(?Prompt1),#ORIG(?Prompt1)
              ENTRY(@n-10.2),AT(200,77,46,12),USE(PaymentAmount),#ORIG(ObligationAmount)
              PROMPT('&Day of month first payment is due:'),AT(74,98),USE(?PromptFirstDay), |
                #ORIG(?Prompt2)
              SPIN(@n3),AT(200,96,25,12),USE(FirstDay),RANGE(1,28),STEP(1),REQ,#ORIG(?Spin1)
              CHECK('&Last day of the month'),AT(233,97),USE(MonthlyLastDay),#ORIG(MonthlyLastDay)
              PROMPT('Day of &month second payment is due:'),AT(74,117),USE(?PromptSecondDay), |
                DISABLE,#ORIG(?Prompt4)
              SPIN(@n3),AT(200,115,25,12),USE(SecondDay),DISABLE,RANGE(1,30),STEP(1),#ORIG(?Spin2)
              CHECK('La&st day of the month'),AT(233,116),USE(SemiMonthlyLastDay),DISABLE, |
                #ORIG(SemiMonthlyLastDay)
              PROMPT('Day of &week payments are due:'),AT(74,136),USE(?PromptDayOfWeek),DISABLE, |
                #ORIG(?Prompt3)
              LIST,AT(200,134,61,12),USE(DayOfWeek),VSCROLL,DISABLE,DROP(7),FORMAT('36L@s9@'), |
                FROM('Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday'),#FIELDS(DayOfWeek), |
                #ORIG(?List1)
            END
          END
          BUTTON('&OK'),AT(235,170,50,15),USE(?OkButton),LEFT,ICON('ok.ico'),DEFAULT
          BUTTON('&Cancel'),AT(288,170,50,15),USE(?CancelButton),LEFT,ICON('cancel.ico')
          BUTTON('&Help'),AT(8,170,50,15),USE(?Help),LEFT,ICON(ICON:Help),STD(STD:Help),#ORIG(?Button3)
        END

[END]
[MODULE]
[COMMON]
FROM Clarion GENERATED
MODIFIED '2021/06/17' '17:37:56'
[PROCEDURE]
NAME CallClientsCases
PROTOTYPE '(*long pCas_id, *long pWhocall),long'
PARAMETERS '(*long pCas_id, *long pWhocall)'
NOEXPORT
[COMMON]
FROM Clarion Source
MODIFIED '2021/06/17' '17:37:56'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
CALLDLLCL CALLDLLCLTYPE
result    LONG(3)  !init to fail - 0=no error 3=error
Newcase   LONG(0)
[END]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  IF ~glo:CallerProcAdd then return 3.
  if ~Calldllcl.init('',0) then
    CALLDLLCL.ADDADDRESS('BRW:CLIENTS',GLO:CallerProcAdd)
    result=CallDllcl.Call_p3('BRW:CLIENTS',address(pCas_id),address(Newcase),address(pWhocall))
    GLO:NEWCASE=Newcase
  end
  calldllcl.kill()
  return result
[END]
[END]
