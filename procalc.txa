EMBED %AfterOpeningReport
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
if ReportWasOpened = True
  !Replace token XXXX with year
  settarget(report)
  szTempString = ?String110{prop:text}
  x# = instring('XXX', szTempString, 1, 1)
  if x#
    szTempString[x# : x# + 3] = sVersionYear
    ?String110{prop:text} = szTempString
  end
  !@ADO 1646468 Vedant ProCalc 2023
!!    IF AltNetResources < 1000 AND |
!!      GLO:FiledAfterSep1 = TRUE
  IF AltNetResources < 1000
  !Vedant - End
   ?STRING3{PROP:Text} =  'LOW-INCOME ' & ?STRING3{PROP:Text}
  END
  settarget()
 end
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 2
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[ADDITION]
NAME CPCSRpts PrintFromQueue
[INSTANCE]
INSTANCE 1
[PROMPTS]
%AllowFileAccess LONG  (0)
%UsingCPCSBreaks LONG  (0)
%InputQueue FIELD  (DUMMY)
%ProcessSeq DEFAULT  ('Ascending')
%PFQcontinue LONG  (0)
%PrintingDeferred LONG  (0)
%DetailBandHandCode MULTI DEFAULT  ()
%AutoPrintDetail LONG  (0)
%DetailBandName DEFAULT  ('')
[REPORT]
Report  REPORT('SupportObligation'),AT(500,1500,7771,8750),PRE(RPT),PAPER(PAPER:LETTER),FONT('Arial', |
          10,,FONT:regular),THOUS
EndOfReportBreak BREAK(EndOfReport),USE(?BREAK1),#ORDINAL(1)
Detail      DETAIL,AT(0,0,7771,5917),USE(?DETAIL1),#ORDINAL(2)
              STRING('Child Support Obligation'),AT(2396,-10),USE(?String1),FONT('Arial',14, |
                COLOR:Black,FONT:regular),#ORIG(?String1),#ORDINAL(3)
              STRING('Using The Texas Attorney General''s XXXX Tax Charts'),AT(1542,229),USE(?String110), |
                FONT(,,,FONT:bold),#ORIG(?String110),#ORDINAL(4)
              STRING('Obligor:'),AT(552,708,594,208),USE(?String2),LEFT,#ORIG(?String2),#ORDINAL(5)
              STRING(@s80),AT(2344,708),USE(GLO:Obligor),#ORIG(?String3),#ORDINAL(6)
              STRING(@s80),AT(2354,927),USE(GLO:Obligee),TRN,#ORIG(?String173),#ORDINAL(7)
              STRING('Obligee:'),AT(552,948),USE(?String172),TRN,#ORIG(?String172),#ORDINAL(8)
              STRING('Calculation date:'),AT(552,1167),USE(?String4),LEFT,#ORIG(?String4), |
                #ORDINAL(9)
              STRING(@d2),AT(2354,1188),USE(GLO:CalcDate),#ORIG(?String5),#ORDINAL(10)
              STRING(@n$-13.2),AT(4667,2094,1042,208),USE(GrossMonthlyIncome),LEFT,#ORIG(?String12), |
                #ORDINAL(11)
              STRING(@s100),AT(292,2115),USE(LOC:STR),#ORIG(?String6),#ORDINAL(12)
              STRING(@n$-13.2),AT(3135,2365),USE(GLO:FEDERALTAX),RIGHT,TRN,#ORIG(?String170), |
                #ORDINAL(13)
              STRING(@n$-13.2),AT(3135,2573),USE(GLO:FICASSTAX),RIGHT,TRN,#ORIG(?String171), |
                #ORDINAL(14)
              STRING('Less Federal Income Tax Withholding'),AT(552,2354),USE(?String168),TRN, |
                #ORIG(?String168),#ORDINAL(15)
              STRING('Less FICA and Medicare'),AT(552,2563),USE(?String169),TRN,#ORIG(?String169), |
                #ORDINAL(16)
              STRING('Net income using AG''s tax charts'),AT(292,2854),USE(?String113),#ORIG(?String113), |
                #ORDINAL(17)
              STRING(@n$-13.2),AT(4667,2875),USE(NetMonthlyIncome),#ORIG(?String114),#ORDINAL(18)
              STRING(@n$-13.2),AT(3135,3125),USE(NontaxableMonthly),RIGHT,TRN,#ORIG(?String112), |
                #ORDINAL(19)
              STRING('Plus monthly nontaxable income'),AT(563,3125),USE(?String111),#ORIG(?String111), |
                #ORDINAL(20)
              STRING(@n3),AT(2719,1396,313,208),USE(TotalChildren),RIGHT,#ORIG(?String13), |
                #ORDINAL(21)
              STRING('Obligor''s total children:'),AT(552,1385),USE(?String7),LEFT,#ORIG(?String7), |
                #ORDINAL(22)
