[EMBED]
EMBED %OtherEvents
[DEFINITION]
[GROUP]
PRIORITY 4000
INSTANCE 2
[END]
EMBED %ProcedureSetup
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
sYear = year(today())
i# = instring('.', sVersionNum, 1, 1)
if i# > 0
  j# = instring('.', sVersionNum, 1, i#+1)
  if j# > 0
    sYear = sVersionNum[i# + 1 : i# + 4]
  else
    if sVersionNum[1] = '2'
      sYear = sVersionNum[1 : i# -1]
    end
  end
end
if SelfEmployed
  sTitleString = 'SELF-EMPLOYED PERSONS ' & sYear & ' TAX CHART (ProCalc Printed)'
else
  sTitleString = 'EMPLOYED PERSONS ' & sYear & ' TAX CHART (ProCalc Printed)'
end
[END]
EMBED %PrePrintFromQueue
[INSTANCES]
WHEN '2'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!Get another data set that should be same with current data set
if QueNdx:2 = 1
  dHiNum     = NQ:HiNum
  dHiNumSS1  = NQ:HiNumSS1
  dHiNumSS2  = NQ:HiNumSS2
  dHiNumFed  = NQ:HiNumFed
  exit
end
if dHiNum    <> NQ:ID or |
   dHiNumSS1 <> NQ:LONUMSS1 or |
   dHiNumSS2 <> NQ:LONUMSS2 or |
   dHiNumFed <> NQ:LONUMFED
  sCheckPoint = 'X'
else
  sCheckPoint = ''
end
dNetMonthlyIncome = NQ:ID - NQ:LONUMSS1 - NQ:LONUMSS2 - NQ:LONUMFED
PRINT(RPT:Detail)
dHiNum     = NQ:HiNum
dHiNumSS1  = NQ:HiNumSS1
dHiNumSS2  = NQ:HiNumSS2
dHiNumFed  = NQ:HiNumFed
[END]
[END]
EMBED %DeclarationSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!Note: AltShiftF11 hot key can print a tax chart based on what I entered in LoadNumQ procedure so that way QA can check the
!      tax chart with this report to make sure the numbers are entered correctly. MA 12/3/08
dID         DECIMAL(7,2)
dHiNum      DECIMAL(7,2)
dLoNumSS1   DECIMAL(9,2)
dHiNumSS1   DECIMAL(9,2)
dLoNumSS2   DECIMAL(9,2)
dHiNumSS2   DECIMAL(9,2)
dLoNumFed   DECIMAL(9,2)
dHiNumFed   DECIMAL(9,2)
sYear       STRING(4)
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 1
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[ADDITION]
NAME CPCSRpts PrintFromQueue
[INSTANCE]
INSTANCE 2
[PROMPTS]
%AllowFileAccess LONG  (0)
%UsingCPCSBreaks LONG  (0)
%InputQueue FIELD  (NumQ)
%ProcessSeq DEFAULT  ('Ascending')
%PFQcontinue LONG  (0)
%PrintingDeferred LONG  (0)
%DetailBandHandCode MULTI DEFAULT  ()
%AutoPrintDetail LONG  (0)
%DetailBandName DEFAULT  ('?Header')
[REPORT]
Report  REPORT,AT(500,781,7385,10094),PRE(RPT),PAPER(PAPER:A4),FONT('Arial',10,,FONT:regular, |
          CHARSET:ANSI),THOUS
          HEADER,AT(500,167,7385,625),USE(?Header)
            STRING(@s255),AT(2208,104),USE(sTitleString),FONT(,,,FONT:bold),CENTER,TRN,#ORIG(?String1)
            STRING('Monthly Gross Wages'),AT(156,458),USE(?String2),FONT(,8,,FONT:underline), |
              TRN,#ORIG(?String2)
            STRING('Medicare'),AT(2729,458),USE(?String4),FONT(,8,,FONT:underline),TRN,#ORIG(?String4)
            STRING('Net Monthly Income'),AT(4833,458),USE(?String6),FONT(,8,,FONT:underline), |
              TRN,#ORIG(?String6)
            STRING('FICA'),AT(1917,458),USE(?String3),FONT(,8,,FONT:underline),TRN,#ORIG(?String3)
            STRING('Federal Income Taxes'),AT(3469,458),USE(?String5),FONT(,8,,FONT:underline), |
              TRN,#ORIG(?String5)
          END
Detail    DETAIL,AT(,,,135),USE(?Detail)
            STRING(@n$11.2),AT(1490,-10),USE(NQ:LoNumSS1),FONT(,8),RIGHT,TRN,#ORIG(?String8)
            STRING(@n$11.2),AT(4875,-10),USE(dNetMonthlyIncome),FONT(,8),RIGHT,TRN,#ORIG(?String11)
            STRING(@s1),AT(167,0),USE(sCheckPoint),FONT(,8,,FONT:bold),TRN,#ORIG(?String12)
            STRING(@n$11.2),AT(396,-10),USE(NQ:ID),FONT(,8),RIGHT,TRN,#ORIG(?String7)
            STRING(@n$11.2),AT(2500,-10),USE(NQ:LoNumSS2),FONT(,8),RIGHT,TRN,#ORIG(?String9)
            STRING(@n$11.2),AT(3604,-10),USE(NQ:LoNumFed),FONT(,8),RIGHT,TRN,#ORIG(?String10)
          END
        END

[PROCEDURE]
NAME GenerateCodeTextFile
NOEXPORT
[COMMON]
DESCRIPTION 'output code to text file for Handheld use'
FROM Clarion Source
MODIFIED '2008/12/04' '13:31:19'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
!Note: AltShiftF12 hot key can generate CodeTaxChart.txt and CodeTaxChart_self.txt depending on the SelfEmployed value
!      so after the text file is created we just copy the generated code from text file to Calc1.cod and Calc2.cod for
!      re-compling ProCalc for Palm and Pocket Pc.    MA 12/3/08
logcl           logcltype
lCount          long
lRecs           long
sWriteStr       string(255)
cFileName       cstring(255)
[END]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
    if records(NumQ) = 0
      return
    end
    if SelfEmployed
      sWriteStr = '!Generated code used by Handheld for Self-Employed persons'
      cFileName = '.\CodeTaxChartSelf.txt'
    else
      sWriteStr = '!Generated code used by Handheld for Employed persons'
      cFileName = '.\CodeTaxChart.txt'
    end
    !Create text file
    if logcl.Init(cFileName)
      message('Initializing text file failed.')
      return
    end
    logcl.suppressdatestamp=1
    logcl.writeline(clip(sWriteStr) & '    ' & format(Today(), @d2))
    lRecs = records(NumQ)
    loop lCount = 1 to lRecs
      get(NumQ, lCount)
      if lCount = lRecs
        logcl.writeline('    ElseIf Level >= ' & clip(left(format(NQ:ID, @n_11.2))))
      elsif lCount = 1
        logcl.writeline('    If Level >= '  & clip(left(format(NQ:ID, @n_11.2))) & ' And Level <= ' & clip(left(format(NQ:HiNum-0.01, @n_11.2))) & ' Then')
      else
        logcl.writeline('    ElseIf Level >= '  & clip(left(format(NQ:ID, @n_11.2))) & ' And Level <= ' & clip(left(format(NQ:HiNum-0.01, @n_11.2))) & ' Then')
      end
      logcl.writeline('      LoNum    = '    & clip(left(format(NQ:ID, @n_11.2))))
      logcl.writeline('      HiNum    = '    & clip(left(format(NQ:HiNum, @n_11.2))))
      logcl.writeline('      LONUMSS1 = ' & clip(left(format(NQ:LONUMSS1, @n_13.2))))
      logcl.writeline('      HINUMSS1 = ' & clip(left(format(NQ:HINUMSS1, @n_13.2))))
      logcl.writeline('      LONUMSS2 = ' & clip(left(format(NQ:LONUMSS2, @n_13.2))))
      logcl.writeline('      HINUMSS2 = ' & clip(left(format(NQ:HINUMSS2, @n_13.2))))
      logcl.writeline('      LONUMFED = ' & clip(left(format(NQ:LONUMFED, @n_13.2))))
      logcl.writeline('      HINUMFED = ' & clip(left(format(NQ:HINUMFED, @n_13.2))))
      if lCount = lRecs
        logcl.writeline('    End If')
      end
    end
    logcl.kill()
    if SelfEmployed
      message('The text file - CodeTaxChartSelf.txt has been created in current directory.')
    else
      message('The text file - CodeTaxChart.txt has been created in current directory.')
    end
[END]
[END]
