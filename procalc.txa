[EMBED]
EMBED %ControlPostEventHandling
[INSTANCES]
WHEN '?CloseButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[GROUP]
PRIORITY 4000
INSTANCE 1
[END]
[END]
WHEN '?MonthlyObligation'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
DO CalculateAmounts
[END]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?MonthlyObligation{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?CalculateButton'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
DO CalculateAmounts
[END]
[END]
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
CalculateAmounts   ROUTINE
    SemiMonthlyAmount = MonthlyObligation/2
    WeeklyAmount = (MonthlyObligation * 12)/52
    BiWeeklyAmount = WeeklyAmount * 2
    DISPLAY()
 
[END]
EMBED %DataSectionBeforeWindow
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
Licensecl            LicenseclType
!KeepWndTop           Wndposcltype
[END]
EMBED %PostWindowEventHandling
[INSTANCES]
WHEN 'OpenWindow'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!Keepwndtop.Topmost(0{PROP:Handle})
[END]
[END]
EMBED %ProcedureInitialize
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!Fogbugz case 10793, call SetGlobals() before checking license and if caller is cscjs then force to use ProCalc.chm as help
! file since the CSCJS does not have it's own help file (The registration PowerPack window has a help button) MA 12/11/06
SetGlobals(cmdline)
IF GLO:CALLER = eCallerIsCSCJS
  HELP('PROCALC.HLP')
  IF Licensecl.init('TX', 0, , eProCalcHelp)   !THE SECOND PARAMETER 1 MEANS SHOWING TREE AND 0 MEANS NO TREE
    DO PROCEDURERETURN
  END
ELSE
  IF Licensecl.init('TX',0)   !THE SECOND PARAMETER 1 MEANS SHOWING TREE AND 0 MEANS NO TREE
    DO PROCEDURERETURN
  END
END
IF Licensecl.CheckLicense('Procalc.dll')  !CHECK THE LICENSE FOR ADDIN BEING STARTED
  Licensecl.Kill()
  DO PROCEDURERETURN
END
Licensecl.Kill()

HELP('PROCALC.HLP')
!SetGlobals(cmdline)    !FOR EXE VERSION DON'T NEED TO CALL SETGLOBALS PROCEDURE  6/27/01

[END]
EMBED %WindowEventHandling
[INSTANCES]
WHEN 'OpenWindow'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
glo:BreakDownObligationThread=Thread()
[END]
[END]
EMBED %AfterWindowClosing
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
clear(glo:BreakDownObligationThread)
[END]
EMBED %AfterWindowOpening
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 1000
PROPERTY:END
IF GLO:CALLER = eCallerIsProDoc
  WINDOW{PROP:Icon} = '~PROWIN.ICO'
ELSE
  WINDOW{PROP:Icon} = '~PROCALC.ICO'
END
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 2
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[ADDITION]
NAME Clarion CloseCurrentWindow
[INSTANCE]
INSTANCE 1
[WINDOW]
window  WINDOW('Calculate Semi-monthly, Biweekly and Weekly Amounts'),AT(,,357,152),FONT('MS Sans Serif', |
          8,,FONT:regular,CHARSET:ANSI),DOUBLE,CENTER,ICON('prowin.ico'),GRAY,MDI
          SHEET,AT(5,5,347,116),USE(?Sheet1),WIZARD,#ORIG(?Sheet1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1)
              STRING('Some Child Support Calculator users asked to be able to calculate' & |
                ' semi-monthly, bi-weekly and weekly'),AT(12,12),USE(?String1),#ORIG(?String1)
              STRING('support amounts when they are given a monthly obligation amount. ' & |
                'That is the purpose of this window. '),AT(12,23),USE(?String2),#ORIG(?String2)
              STRING('Simply enter the amount of the monthly obligation and then click on "C'), |
                AT(12,33),USE(?String3),#ORIG(?String3)
              STRING('a'),AT(232,33),USE(?String10),FONT(,,,FONT:underline),#ORIG(?String10)
              STRING('lculate" or just press your tab key.'),AT(236,33),USE(?String11),#ORIG(?String11)
              PROMPT('&Monthly support obligation amount:'),AT(46,55),USE(?Prompt1),#ORIG(?Prompt1)
              ENTRY(@n-11.2),AT(161,53,60,12),USE(MonthlyObligation),#ORIG(MonthlyObligation)
              BUTTON('C&alculate'),AT(225,50,60,17),USE(?CalculateButton),LEFT,ICON('Calc.ico'), |
                #ORIG(?Button1)
              STRING('Semi-monthly'),AT(85,85),USE(?String4),FONT(,,,FONT:bold+FONT:underline), |
                #ORIG(?String4)
              STRING(@n$11.2),AT(83,97),USE(SemiMonthlyAmount),RIGHT,#ORIG(?String7)
              STRING('Weekly'),AT(177,85),USE(?String5),FONT(,,,FONT:bold+FONT:underline), |
                #ORIG(?String5)
              STRING(@n$11.2),AT(161,97),USE(WeeklyAmount),RIGHT,#ORIG(?String8)
              STRING('Biweekly'),AT(242,85),USE(?String6),FONT(,,,FONT:bold+FONT:underline), |
                #ORIG(?String6)
              STRING(@n$11.2),AT(231,97),USE(BiWeeklyAmount),RIGHT,#ORIG(?String9)
            END
          END
          BUTTON('&Close'),AT(157,129,50,14),USE(?CloseButton),LEFT,ICON('5exit.ico'),#ORIG(?Button2)
        END

[END]
