[EMBED]
EMBED %HandCodeEventOpnWin
[DEFINITION]
[GROUP]
PRIORITY 4000
INSTANCE 1
[END]
EMBED %EndOfReportGeneration
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
PRINT(RPT:SummaryDetail)
[END]
EMBED %ProcedureSetup
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
CASE PAR:FREQUENCY
OF 'A'
  LOC:FREQUENCY = 'Monthly'
OF 'B'
  LOC:FREQUENCY = 'Semi-Monthly'
OF 'C'
  LOC:FREQUENCY = 'Weekly'
OF 'D'
  LOC:FREQUENCY = 'Biweekly'
END

LOC:TotalNoPayments = 0
LOOP I# = 1 TO RECORDS(QAMORTIZE)
  GET(QAMORTIZE,I#)
  IF ERRORCODE() THEN BREAK.
  LOC:TotalNoPayments += 1
  LOC:TotalToInterest += QAM:AppliedInterest
END

!Ma - Fogbugz case 12732, if QAmortize is empty then clear total paid 12/5/07
if LOC:TotalNoPayments = 0
  LOC:TOTALPAID = 0
else
!   @Parth - FB28903 REVIEW: Discussion
!    LOC:TOTALPAID = LOC:TotalToInterest + GLO:TotalObligations
  LOC:TOTALPAID = LOC:TotalToInterest + GLO:Totals:TotalObligations
!   @Parth 
end
GET(QAMORTIZE,1)
IF ~ERRORCODE()
  LOC:PaymentAmount = QAM:PaymentAmount
END

GET(QAMORTIZE,RECORDS(QAMORTIZE))
IF ~ ERRORCODE()
  LOC:DateLastPayment = QAM:PaymentDate
  LOC:AmountLastPayment = QAM:PaymentAmount
END
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 2
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[ADDITION]
NAME CPCSRpts PrintFromQueue
[INSTANCE]
INSTANCE 1
[PROMPTS]
%AllowFileAccess LONG  (0)
%UsingCPCSBreaks LONG  (0)
%InputQueue FIELD  (QAmortize)
%ProcessSeq DEFAULT  ('Ascending')
%DetailBandHandCode MULTI DEFAULT  ()
%AutoPrintDetail LONG  (1)
%DetailBandName DEFAULT  ('detail1')
%PFQcontinue LONG  (0)
%PrintingDeferred LONG  (0)
[REPORT]
report  REPORT('ArrearageAmort'),AT(500,2260,7000,8000),PRE(RPT),PAPER(PAPER:LETTER),FONT('Arial', |
          10,,FONT:regular),THOUS
          HEADER,AT(500,500,7677,1760),#ORDINAL(1)
            STRING('Page:'),AT(5365,594),USE(?String40),#ORDINAL(2)
            STRING(@n-4),AT(5760,594),USE(?ReportPageNo),PAGENO,#ORDINAL(3)
            STRING(@n6.2),AT(1750,813),USE(GLO:IntRate),RIGHT,TRN,#ORIG(?String35),#ORDINAL(4)
            STRING('Interest rate: {12}% simple interest from'),AT(1000,813),USE(?String127), |
              TRN,#ORIG(?String127),#ORDINAL(5)
            STRING(@d1),AT(3646,813),USE(GLO:CalcDate,,?GLO:CalcDate:2),TRN,#ORIG(?String34), |
              #ORDINAL(6)
            STRING('Amount of payments:'),AT(479,1021),USE(?String28),TRN,#ORIG(?String28), |
              #ORDINAL(7)
            STRING(@n$8.2),AT(1917,1042),USE(LOC:PaymentAmount),LEFT,TRN,#ORIG(?String32), |
              #ORDINAL(8)
            STRING('Payment frequency:'),AT(542,1302),USE(?String29),TRN,#ORIG(?String29), |
              #ORDINAL(9)
            STRING(@s20),AT(1917,1313),USE(LOC:Frequency),LEFT,#ORIG(LOC:Frequency),#ORDINAL(10)
            STRING('Total obligation:'),AT(813,573),USE(?String126),TRN,#ORIG(?String126), |
              #ORDINAL(11)
            STRING(@n$11.2),AT(1885,583),USE(GLO:Totals:TotalObligations),LEFT,#ORIG(GLO:Totals:TotalObligations), |
              #ORDINAL(12)
            STRING('Payment date'),AT(521,1563),USE(?String119),FONT(,,,FONT:underline),TRN, |
              #ORIG(?String119),#ORDINAL(13)
            STRING('Amount'),AT(1656,1563),USE(?String120),FONT(,,,FONT:underline),TRN,#ORIG(?String120), |
              #ORDINAL(14)
            STRING('Applied to Interest'),AT(2333,1563),USE(?String121),FONT(,,,FONT:underline), |
              TRN,#ORIG(?String121),#ORDINAL(15)
            STRING('Applied to Principal'),AT(3594,1563),USE(?String122),FONT(,,,FONT:underline), |
              TRN,#ORIG(?String122),#ORDINAL(16)
            STRING('New Principal Balance'),AT(5010,1563),USE(?String123),FONT(,,,FONT:underline), |
              TRN,#ORIG(?String123),#ORDINAL(17)
            STRING('CHILD SUPPORT ARREARAGE AMORTIZATION SCHEDULE'),AT(1042,52),USE(?String59), |
              FONT('Arial',14,,FONT:bold),#ORDINAL(18)
            STRING('Date:'),AT(5396,396),USE(?String60),#ORDINAL(19)
            STRING(@d1),AT(5760,396),USE(GLO:CalcDate),#ORDINAL(20)
          END
detail1   DETAIL,AT(31,,7646,260),#ORDINAL(21)
            STRING(@d1),AT(510,52),USE(QAM:PaymentDate),RIGHT(1),#ORIG(QAM:PaymentDate),#ORDINAL(22)
            STRING(@n9.2),AT(3552,52),USE(QAM:AppliedPrincipal),DECIMAL(12),#ORIG(QAM:AppliedPrincipal), |
              #ORDINAL(23)
            STRING(@n11.2),AT(4979,63),USE(QAM:NewBalance),DECIMAL(12),#ORIG(QAM:NewBalance), |
              #ORDINAL(24)
            STRING(@n9.2),AT(2167,31),USE(QAM:AppliedInterest),DECIMAL(12),#ORIG(QAM:AppliedInterest), |
              #ORDINAL(25)
            STRING(@N9.2),AT(1208,31),USE(QAM:PaymentAmount),DECIMAL(12),#ORIG(QAM:PaymentAmount), |
              #ORDINAL(26)
            LINE,AT(115,260,6781,0),USE(?Line2),COLOR(COLOR:Black),#ORDINAL(27)
          END
SummaryDetail DETAIL,AT(490,10,7188,7615),ALONE,#ORDINAL(28)
            STRING('Summary Page'),AT(2531,10),USE(?String2),FONT('Arial',14,,FONT:bold),#ORDINAL(29)
            STRING('Total # of payments:'),AT(427,583),USE(?String124),FONT(,12),TRN,#ORIG(?String124), |
              #ORDINAL(30)
            STRING(@n4),AT(2531,604),USE(LOC:TotalNoPayments),RIGHT,TRN,#ORIG(?String32),#ORDINAL(31)
            STRING('Total amount paid:'),AT(542,917),USE(?String125),FONT(,12),TRN,#ORIG(?String125), |
              #ORDINAL(32)
            STRING(@n$11.2),AT(2063,938),USE(LOC:TOTALPAID),RIGHT,TRN,#ORIG(?String32),#ORDINAL(33)
            STRING('Total applied to interest:'),AT(146,1250),USE(?String17),FONT(,12),#ORDINAL(34)
            STRING(@n$11.2),AT(2063,1271),USE(LOC:TotalToInterest),RIGHT,TRN,#ORIG(?String32), |
              #ORDINAL(35)
            STRING('Date of last payment:'),AT(354,1583),USE(?String30),FONT(,12),TRN,#ORIG(?String30), |
              #ORDINAL(36)
            STRING(@d1),AT(2323,1615),USE(LOC:DateLastPayment),RIGHT,TRN,#ORIG(?String32), |
              #ORDINAL(37)
            STRING('Amount of last payment:'),AT(156,1938),USE(?String31),FONT(,12),TRN,#ORIG(?String31), |
              #ORDINAL(38)
            STRING(@n$11.2),AT(2063,1938),USE(LOC:AmountLastPayment),RIGHT,TRN,#ORIG(?String33), |
              #ORDINAL(39)
          END
        END

