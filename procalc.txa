!@Parth - FB28903 ExportFinishOutFAMAfterSep1TotalsChild    ROUTINE
ExportFinishOutFAMAfterSep1TotalsChild    ROUTINE
  
!  If KCOUNTERChild = 0 THEN EXIT.
  CLEAR(ANS:INDEXES)
  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:TotalRemaining,@N-13.2))
  ANS:OBJ_ID      = 'PX220'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:ConfirmedPrincipalBalance,@N-13.2))
  ANS:OBJ_ID      = 'PX221'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:ConfirmedInterestBalance,@N-13.2))
  ANS:OBJ_ID      = 'PX222'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:UnconfirmedPrincipalBalance,@N-13.2))
  ANS:OBJ_ID      = 'PX223'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:UnconfirmedInterestBalance,@N-13.2))
  ANS:OBJ_ID      = 'PX224'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  !MA ADDED FOLLOWING NEW TOKENS TO BE SAVED   6/27/01
  ANS:ANSWER      = LEFT(FORMAT(ATTChild:Attyfeescosts,@N-13.2))
  ANS:OBJ_ID      = 'PX228'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:AttyfeescostsBalance,@N-13.2))
  ANS:OBJ_ID      = 'PX229'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(ATTChild:InterestRate,@N6.2))
  ANS:OBJ_ID      = 'PX231'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = ATTChild:InterestType
  ANS:OBJ_ID      = 'PX232'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:AttyfeescostsIntBalance,@N-13.2))
  ANS:OBJ_ID      = 'PX233'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:PayAttyfeescosts,@N-13.2))
  ANS:OBJ_ID      = 'PX234'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:PayAttyfeescostsInt,@N-13.2))
  ANS:OBJ_ID      = 'PX235'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(NAMChild:ConfirmedInterestRate,@N6.2))
  ANS:OBJ_ID      = 'PX236'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = NAMChild:InterestType
  ANS:OBJ_ID      = 'PX237'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(NAMChild:ConfirmedPrincipal,@N-13.2))
  ANS:OBJ_ID      = 'PX238'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(NAMChild:ConfirmedDate,@D01))
  ANS:OBJ_ID      = 'PX239'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  IF EXTDebitChild:DebitDate
    ANS:ANSWER      = LEFT(FORMAT(EXTDebitChild:DebitDate,@D01))
  ELSE
    ANS:ANSWER      =''
  END
  ANS:OBJ_ID      = 'PX240'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(EXTDebitChild:DebitUobl,@N-11.2))
  ANS:OBJ_ID      = 'PX241'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(EXTDebitChild:DebitUint,@N-11.2))
  ANS:OBJ_ID      = 'PX242'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(EXTDebitChild:DebitCobl,@N-11.2))
  ANS:OBJ_ID      = 'PX243'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(EXTDebitChild:DebitCint,@N-11.2))
  ANS:OBJ_ID      = 'PX244'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:PayConfirmedO,@N-11.2))
  ANS:OBJ_ID      = 'PX245'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:PayUnconfirmedO,@N-11.2))
  ANS:OBJ_ID      = 'PX246'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:PayConfirmedI,@N-11.2))
  ANS:OBJ_ID      = 'PX247'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(GLO:TotalsChild:PayUnconfirmedI,@N-11.2))
  ANS:OBJ_ID      = 'PX248'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)
  
! GLO:CalcDate does not need to be C M D 
  ANS:ANSWER      = LEFT(FORMAT(GLO:CalcDate,@D2))
  ANS:OBJ_ID      = 'PX215'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)
!@Parth
  
  !This gets the first reportqueue
  ! record which is an obligation
  LOOP QCOUNTER = 1 TO MaxLoop                    !Loop 1 less than # of records because
                                                  ! processpayments tacked an extra one
                                                  ! at the end for calculating interest
    GET(ReportQueue,QCounter)
    IF ERRORCODE() THEN BREAK.
    IF CLIP(UPPER(RPQ:ObligationType)) <> 'CHILD' THEN CYCLE.
    IF RPQ:Type = 'O' AND RPQ:AmountO > 0 
      ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountO,@N-11.2))
      ANS:OBJ_ID      = 'PX225'     !AMOUNT OF FIRST OBLIGATION
      ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
      ADD(ANSWERS)

      ANS:ANSWER      = LEFT(FORMAT(RPQ:Date,@D4))
      ANS:OBJ_ID      = 'PX226'     !DATE OF FIRST OBLIGATION
      ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
      ADD(ANSWERS)

      BREAK
    END
  END

  !Loop backwards through reportqueue
  ! looking for the last obligation
  LOOP QCOUNTER = MaxLoop TO 1 BY -1
    GET(ReportQueue,QCounter)
    IF ERRORCODE() THEN BREAK.
    IF CLIP(UPPER(RPQ:ObligationType)) <> 'CHILD' THEN CYCLE.
    IF RPQ:Type = 'O' AND RPQ:AmountO > 0
      ANS:ANSWER      = LEFT(FORMAT(RPQ:Date,@D4))
      ANS:OBJ_ID      = 'PX227'    !DATE OF LAST OBLIGATION
      ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
      ADD(ANSWERS)
      BREAK
    END
  END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
