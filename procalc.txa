[WINDOW]
window  WINDOW('Enter A Range Of Payments'),AT(,,347,188),FONT('MS Sans Serif',8,,FONT:regular), |
          DOUBLE,CENTER,GRAY,HLP('~Range_Insert_Form')
          SHEET,AT(8,4,331,158),USE(?Sheet1),WIZARD,#ORIG(?Sheet1),#ORDINAL(1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1),#ORDINAL(2)
              GROUP('&Inclusive Dates'),AT(14,13,99,57),USE(?Group1),BOXED,#ORIG(?Group1), |
                #ORDINAL(3)
                STRING('(mm/dd/yyyy)'),AT(44,24),USE(?String3),#ORIG(?String3),#ORDINAL(4)
                PROMPT('&From:'),AT(19,37),USE(?Prompt5),#ORIG(?Prompt5),#ORDINAL(5)
                ENTRY(@D2<50B),AT(44,35,45,12),USE(FromDate),#ORIG(FromDate),#ORDINAL(6)
                BUTTON,AT(92,33,15,14),USE(?Calendar),ICON('smcal.ico'),FLAT,SKIP,#ORIG(?Calendar), |
                  #SEQ(3),#ORDINAL(7)
                PROMPT('&To:'),AT(19,53),USE(?Prompt6),#ORIG(?Prompt6),#ORDINAL(8)
                ENTRY(@d2<50B),AT(44,51,45,12),USE(ToDate),REQ,#ORIG(ToDate),#ORDINAL(9)
                BUTTON,AT(92,50,15,14),USE(?Calendar:2),ICON('smcal.ico'),FLAT,SKIP,#ORIG(?Calendar), |
                  #SEQ(4),#ORDINAL(10)
              END
              OPTION('&Payment Options'),AT(119,13,214,58),USE(PaymentOption),BOXED,#ORIG(Option1), |
                #ORDINAL(11)
                RADIO('Monthly'),AT(129,42),USE(?Option1:Monthly),VALUE('A'),#ORIG(?Option1:Radio1), |
                  #ORDINAL(12)
                RADIO('Semi-monthly'),AT(173,42),USE(?Option1:semimonthly),VALUE('B'),#ORIG(?Option1:Radio2), |
                  #ORDINAL(13)
                RADIO('Weekly'),AT(233,42),USE(?Option1:weekly),VALUE('C'),#ORIG(?Option1:Radio3), |
                  #ORDINAL(14)
                RADIO('Bi-weekly'),AT(281,42),USE(?Option1:biweekly),VALUE('D'),#ORIG(?Option1:Radio4), |
                  #ORDINAL(15)
              END
              PROMPT('&Amount of each payment:'),AT(58,79),USE(?Prompt1),#ORIG(?Prompt1),#ORDINAL(16)
              ENTRY(@n-10.2),AT(195,77,49,12),USE(PaymentAmount),#ORIG(ObligationAmount),#ORDINAL(17)
              PROMPT('&Day of month first payment was made:'),AT(58,96),USE(?PromptFirstDay), |
                #ORIG(?Prompt2),#ORDINAL(18)
              SPIN(@n3),AT(195,94,25,12),USE(FirstDay),RANGE(1,28),STEP(1),REQ,#ORIG(?Spin1), |
                #ORDINAL(19)
              CHECK('&Last day of the month'),AT(225,95,,11),USE(MonthlyLastDay),VALUE('1', |
                '0'),#ORIG(MonthlyLastDay),#ORDINAL(20)
              PROMPT('Day of &month second payment was made:'),AT(58,115),USE(?PromptSecondDay), |
                DISABLE,#ORIG(?Prompt4),#ORDINAL(21)
              SPIN(@n3),AT(195,113,25,12),USE(SecondDay),DISABLE,RANGE(1,30),STEP(1),#ORIG(?Spin2), |
                #ORDINAL(22)
              CHECK('La&st day of the month'),AT(225,114),USE(SemiMonthlyLastDay),DISABLE, |
                VALUE('1','0'),#ORIG(SemiMonthlyLastDay),#ORDINAL(23)
              PROMPT('Day of &week payments were made:'),AT(58,133),USE(?PromptDayOfWeek), |
                DISABLE,#ORIG(?Prompt3),#ORDINAL(24)
              LIST,AT(195,131,61,12),USE(DayOfWeek),VSCROLL,DISABLE,DROP(7),FORMAT('36L@s9@'), |
                FROM('Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday'),#FIELDS(DayOfWeek), |
                #ORIG(?List1),#ORDINAL(25)
            END
          END
          BUTTON('&OK'),AT(236,169,50,15),USE(?OkButton),LEFT,ICON('ok.ico'),DEFAULT,#ORDINAL(26)
          BUTTON('&Cancel'),AT(289,169,50,15),USE(?CancelButton),LEFT,ICON('cancel.ico'),#ORDINAL(27)
          BUTTON('&Help'),AT(8,169,50,15),USE(?Help),LEFT,ICON(ICON:Help),STD(STD:Help),#ORIG(?Button3), |
            #ORDINAL(28)
        END

[END]
