ExplainDetail         DETAIL,AT(0,10,7000,11896),USE(?DETAIL2)
                        STRING('HOW THE DELINQUENT SUPPORT CALCULATOR CALCULATES CHILD SUPPORT'), |
                          AT(94,10),USE(?String72),FONT('Arial',11,COLOR:Black,FONT:bold)
                        STRING('ARREARAGES'),AT(94,187),USE(?String247),FONT('Arial',11, |
                          COLOR:Black,FONT:bold)
                        STRING('Subchapter F of Chapter 157 of the Texas Family Code details' & |
                          ' how delinquent {{supporttype} support'),AT(208,437,6021,208), |
                          USE(?String73)
                        STRING(' obligations are to be calculated. The Delinquent Support Ca' & |
                          'lculator follows those procedures for calculating'),AT(167,604), |
                          USE(?String74)
                        STRING('interest due and applying payments to current obligations, a' & |
                          'ccrued interest, and delinquent obligations.*'),AT(208,760), |
                          USE(?String75)
                        STRING('INTEREST CALCULATIONS:'),AT(177,1250),USE(?String76), |
                          FONT(,,COLOR:Black,FONT:bold)
                        STRING('(Section 157.265 and 157.266)'),AT(2083,1240),USE(?String83)
                        STRING('(1)  No interest is charged on unconfirmed obligations prior' & |
                          ' to September 1, 1991.**'),AT(344,1500),USE(?String77)
                        STRING('(2)  Interest begins accruing once the obligation becomes de' & |
                          'linquent.'),AT(344,1708),USE(?String78)
                        STRING('(3)  An obligation becomes delinquent if it is not paid by t' & |
                          'he 31st day after it is due.'),AT(344,1917),USE(?String135),TRN
                        STRING('(4)  For obligations due on or after January 1, 2000, only t' & |
                          'he portion of delinquent {{supporttype} support'),AT(344,2135), |
                          USE(?String137),TRN
                        STRING('that is greater than the amount of one monthly periodic supp' & |
                          'ort obligation accrues interest.'),AT(583,2323),USE(?String141), |
                          TRN
                        STRING('(6)  Interest on unconfirmed arrearages that accrues on or a' & |
                          'fter January 1,2002 is calculated at'),AT(344,2875,6542,208), |
                          USE(?String79),TRN
                        STRING('(5)  Interest on unconfirmed arrearages that accrues between' & |
                          ' September 1, 1991 and '),AT(344,2521,6542,208),USE(?String79:2)
                        STRING('6% SIMPLE INTEREST.'),AT(573,3052,6313,208),USE(?String142:2),TRN
                        STRING('December 31, 2001 is calculated at 12% SIMPLE INTEREST.'), |
                          AT(573,2698,6313,208),USE(?String142),TRN
                        STRING('(7)  Interest on confirmed arrearages is calculated at the r' & |
                          'ate and as either simple or compound'),AT(344,3240), |
                          USE(?String80)
                        STRING('both as specified by the user.'),AT(583,3427),USE(?String81)
                        STRING('APPLICATION OF PAYMENTS MADE BEFORE January 1, 2010:'), |
                          AT(208,3802),USE(?String82),FONT(,,COLOR:Black,FONT:bold)
                        STRING('(Section 157.268)'),AT(4385,3802),USE(?String84)
                        STRING('Payments received are applied in the following order:'), |
                          AT(219,3990),USE(?String85)
                        STRING('(1)  Current {{supporttype} support;'),AT(323,4167),USE(?String86)
                        STRING('(2)  Non-delinquent {{supporttype} support owed;'),AT(323,4375), |
                          USE(?String87)
                        STRING('(3)  Interest on unconfirmed and confirmed obligations;'), |
                          AT(323,4583),USE(?String88)
                        STRING('(4)  Principal amount of unconfirmed obligations;'),AT(323,4792), |
                          USE(?String89)
                        STRING('(5)  Principal amount of confirmed obligations; and'),AT(323,4990), |
                          USE(?String90)
                        STRING('(6)  Attorney''s fees or costs, or Title IV-D service fees a' & |
                          'uthorized under Section 231.103 for which'),AT(323,5198), |
                          USE(?String139),TRN
                        STRING('the obligor is responsible.'),AT(552,5385),USE(?String147),TRN
                        STRING('APPLICATION OF PAYMENTS MADE ON OR AFTER January 1, 2010:'), |
                          AT(208,5750),USE(?String282),FONT(,,COLOR:Black,FONT:bold)
                        STRING('(Section 157.268)'),AT(4760,5750),USE(?String284)
                        STRING('Payments received are applied in the following order:'), |
                          AT(219,5937),USE(?String285)
                        STRING('(1)  Current {{supporttype} support;'),AT(323,6115), |
                          USE(?String286)
                        STRING('(2)  Non-delinquent {{supporttype} support owed;'),AT(323,6323), |
                          USE(?String287)
                        STRING('(3)  Principal amount of unconfirmed obligations;'),AT(323,6531), |
                          USE(?String289)
                        STRING('(4)  Principal amount of confirmed obligations;'),AT(323,6740), |
                          USE(?String290)
                        STRING('(5)  Interest on unconfirmed and confirmed obligations; and'), |
                          AT(323,6937),USE(?String288)
                        STRING('(6)  Attorney''s fees or costs, or Title IV-D service fees a' & |
                          'uthorized under Section 231.103 for which'),AT(323,7146), |
                          USE(?String239),TRN
                        STRING('the obligor is responsible.'),AT(552,7333),USE(?String247:2),TRN
                        STRING('APPLICATION OF PAYMENTS MADE ON JUDGMENTS RENDERED ON OR AFT' & |
                          'ER September 1,'),AT(208,7708),USE(?String240),FONT(,, |
                          COLOR:Black,FONT:bold)
                        STRING('2021:'),AT(208,7896),USE(?String240:2),FONT(,,COLOR:Black, |
                          FONT:bold)
                        STRING('(42 U.S.C. Section 657)'),AT(625,7896),USE(?String241)
                        STRING('Payments received are applied per Texas Family Code 157.268 ' & |
                          'above.  Payments received are'),AT(219,8073),USE(?String242)
                        STRING('allocated at each level of prority in the following order:'), |
                          AT(219,8250),USE(?String243)
                        STRING('(1)  Child support;'),AT(323,8427),USE(?String244)
                        STRING('(2)  Medical support;'),AT(323,8635),USE(?String245)
                        STRING('(3)  Dental support;'),AT(323,8844),USE(?String246),TRN
                        STRING('*SPECIAL NOTE ABOUT DEBITS'),AT(208,9219),USE(?String110), |
                          FONT(,,COLOR:Black,FONT:bold)
                        STRING('This special feature allows you to accommodate the rare occa' & |
                          'sion when an obligor overpaid and then'),AT(375,9406), |
                          USE(?String111)
                        STRING('some amount is refunded.  This will allow you to credit the ' & |
                          'amount back in whatever manner is'),AT(375,9594),USE(?String112)
                        STRING('appropriate.  There is no statutory guideline or provision f' & |
                          'or this.  The most common situation'),AT(375,9781), |
                          USE(?String113)
                        STRING('would be when the Attorney General garnishes a tax refund an' & |
                          'd applies that to delinquent {{supporttype}'),AT(375,9969), |
                          USE(?String114)
                        STRING('support.  Then, several months later, the overpayment is rec' & |
                          'ognized and a refund is sent to the'),AT(375,10156), |
                          USE(?String115)
                        STRING('obligor.  At that point, the amount of the refund would need' & |
                          ' to be debited.  You may not want to'),AT(375,10344), |
                          USE(?String116)
                        STRING('simply reduce the original payment because then obligor migh' & |
                          't be charged interest for that period.'),AT(375,10531), |
                          USE(?String117)
                        STRING('**SPECIAL NOTE ABOUT INTEREST ON UNCONFIRMED AMOUNTS'), |
                          AT(208,10865),USE(?String95),FONT(,,COLOR:Black,FONT:bold)
                        STRING('Interest on unconfirmed obligations was first authorized in ' & |
                          '1991 in Section 14.34 of the Family'),AT(375,11062), |
                          USE(?String96)
                        STRING('Code (HB 769).  The legislation explicitly stated that it on' & |
                          'ly applied to obligations due and'),AT(375,11271),USE(?String97)
                        STRING('owing after the effective date of the act (September 1, 1991' & |
                          '). Prior to September 1, 1991, interest'),AT(375,11469), |
                          USE(?String98)
                        STRING('on unconfirmed amounts was provided for at common law as a m' & |
                          'atter of right and is not calculated '),AT(375,11667), |
                          USE(?String145),TRN
                        STRING('Arrearages are calculated for obligations for child support,' & |
                          ' medical support and dental support.'),AT(208,917,6937,198), |
                          USE(?String75:3)
                      END
ExplainDetail2        DETAIL,AT(0,0,7000,2219),USE(?DETAIL3),PAGEAFTER(-1)
                        STRING('by the Delinquency Support Calculator. In 1993, HB 758 amend' & |
                          'ed Sec. 14.34 by increasing the'),AT(385,10),USE(?String146),TRN
                        STRING('interest rate to 12% simple interest. It also requires calcu' & |
                          'lation of interest from the day it becomes'),AT(385,219), |
                          USE(?String99)
                        STRING('delinquent instead of from the date it accrues. HB 758 provi' & |
                          'ded that it applies to any accrued arrears'),AT(385,427), |
                          USE(?String100)
                        STRING('that were owed on or after September 1, 1991. In 1995, Secti' & |
                          'on 14.34 was moved to Section 157.265'),AT(385,635), |
                          USE(?String101)
                        STRING('in the new Texas Family Code. Section 157.265 was amended by' & |
                          ' 1999 legislation, adding the '),AT(385,854),USE(?String102)
                        STRING('provision that only the portion of delinquent {{supporttype}' & |
                          ' support exceeding one month''s obligation is'),AT(385,1063), |
                          USE(?String125),TRN
                        STRING('subject to interest. It was amended again in 2001 by SB 776,' & |
                          ' reducing the interest rate from 12%'),AT(385,1271), |
                          USE(?String127),TRN
                        STRING('to 6% for interest accruing on or after January 1, 2002.  Se' & |
                          'e In Re A.R.J., 2003 WL 187430,'),AT(385,1469,5677,208), |
                          USE(?String132),TRN
                        STRING('(Tex.App. - Dallas January 29, 2003)(No. 05-02-01033-CV).   ' & |
                          'NOTE:  Any interest calculations on'),AT(385,1677,6333,208), |
                          USE(?String143),TRN
                        STRING('unconfirmed amounts due prior to September 1, 1991 must be d' & |
                          'one manually.'),AT(385,1896),USE(?String144),TRN
                      END
                    END


