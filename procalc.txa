EMBED %AfterWindowOpening
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 1000
PROPERTY:END
sVersionNum = GetDllInternalName()

!Extract the year from sVersionNum to be used elsewhere.
x# = instring('.', sVersionNum, 1, 1)
y# = instring('.', sVersionNum, 1, x# + 1)
if x# and y#
  sVersionYear = sVersionNum[x# + 1 : y# - 1]
end

!Expecting a periods between the year
assert(len(clip(sVersionYear)) = 4, 'Extracting year from "Internal Name" resource failed.')



IF GLO:CALLER <> eCallerIsCSCJS
  !Ma - Fogbugz case 10891, do following only if glo:nocase = false 4/12/07
  if ~glo:nocase
  LOCALCL.GetCaseDesc()
  LOCALCL.GetContactName()
  0{PROP:TEXT} = CLIP(0{PROP:TEXT}) & ' ' & sVersionNum & CHOOSE(sFullName = '','',' - ') & CLIP(sFullName) & |
                 CHOOSE(sCaseDesc = '','',' - Case: ') & sCaseDesc
END
END
IF GLO:CALLER = eCallerIsProDoc
  WINDOW{PROP:Icon} = '~PROWIN.ICO'
ELSE
  WINDOW{PROP:Icon} = '~PROCALC.ICO'
END
[END]
EMBED %LocalProcedures
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
LOCALCL.GetCaseDesc     PROCEDURE()!,STRING
  CODE
  sCaseDesc = ''
  CAS:CAS_ID = GLO:CAS_ID
  SET(CAS:kCAS_ID, CAS:kCAS_ID )
  NEXT(Cases)
  IF ~ERRORCODE() AND CAS:CAS_ID = GLO:CAS_ID
    IF GLO:CON_ID = 0
      GLO:CON_ID = CAS:CON_ID
    END
    sCaseDesc = CAS:Description
  END
  RETURN


LOCALCL.GetContactName   PROCEDURE()!,STRING
  CODE
  sFullName = ''
  IF GLO:CON_ID > 0
    clear(contacts)
    CON:CON_ID = GLO:CON_ID
    SET(CON:kCON_ID,CON:kCON_ID)
    NEXT(Contacts)
    IF ~ERRORCODE() AND CON:CON_ID = GLO:CON_ID
      sFullName = CON:L_NAME
      IF ~CON:IsBusiness
        IF CON:L_NAME AND (CON:F_NAME OR CON:M_NAME)
          sFullName = CLIP(sFullName) & ','
        END
        IF CON:F_NAME
          sFullName = CLIP(sFullName) & CHOOSE(sFullName = '', '', ' ') & CON:F_NAME
        END
        IF CON:M_NAME
          sFullName = CLIP(sFullName) & CHOOSE(sFullName = '', '', ' ') & CON:M_NAME
        END
        IF LEN(CLIP(CON:M_NAME)) = 1
          sFullName = CLIP(sFullName) & '.'
        END
      END
    END
  END
  RETURN

LOCALCL.AskCanceling     PROCEDURE()!,byte
bRetVal     BYTE(TRUE)
CODE
  DebugCL.Send('1')
  IF ~GLO:NOCASE AND ~LOC:OKBUTTON AND ~bAskedCanceling
    DebugCL.Send('2')
    IF window{PROP:ICONIZE}=TRUE
      DebugCL.Send('3')
      window{PROP:ICONIZE}=FALSE
      DebugCL.Send('4')
    END
    DebugCL.Send('5')
    CASE MESSAGE('Canceling will cause you to lose any information you have|entered since '|
               & 'the last save. Do you still want to Cancel?','Caution',|
                  ICON:EXCLAMATION,BUTTON:YES+BUTTON:NO,BUTTON:NO)
    OF BUTTON:NO
      DebugCL.Send('6')
      bRetVal = FALSE
      DebugCL.Send('7')
    OF BUTTON:YES
      DebugCL.Send('8')
      bAskedCanceling = TRUE
      DebugCL.Send('9')
    END
    DebugCL.Send('10')
  END
  DebugCL.Send('bRetVal: ' & bRetVal)
  RETURN bRetVal
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
LocateNumQ procedure(*DECIMAL plId)

lLowerLimit    long
lUpperLimit    long
lMiddleRec    long
lRecsToSearch  long
lLoopCount     long

  code
    lLowerLimit = 1
    lUpperLimit = records(NUMQ)

    loop lLoopCount = 1 to 10
      lRecsToSearch = (lUpperLimit - lLowerLimit)

      if lRecsToSearch < 2
        !Close enough. Now interate.
        loop lMiddleRec = lLowerLimit to lUpperLimit
          get(NumQ , lMiddleRec)
          if NQ:ID <= plId and NQ:HiNum > plId
            return
          end
        end
      else
        lMiddleRec = ((lRecsToSearch + 1) / 2) + lLowerLimit - 1
      end

      get(NumQ , lMiddleRec)
      if NQ:ID <= plId and NQ:HiNum > plId
        return
      end

      if NQ:ID < plId
        lLowerLimit = lMiddleRec + 1
      else
        lUpperLimit = lMiddleRec - 1
      end
    end

    !If not found within 10 interations then something is very wrong.
    !Should find record within 6 interations.
?   assert(0, 'plId is out of range')

    return


[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
GetDllInternalName procedure() !,string

  pragma('link(ver%S%.lib)')

DllName          equate('procalc.dll')

pathcl           pathcltype
VerCl            class(VerClType),implements(IVerCallBack)
InternalName       cstring(10)
                 end

TempFullDllPath  CSTRING(FilepathMax + 1)
TempDllPath      like(TempFullDllPath)

szRetVal         cstring(40)

  code

    JUNK# = GetModuleFileName(SYSTEM{PROP:AppInstance},address(TempFullDllPath),SIZE(TempFullDllPath))
    pathcl.getPath(TempFullDllPath, TempDllPath)
    TempFullDllPath = TempDllPath & DllName

    verCl.init()
    verCl.setCallback(address(verCl.IVerCallBack))
    IF verCl.ReadVersionResource(TempFullDllPath) = 0 !level:benign

      szRetVal = clip(VerCl.InternalName)

    END
    VerCl.kill()

    return szRetVal


VerCl.IVerCallback.SaveResultcb procedure(*cstring titlestr, *cstring result)

  code
  if (titleStr = 'Internal Name')
    Self.InternalName = result
  end

  return

[END]
