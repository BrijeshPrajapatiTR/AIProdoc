ExplanationDetail7500 DETAIL,AT(0,0,,6167),USE(?DETAIL4),PAGEBEFORE(-1),#ORDINAL(203)
            STRING('HOW CHILD SUPPORT CALCULATOR CALCULATES CHILD SUPPORT OBLIGATIONS'),AT(1052, |
              104),USE(?String324),FONT(,,,FONT:bold),CENTER,#ORDINAL(204)
            STRING('Child Support Calculator applies the guidelines found in Chapter 15' & |
              '4, Subchapter C (Sec 154.121 et seq)'),AT(604,563),USE(?String325),#ORDINAL(205)
            STRING('of the Texas Family Code. It performs the following steps:'),AT(604,740), |
              USE(?String326),#ORDINAL(206)
            STRING('1.  Calculate net monthly income by multiplying the gross monthly i' & |
              'ncome by the appropriate'),AT(615,990,6240,208),USE(?String327),#ORDINAL(207)
            STRING('percentage found in the Attorney General''s promulgated tax chart. ' & |
              'This chart is authorized in'),AT(823,1156),USE(?String328),#ORDINAL(208)
            STRING('Section 154.061 and is used to deduct a standard amount for social ' & |
              'security and income taxes.'),AT(823,1323),USE(?String329),TRN,#ORDINAL(209)
            STRING('2.  Net resources are calculated by the following steps (Sec. 154.062):'), |
              AT(615,1542),USE(?String330),#ORDINAL(210)
            STRING('a.  add non-taxable income;'),AT(823,1719),USE(?String331),#ORDINAL(211)
            STRING('b.  deduct monthly expenses for health insurance coverage or cash m' & |
              'edical support for obligor''s children;'),AT(823,1875),USE(?String332),#ORDINAL(212)
            STRING('c.  deduct any monthly amount for union dues;'),AT(823,2042),USE(?String333), |
              #ORDINAL(213)
            STRING('d.  deduct any amounts for state income tax; and'),AT(823,2198),USE(?String334), |
              #ORDINAL(214)
            STRING('e.  deduct any amounts you want to argue to the judge that should b' & |
              'e considered under Section 154.123.'),AT(823,2344),USE(?String335),TRN,#ORDINAL(215)
            STRING('4.  Calculate obligor''s support obligation by multiplying adjusted' & |
              ' net resources by the percentages found'),AT(615,3021),USE(?String336),TRN, |
              #ORDINAL(216)
            STRING('in Sec.154.125.  This section provides different percentages for di' & |
              'fferent numbers of children.'),AT(823,3198),USE(?String337),#ORDINAL(217)
            STRING('3.  If obligor is obligated  to support children in more than one h' & |
              'ousehold, then the adjustments'),AT(615,2604,6292,208),USE(?String338),#ORDINAL(218)
            STRING('provided in Section 154.128 are applied to calculate adjusted net resources.'), |
              AT(823,2771,5792,208),USE(?String339),#ORDINAL(219)
            STRING('5.  If the child(ren) are receiving disability income, then, as pro' & |
              'vided in Section 154.132, the amount of that'),AT(625,3469),USE(?String358), |
              TRN,#ORDINAL(220)
            STRING('disability income is deducted from the monthly support obligation.'),AT(813, |
              3656),USE(?String359),TRN,#ORDINAL(221)
            STRING('6.  If the child(ren) are receiving Social Security Old Age benefit' & |
              's, then, as provided in Section 154.133, the'),AT(625,3938),USE(?String366), |
              TRN,#ORDINAL(222)
            STRING('amount of those benefits is deducted from the monthly support obligation.'), |
              AT(813,4125),USE(?String367),TRN,#ORDINAL(223)
            STRING('7.  If the obligee has other minor dependents covered under the sam' & |
              'e health insurance plan, the court shall divide'),AT(625,4448),USE(?String368), |
              TRN,#ORIG(?String368),#ORDINAL(224)
            STRING('the total cost to the obligee for the insurance by the total number' & |
              ' of minor dependents, including the child, '),AT(823,4635),USE(?String369), |
              TRN,#ORIG(?String369),#ORDINAL(225)
            STRING('covered under the plan.'),AT(813,4813),USE(?String370),TRN,#ORIG(?String370), |
              #ORDINAL(226)
            STRING('NOTE - Section 154.125 provides that the child support guidelines a' & |
              'pply only if the obligor''s monthly net'),AT(604,5323),USE(?String371),TRN, |
              #ORIG(?String371),#ORDINAL(227)
            STRING('resources are $7,500.00 or less.  Section 154.126 contains instruct' & |
              'ions for situations where resources'),AT(604,5521),USE(?String372),TRN,#ORIG(?String372), |
              #ORDINAL(228)
            STRING('exceed $7,500.00.'),AT(604,5719),USE(?String373),TRN,#ORIG(?String373), |
              #ORDINAL(229)
          END
