[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.PayCurrentOblBefore  PROCEDURE(STRING ObligationType, long ObligationCount = -1, BYTE lookBack30 = FALSE)
COUNT                             LONG
Uobl                              DECIMAL(9,2)
AplUobl                           DECIMAL(9,2)
Cobl                              DECIMAL(9,2)
Cint                              DECIMAL(9,2)
AttyFeesCostBalance               DECIMAL(8,2)
AttyFeesCostBalanceInt            DECIMAL(8,2)
PaidCounters                      STRING(500)
OCount                            LONG
PaidAmount                        LONG
StartLoc                          LONG
LengthLoc                         LONG
SearchLen                         LONG
IsBalBeforeProcessed              BYTE
LoockBackReducedAmt               LONG
LoockBackCount                    LONG
LOC:SaveAmtDate                   LONG

  CODE
    
    IsBalBeforeProcessed = false
    LoockBackReducedAmt = 0
    LoockBackCount = 0
    DebugCL.Send('PayCurrentOblBefore Start ObligationType: ' & ObligationType & ', ObligationCount: ' & ObligationCount & ', lookBack30' & lookBack30)
    IF ObligationCount = -1
      ObligationCount = QCOUNTER
    END
    
    IF ~PBalance 
      RETURN                     !Exit if all of the pmt has
    END                        ! been applied

    IF QCounter = 1                             !If this is the first activity
      RETURN                                      ! there's nothing to apply
    END                                           ! the payment to

    !GET(ReportQueue,QCOUNTER)
    GET(ReportQueue,ObligationCount)
    
    DebugCL.Send('PayCurrentOblBefore - RPQ:Uobl: ' & RPQ:Uobl & ', RPQ:ObligationType: ' & RPQ:ObligationType & ', RPQ:Type: ' & RPQ:Type )
    
    LOC:SaveDate = RPQ:Date
    LOC:MONTH = MONTH(RPQ:Date)      !MA ADDED   2/25/02
    LOC:YEAR  = YEAR(RPQ:Date)       !MA ADDED   2/25/02
    !Nikita Added additional condition in below if condition
    !IF RPQ:Uobl <= 0                            !If there is no obligation balance owed
    IF RPQ:Uobl <= 0                            !If there is no obligation balance owed
      DebugCL.Send('PayCurrentOblBefore - return without anything')
      RETURN                                    ! exit without doing anything
    END

    !PCOUNTER = QCOUNTER
    PCOUNTER = ObligationCount
    !PCOUNTER = QCOUNTER+1                       !NOTE - PCOUNTER is set at 1 past QCOUNTER
                                              ! so that this will also work if processing
                                              ! a credit balance with the current record
                                              ! being an obligation
    !Nikita End
    GET(ReportQueue, PCounter)
    !Nikita - Start pay current obligation
    !If ERRORCODE() THEN BREAK.
    DebugCL.Send('1 PCOB PCounter: ' & PCounter & ', RPQ:ObligationType: ' & RPQ:ObligationType)
    !Nikita - End pay current obligation
    
    ApplyTotal = 0
    PaidCounters = '' !Nikita - Reset the string
    !Nikita - Can create a routien
    IF UPPER(ObligationType) = 'CHILD'
      OCount = 1
    END
    IF UPPER(ObligationType) = 'MEDICAL'
      OCount = 2
    END
    IF UPPER(ObligationType) = 'DENTAL'
      OCount = 3
    END
    LOC:SaveAmtDate = RPQ:Date
    
    !Nikita - End
    LOOP                                                          !Now loop backwards totaling any
      !Nikita - pass InclidePayment  as false
      Util.GetPreviousReportQueueObligationType(ObligationType, Pointer(ReportQueue), FALSE)   ! obligation amounts that are current
                                              ! then this amount will be deducted
      If ERRORCODE() OR POINTER(ReportQueue) <= 0 THEN 
        BREAK                ! from the current record's Uobl
      END
      DebugCL.Send('2 PCOB PCounter: ' & PCounter & ', RPQ:Cobl: ' & RPQ:Cobl & ', LOC:MONTH: ' & LOC:MONTH & ', LOC:YEAR: ' & LOC:YEAR)
      DebugCL.Send('2.0 RPQ:Date: ' & Format(RPQ:Date,@d2) )
      DebugCL.Send('2.1 Pointer(ReportQueue): ' & Pointer(ReportQueue)) 
      !Nikita - Added below condition to look back before 30 days

      IF LOC:MONTH<>MONTH(RPQ:Date) OR LOC:YEAR<>YEAR(RPQ:Date) 
        DebugCL.Send('3 PCOB')
        BREAK
      END
      
      DebugCL.Send('4 PCOB')
      !IF UPPER(ObligationType) <>  UPPER(RPQ:ObligationType) and Clip(RPQ:ObligationType) <> '' !Nikita - Commented the line
      IF UPPER(ObligationType) <>  UPPER(RPQ:ObligationType) 
        DebugCL.Send('5 PCOB RPQ:ObligationType: ' & RPQ:ObligationType & ', ObligationType: ' & ObligationType)
        CYCLE
      END
      DebugCL.Send('6 PCOB RPQ:Type: ' & RPQ:Type)
      If RPQ:Type = 'P'                         !Don't pay payments
        DebugCL.Send('7 PCOB')
        CYCLE
      END
      DebugCL.Send('8 PCOB')

      !Nikita
      DebugCL.Send('.1 PCOB')
       IF RPQ:UnpaidBalance <= 0 !If there's nothing owed on this
                                            ! obligation cycle and look for
                                            ! another current obligation
        StartLoc = INSTRING('(' & Pointer(ReportQueue) & ':', CLIP(CurrContextPaidAmount[OCount]), 1, 1)
        SearchLen = Len('(' & Pointer(ReportQueue) & ':')
        DebugCL.Send('Found Counter - ' & CLIP(CurrContextPaidAmount[OCount]))
        IF StartLoc > 0
          LengthLoc = INSTRING(')',  CLIP(CurrContextPaidAmount[OCount]) + 1 , 1)
          PaidAmount = SUB(CLIP(CurrContextPaidAmount[OCount]), StartLoc + SearchLen + 1, LengthLoc - 1 )
          DebugCL.Send('Inside Found Counter - PaidAmount: ' & PaidAmount & ', LengthLoc: ' &  LengthLoc & ', StartLoc: ' & StartLoc & ', SearchLen: ' & SearchLen)
          
          ApplyTotal += PaidAmount !RPQ:AMOUNTO
        END
        DebugCL.Send('8.1 RPQ:AplUobl: ' & RPQ:AplUobl & ', ApplyTotal: ' & ApplyTotal)
        CYCLE
      END
    
      DebugCL.Send('9 PCOB RPQ:UnpaidBalance: ' & RPQ:UnpaidBalance & ', PBalance: ' & PBalance)
      IF RPQ:UnpaidBalance
        DebugCL.Send('10 PCOB')
        IF PBalance >= RPQ:UnpaidBalance      !If balance of pmt will pay this obl
          DebugCL.Send('11 PCOB')
          !Nikita - set current payment details
          PaidCounters = '(' & Pointer(ReportQueue) & ': ' & RPQ:UnpaidBalance & ')'
          DebugCL.Send(' 1 PaidCounters: ' & PaidCounters)
          
          CurrContextPaidAmount[OCount] = CLIP(CurrContextPaidAmount[OCount]) & CLIP(PaidCounters)
          DebugCL.Send('PaidCounters: ' & CLIP(CurrContextPaidAmount[OCount]))
          !Nikita - End
          
          ApplyTotal += RPQ:UnpaidBalance     ! reduce pmt balance
          PBalance -= RPQ:UnpaidBalance       ! will pay off complet uobl
                        ! show this obligation completely paid
          !Nikita - TODO
          RPQ:DelAmtDate = LOC:SaveAmtDate
          !Nikita - END
          
          RPQ:UnpaidBalance = 0 
          DebugCL.Send('9.1 PCOB RPQ:UnpaidBalance: ' & RPQ:UnpaidBalance & ', PBalance: ' & PBalance & ', ApplyTotal: ' & ApplyTotal)
          
          PUT(ReportQueue)
          IF COMMAND('/LOG')
            logcl.writeline(,'Apply ' & RPQ:UnpaidBalance & ' to ' & Format(RPQ:Date,@d2) & ' unpaidbal=0 pbal='&pbalance)
          END
          Debugcl.Send('--DBG-- Apply ' & RPQ:UnpaidBalance & ' to ' & Format(RPQ:Date,@d2) & ' unpaidbal=0 pbal='&pbalance)
          CYCLE
        ELSE                                  !If balance won't pay the obligation
          DebugCL.Send('12 PCOB Pointer(ReportQueue): ' & Pointer(ReportQueue))
          
          ApplyTotal += PBalance              ! track amount paid and
          RPQ:UnpaidBalance -= PBalance       ! reduce balance of this obl
          
          !Nikita - set current payment details
          PaidCounters = '(' & Pointer(ReportQueue) & ': ' & PBalance & ')'
          DebugCL.Send(' 1 PaidCounters: ' & PaidCounters)
          
          CurrContextPaidAmount[OCount] = CLIP(CurrContextPaidAmount[OCount]) & CLIP(PaidCounters)
          DebugCL.Send('PaidCounters: ' & CLIP(CurrContextPaidAmount[OCount]))
          RPQ:DelAmtDate = LOC:SaveAmtDate !To add only
          
          PBalance = 0 
          
          DebugCL.Send('9.2 PCOB RPQ:UnpaidBalance: ' & RPQ:UnpaidBalance & ', PBalance: ' & PBalance & ', ApplyTotal: ' & ApplyTotal)
          
          PUT(ReportQueue)
          IF COMMAND('/LOG')
            logcl.writeline(,'Apply ' & pBalance & ' to ' & Format(RPQ:Date,@d2) & ' unpaidbal='&rpq:unpaidbalance& ' pbal=0')
          END
          Debugcl.Send('--DBG-- Apply ' & pBalance & ' to ' & Format(RPQ:Date,@d2) & ' unpaidbal='&rpq:unpaidbalance& ' pbal=0')
          ! show no payment left
          BREAK  ! then break
        END
        DebugCL.Send('13 PCOB')
      END
      DebugCL.Send('14 PCOB')
    END
    DebugCL.Send('15 PCOB')
    
  !We have now totaled up all remaining obligations
  ! which accrued less than 31 days from the date
  ! of the payment - this total is held in
  ! ApplyTotal
  !MESSAGE('PayCurrentOblBefore: QCounter: ' & QCounter)
    !Nikita - Added below if condition to calculate UOBL etc based on previous obligation record
    IF POINTER(ReportQueue) < ObligationCount - 4
      Util.GetPreviousReportQueueObligationType(ObligationType, ObligationCount, FALSE)   
    END
    Uobl = RPQ:Uobl - ApplyTotal
    DebugCL.Send('15.1 PCOB ApplyTotal: ' & ApplyTotal & ', RPQ:Uobl: ' & RPQ:Uobl & ', ObligationCount: ' & ObligationCount & ', Pointer(ReportQueue): ' & Pointer(ReportQueue))
    !Niktia - modified below condition as in PCOB first we made payment against the current month, hence sum to previous PLUOBL is not require
    !AplUobl = RPQ:AplUobl + ApplyTotal
    AplUobl = ApplyTotal
    !Nikita - END
  
    !Nikita - End
    DebugCL.Send('15.2 PCOB RPQ:Cobl: ' & RPQ:Cobl & ', RPQ:Attyfeescosts: ' & RPQ:Attyfeescosts & ', AplUobl ' & AplUobl)
    Cobl = RPQ:Cobl
    Cint = RPQ:Cint
    AttyFeesCostBalance = RPQ:Attyfeescosts
    AttyFeesCostBalanceInt = RPQ:AttyfeescostsInt

    
    GET(ReportQueue,ObligationCount)
    
    DebugCL.Send('15.3 PCOB Child: ' & CLIP(CurrContextPaidAmount[1]) & ' , Medical: ' & CLIP(CurrContextPaidAmount[2]) & ', Dental: ' & CLIP(CurrContextPaidAmount[3]))
    IF ERRORCODE()
      DebugCL.Send('ERROR On ObligationCount ' & ObligationCount)
    ELSE
      DebugCL.Send('16 PCOB')
      RPQ:Uobl = Uobl
      DebugCL.Send('17 PCOB ApplyTotal: ' & ApplyTotal & ', RPQ:Uobl: ' & RPQ:Uobl & ', ObligationCount: ' & ObligationCount & ', Cobl: ' & Cobl & ', AttyFeesCostBalance: ' & AttyFeesCostBalance )
       
      DebugCL.Send('18 PCOB RPQ:AplUobl: ' & RPQ:AplUobl & ', RPQ:AmountP: ' & RPQ:AmountP)
      !Nikita - Set AmountP to PBalance
      RPQ:AplUobl = AplUobl
      RPQ:AmountP = ApplyTotal !//TODO -It can be Pbalance or ApplyTotal - Set based on next payment logic

!!!!      RPQ:Cobl = Cobl
!!!!      RPQ:Cint = Cint
!!!!      RPQ:Attyfeescosts = AttyFeesCostBalance
!!!!      RPQ:AttyfeescostsInt = AttyFeesCostBalanceInt
  !****changed on 5/12/97 by ALS
  !deliquent balances will be updated when UINT is called
  !the payments were applied to current obligations so should not affect delinquent obligations
  !--------------------------------------------------------------------
      PUT(ReportQueue)
    END
  
  

!------------------------------
!------------------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.PayCurrentOblAfter   PROCEDURE(STRING ObligationType, LONG loc:month, LONG loc:year, LONG Glo:Calcdate, long ObligationCount = -1)
tempdecimal                       like(RPQ:UnpaidBalance)
LOC:SaveAmtDate                   LONG
CODE
!MA ADDED THIS ROUTINE TO LOOK FORWARD FOR CURRENT OBLIGATION(SAME MONTH AS CURRENT PAYMENT)  2/25/02
  DebugCL.Send('1 PCOA PBalance: ' & PBalance & ', ObligationCount: ' & ObligationCount)
  
  IF ObligationCount = -1
      ObligationCount = QCOUNTER
  END
  
  IF ~PBalance 
    RETURN
  END                                       !Exit if all of the pmt has
                                              ! been applied
  DebugCL.Send('2 PCOA ObligationCount ' & ObligationCount)
  IF ObligationCount = 1                             !If this is the first activity
    RETURN                                      ! there's nothing to apply
  END                                         ! the payment to
  ApplyTotal = 0
!  PCOUNTER = QCOUNTER
  PCOUNTER = ObligationCount
  DebugCL.Send('3 PCOA PCounter: ' & PCounter)
  GET(ReportQueue,PCounter)  
  LOC:SaveAmtDate = RPQ:Date
  LOOP
    !Nikita - Pass correct paramenter in last
    !Util.GetNextReportQueueObligationType(ObligationType, pointer(ReportQueue))
    Util.GetNextReportQueueObligationType(ObligationType, pointer(ReportQueue), FALSE, TRUE)
    !Nikita - End
    
    if ErrorCode() OR POINTER(ReportQueue) > RECORDS(ReportQueue)
       DebugCL.Send('4 PCOA ERRORCODE: ' & ERRORCODE())
      BREAK
    END
    
    IF LOC:MONTH<>MONTH(RPQ:Date) OR LOC:YEAR<>YEAR(RPQ:Date)   !SEE IF IT'S IN SAME MONTH
      DebugCL.Send('5 PCOA break inside month condition')
      BREAK
    END
    IF RPQ:Date > GLO:CalcDate                                    !THEN SEE IF IT'S AFTER THE CUT OFF DATE
      DebugCL.Send('6 PCOA break inside date condition')
      BREAK
    END
    IF UPPER(ObligationType) <>  UPPER(RPQ:ObligationType) 
      DebugCL.Send('7 PCOA break inside obligation condition')
      CYCLE 
    END
    If UPPER(RPQ:Type) <> 'O' AND UPPER(RPQ:Type)<>'F'                        !THEN SEE IF IT'S OBLIGATION
      DebugCL.Send('8 PCOA break inside type condition')
      CYCLE
    END
    IF RPQ:UnpaidBalance <= 0 
      DebugCL.Send('9 PCOA break inside RPQ:UnpaidBalance')
      CYCLE
    END
    
    DebugCL.Send('10 PCOA RPQ:UnpaidBalance: ' & RPQ:UnpaidBalance & ', POINTER: ' & POINTER(ReportQueue) )
    DebugCL.Send('10.1 PCOA RPQ:Uobl: ' & RPQ:Uobl )
    IF RPQ:UnpaidBalance
      IF PBalance >= RPQ:UnpaidBalance
        PBalance -= RPQ:UnpaidBalance
        RPQ:REDUCEDAMOUNT+=RPQ:UnpaidBalance   !THE RPQ:REDUCEDAMOUNT IS A NEW FIELD TO HOLD THE
        ApplyTotal += RPQ:unpaidBalance        ! AMOUNT GOING TO BE REDUCED WHEN LOOP THROUGH TO THERE
        RPQ:unpaidBalance=0
        !RPQ:DelAmtDate = LOC:SaveAmtDate
        PUT(ReportQueue)
        !RPQ:REDUCEDAMOUNT=0
        DebugCL.Send('10 before cycle PBalance: ' & PBalance)
        !Nikita - Comment
        CYCLE
        !BREAK
        !Nikita - End
      ELSE
        !Nikita - TODO
        RPQ:REDUCEDAMOUNT+=PBalance 
        !Niktia - END
        !RPQ:REDUCEDAMOUNT+=PBalance
        RPQ:unpaidbalance -=PBalance
        !RPQ:DelAmtDate = LOC:SaveAmtDate
        PUT(ReportQueue)
        !RPQ:REDUCEDAMOUNT=0
        ApplyTotal += PBalance
        PBalance = 0
        DebugCL.Send('11 before break PBalance: ' & PBalance)
        BREAK
      END
    END
  END
  GET(ReportQueue,ObligationCount)
  !Nikita - Added on 02/17/22 - Reverted on 21st feb 22
  !!!RPQ:Uobl -= ApplyTotal
  !Nikita - End
  RPQ:AplUobl += ApplyTotal
  RPQ:AmountP += ApplyTotal
  DebugCL.Send('12 RPQ:AplUobl: ' & RPQ:AplUobl & ', RPQ:AmountP: ' & RPQ:AmountP & ', RPQ:Uobl: ' & RPQ:Uobl)
  PUT(ReportQueue)
  GET(ReportQueue,ObligationCount)


[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.PayDelinquentObl Procedure(string ObligationType, long ObligationCount = -1)
AppliedToBeforeD010100        decimal(8,2)  !this is the amount applied to obligations
                                     !before D010100 and is used to update rpq:uoblbefore
AppliedToAfterD010100         decimal(8,2)
LOC:SaveAmtDate               LONG
LOC:AppliedTotal              DECIMAL(8,2)
CODE
  IF COMMAND('/LOG')
    logcl.writeline(,'')
    logcl.writeline(,'Apply payment to delinquent obl. Payment='&pbalance)
  END
  DebugCL.Send('1. Pay Delinquent Obl Start - ObligationType: ' & ObligationType & ', QCounter: ' & QCounter & ', PBalance: ' & PBalance & ', ObligationCount: ' & ObligationCount)
  
  IF ObligationCount = -1
      ObligationCount = QCOUNTER
  END
  
  IF ~PBalance                                !Exit if all of the pmt has
    RETURN                                    ! been applied
  END
    
  IF ObligationCount = 1                             !If this is the first activity
    RETURN                                      ! there's nothing to apply
  END                                          ! the payment to

  GET(ReportQueue,ObligationCount)
  IF UPPER(RPQ:ObligationType) <> UPPER(ObligationType)  and Clip(RPQ:ObligationType) <> ''
    DebugCL.Send('2. Pay Delinquent Obl End inside IF')
    RETURN
  END
  
  !Nikita - Commented below code
!  IF RPQ:Uobl <= 0                           !If there is no obligation balance owed
!    DebugCL.Send('3. Pay Delinquent Obl End RPQ:Uobl is <0')
!    RETURN                                      ! exit without doing anything
!  END
  !Nikita - End
  
  DebugCL.Send('4. Pay Delinquent Obl - before loop')
  !GOING TO BEGINNING OF OBLIGATION THEN PAYING FORWARD WILL PAY TYPE 1 DELINQUENT FIRST(BEFORE 1/1/2000)
  !MA 3/5/02 - FIFO
  LOC:AltCounter = 0                          !1997.3 Added by Alan 08/97
  LOC:AltBalance = Pbalance                   ! because the remaining balances
  !LOC:SaveAmtDate = RPQ:Date
  LOC:AppliedTotal = 0
  
  !Nikita - Set first pointer of based on their respective Obligation type
  IF UPPER(ObligationType) = 'CHILD'
    LOC:AltCounter = 1
  ELSIF UPPER(ObligationType) = 'MEDICAL'
    LOC:AltCounter = 2
  ELSIF UPPER(ObligationType) = 'DENTAL'
    LOC:AltCounter = 3
  END
  GET(ReportQueue,LOC:AltCounter)
  !Nikita - END
  
  LOOP   
      DebugCL.Send('5. Pay Delinquent Obl - Loop start POINTER: ' & POINTER(ReportQueue))                         ! report was showing some obligations ! with too much remaining.
      DebugCL.Send('6. Pay Delinquent Obl  RPQ:UnpaidBalance: ' & RPQ:UnpaidBalance & ', LOC:AltBalance: ' & LOC:AltBalance)
      !DebugCL.Send('6.1. Pay Delinquent Obl  LOC:DelPointer : ' & LOC:DelPointer  & ', LOC:DelMonth: ' & LOC:DelMonth & ', LOC:DelYear: ' & LOC:DelYear)
      
      IF RPQ:UnpaidBalance
        IF LOC:AltBalance >= RPQ:UnpaidBalance
          LOC:AltBalance -= RPQ:UnpaidBalance
          !added to track money applied to obligations before 1/1/00
          IF RPQ:Date<D010100 THEN
            AppliedToBeforeD010100 +=RPQ:UnpaidBalance
          else
            AppliedToAfterD010100  +=RPQ:unpaidBalance
          end
          IF COMMAND('/LOG')
            logcl.writeline(,RPQ:unpaidbalance & ' applied against ' & format(RPQ:Date,@d2))
          END
          LOC:AppliedTotal += RPQ:UnpaidBalance
          RPQ:UnpaidBalance = 0
          
          RPQ:DelAmtDate = LOC:SaveAmtDate

          PUT(ReportQueue)
          !CYCLE
          DebugCL.Send('6.5 Pay Delinquent Obl  RPQ:UnpaidBalance: ' & RPQ:UnpaidBalance & ', RPQ:REDUCEDAMOUNT: ' & RPQ:REDUCEDAMOUNT)
        ELSE
          RPQ:UnpaidBalance -= LOC:AltBalance
          !added to track money applied to obligations before 1/1/00
          if RPQ:Date<D010100 then
            AppliedToBeforeD010100 +=Loc:AltBalance
          else
            AppliedToAfterD010100  +=Loc:AltBalance
          end
          IF COMMAND('/LOG')
            logcl.writeline(,loc:AltBalance & ' applied against ' & format(RPQ:Date,@d2))
          END
          LOC:AppliedTotal += LOC:AltBalance
  !        !Nikita - TODO
  !        RPQ:REDUCEDAMOUNT += LOC:AltBalance
  !        !Nikita - END
          LOC:AltBalance = 0
          RPQ:DelAmtDate = LOC:SaveAmtDate
          
          PUT(ReportQueue)
          DebugCL.Send('6.6 Pay Delinquent Obl  RPQ:UnpaidBalance: ' & RPQ:UnpaidBalance & ', RPQ:REDUCEDAMOUNT: ' & RPQ:REDUCEDAMOUNT)
          BREAK
        END
      END
      !Nikita - Added below code to get next record
      !Nikita - TODO getting previous records on the place of next records due as previous records we known as Delinquent
      !As per new logic of 3 Obligation type, suppose to pay current obligation
      Util.GetNextReportQueueObligationType(UPPER(ObligationType), POINTER(ReportQueue), FALSE, FALSE) !This loops backwards updating
      !Util.GetPreviousReportQueueObligationType(UPPER(ObligationType), POINTER(ReportQueue), FALSE) !This loops backwards updating
      
      !Nikita - END
      IF Errorcode() OR POINTER(ReportQueue) = 0  OR POINTER(ReportQueue) >= ObligationCount    ! the remaining balance
        BREAK
      END
      DebugCL.Send('7. Pay Delinquent Obl  RPQ:UnpaidBalance: ' & RPQ:UnpaidBalance & ', LOC:AltBalance: ' & LOC:AltBalance)
  END
  DebugCL.Send('8. PayDelinquentObl - Pointer: ' & Pointer(ReportQueue) & ', LOC:AltBalance: ' & LOC:AltBalance)
  
  GET(ReportQueue,ObligationCount)
  DebugCL.Send('8.1 PayDelinquentObl - RPQ:Uobl: ' & RPQ:Uobl & ', RPQ:AplUobl: ' & RPQ:AplUobl & ', LOC:AppliedTotal: ' & LOC:AppliedTotal )

  !Nikita - Commented below if section since for Type = 'P' always have UOBL < 0 
  IF RPQ:Uobl <= 0                           !If there is no obligation balance owed
    DebugCL.Send('9. Pay Delinquent Obl return RPQ:Uobl <= 0 ')
    RETURN                                      ! exit without doing anything
  END
  !Nikita - End
  
  IF UPPER(RPQ:ObligationType) <> UPPER(ObligationType)
    DebugCL.Send('9.1 Pay Delinquent Obl return RPQ:ObligationType <> ObligationType ')
    RETURN
  END
  
  DebugCL.Send('9.2 PayDelinquentObl - RPQ:Uobl: ' & RPQ:Uobl & ', RPQ:AplUobl: ' & RPQ:AplUobl & ', RPQ:AmountP: ' & RPQ:AmountP)
  !LOC:AppliedTotal = PBalance - LOC:AltBalance
  DebugCL.Send('9.3 PayDelinquentObl - LOC:AppliedTotal: ' & RPQ:AmountP)
  
  RPQ:AplUobl += LOC:AppliedTotal
  RPQ:AmountP +=  LOC:AppliedTotal
  
  
  IF PBalance >= RPQ:Uobl                     !If balance of pmt will
    PBalance -= RPQ:Uobl                      ! will pay off this obl
    
    RPQ:Uobl = 0
  ELSE                                        !If balance won't pay the obligation
    RPQ:Uobl -= PBalance                      ! reduce the uobl
    
    !-------------------------------------------
    PBalance = 0                              ! show no payment left
  END
  
  DebugCL.Send('10. PayDelinquentObl - RPQ:Uobl: ' & RPQ:Uobl & ', RPQ:AplUobl: ' & RPQ:AplUobl & ', RPQ:AmountP: ' & RPQ:AmountP)
  
  !Update deliquentbalances with money applied
  !note: delinquent balances can become negative
  RPQ:DelBalBefore -= AppliedToBeforeD010100
  RPQ:DelBalAfter  -= AppliedToAfterD010100
  IF COMMAND('/LOG')
    logcl.writeline(,'Payment date='&format(RPQ:Date,@d2))
    logcl.writeline(,'Applied to before: '& AppliedToBeforeD010100 & ' delbalbefore updated to: ' & RPQ:DelBalBefore)
    logcl.writeline(,'Applied to after: '& AppliedToAfterD010100 & ' delbalafter updated to: ' & RPQ:DelBalAfter)
  END
  DebugCL.Send('11. PayDelinquentObl - RPQ:Uobl: ' & RPQ:Uobl & ', RPQ:AplUobl: ' & RPQ:AplUobl)

  PUT(ReportQueue)
  GET(ReportQueue,QCOUNTER)                      !Reactivate the current
                                                        ! record

!--------------------------

!-------------------------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.PayCurrentOblBack30  Procedure(String ObligationType, long ObligationCount = -1)
LoockBackReducedAmt               LONG
  Code
    !------------------------------ 
    DebugCL.Send('1 PCOB30 ObligationType: ' & ObligationType & ', ObligationCount: ' & ObligationCount)
    IF ObligationCount = -1
      ObligationCount = QCOUNTER
    END
    !This will pay non-delinquent obligation
    IF ~PBalance                                !Exit if all of the pmt has
      RETURN                                      ! been applied
    END
      
    IF ObligationCount = 1                             !If this is the first activity
      RETURN                                      ! there's nothing to apply
    END                                          ! the payment to

    GET(ReportQueue,ObligationCount)
    IF UPPER(RPQ:ObligationType) <> UPPER(ObligationType)  and Clip(RPQ:ObligationType) <> ''
      DebugCL.Send('2 PCOB30 return inside ObligationType ' & ObligationType & ', RPQ:ObligationType: ' & RPQ:ObligationType)
      RETURN
    END

    LOC:SaveDate = RPQ:Date
    !IF RPQ:Uobl <= 0                            !If there is no obligation balance owed
    IF RPQ:Uobl <= 0                            !If there is no obligation balance owed
      DebugCL.Send('3 Pay Current Obl Back30 - return without anything')
      RETURN                                    ! exit without doing anything
    END

    PCOUNTER = ObligationCount
    !PCOUNTER = ObligationCount + 1                !NOTE - PCOUNTER is set at 1 past QCOUNTER
                                                  ! so that this will also work if processing
                                                  ! a credit balance with the current record
                                                  ! being an obligation
      !-----!LOOK BACKWARD TO FIND THE OLDEST DAY IN 30 DAYS  3/5/02  MA ----
    DebugCL.Send('4 Pay Current Obl Back30 - LOC:SaveDate: ' & Format(LOC:SaveDate,@d2))
    LOOP
!      PCOUNTER -= 1
      Util.GetPreviousReportQueueObligationType(ObligationType, Pointer(ReportQueue), FALSE) 
      If ERRORCODE() THEN 
        BREAK
      END
      
      IF UPPER(RPQ:ObligationType) <> UPPER(ObligationType) AND Clip(RPQ:ObligationType) <> ''
        DebugCL.Send('Pay Current Obl Back30 - Cycle')
        CYCLE
      END
      DebugCL.Send('5 Pay Current Obl Back30 - RPQ:Date: ' & FORMAT(RPQ:Date,@d2))
      If LOC:SaveDate - RPQ:Date > 30
        DebugCL.Send('6 Pay Current Obl Back30 - Break')
        BREAK
      END

      If RPQ:Type = 'P'
        CYCLE
      END
    END !Edn of the loop
      !-----------------------------------------------------------------------
    ApplyTotal = 0
    LOOP                                        !Now loop forwards totaling any
!      PCOUNTER += 1                             ! obligation amounts that are current
!      If PCOUNTER > ObligationCount
!        BREAK
!      END
      DebugCL.Send('7 Pay Current Obl Back30 Inside loop - Pointer: ' & POINTER(ReportQueue))
      Util.GetNextReportQueueObligationType(ObligationType, Pointer(ReportQueue), FALSE, TRUE)                 ! then this amount will be deducted
      IF ERRORCODE() OR POINTER(ReportQueue) > ObligationCount THEN 
        BREAK                ! from the current record's Uobl
      END
      
      DebugCL.Send('8 Pay Current Obl Back30 Inside loop - Pointer: ' & POINTER(ReportQueue))
      
      If RPQ:Type = 'P'                         !Don't pay payments
        DebugCL.Send('9 Pay Current Obl Back30 type P')
        CYCLE
      END
      IF UPPER(RPQ:ObligationType) <> UPPER(ObligationType)
        DebugCL.Send('10 Pay Current Obl Back30')
        CYCLE
      END

      IF RPQ:UnpaidBalance <= 0               !If there's nothing owed on this
         DebugCL.Send('10 Pay Current Obl Back30 - unpaid is 0')
        CYCLE                                 ! obligation cycle and look for
      END                                     ! another current obligation

      !Nikita - TODO
!      IF MONTH(RPQ:Date) <> MONTH(LOC:SaveDate) OR YEAR(RPQ:Date) <> YEAR(LOC:SaveDate)
!        DebugCL.Send('10.1 Pay Current Obl Back30 - Non WEEKLY - CYCLE with month condition')
!        Cycle
!      END
      If LOC:SaveDate - RPQ:Date > 30
        DebugCL.Send('6 Pay Current Obl Back30 - Break')
        BREAK
      END
      !Nikita - END
      
      IF RPQ:UnpaidBalance
        IF PBalance >= RPQ:UnpaidBalance      !If balance of pmt will pay this obl
          DebugCL.Send('11 Pay Current Obl Back30 ')
          ApplyTotal += RPQ:UnpaidBalance     ! reduce pmt balance
          PBalance -= RPQ:UnpaidBalance       ! will pay off complet uobl
          RPQ:UnpaidBalance = 0               ! show this obligation completely paid
          !Nikita
          LoockBackReducedAmt += RPQ:UnpaidBalance
          !Nikita - TODO Commented below on 17Jan
!!!          RPQ:REDUCEDAMOUNT += RPQ:UnpaidBalance
          !Nikita - END
          !Nikita - End
          PUT(ReportQueue)
          CYCLE
        ELSE                                  !If balance won't pay the obligation
          DebugCL.Send('12 Pay Current Obl Back30 ')
          ApplyTotal += PBalance              ! track amount paid and
          RPQ:UnpaidBalance -= PBalance       ! reduce balance of this obl
          !Nikita
          LoockBackReducedAmt += PBalance
          !Nikita - TODO Commented below on 17Jan
!!!          RPQ:REDUCEDAMOUNT += PBalance
          !Nikita - END
          !Nikita - END
          PUT(ReportQueue)
          PBalance = 0                            ! show no payment left
          BREAK                                   ! then break
        END
      END
    END
    
    !Nikita - Added below if condition to calculate 
    IF POINTER(ReportQueue) < ObligationCount - 4
      Util.GetPreviousReportQueueObligationType(ObligationType, ObligationCount, FALSE)   
    END
    
!    IF CLIP(UPPER(RPQ:ObligationType)) =  'MEDICAL' OR CLIP(UPPER(RPQ:ObligationType)) = 'DENTAL' !Nikita - TODO check if an remove the hardcoding
      !!RPQ:delbalafter -= LoockBackReducedAmt
      PUT(ReportQueue)
!    END
    !Nikita - END
                                                    !We have now totaled up all remaining obligations
                                                    ! which accrued less than 31 days from the date
                                                    ! of the payment - this total is held in
                                                    ! ApplyTotal
    GET(ReportQueue,ObligationCount)
    RPQ:Uobl -= ApplyTotal
    RPQ:AplUobl += ApplyTotal  !****changed on 5/12/97 by ALS
    RPQ:AmountP += ApplyTotal !//TODO -It can be Pbalance or ApplyTotal - Set based on next payment logic
      !delinquent balances are unchanged since these payments are current and
      ! delinquent balances will be updated when uint is called
      !--------------------------------------------------------------------
    DebugCL.Send('PayCurrentOblBack30 RPQ:AplUobl: ' & RPQ:AplUobl)
    PUT(ReportQueue)

Calculator.UIntNew    PROCEDURE(long ObligationCount = -1)         !Calculate interest on unconfirmed obligation
!input: ReportQ
!       QCounter = pointer into reportq of the record we are to calc interest to,assume it points to an obligations
!----------------------
basedate long,auto    !date of record we are calc interest to - QCounter is its pointer
rtn:ptr  long,auto    !junk pointer variable - can be clear,reused - dont assume it has any particular value
StartDate long,auto   !date of the record to start int calc from
enddate long,auto   !intermediate date we calc with
!@Parth - FB28903
RTN:CurrentObligationTotals &GLO:TotalsGroupType
rtn:ObligationType  string(7)
LOC:AddedDelAmt       LONG
PQCounter             LONG
!@Parth
  CODE
    
    IF ObligationCount = -1
      PQCounter = QCounter
    ELSE
      PQCounter = ObligationCount
    END
    
    GET(ReportQueue,PQCounter)

    rtn:ObligationType = UPPER(RPQ:ObligationType)
    RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(rtn:ObligationType))) 
    BaseDate=RPQ:Date
    
    DebugCL.Send('1 Uint New Start - rtn:ObligationType: ' & rtn:ObligationType & ', basedate: ' & format(basedate, @D2) & ', PQCounter ' & PQCounter & ', QCounter: ' & QCOUNTER)
    DebugCL.Send('1.1 Uint New -  RTN:CurrentObligationTotals.UnconfirmedPrincipalBalance: ' & RTN:CurrentObligationTotals.UnconfirmedPrincipalBalance)
      
    IF COMMAND('/LOG')
      logcl.writeline(,'') !blank separator line
      logcl.writeline(,'')
      Logcl.writeline(,'Call UInt for basedate='&format(RPQ:Date,@D2) & ' Pbalance='&pBalance & ' unpaidbal='&rpq:unpaidbalance)
    END  ! Move below condition out of the log condition 
    
    DebugCL.Send('2 Uint New - Pbalance: ' & pBalance & ', RPQ:unpaidbalance: ' & RPQ:unpaidbalance)
    
    IF PQCounter > 1 THEN
          !get(ReportQueue,Qcounter-1)
          
          !Nikita - Modify include payment parameter
          !Util.GetPreviousReportQueueObligationType(rtn:ObligationType, -1)
          Util.GetPreviousReportQueueObligationType(rtn:ObligationType, PQCounter, FALSE)
          !Nikita - End
          logcl.writeline(,'delbalbefore='&RPQ:DelBalBefore & '  Delbalafter='&RPQ:DelBalAfter)
          Debugcl.send('3 Uint Previous result delbalbefore='&RPQ:DelBalBefore & '  Delbalafter='&RPQ:DelBalAfter & ', RPQ:Cobl: ' & RPQ:Cobl & ', POINTER(ReportQueue): ' & POINTER(ReportQueue) )
          GET(ReportQueue,PQCounter)
    END
    !set the delinquent date = 1st day interest will be charged
    !if delinquency date is before 9/1 then set to 9/1
      
    case RPQ:Type
    of 'D'
    orof 'O'
    orOF 'F'
      DebugCL.Send('3.1 UInt New Before - RPQ:Date : ' & format(RPQ:Date ,@d2) & ', RpQ:DelDate: ' & format(RpQ:DelDate ,@d2) )
      RpQ:DelDate = RPQ:Date + 30
      if RPQ:DelDate < 69643 then RPQ:DelDate = 69643.  !allow for 9/1 as earliest
      DebugCL.Send('4 UInt Before Put - Modify RPQ:DelDate RpQ:DelDate : ' & format(RpQ:DelDate ,@d2) )
      put(ReportQueue)
    of 'P'
      RPQ:DelDate=RPQ:Date
    end

    IF RPQ:Date < 69643 THEN
      IF COMMAND('/LOG')
        logcl.writeline(,'exit uint because before 9-1-91')
      END
      Debugcl.Send('5 UInt exit uint because before 9-1-91')
      RETURN
    END            !No interest accrues on obls
                                          ! before Sept 1, 1991
                                          !also this will never become delinquent so delinquent date can stay 0

    IF RPQ:Uobl <= 0 THEN
      IF COMMAND('/LOG')
        logcl.writeline(,'exit uint because unconfirmed obligation=0')
      END
      Debugcl.send('6 Uint New exit uint because unconfirmed obligation=0')
      RETURN
    END                  !If no obligation due, can't be interest and delbalbefore/after must be 0 too
  
!!    !IF FIRST RECORD EXIT
!!    !Nikita - Passing Include payment to "false" 
!!    Util.GetNextReportQueueObligationType(UPPER(rtn:ObligationType), 0, FALSE)
!!    !Nikita - End
!!    DebugCL.Send('7 Uint POINTER(ReportQueue): ' & POINTER(ReportQueue))
!!    IF ERRORCODE() or pointer(ReportQueue) = QCOUNTER
!!      IF COMMAND('/LOG')  
!!        logcl.writeline(,'exit uint because on line 1')
!!      END
!!      Debugcl.Send('8 exit uint because on line 1')
!!      EXIT                                        ! interest if this is the
!!    END                                           ! first record

    IF PQCounter = 1                               !Can't be any unconfirmed
      compile('***',debugflag)
      logcl.writeline(,'exit uint because on line 1')
      ***
      RETURN
    END

!!    !calc the obligation amount
    GET(ReportQueue,PQCounter)
!!    !get the obligation for the current record but will probably be overwritten below
!!    CASE CLIP(RPQ:Frequency)        !GET MONTHLY OBLIGATION OF CURRENT RECORD  MA 2/22/02
!!    OF 'Monthly'
!!      MonthlyOblSub =RPQ:AmountO
!!    OF 'Semi-monthly'
!!      MonthlyOblSub=RPQ:AmountO*2
!!    OF 'Weekly'
!!      MonthlyOblSub=(RPQ:AmountO*52)/12
!!    OF 'Bi-weekly'
!!      MonthlyOblSub=(RPQ:AmountO*26)/12
!!    ELSE
!!      MonthlyOblSub=RPQ:AmountO
!!    END
!!
!!    Debugcl.Send('9 UINT New - CLIP(RPQ:Frequency): ' & CLIP(RPQ:Frequency) & ', RPQ:AmountO: ' & RPQ:AmountO & ', MonthlyOblSub: ' & MonthlyOblSub )
    
    !during 2003 revisions I was told to change to the prior month monthly obligation
    !  for ALL cases NOT just for the final line or if Rpq:type<>'O'

    !  if MonthlyOblSub=0 or RPQ:Type<>'O' then
    !for the final line or other line without an amountO, get the monthly obligation by looping backward
    MonthlyOblSub=0
    LOOP
      DebugCL.Send('1 UInt New Loop POINTER(ReportQueue): ' & POINTER(ReportQueue))
      !get the previous record
      
      IF RPQ:Type='O' AND UPPER(RPQ:ObligationType) = rtn:ObligationType AND RPQ:AmountO > 0 AND RPQ:IsDummyProcess = FALSE then
        MonthlyOblSub=0
        CASE CLIP(RPQ:Frequency)        !GET MONTHLY OBLIGATION OF CURRENT RECORD  MA 2/22/02
        OF 'Monthly'
          MonthlyOblSub=RPQ:AmountO
        OF 'Semi-monthly'
          MonthlyOblSub=RPQ:AmountO*2
        OF 'Weekly'
          MonthlyOblSub=(RPQ:AmountO*52)/12
        OF 'Bi-weekly'
          MonthlyOblSub=(RPQ:AmountO*26)/12
        ELSE
          MonthlyOblSub=RPQ:AmountO
        END
      END
      
      DebugCL.Send('2 UInt New Loop MonthlyOblSub: ' & MonthlyOblSub)
      !IF MonthlyOblSub > 0 and RPQ:Type='O' 
      IF MonthlyOblSub > 0 and RPQ:Type='O' AND POINTER(ReportQueue) <> PQCounter  AND RPQ:IsDummyProcess = FALSE 
        DebugCL.Send('Uint Break')
        BREAK
      END  
      
      IF POINTER(ReportQueue) = 1 
        DebugCL.Send('Get monthly obligation Break for 1')
        BREAK
      END 
      !get(ReportQueue, pointer(ReportQueue)-1)
      !Nikita - Added IncludePayment condition faslse in below call
      Util.GetPreviousReportQueueObligationType(rtn:ObligationType, Pointer(ReportQueue), FALSE)
      !Niita - End
      If ERRORCODE() 
        BREAK
      END
    END !Loop 1 end
    
!  end
    !Niktia - Comment log detrails to avoid repetative work
!    IF COMMAND('/LOG')
!      Get(ReportQueue,Qcounter)
!      logcl.writeline(,'BaseDate='&format(RPQ:date,@d2)&' monthlyobl='&Monthlyoblsub)
!    END
    !Niktia - END
    Get(ReportQueue,PQCounter)
    Debugcl.Send('3 Uint loop BaseDate= ' & format(RPQ:date,@d2) & ' monthlyobl= ' & Monthlyoblsub & ', PQCounter: ' & PQCounter)

    !get stuff from the previous record
    !GET(ReportQueue,QCOUNTER-1)
    !Nikita - Check if need to pass IncludePayment as FALSE
    Util.GetPreviousReportQueueObligationType(rtn:ObligationType,PQCounter, FALSE)
    IF ERRORCODE()
      MESSAGE('ERROR calculating interest on unconfirmed interest.'|
        & ' The printout may not be correct. 2QCOUNTER' & QCOUNTER,,ICON:EXCLAMATION, |
        BUTTON:OK,BUTTON:OK)
      GET(ReportQueue,PQCounter)
      RETURN
    END
  
    DebugCL.Send('4 UInt Loop PQCounter: ' & PQCounter & ', POINTER(ReportQueue): ' & POINTER(ReportQueue) & ', RPQ:Uobl: ' & RPQ:Uobl )
    
    RTN:CurrentObligationTotals.UnconfirmedPrincipalBalance = RPQ:Uobl
    DebugCL.Send('5 UInt Loop BaseDate : ' & format(BaseDate,@d2) & ', FirstTimeIn2000: ' & FirstTimeIn2000 & ', RPQ:DelBalAfter ' & RPQ:DelBalAfter)
    if BaseDate>=D010100 and FirstTimeIn2000=False
      !first time in 2000, look at the previous (last time in 1999) delbalbefore to see if its a credit
      ! if is a credit, copy it over to DelBalAfter
      ! this is like providing a starting balance for DelBalAfter and closing out DelBalBefore
      FirstTimeIn2000 = True
      if RPQ:DelBalBefore<0 then
        !credit balance at the end of 1999
        RTN:CurrentObligationTotals.DelBalBefore = 0
        RTN:CurrentObligationTotals.DelBalAfter = RPQ:DelBalAfter + RPQ:DelBalBefore
      end
    else
      !this is the normal case - just save the delinquent balances to the variable
      RTN:CurrentObligationTotals.DelBalBefore = RPQ:DelBalBefore
      RTN:CurrentObligationTotals.DelBalAfter = RpQ:DelbalAFter
    end
    
    DebugCL.Send('5 UInt RTN:CurrentObligationTotals.DelBalAfter: ' & RTN:CurrentObligationTotals.DelBalAfter & ', RpQ:DelbalAFter: ' & RpQ:DelbalAFter )
    
    !RTN:CurrentObligationTotals.UnconfirmedInterestBalance = RPQ:Uint
    RTN:CurrentObligationTotals.UnconfirmedInterestBalance = RPQ:Uint
    RTN:CurrentObligationTotals.UnconfirmedLastDate = RPQ:DATE
    StartDate = RPQ:Date
    
    IF RTN:CurrentObligationTotals.UnconfirmedLastDate < 69643 then !69643= 9/1/91 = earliest day to cal int from
      RTN:CurrentObligationTotals.unconfirmedLastDate = 69643
    end

    IF COMMAND('/LOG')
      logcl.writeline(,'startDate='&format(startdate,@d2)& ' delbalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' delbalafter='&RTN:CurrentObligationTotals.DelBalAfter)
    END
    DebugCl.Send('startDate= ' & format(startdate,@d2) & ' delbalbefore= ' & RTN:CurrentObligationTotals.DelBalBefore & ' delbalafter= ' & RTN:CurrentObligationTotals.DelBalAfter)
 
    !1st find the first record not in the delinquent balance was calculated then get the next record
    Get(ReportQueue, PQCounter)
    DebugCL.Send('6 UInt New Loop QCOUNTER : ' & QCOUNTER)
    

    LOOP !Loop 2
      DebugCL.Send('7 UInt NEw Loop 2 - Pointer(ReportQueue) : ' & Pointer(ReportQueue))
      
      IF RPQ:interestFlag 
        !go foward and get the 1st one with no interest flag
        !Get(ReportQueue,Rtn:ptr+1)
        Util.GetNextReportQueueObligationType(rtn:ObligationType, Pointer(ReportQueue), FALSE, FALSE) !Nikita - TODO Pass last parameter to true
        BREAK
      END 
      DebugCL.Send('8 UInt New Loop 2 - Pointer(ReportQueue) : ' & Pointer(ReportQueue))
      
      !Nikita - Check if need to pass IncludePayment as FALSE
      Util.GetPreviousReportQueueObligationType(rtn:ObligationType, Pointer(ReportQueue), FALSE)
      If ERRORCODE()
        !GET FIRST ONE
        Util.GetNextReportQueueObligationType(rtn:ObligationType, 0, FALSE, FALSE) !Nikita - Pass last parameter to true
        BREAK
      END 
      DebugCL.Send('9 UInt New Loop 2 - Pointer(ReportQueue) : ' & Pointer(ReportQueue))
    END !Loop 2 end
    
    IF COMMAND('/LOG')
      logcl.writeline(,'First record not in delinquent balance is: ' &format(RPQ:Date,@d2))
    END
    
    DEbugcl.Send('10 UInt New - First record not in delinquent balance is: ' &format(RPQ:Date,@d2) & ':position=' & pointer(ReportQueue))

    !now come foward and calculate
    !startdate is already set to the date of the previous record
    RTN:CurrentObligationTotals.NewInterest=0
    
    LOOP !Start of Loop 3
    !exit if we hit the base row we are calculating to
    !Enddate is where we have calculated interest up to
    !RTN:CurrentObligationTotals.DelBalBefore/after are the current delbalances
      Debugcl.Send('11 Unit New Loop 3 - Processing pointer:'& POINTER(ReportQueue) & '   Against PQCounter:' & PQCounter)
      IF POINTER(ReportQueue) >= PQCounter !Nikita - TODO Correct the comparision  
        DebugCL.Send('11.1 UInt  New Loop 3 - Break')
        BREAK
      END    

      CASE RPQ:Type
      OF 'D'
      OROF 'F'
      OROF 'O'
        !Nikita- TODO
        LOC:AddedDelAmt = 0
        !Nikita - END
        !see if this record is delinquent
        DebugCL.Send('11.2 Loop 3: BaseDate: ' & Format(BaseDate,@d2) & ', RPQ:DelDate: ' & Format(RPQ:DelDate,@d2) & ', Pointer: ' &  POINTER(ReportQueue))
        
         IF RPQ:DelDate < BaseDate THEN 
          !its delinquent
          IF COMMAND('/LOG')
            logcl.writeline(,'Newly delinquent: 42' & Format(RPQ:Date,@d2) & ' on: '& format(RPQ:DelDate,@d2) & ' unpaidbal='& RPQ:unpaidBalance)
          END
          Debugcl.Send('12 Uit Loop 3- Newly delinquent: ' & Format(RPQ:Date,@d2) & ' on: '& format(RPQ:DelDate,@d2) & ' unpaidbal='& RPQ:unpaidBalance)

          !Nikita - Correct till the line
          
          EndDate = RPQ:Deldate
          RTN:CurrentObligationTotals.Days = EndDate-Startdate !calc by class
          IF COMMAND('/LOG')
            logcl.writeline(,'Start='&format(Startdate,@d2) & ' enddate='&format(enddate,@d2) & ' days='&RTN:CurrentObligationTotals.Days)
          END
          
          Debugcl.Send('13 UInt New Loop 3 - Start= ' & format(Startdate,@d2) & ' enddate= '& format(enddate,@d2) & ' days= '& RTN:CurrentObligationTotals.Days)
          Debugcl.Send('13.1 UInt New Loop 3 QCOUNTER: ' & QCOUNTER & ', POINTER(ReportQueue): ' & POINTER(ReportQueue) & ', RTN:CurrentObligationTotals.DelBalBefore: ' & RTN:CurrentObligationTotals.DelBalBefore)
          IF RTN:CurrentObligationTotals.Days > 0 then
            
            !RTN:CurrentObligationTotals &= (Util.GetObligationTotals(rtn:ObligationType)) 
            DebugCL.Send('13.2 UInt Loop 3 DelBalBefore: ' & RTN:CurrentObligationTotals.DelBalBefore & ', DelBalAfter: ' & RTN:CurrentObligationTotals.DelBalAfter & ', Days: ' & RTN:CurrentObligationTotals.Days)
            
            IF RTN:CurrentObligationTotals.DelBalBefore > 0
                IntCalcClass.CalcInt(StartDate, EndDate, RTN:CurrentObligationTotals.DelBalBefore, RTN:CurrentObligationTotals.Days, RTN:CurrentObligationTotals.CalcInterest)
                !RTN:CurrentObligationTotals.DailyRate = (RTN:CurrentObligationTotals.DelBalBefore * .06) / 365
                RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
                Debugcl.Send('13.2 UInt 3 - Insite Calculation RTN:CurrentObligationTotals.NewInterest: ' & RTN:CurrentObligationTotals.NewInterest) 
            ELSE
                Debugcl.Send('13.2 UInt 3 - Clear RTN values ') 
                CLEAR(RTN:CurrentObligationTotals.CalcInterest)
            END
            IF COMMAND('/LOG')
              logcl.writeline(,'DelBalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
            END
            DebugCl.Send('14 Unit Loop 3 - DelBalafter= '& RTN:CurrentObligationTotals.DelBalAfter & ' Interest= ' & RTN:CurrentObligationTotals.CalcInterest)
            
            !Nikita - Added MonthlyOblsub > 0 condition on 25th Jan 22
            !IF RTN:CurrentObligationTotals.DelBalAfter - MonthlyOblsub > 0
            IF RTN:CurrentObligationTotals.DelBalAfter - MonthlyOblsub > 0 !AND MonthlyOblsub > 0
              Principle = RTN:CurrentObligationTotals.DelBalAfter - MonthlyoblSub
              IntCalcClass.CalcInt(StartDate,EndDate,Principle,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
              RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
              Debugcl.Send('14.2 UInt 3 - calculate RTN:CurrentObligationTotals.NewInterest: ' & RTN:CurrentObligationTotals.NewInterest) 
            ELSE
              Debugcl.Send('14.2 UInt 3 - Clear RTN values ') 
              CLEAR(RTN:CurrentObligationTotals.CalcInterest)
            END
            
            IF COMMAND('/LOG')
              logcl.writeline(,'DelBalafter='&choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub>0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
            END
            DebugCl.Send('15 Unit Loop 3  - DelBalafter= '& choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub > 0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest= '& RTN:CurrentObligationTotals.CalcInterest)
          END
          DebugCL.Send('15.1 Unit Loop 3 rtn:ObligationTyp: ' & rtn:ObligationType)  
          RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(rtn:ObligationType)))   

          DebugCl.Send('16 Unit Loop 3  - RTN:CurrentObligationTotals : ' & RTN:CurrentObligationTotals)
          
          DebugCl.Send('16.1 Unit Loop 3  - RPQ:DelDate : ' & FORMAT(RPQ:DelDate,@d2) & ', EndDate: ' & FORMAT(EndDate,@d2))
          !if this calc ended at the delinquent date meaning we are now ready to add it to the balance then do it
          if RPQ:DelDate = EndDate then
            DebugCL.Send('Nikita 1 - Added inside loop RPQ:UnpaidBalance: ' & ', current DelBalAfter: ' &  RTN:CurrentObligationTotals.DelBalAfter )
            if RPQ:Date < D010100 then
              RTN:CurrentObligationTotals.delBalBefore += RPQ:UnpaidBalance
            else
              RTN:CurrentObligationTotals.DelBalAfter  += RPQ:UnpaidBalance
            end
            DebugCL.Send('Nikita 2 - Added inside loop RPQ:UnpaidBalance: ' & ', current DelBalAfter: ' &  RTN:CurrentObligationTotals.DelBalAfter )
            IF COMMAND('/LOG')
              logcl.writeline(,'updatebal DelBalbefore='&RTN:CurrentObligationTotals.DelBalbefore & ' DelBalAfter='& RTN:CurrentObligationTotals.DelBalAfter &' unpaidbal='&RPQ:unpaidbalance)
            END
            !Nikita - Added to solve UINT issue - TODO
            LOC:AddedDelAmt = RPQ:UnpaidBalance
            !END
            Debugcl.Send('updatebal DelBalbefore='&RTN:CurrentObligationTotals.DelBalbefore & ' DelBalAfter='& RTN:CurrentObligationTotals.DelBalAfter &' unpaidbal='&RPQ:unpaidbalance)
          END
          RPQ:interestFlag = True
          
          !DebugCL.Send('17 UInt - Before Put -  RTN:CurrentObligationTotals.delBalBefore : ' &  RTN:CurrentObligationTotals.delBalBefore & ', RTN:CurrentObligationTotals.DelBalAfter : ' & RTN:CurrentObligationTotals.DelBalAfter)
          put(ReportQueue)
          StartDate=Enddate
          
          DebugCL.Send('17 UInt - Before Put - RTN:CurrentObligationTotals.DelBalAfter : ' & RTN:CurrentObligationTotals.DelBalAfter & ', For Next row StartDate: ' & format(StartDate,@d2))
          
        else
          IF COMMAND('/LOG')
            logcl.writeline(,'Not delinquent yet: ' & Format(RPQ:Date,@d2) & ' unpaidbal='& RPQ:unpaidBalance &' deldate='&format(RPQ:deldate,@d2) & ' basedate='&format(basedate,@d2))
          END
          Debugcl.Send('18 UNIT Loop - Not delinquent yet: ' & Format(RPQ:Date,@d2) & ' unpaidbal='& RPQ:unpaidBalance &' deldate='&format(RPQ:deldate,@d2) & ' basedate='&format(basedate,@d2))
        end
      of 'P'
        !EndDate = RPQ:Deldate
        !not an error, just skip it
      else
        !error - it's final or unknow type
        if debugflag then Message('Hit an unknow or bad type during uint calc of: '&rpq:type).
      end
      
      !get the next record
      !THIS LOOP SHOULD WORK BUT IS CAUSING INTREST TO CALCULATE WIERD
      Util.GetNextReportQueueObligationType(UPPER(rtn:ObligationType), Pointer(ReportQueue), FALSE, FALSE) !Nikita - TODO Pass last parameter as true
      if errorcode() AND Pointer(ReportQueue) > PQCounter
        BREAK
      END 
      
      Debugcl.Send('19 UNIT Loop - Pointer(ReportQueue) : ' & Pointer(ReportQueue) & ', RPQ:ObligationType: ' & RPQ:ObligationType & ', rtn:ObligationType: ' & rtn:ObligationType )
    END !End of Loop 3
    !END !Nikita - End of 3 times loop
    
    !reget the current record for the last leg of the interest calc to this date
    !Start is where we have calculated interest up to
    !RTN:CurrentObligationTotals.DelBalBefore/after are the current delbalances
    Get(ReportQueue,PQCounter)
    EndDate = BaseDate
    RTN:CurrentObligationTotals.Days=EndDate-Startdate
    IF COMMAND('/LOG')
      logcl.writeline(,'Finalleg Start='&format(Startdate,@d2) & ' enddate='&format(enddate,@d2) & ' days='&RTN:CurrentObligationTotals.Days)
    END
    Debugcl.Send('20 UInt - Finalleg Start='&format(Startdate,@d2) & ' enddate='&format(enddate,@d2) & ' days='&RTN:CurrentObligationTotals.Days)
    RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(rtn:ObligationType)))   

    
    if RTN:CurrentObligationTotals.Days > 0 then
      if RTN:CurrentObligationTotals.DelBalBefore > 0
        IntCalcClass.CalcInt(StartDate,EndDate,RTN:CurrentObligationTotals.DelBalBefore,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
        RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
      else
        clear(RTN:CurrentObligationTotals.CalcInterest)
      end
      IF COMMAND('/LOG')
        logcl.writeline(,'DelBalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
      END
      Debugcl.Send('21 UInt - DelBalafter = '& RTN:CurrentObligationTotals.DelBalAfter & ' MonthlyOblsub = '& MonthlyOblsub)
      
      !Nikita - Added MonthlyOblsub > 0 condition on 25th Jan 22
      !if RTN:CurrentObligationTotals.DelBalAfter - MonthlyOblsub > 0
      IF RTN:CurrentObligationTotals.DelBalAfter - MonthlyOblsub > 0 !AND MonthlyOblsub > 0
        Principle=RTN:CurrentObligationTotals.DelBalAfter-MonthlyOblSub
        IntCalcClass.CalcInt(StartDate,EndDate,Principle,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
        RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
      else
        clear(RTN:CurrentObligationTotals.CalcInterest)
      end
      IF COMMAND('/LOG')
        logcl.writeline(,'DelBalafter='&choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub>0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
      END
      Debugcl.Send('22 UInt DelBalafter= '&choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub>0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest= '& RTN:CurrentObligationTotals.NewInterest)
    end

    !if this calc ended at the delinquent date meaning we are now ready to add it to the balance then do it
    if RPQ:DelDate = EndDate then
      DebugCL.Send('Nikita 2 - 22.1 UINT inside the UInt issue fix RPQ:UnpaidBalance:' & RPQ:UnpaidBalance & ', DelBalAfter: ' & RTN:CurrentObligationTotals.DelBalAfter )
      !RPQ:REDUCEDAMOUNT = RPQ:UnpaidBalance
      if RPQ:Date < D010100 then
        RTN:CurrentObligationTotals.delBalBefore += RPQ:UnpaidBalance
      else
        RTN:CurrentObligationTotals.DelBalAfter  += RPQ:UnpaidBalance
      end
      DebugCL.Send('Nikita 3 - 22.1 UINT inside the UInt issue fix RPQ:UnpaidBalance:' & RPQ:UnpaidBalance & ', DelBalAfter: ' & RTN:CurrentObligationTotals.DelBalAfter )
      IF COMMAND('/LOG')
        logcl.writeline(,'updatebal DelBalbefore='&RTN:CurrentObligationTotals.DelBalbefore & ' DelBalAfter='& RTN:CurrentObligationTotals.DelBalAfter)
      END
      Debugcl.Send('23 UInt - updatebal DelBalbefore= '&RTN:CurrentObligationTotals.DelBalbefore & ' DelBalAfter= '& RTN:CurrentObligationTotals.DelBalAfter)
    END
    
    !Nikita - TODO
    IF LOC:AddedDelAmt > 0
      RPQ:IsDelBalAdded = TRUE
      RPQ:DelAmtDate = RPQ:Date
    END
    !Niktia - END

    !final update of a few fields then saveit
    RPQ:DelBalBefore = RTN:CurrentObligationTotals.DelBalBefore
    RPQ:DelBalAfter  = RTN:CurrentObligationTotals.DelBalAfter
    
    RPQ:uint  = RTN:CurrentObligationTotals.UnconfirmedInterestBalance + RTN:CurrentObligationTotals.NewInterest
    !Nikita - End
    IF COMMAND('/LOG')
      logcl.writeline(,'Delbalbefore='&RTN:CurrentObligationTotals.DelBalBefore & '  delbalafter='&RTN:CurrentObligationTotals.DelBalAfter & '  newint='&RTN:CurrentObligationTotals.NewInterest & '  intbal='&rpq:uint)
    END
    Debugcl.Send('24 UInt - Delbalbefore= '& RTN:CurrentObligationTotals.DelBalBefore & '  delbalafter = ' & RTN:CurrentObligationTotals.DelBalAfter & '  newint= ' & RTN:CurrentObligationTotals.NewInterest & '  intbal='&rpq:uint)
    
    !Nikita - Enable below code to manage before
    IF LOC:DoApplyPayment AND PBalance
      IF PBalance >= RPQ:Uint                     !If balance of pmt will
        PBalance -= RPQ:Uint                      ! will pay off this int
        RPQ:AplUint = RPQ:Uint                    ! save amount paid
        RPQ:AmountP += RPQ:Uint
        RPQ:Uint = 0                              ! and set balance at 0
      ELSE                                        !If won' pay off the interest
        RPQ:Uint -= PBalance                      ! reduce the interest balance by the payment left
        RPQ:AplUint = PBalance                    ! store the amount applied
        RPQ:AmountP += PBalance
        PBalance = 0                              ! then set the payment left to 0
      END
    END
    !Nikita - End
    
    DebugCL.Send('25 UInt Before final put POINTER(ReportQueue): ' & POINTER(ReportQueue) & ', PBalance : ' & PBalance )
    PUT(ReportQueue)                              !Save even if there is no
                                                ! new interest because this
                                                ! is what carries existing
                                                ! interest balance forward

    IF ERRORCODE()
      MESSAGE('ERROR saving interest calculation on unconfirmed interest.'|
        & ' The printout may not be correct.',,ICON:EXCLAMATION, |
        BUTTON:OK,BUTTON:OK)
    END
    
   
    GET(ReportQueue,QCounter)
    RETURN
    
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.CIntNew  Procedure(long ObligationCount = -1)
RTN:CurrentObligationTotals   &GLO:TotalsGroupType
PQCounter             LONG
CODE
    IF ObligationCount = -1
      PQCounter = QCounter
    ELSE
      PQCounter = ObligationCount
    END
  
  GET(ReportQueue,PQCounter)
  RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 

  DebugCL.Send('Cint Routine Start - PQCounter : ' & PQCounter & ', RTN:CurrentObligationTotals.ConfirmedPrincipalBalance: ' & RTN:CurrentObligationTotals.ConfirmedPrincipalBalance)
  IF RTN:CurrentObligationTotals.ConfirmedPrincipalBalance <= 0
    RETURN
  END

  IF RPQ:DATE <= RTN:CurrentObligationTotals.DateRendered                !Actually had a customer who called and had
    RETURN                                         ! a judgment that was later than the first
  END                                            ! obligation - this addresses that

  IF PQCounter = 1                                !If this is the first record
    !Nikita  - Passed False
    util.GetNextReportQueueObligationType('CHILD',0, FALSE)
    !Nikita - End
    if ~ErrorCode()
      util.SetNamAndAttyObjects('CHILD')
      IF NAM:InterestType='COMPOUND'
        DO FirstCompound
      ELSE
        RTN:CurrentObligationTotals.ConfirmedInterestBalance=0
        GLO:Totals:ConfirmedInterestBalance = 0
        RTN:CurrentObligationTotals.CompoundBalance = 0
      END
    END
    
    util.GetNextReportQueueObligationType('MEDICAL',0, FALSE)
    if ~ErrorCode()
      util.SetNamAndAttyObjects('MEDICAL')
      IF NAM:InterestType='COMPOUND'
        DO FirstCompound
      ELSE
        RTN:CurrentObligationTotals.ConfirmedInterestBalance=0
        GLO:Totals:ConfirmedInterestBalance = 0
        RTN:CurrentObligationTotals.CompoundBalance = 0
      END
    END
    
    util.GetNextReportQueueObligationType('DENTAL',0, FALSE)
    if ~ErrorCode()
      util.SetNamAndAttyObjects('DENTAL')
      IF NAM:InterestType='COMPOUND'
        DO FirstCompound
      ELSE
        RTN:CurrentObligationTotals.ConfirmedInterestBalance=0
        GLO:Totals:ConfirmedInterestBalance = 0
        RTN:CurrentObligationTotals.CompoundBalance = 0
      END
    END    
  ELSE
    !If not the first record
    DebugCL.Send('Cint Routine - RPQ:ObligationType: ' & RPQ:ObligationType )
    util.SetNamAndAttyObjects(UPPER(RPQ:ObligationType))
    IF NAM:InterestType='COMPOUND' and RPQ:Date |  !If it's been a year since compounding
      - RTN:CurrentObligationTotals.LastCompoundDate >= 365                ! and the user wants to compound, this
      ! routine will calculate interest up to
      DO CompoundInterest                          ! the date where interest is compounded
      ! and then set the following variables:
      !  GLO:Totals:ConfirmedLastDate
      !  GLO:ConfirmedInterestBalance
      GET(ReportQueue,PQCounter)
      RTN:CurrentObligationTotals.ConfirmedPrincipalBalance=RPQ:Cobl
      GLO:Totals:ConfirmedPrincipalBalance=RPQ:Cobl
    ELSE
      DebugCL.Send('1.1 Cint: before GetPrev: RPQ:ObligationType: ' & RPQ:ObligationType & ', PQCounter ' & PQCounter)
      !Nikita - Added IncludePayment to false
      Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), PQCounter, FALSE)
      !Niktia - End
      IF ERRORCODE()
        DebugCL.Send('1.2 Cint:Inside Error before GetPrev: RPQ:ObligationType: ' & RPQ:ObligationType & ', PQCounter ' & PQCounter)
        MESSAGE('ERROR calculating interest on confirmed interest.'|
          & ' The printout may not be correct. PQCounter: ' & PQCounter,,ICON:EXCLAMATION, |
          BUTTON:OK,BUTTON:OK)
        RETURN
      END
      DebugCL.Send('1.3 Cint : RPQ:Cobl: ' & RPQ:Cobl)
      RTN:CurrentObligationTotals.ConfirmedLastDate = RPQ:Date
      RTN:CurrentObligationTotals.ConfirmedPrincipalBalance=RPQ:Cobl
      !Nikita Change
      GLO:Totals:ConfirmedLastDate = RPQ:Date
      !Nikita Change End
      GLO:Totals:ConfirmedPrincipalBalance=RPQ:Cobl
      
      RTN:CurrentObligationTotals.ConfirmedInterestBalance=RPQ:Cint
      GLO:Totals:ConfirmedInterestBalance=RPQ:Cint
      DebugCL.Send('1.4 Cint: before GetPrev: RPQ:ObligationType: ' & RPQ:ObligationType & ', PQCounter: ' & PQCounter)
    END
  END
    
  GET(ReportQueue,PQCounter)
  RPQ:Cint = RTN:CurrentObligationTotals.ConfirmedInterestBalance                      
  RPQ:Cobl = RTN:CurrentObligationTotals.ConfirmedPrincipalBalance 
  DebugCL.Send('1.5 Cint: RPQ:Cobl: '& RPQ:Cobl & ', RPQ:Cint: ' & RPQ:Cint)
  RTN:CurrentObligationTotals.DailyRate = ((RTN:CurrentObligationTotals.CompoundBalance + |
    RTN:CurrentObligationTotals.ConfirmedPrincipalBalance) * RTN:CurrentObligationTotals.ConfIntRate) / 365
  RTN:CurrentObligationTotals.Days = RPQ:Date - RTN:CurrentObligationTotals.ConfirmedLastDate
  RTN:CurrentObligationTotals.NewInterest = RTN:CurrentObligationTotals.DailyRate * RTN:CurrentObligationTotals.Days

  DebugCL.Send('1.6 Cint: DailyRate: '& RTN:CurrentObligationTotals.DailyRate & ', Days: ' & RTN:CurrentObligationTotals.Days & ', NewInterest: ' & RTN:CurrentObligationTotals.NewInterest)
  DebugCL.Send('1.6 Cint: CompoundBalance:' & RTN:CurrentObligationTotals.CompoundBalance & ', ConfirmedPrincipalBalance: ' & RTN:CurrentObligationTotals.ConfirmedPrincipalBalance & ', ConfIntRate: ' & RTN:CurrentObligationTotals.ConfIntRate)
  
  IF RTN:CurrentObligationTotals.NewInterest > 0
    RPQ:Cint += RTN:CurrentObligationTotals.NewInterest
  END

  !Nikita - Enable below line for before 2010 case 
  IF LOC:DoApplyPayment AND PBalance
    IF PBalance >= RPQ:Cint                     !If balance of pmt will
      PBalance -= RPQ:Cint                      ! will pay off this int
      RPQ:AplCint = RPQ:Cint                    ! save amount paid
      RPQ:AmountP += RPQ:Cint
      RPQ:Cint = 0                              ! and set balance at 0
      
    ELSE                                        !If won' pay off the interest
      RPQ:Cint -= PBalance                      ! reduce the interest balance by the payment left
      RPQ:AplCint = PBalance                    ! store the amount applied
      RPQ:AmountP += PBalance
      PBalance = 0                              ! then set the payment left to 0
    END
  END
  !Nikita - End

  IF RPQ:Cint < RTN:CurrentObligationTotals.CompoundBalance             !As obligor pays off interest, if he pays off
    RTN:CurrentObligationTotals.CompoundBalance = RPQ:Cint              ! all that has accrued this year, this makes sure
  END                                           ! that the compounded interest is paid off as he
  ! makes further payments


  PUT(ReportQueue)                              !Save the changes so far
  IF ERRORCODE()
    MESSAGE('ERROR saving interest calculation on unconfirmed interest.'|
      & ' The printout may not be correct.',,ICON:EXCLAMATION, |
      BUTTON:OK,BUTTON:OK)
  END
    
  GET(ReportQueue,QCounter)                     !Reactivate the current
  ! record
[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
LoadDebitChild   ROUTINE
!-------------------------------
  Debugcl.send('Start Of ROUTINE LoadDebitChild')
  !!!I've commented out reading the debit file record because its buffer
  !  is already current
!  EXT:CaseID = CAS:CaseID
!  SET(EXT:CaseKey,EXT:CaseKey)
!  NEXT(EXTRA)
!  IF ~ERRORCODE() AND EXT:CaseID = CAS:CaseID
  IF RPQ:DATE > 0 AND |
    (EXTDebitChild:DebitUobl > 0 OR EXTDebitChild:DebitUint > 0 OR EXTDebitChild:DebitCobl > 0 OR EXTDebitChild:DebitCint > 0)
    IF EXTDebitChild:DebitDate<=GLO:CALCDATE   !USING CUT OFF DATE  MA 3/5/02
      clear(ReportQueue)
      RPQ:ObligationType = 'Child'
      RPQ:Date = EXTDebitChild:DebitDate
      RPQ:DateFormatted = FORMAT(EXTDebitChild:DebitDate, @d2)
      RPQ:Type = 'D'
      RPQ:AmountP = 0
      RPQ:AmountO = EXTDebitChild:DebitUobl !0
      RPQ:UnpaidBalance = EXTDebitChild:DebitUobl !0
      RPQ:DebitUobl = EXTDebitChild:DebitUobl
      RPQ:DebitUint = EXTDebitChild:DebitUint
      RPQ:DebitCobl = EXTDebitChild:DebitCobl
      RPQ:DebitCint = EXTDebitChild:DebitCint
      RPQ:TypeSort = 4
      RPQ:dummybyte = 0  
      RPQ:IsDummyProcess = 0                     !Nikita - added to differentiate row
      RPQ:DebitMessage = 'DEBIT123'           !This is printed on the del report
      RPQ:REDUCEDAMOUNT=0
      RPQ:IsJudgement = 0
      ADD(ReportQueue)
      
      !Nikita - Check if same date debit present for Medical/Dental type or not, if not then add it
      IF  EXTDebitMedical:DebitDate <> EXTDebitChild:DebitDate
        !Niktia - Add medical debit row
        DebugCL.Send('1. Load DebitChild - Added medical dummy debit row ')
        RPQ:ObligationType = 'Medical'
        RPQ:Date = EXTDebitChild:DebitDate
        RPQ:DateFormatted = FORMAT(EXTDebitChild:DebitDate, @d2)
        RPQ:Type = 'D'
        RPQ:AmountP = 0
        RPQ:AmountO = 0
        RPQ:UnpaidBalance = 0
        RPQ:DebitUobl = 0
        RPQ:DebitUint = 0
        RPQ:DebitCobl = 0
        RPQ:DebitCint = 0
        RPQ:TypeSort = 5
        RPQ:dummybyte = 1 
        RPQ:IsDummyProcess = 1
        RPQ:DebitMessage = 'DEBIT123'           
        RPQ:REDUCEDAMOUNT=0
        RPQ:IsJudgement = 0
        ADD(ReportQueue)
      END
      
      IF EXTDebitDental:DebitDate <> EXTDebitChild:DebitDate
        !Niktia - Add dental debit row
        DebugCL.Send('2. Load DebitChild - Added dental dummy debit row ')
        RPQ:ObligationType = 'Dental'
        RPQ:Date = EXTDebitChild:DebitDate
        RPQ:DateFormatted = FORMAT(EXTDebitChild:DebitDate, @d2)
        RPQ:Type = 'D'
        RPQ:AmountP = 0
        RPQ:AmountO = 0
        RPQ:UnpaidBalance = 0
        RPQ:DebitUobl = 0
        RPQ:DebitUint = 0
        RPQ:DebitCobl = 0
        RPQ:DebitCint = 0
        RPQ:TypeSort = 6
        RPQ:dummybyte = 1   
        RPQ:IsDummyProcess = 1
        RPQ:DebitMessage = 'DEBIT123'           
        RPQ:REDUCEDAMOUNT=0
        RPQ:IsJudgement = 0
        ADD(ReportQueue)
      END
      !Nikita - END
    END
  END
  CLEAR(RPQ:DebitMessage) !this was still set as payments and final was processed
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
LoadDebitMedical   ROUTINE
!-------------------------------

  !!!I've commented out reading the debit file record because its buffer
  !  is already current
!  EXT:CaseID = CAS:CaseID
!  SET(EXT:CaseKey,EXT:CaseKey)
!  NEXT(EXTRA)
!  IF ~ERRORCODE() AND EXT:CaseID = CAS:CaseID
  IF RPQ:DATE > 0 AND |
    (EXTDebitMedical:DebitUobl > 0 OR EXTDebitMedical:DebitUint > 0 OR EXTDebitMedical:DebitCobl > 0 OR EXTDebitMedical:DebitCint > 0)
    IF EXTDebitMedical:DebitDate<=GLO:CALCDATE   !USING CUT OFF DATE  MA 3/5/02
      CLEAR(ReportQueue)
      RPQ:ObligationType = 'Medical'
      RPQ:Date = EXTDebitMedical:DebitDate
      RPQ:DateFormatted = FORMAT(EXTDebitMedical:DebitDate, @d2)
      RPQ:Type = 'D'
      RPQ:AmountP = 0
      RPQ:AmountO = EXTDebitMedical:DebitUobl !0
      RPQ:UnpaidBalance = EXTDebitMedical:DebitUobl !0
      RPQ:DebitUobl = EXTDebitMedical:DebitUobl
      RPQ:DebitUint = EXTDebitMedical:DebitUint
      RPQ:DebitCobl = EXTDebitMedical:DebitCobl
      RPQ:DebitCint = EXTDebitMedical:DebitCint
      RPQ:TypeSort = 5
      RPQ:dummybyte = 0                       !Nikita - added to differentiate row
      RPQ:IsDummyProcess = 0
      RPQ:DebitMessage = 'DEBIT'           !This is printed on the del report
      RPQ:REDUCEDAMOUNT=0
      RPQ:IsJudgement = 0
      ADD(ReportQueue)
      
      !Nikita - Check if same date debit present for Child/Dental type or not, if not then add it
      IF EXTDebitChild:DebitDate <> EXTDebitMedical:DebitDate  
        !Niktia - Add child debit row
        DebugCL.Send('1. Load DebitMedical - Added child dummy debit row ')
        RPQ:ObligationType = 'Child'
        RPQ:Date = EXTDebitMedical:DebitDate
        RPQ:DateFormatted = FORMAT(EXTDebitMedical:DebitDate, @d2)
        RPQ:Type = 'D'
        RPQ:AmountP = 0
        RPQ:AmountO = 0
        RPQ:UnpaidBalance = 0
        RPQ:DebitUobl = 0
        RPQ:DebitUint = 0
        RPQ:DebitCobl = 0
        RPQ:DebitCint = 0
        RPQ:TypeSort = 4
        RPQ:dummybyte = 1  
        RPQ:IsDummyProcess = 1
        RPQ:DebitMessage = 'DEBIT'           
        RPQ:REDUCEDAMOUNT=0
        RPQ:IsJudgement = 0
        ADD(ReportQueue)
      END
      !Check if Detals need to add as dummy, as well not added already from Load Child Debit
      DebugCL.Send('2.0 Load DebitMedical - EXTDebitChild:DebitDate : ' & EXTDebitChild:DebitDate)
      IF EXTDebitDental:DebitDate <> EXTDebitMedical:DebitDate AND EXTDebitMedical:DebitDate <> EXTDebitChild:DebitDate 
        !Niktia - Add dental debit row
        DebugCL.Send('2. Load DebitMedical - Added dental dummy debit row ')
        RPQ:ObligationType = 'Dental'
        RPQ:Date = EXTDebitMedical:DebitDate
        RPQ:DateFormatted = FORMAT(EXTDebitMedical:DebitDate, @d2)
        RPQ:Type = 'D'
        RPQ:AmountP = 0
        RPQ:AmountO = 0
        RPQ:UnpaidBalance = 0
        RPQ:DebitUobl = 0
        RPQ:DebitUint = 0
        RPQ:DebitCobl = 0
        RPQ:DebitCint = 0
        RPQ:TypeSort = 6
        RPQ:dummybyte = 1   
        RPQ:IsDummyProcess = 1
        RPQ:DebitMessage = 'DEBIT'           
        RPQ:REDUCEDAMOUNT=0
        RPQ:IsJudgement = 0
        ADD(ReportQueue)
      END
      !Nikita - END
    END
  END
  CLEAR(RPQ:DebitMessage) !this was still set as payments and final was processed
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
LoadDebitDental   ROUTINE
!-------------------------------

  !!!I've commented out reading the debit file record because its buffer
  !  is already current
!  EXT:CaseID = CAS:CaseID
!  SET(EXT:CaseKey,EXT:CaseKey)
!  NEXT(EXTRA)
!  IF ~ERRORCODE() AND EXT:CaseID = CAS:CaseID
  IF RPQ:DATE > 0 AND |
    (EXTDebitDental:DebitUobl > 0 OR EXTDebitDental:DebitUint > 0 OR EXTDebitDental:DebitCobl > 0 OR EXTDebitDental:DebitCint > 0)
    IF EXTDebitDental:DebitDate<=GLO:CALCDATE   !USING CUT OFF DATE  MA 3/5/02
      CLEAR(ReportQueue)
      RPQ:ObligationType = 'Dental'     
      RPQ:Date = EXTDebitDental:DebitDate
      RPQ:DateFormatted = FORMAT(EXTDebitDental:DebitDate, @d2)
      RPQ:Type = 'D'
      RPQ:AmountP = 0
      RPQ:AmountO = EXTDebitDental:DebitUobl !0
      RPQ:UnpaidBalance = EXTDebitDental:DebitUobl !0
      RPQ:DebitUobl = EXTDebitDental:DebitUobl
      RPQ:DebitUint = EXTDebitDental:DebitUint
      RPQ:DebitCobl = EXTDebitDental:DebitCobl
      RPQ:DebitCint = EXTDebitDental:DebitCint
      RPQ:TypeSort = 6
      RPQ:dummybyte = 0                       !Nikita - added to differentiate row
      RPQ:IsDummyProcess = 0
      RPQ:DebitMessage = 'DEBIT'           !This is printed on the del report
      RPQ:REDUCEDAMOUNT=0
      RPQ:IsJudgement = 0
      ADD(ReportQueue)
      
      !Nikita - Check if same date debit present for Child/Medical type or not, if not then add it
      IF EXTDebitChild:DebitDate <> EXTDebitDental:DebitDate AND EXTDebitMedical:DebitDate <> EXTDebitDental:DebitDate 
        !Niktia - Add child debit row
        DebugCL.Send('1. Load DebitDental - Added child dummy debit row ')
        RPQ:ObligationType = 'Child'
        RPQ:Date = EXTDebitDental:DebitDate
        RPQ:DateFormatted = FORMAT(EXTDebitDental:DebitDate, @d2)
        RPQ:Type = 'D'
        RPQ:AmountP = 0
        RPQ:AmountO = 0
        RPQ:UnpaidBalance = 0
        RPQ:DebitUobl = 0
        RPQ:DebitUint = 0
        RPQ:DebitCobl = 0
        RPQ:DebitCint = 0
        RPQ:TypeSort = 4
        RPQ:dummybyte = 1    
        RPQ:IsDummyProcess = 1
        RPQ:DebitMessage = 'DEBIT'           
        RPQ:REDUCEDAMOUNT=0
        RPQ:IsJudgement = 0
        ADD(ReportQueue)
      END
      
      IF EXTDebitMedical:DebitDate <> EXTDebitDental:DebitDate AND EXTDebitDental:DebitDate <> EXTDebitChild:DebitDate
        !Niktia - Add medical debit row
        DebugCL.Send('2. Load DebitDental - Added medical dummy debit row')
        RPQ:ObligationType = 'Medical'
        RPQ:Date = EXTDebitDental:DebitDate
        RPQ:DateFormatted = FORMAT(EXTDebitDental:DebitDate, @d2)
        RPQ:Type = 'D'
        RPQ:AmountP = 0
        RPQ:AmountO = 0
        RPQ:UnpaidBalance = 0
        RPQ:DebitUobl = 0
        RPQ:DebitUint = 0
        RPQ:DebitCobl = 0
        RPQ:DebitCint = 0
        RPQ:TypeSort = 5
        RPQ:dummybyte = 1     
        RPQ:IsDummyProcess = 1
        RPQ:DebitMessage = 'DEBIT'           
        RPQ:REDUCEDAMOUNT=0
        RPQ:IsJudgement = 0
        ADD(ReportQueue)
      END
      !Nikita - END
    END
  END
  CLEAR(RPQ:DebitMessage) !this was still set as payments and final was processed
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
Cint                ROUTINE         !Calculate interest on confirmed obligation
!----------------------
!@Parth - FB28903
DATA
RTN:CurrentObligationTotals   &GLO:TotalsGroupType
CODE
    
  GET(ReportQueue,QCOUNTER)
  RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 

  DebugCL.Send('Cint Routine Start - QCOUNTER : ' & QCOUNTER & ', RTN:CurrentObligationTotals.ConfirmedPrincipalBalance: ' & RTN:CurrentObligationTotals.ConfirmedPrincipalBalance)
  IF RTN:CurrentObligationTotals.ConfirmedPrincipalBalance <= 0
    EXIT
  END

  IF RPQ:DATE <= RTN:CurrentObligationTotals.DateRendered                !Actually had a customer who called and had
    EXIT                                         ! a judgment that was later than the first
  END                                            ! obligation - this addresses that

  IF QCounter = 1                                !If this is the first record
    !Nikita  - Passed False
    util.GetNextReportQueueObligationType('CHILD',0, FALSE)
    !Nikita - End
    if ~ErrorCode()
      util.SetNamAndAttyObjects('CHILD')
      IF NAM:InterestType='COMPOUND'
        DO FirstCompound
      ELSE
        RTN:CurrentObligationTotals.ConfirmedInterestBalance=0
        GLO:Totals:ConfirmedInterestBalance = 0
        RTN:CurrentObligationTotals.CompoundBalance = 0
      END
    END
    
    util.GetNextReportQueueObligationType('MEDICAL',0, FALSE)
    if ~ErrorCode()
      util.SetNamAndAttyObjects('MEDICAL')
      IF NAM:InterestType='COMPOUND'
        DO FirstCompound
      ELSE
        RTN:CurrentObligationTotals.ConfirmedInterestBalance=0
        GLO:Totals:ConfirmedInterestBalance = 0
        RTN:CurrentObligationTotals.CompoundBalance = 0
      END
    END
    
    util.GetNextReportQueueObligationType('DENTAL',0, FALSE)
    if ~ErrorCode()
      util.SetNamAndAttyObjects('DENTAL')
      IF NAM:InterestType='COMPOUND'
        DO FirstCompound
      ELSE
        RTN:CurrentObligationTotals.ConfirmedInterestBalance=0
        GLO:Totals:ConfirmedInterestBalance = 0
        RTN:CurrentObligationTotals.CompoundBalance = 0
      END
    END    
  ELSE
    !If not the first record
    DebugCL.Send('Cint Routine - RPQ:ObligationType: ' & RPQ:ObligationType )
    util.SetNamAndAttyObjects(UPPER(RPQ:ObligationType))
    IF NAM:InterestType='COMPOUND' and RPQ:Date |  !If it's been a year since compounding
      - RTN:CurrentObligationTotals.LastCompoundDate >= 365                ! and the user wants to compound, this
      ! routine will calculate interest up to
      DO CompoundInterest                          ! the date where interest is compounded
      ! and then set the following variables:
      !  GLO:Totals:ConfirmedLastDate
      !  GLO:ConfirmedInterestBalance
      GET(ReportQueue,QCOUNTER)
      RTN:CurrentObligationTotals.ConfirmedPrincipalBalance=RPQ:Cobl
      GLO:Totals:ConfirmedPrincipalBalance=RPQ:Cobl
    ELSE
      DebugCL.Send('1.1 Cint: before GetPrev: RPQ:ObligationType: ' & RPQ:ObligationType & ', QCOUNTER: ' & QCOUNTER)
      !Nikita - Added IncludePayment to false
      Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), -1, FALSE)
      !Niktia - End
      IF ERRORCODE()
        DebugCL.Send('1.2 Cint:Inside Error before GetPrev: RPQ:ObligationType: ' & RPQ:ObligationType & ', QCOUNTER: ' & QCOUNTER)
        MESSAGE('ERROR calculating interest on confirmed interest.'|
          & ' The printout may not be correct. QCounter: ' & QCOUNTER,,ICON:EXCLAMATION, |
          BUTTON:OK,BUTTON:OK)
        EXIT
      END
      DebugCL.Send('1.3 Cint : RPQ:Cobl: ' & RPQ:Cobl)
      RTN:CurrentObligationTotals.ConfirmedLastDate = RPQ:Date
      RTN:CurrentObligationTotals.ConfirmedPrincipalBalance=RPQ:Cobl
      !Nikita Change
      GLO:Totals:ConfirmedLastDate = RPQ:Date
      !Nikita Change End
      GLO:Totals:ConfirmedPrincipalBalance=RPQ:Cobl
      
      RTN:CurrentObligationTotals.ConfirmedInterestBalance=RPQ:Cint
      GLO:Totals:ConfirmedInterestBalance=RPQ:Cint
      DebugCL.Send('1.1 Cint: before GetPrev: RPQ:ObligationType: ' & RPQ:ObligationType & ', QCOUNTER: ' & QCOUNTER)
    END
  END
    
  GET(ReportQueue,QCounter)
  RPQ:Cint = RTN:CurrentObligationTotals.ConfirmedInterestBalance                      
  RPQ:Cobl = RTN:CurrentObligationTotals.ConfirmedPrincipalBalance 
  DebugCL.Send('Cint RPQ:Cobl: '& RPQ:Cobl)
  RTN:CurrentObligationTotals.DailyRate = ((RTN:CurrentObligationTotals.CompoundBalance + |
    RTN:CurrentObligationTotals.ConfirmedPrincipalBalance) * RTN:CurrentObligationTotals.ConfIntRate) / 365
  RTN:CurrentObligationTotals.Days = RPQ:Date - RTN:CurrentObligationTotals.ConfirmedLastDate
  RTN:CurrentObligationTotals.NewInterest = RTN:CurrentObligationTotals.DailyRate * RTN:CurrentObligationTotals.Days

  IF RTN:CurrentObligationTotals.NewInterest > 0
    RPQ:Cint += RTN:CurrentObligationTotals.NewInterest
  END

  !Nikita - Enable below line for before 2010 case 
  IF LOC:DoApplyPayment AND PBalance
    IF PBalance >= RPQ:Cint                     !If balance of pmt will
      PBalance -= RPQ:Cint                      ! will pay off this int
      RPQ:AplCint = RPQ:Cint                    ! save amount paid
      RPQ:AmountP += RPQ:Cint
      RPQ:Cint = 0                              ! and set balance at 0
      
    ELSE                                        !If won' pay off the interest
      RPQ:Cint -= PBalance                      ! reduce the interest balance by the payment left
      RPQ:AplCint = PBalance                    ! store the amount applied
      RPQ:AmountP += PBalance
      PBalance = 0                              ! then set the payment left to 0
    END
  END
  !Nikita - End

  IF RPQ:Cint < RTN:CurrentObligationTotals.CompoundBalance             !As obligor pays off interest, if he pays off
    RTN:CurrentObligationTotals.CompoundBalance = RPQ:Cint              ! all that has accrued this year, this makes sure
  END                                           ! that the compounded interest is paid off as he
  ! makes further payments


  PUT(ReportQueue)                              !Save the changes so far
  IF ERRORCODE()
    MESSAGE('ERROR saving interest calculation on unconfirmed interest.'|
      & ' The printout may not be correct.',,ICON:EXCLAMATION, |
      BUTTON:OK,BUTTON:OK)
  END
    
  GET(ReportQueue,QCounter)                     !Reactivate the current
  ! record

!-------------------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
Uint    ROUTINE         !Calculate interest on unconfirmed obligation
!input: ReportQ
!       QCounter = pointer into reportq of the record we are to calc interest to,assume it points to an obligations
!----------------------
  data
basedate long,auto    !date of record we are calc interest to - QCounter is its pointer
rtn:ptr  long,auto    !junk pointer variable - can be clear,reused - dont assume it has any particular value
StartDate long,auto   !date of the record to start int calc from
enddate long,auto   !intermediate date we calc with
!@Parth - FB28903
RTN:CurrentObligationTotals &GLO:TotalsGroupType
rtn:ObligationType  string(7)
LOC:AddedDelAmt      LONG
!@Parth
  code
    GET(ReportQueue,QCOUNTER)

    rtn:ObligationType = UPPER(RPQ:ObligationType)
    RTN:CurrentObligationTotals &= (Util.GetObligationTotals( rtn:ObligationType)) 
    BaseDate=RPQ:Date
    
    DebugCL.Send('1 Uint Start - rtn:ObligationType: ' & rtn:ObligationType & ', basedate: ' & format(basedate, @D2) & ', QCOUNTER: ' & QCOUNTER)
    DebugCL.Send('1.1 Uint -  RTN:CurrentObligationTotals.UnconfirmedPrincipalBalance: ' & RTN:CurrentObligationTotals.UnconfirmedPrincipalBalance)
      
    IF COMMAND('/LOG')
      logcl.writeline(,'') !blank separator line
      logcl.writeline(,'')
      Logcl.writeline(,'Call UInt for basedate='&format(RPQ:Date,@D2) & ' Pbalance='&pBalance & ' unpaidbal='&rpq:unpaidbalance)
    END  ! Move below condition out of the log condition 
    
    DebugCL.Send('2 Uint - Pbalance: ' & pBalance & ', RPQ:unpaidbalance: ' & RPQ:unpaidbalance)
    
    if qcounter>1 then
          !get(ReportQueue,Qcounter-1)
          
          !Nikita - Modify include payment parameter
          !Util.GetPreviousReportQueueObligationType(rtn:ObligationType, -1)
          Util.GetPreviousReportQueueObligationType(rtn:ObligationType, -1, FALSE)
          !Nikita - End
          logcl.writeline(,'delbalbefore='&RPQ:DelBalBefore & '  Delbalafter='&RPQ:DelBalAfter)
          Debugcl.send('3 Uint Previous result delbalbefore='&RPQ:DelBalBefore & '  Delbalafter='&RPQ:DelBalAfter & ', RPQ:Cobl: ' & RPQ:Cobl & ', POINTER(ReportQueue): ' & POINTER(ReportQueue) )
          get(ReportQueue,Qcounter)
    end
    !set the delinquent date = 1st day interest will be charged
    !if delinquency date is before 9/1 then set to 9/1
      
    case RPQ:Type
    of 'D'
    orof 'O'
    orOF 'F'
      DebugCL.Send('3.1 UInt Before - RPQ:Date : ' & format(RPQ:Date ,@d2) & ', RpQ:DelDate: ' & format(RpQ:DelDate ,@d2) )
      RpQ:DelDate = RPQ:Date + 30
      if RPQ:DelDate < 69643 then RPQ:DelDate = 69643.  !allow for 9/1 as earliest
      DebugCL.Send('4 UInt Before Put - Modify RPQ:DelDate RpQ:DelDate : ' & format(RpQ:DelDate ,@d2) )
      put(ReportQueue)
    of 'P'
      RPQ:DelDate=RPQ:Date
      !Nikita - Added to save the modified date
      !put(ReportQueue)
      !Nikita - End
    end

    IF RPQ:Date< 69643 THEN
      IF COMMAND('/LOG')
        logcl.writeline(,'exit uint because before 9-1-91')
      END
      Debugcl.Send('5 UInt exit uint because before 9-1-91')
      EXIT
    END            !No interest accrues on obls
                                          ! before Sept 1, 1991
                                          !also this will never become delinquent so delinquent date can stay 0

    IF RPQ:Uobl <= 0 THEN
      IF COMMAND('/LOG')
        logcl.writeline(,'exit uint because unconfirmed obligation=0')
      END
      Debugcl.send('6 Uint exit uint because unconfirmed obligation=0')
      EXIT
    END                  !If no obligation due, can't be interest and delbalbefore/after must be 0 too
  
!!    !IF FIRST RECORD EXIT
!!    !Nikita - Passing Include payment to "false" 
!!    Util.GetNextReportQueueObligationType(UPPER(rtn:ObligationType), 0, FALSE)
!!    !Nikita - End
!!    DebugCL.Send('7 Uint POINTER(ReportQueue): ' & POINTER(ReportQueue))
!!    IF ERRORCODE() or pointer(ReportQueue) = QCOUNTER
!!      IF COMMAND('/LOG')  
!!        logcl.writeline(,'exit uint because on line 1')
!!      END
!!      Debugcl.Send('8 exit uint because on line 1')
!!      EXIT                                        ! interest if this is the
!!    END                                           ! first record

    IF QCOUNTER = 1                               !Can't be any unconfirmed
      compile('***',debugflag)
      logcl.writeline(,'exit uint because on line 1')
      ***
      EXIT
    END

    !calc the obligation amount
    get(ReportQueue,Qcounter)
    !get the obligation for the current record but will probably be overwritten below
    CASE CLIP(RPQ:Frequency)        !GET MONTHLY OBLIGATION OF CURRENT RECORD  MA 2/22/02
    OF 'Monthly'
      MonthlyOblSub =RPQ:AmountO
    OF 'Semi-monthly'
      MonthlyOblSub=RPQ:AmountO*2
    OF 'Weekly'
      MonthlyOblSub=(RPQ:AmountO*52)/12
    OF 'Bi-weekly'
      MonthlyOblSub=(RPQ:AmountO*26)/12
    ELSE
      MonthlyOblSub=0
    END

    Debugcl.Send('9 UINT - CLIP(RPQ:Frequency): ' & CLIP(RPQ:Frequency) & ', RPQ:AmountO: ' & RPQ:AmountO & ', MonthlyOblSub: ' & MonthlyOblSub )
    
    !during 2003 revisions I was told to change to the prior month monthly obligation
    !  for ALL cases NOT just for the final line or if Rpq:type<>'O'

    !  if MonthlyOblSub=0 or RPQ:Type<>'O' then
    !for the final line or other line without an amountO, get the monthly obligation by looping backward
    LOOP
      DebugCL.Send('1 UInt Loop POINTER(ReportQueue): ' & POINTER(ReportQueue))
      !get the previous record
      IF POINTER(ReportQueue) = 1 
        BREAK
      END      
      !get(ReportQueue, pointer(ReportQueue)-1)
      !Nikita - Added IncludePayment condition faslse in below call
      Util.GetPreviousReportQueueObligationType(rtn:ObligationType, Pointer(ReportQueue), FALSE)
      !Niita - End
      If ERRORCODE()
        BREAK
      END
      
      if RPQ:Type='O' then
        CASE CLIP(RPQ:Frequency)        !GET MONTHLY OBLIGATION OF CURRENT RECORD  MA 2/22/02
        OF 'Monthly'
          MonthlyOblSub=RPQ:AmountO
        OF 'Semi-monthly'
          MonthlyOblSub=RPQ:AmountO*2
        OF 'Weekly'
          MonthlyOblSub=(RPQ:AmountO*52)/12
        OF 'Bi-weekly'
          MonthlyOblSub=(RPQ:AmountO*26)/12
        ELSE
          MonthlyOblSub=0
        END
      end
      DebugCL.Send('2 UInt Loop MonthlyOblSub: ' & MonthlyOblSub)
      IF MonthlyOblSub > 0 and RPQ:Type='O' 
        DebugCL.Send('Uint Break')
        BREAK
      END      
    END !Loop 1 end
    
!  end
    !Niktia - Comment log detrails to avoid repetative work
!    IF COMMAND('/LOG')
!      Get(ReportQueue,Qcounter)
!      logcl.writeline(,'BaseDate='&format(RPQ:date,@d2)&' monthlyobl='&Monthlyoblsub)
!    END
    !Niktia - END
    Get(ReportQueue,Qcounter)
    Debugcl.Send('3 Uint loop BaseDate= ' & format(RPQ:date,@d2) & ' monthlyobl= ' & Monthlyoblsub & ', Qcounter: ' & Qcounter)

    !get stuff from the previous record
    !GET(ReportQueue,QCOUNTER-1)
    !Nikita - Check if need to pass IncludePayment as FALSE
    Util.GetPreviousReportQueueObligationType(rtn:ObligationType,QCOUNTER, FALSE)
    IF ERRORCODE()
      MESSAGE('ERROR calculating interest on unconfirmed interest.'|
        & ' The printout may not be correct. 2QCOUNTER' & QCOUNTER,,ICON:EXCLAMATION, |
        BUTTON:OK,BUTTON:OK)
      GET(ReportQueue,QCOUNTER)
      EXIT
    END
  
    IF RPQ:Type = 'P'
      DebugCL.Send('UINT To test PTQ:Type -' & RPQ:Type & ', RPQ:deldate: ' & RPQ:deldate & ', RPQ:deldate: ' & Format(RPQ:deldate, @d2))
    END
    
    DebugCL.Send('4 UInt Loop QCOUNTER: ' & QCOUNTER & ', POINTER(ReportQueue): ' & POINTER(ReportQueue) & ', RPQ:Uobl: ' & RPQ:Uobl )
    
    RTN:CurrentObligationTotals.UnconfirmedPrincipalBalance = RPQ:Uobl
    DebugCL.Send('5 UInt Loop BaseDate : ' & format(BaseDate,@d2) & ', FirstTimeIn2000: ' & FirstTimeIn2000 & ', RPQ:DelBalAfter ' & RPQ:DelBalAfter)
    if BaseDate>=D010100 and FirstTimeIn2000=False
      !first time in 2000, look at the previous (last time in 1999) delbalbefore to see if its a credit
      ! if is a credit, copy it over to DelBalAfter
      ! this is like providing a starting balance for DelBalAfter and closing out DelBalBefore
      FirstTimeIn2000 = True
      if RPQ:DelBalBefore<0 then
        !credit balance at the end of 1999
        RTN:CurrentObligationTotals.DelBalBefore = 0
        RTN:CurrentObligationTotals.DelBalAfter = RPQ:DelBalAfter + RPQ:DelBalBefore
      end
    else
      !this is the normal case - just save the delinquent balances to the variable
      DebugCL.Send('5.0 Uint ')
      RTN:CurrentObligationTotals.DelBalBefore = RPQ:DelBalBefore
      RTN:CurrentObligationTotals.DelBalAfter = RpQ:DelbalAFter
    end
    
    DebugCL.Send('5 UInt RTN:CurrentObligationTotals.DelBalAfter: ' & RTN:CurrentObligationTotals.DelBalAfter & ', RpQ:DelbalAFter: ' & RpQ:DelbalAFter )
    DebugCL.Send('5.1 UInt Pointer: ' & POINTER(ReportQueue) & ', RPQ:AmountP: ' & RPQ:AmountP)
    !RTN:CurrentObligationTotals.UnconfirmedInterestBalance = RPQ:Uint
    RTN:CurrentObligationTotals.UnconfirmedInterestBalance = RPQ:Uint
    RTN:CurrentObligationTotals.UnconfirmedLastDate = RPQ:DATE
    StartDate = RPQ:Date
    
    IF RTN:CurrentObligationTotals.UnconfirmedLastDate < 69643 then !69643= 9/1/91 = earliest day to cal int from
      RTN:CurrentObligationTotals.unconfirmedLastDate = 69643
    end

    IF COMMAND('/LOG')
      logcl.writeline(,'startDate='&format(startdate,@d2)& ' delbalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' delbalafter='&RTN:CurrentObligationTotals.DelBalAfter)
    END
    DebugCl.Send('startDate= ' & format(startdate,@d2) & ' delbalbefore= ' & RTN:CurrentObligationTotals.DelBalBefore & ' delbalafter= ' & RTN:CurrentObligationTotals.DelBalAfter)
 
    !1st find the first record not in the delinquent balance was calculated then get the next record
    Get(ReportQueue, QCOUNTER)
    DebugCL.Send('6 UInt Loop QCOUNTER : ' & QCOUNTER)
    
    LOOP !Loop 2
      DebugCL.Send('7 UInt Loop 2 - Pointer(ReportQueue) : ' & Pointer(ReportQueue))
      !Nikita - Check if need to pass IncludePayment as FALSE
      Util.GetPreviousReportQueueObligationType(rtn:ObligationType, Pointer(ReportQueue), FALSE)
      If ERRORCODE()
        !GET FIRST ONE
        Util.GetNextReportQueueObligationType(rtn:ObligationType, 0, FALSE)
        BREAK
      END 
      DebugCL.Send('8 UInt Loop 2 - Pointer(ReportQueue) : ' & Pointer(ReportQueue))
      IF RPQ:interestFlag 
        !go foward and get the 1st one with no interest flag
        !Get(ReportQueue,Rtn:ptr+1)
        Util.GetNextReportQueueObligationType(rtn:ObligationType, Pointer(ReportQueue), FALSE)
        BREAK
      END 
      DebugCL.Send('9 UInt Loop 2 - Pointer(ReportQueue) : ' & Pointer(ReportQueue))
    END !Loop 2 end

    IF COMMAND('/LOG')
      logcl.writeline(,'First record not in delinquent balance is: ' &format(RPQ:Date,@d2))
    END
    DEbugcl.Send('10 UInt - First record not in delinquent balance is: ' &format(RPQ:Date,@d2) & ':position=' & pointer(ReportQueue))

    !now come foward and calculate
    !startdate is already set to the date of the previous record
    RTN:CurrentObligationTotals.NewInterest=0
    
    LOOP !Start of Loop 3
    !exit if we hit the base row we are calculating to
    !Enddate is where we have calculated interest up to
    !RTN:CurrentObligationTotals.DelBalBefore/after are the current delbalances
      Debugcl.Send('11 Unit Loop 3 - Processing pointer:'& POINTER(ReportQueue) & '   Against Counter:' & QCounter)
      IF POINTER(ReportQueue) = Qcounter 
        DebugCL.Send('11.1 UInt Loop 3 - Break')
        BREAK
      END    

      CASE RPQ:Type
      OF 'D'
      OROF 'F'
      OROF 'O'
!        !Nikita- TODO
!        LOC:AddedDelAmt = 0
!        !Nikita - END
        !see if this record is delinquent
        DebugCL.Send('11.2 Loop 3: BaseDate: ' & Format(BaseDate,@d2) & ', RPQ:DelDate: ' & Format(RPQ:DelDate,@d2) & ', Pointer: ' &  POINTER(ReportQueue))
        
         IF RPQ:DelDate < BaseDate THEN 
          !its delinquent
          IF COMMAND('/LOG')
            logcl.writeline(,'Newly delinquent: 42' & Format(RPQ:Date,@d2) & ' on: '& format(RPQ:DelDate,@d2) & ' unpaidbal='& RPQ:unpaidBalance)
          END
          Debugcl.Send('12 Uit Loop 3- Newly delinquent: ' & Format(RPQ:Date,@d2) & ' on: '& format(RPQ:DelDate,@d2) & ' unpaidbal='& RPQ:unpaidBalance)

          !Nikita - Correct till the line
          
          EndDate = RPQ:Deldate
          RTN:CurrentObligationTotals.Days = EndDate-Startdate !calc by class
          IF COMMAND('/LOG')
            logcl.writeline(,'Start='&format(Startdate,@d2) & ' enddate='&format(enddate,@d2) & ' days='&RTN:CurrentObligationTotals.Days)
          END
          
          Debugcl.Send('13 UInt Loop 3 - Start= ' & format(Startdate,@d2) & ' enddate= '& format(enddate,@d2) & ' days= '& RTN:CurrentObligationTotals.Days)
          Debugcl.Send('13.1 UInt Loop 3 QCOUNTER: ' & QCOUNTER & ', POINTER(ReportQueue): ' & POINTER(ReportQueue) & ', RTN:CurrentObligationTotals.DelBalBefore: ' & RTN:CurrentObligationTotals.DelBalBefore)
          IF RTN:CurrentObligationTotals.Days > 0 then
            
            !RTN:CurrentObligationTotals &= (Util.GetObligationTotals(rtn:ObligationType)) 
            DebugCL.Send('13.2 UInt Loop 3 DelBalBefore: ' & RTN:CurrentObligationTotals.DelBalBefore & ', DelBalAfter: ' & RTN:CurrentObligationTotals.DelBalAfter & ', Days: ' & RTN:CurrentObligationTotals.Days)
            
            IF RTN:CurrentObligationTotals.DelBalBefore > 0
                IntCalcClass.CalcInt(StartDate, EndDate, RTN:CurrentObligationTotals.DelBalBefore, RTN:CurrentObligationTotals.Days, RTN:CurrentObligationTotals.CalcInterest)
                !RTN:CurrentObligationTotals.DailyRate = (RTN:CurrentObligationTotals.DelBalBefore * .06) / 365
                RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
                Debugcl.Send('13.2 UInt 3 - Insite Calculation RTN:CurrentObligationTotals.NewInterest: ' & RTN:CurrentObligationTotals.NewInterest) 
            ELSE
                Debugcl.Send('13.2 UInt 3 - Clear RTN values ') 
                CLEAR(RTN:CurrentObligationTotals.CalcInterest)
            END
            IF COMMAND('/LOG')
              logcl.writeline(,'DelBalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
            END
            DebugCl.Send('14 Unit Loop 3 - DelBalafter= '& RTN:CurrentObligationTotals.DelBalAfter & ' Interest= ' & RTN:CurrentObligationTotals.CalcInterest)
            
            IF RTN:CurrentObligationTotals.DelBalAfter - MonthlyOblsub > 0
              Principle = RTN:CurrentObligationTotals.DelBalAfter - MonthlyoblSub
              IntCalcClass.CalcInt(StartDate,EndDate,Principle,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
              RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
              Debugcl.Send('14.2 UInt 3 - calculate RTN:CurrentObligationTotals.NewInterest: ' & RTN:CurrentObligationTotals.NewInterest) 
            ELSE
              Debugcl.Send('14.2 UInt 3 - Clear RTN values ') 
              CLEAR(RTN:CurrentObligationTotals.CalcInterest)
            END
            
            IF COMMAND('/LOG')
              logcl.writeline(,'DelBalafter='&choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub>0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
            END
            DebugCl.Send('15 Unit Loop 3  - DelBalafter= '& choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub > 0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest= '& RTN:CurrentObligationTotals.CalcInterest)
          END
          RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(rtn:ObligationType)))   

          DebugCl.Send('16 Unit Loop 3  - RTN:CurrentObligationTotals : ' & RTN:CurrentObligationTotals)
          
          DebugCl.Send('16.1 Unit Loop 3  - RPQ:DelDate : ' & FORMAT(RPQ:DelDate,@d2) & ', EndDate: ' & FORMAT(EndDate,@d2))
          !if this calc ended at the delinquent date meaning we are now ready to add it to the balance then do it
          if RPQ:DelDate = EndDate then
            DebugCL.Send('Nikita 1 - Added inside loop RPQ:UnpaidBalance: ' & ', current DelBalAfter: ' &  RTN:CurrentObligationTotals.DelBalAfter )
            if RPQ:Date < D010100 then
              RTN:CurrentObligationTotals.delBalBefore += RPQ:UnpaidBalance
            else
              RTN:CurrentObligationTotals.DelBalAfter  += RPQ:UnpaidBalance
            end
            DebugCL.Send('Nikita 2 - Added inside loop RPQ:UnpaidBalance: ' & ', current DelBalAfter: ' &  RTN:CurrentObligationTotals.DelBalAfter )
            IF COMMAND('/LOG')
              logcl.writeline(,'updatebal DelBalbefore='&RTN:CurrentObligationTotals.DelBalbefore & ' DelBalAfter='& RTN:CurrentObligationTotals.DelBalAfter &' unpaidbal='&RPQ:unpaidbalance)
            END
            !Nikita - Added to solve UINT issue - TODO
!            LOC:AddedDelAmt = RPQ:UnpaidBalance
!!            IF UPPER(RPQ:ObligationType) = 'CHILD'
!!              CurrContextDelAfterAmt[1] = TRUE
!!            ELSIF UPPER(RPQ:ObligationType) = 'MEDICAL'
!!              CurrContextDelAfterAmt[2] = TRUE
!!            ELSIF UPPER(RPQ:ObligationType) = 'DENTAL'
!!              CurrContextDelAfterAmt[3] = TRUE
!!            END
            !END
            Debugcl.Send('updatebal DelBalbefore='&RTN:CurrentObligationTotals.DelBalbefore & ' DelBalAfter='& RTN:CurrentObligationTotals.DelBalAfter &' unpaidbal='&RPQ:unpaidbalance)
          END
          RPQ:interestFlag = True
          
          !DebugCL.Send('17 UInt - Before Put -  RTN:CurrentObligationTotals.delBalBefore : ' &  RTN:CurrentObligationTotals.delBalBefore & ', RTN:CurrentObligationTotals.DelBalAfter : ' & RTN:CurrentObligationTotals.DelBalAfter)
          put(ReportQueue)
          StartDate=Enddate
          
          DebugCL.Send('17 UInt - Before Put - RTN:CurrentObligationTotals.DelBalAfter : ' & RTN:CurrentObligationTotals.DelBalAfter & ', For Next row StartDate: ' & StartDate)
          
        else
          IF COMMAND('/LOG')
            logcl.writeline(,'Not delinquent yet: ' & Format(RPQ:Date,@d2) & ' unpaidbal='& RPQ:unpaidBalance &' deldate='&format(RPQ:deldate,@d2) & ' basedate='&format(basedate,@d2))
          END
          Debugcl.Send('18 UNIT Loop - Not delinquent yet: ' & Format(RPQ:Date,@d2) & ' unpaidbal='& RPQ:unpaidBalance &' deldate='&format(RPQ:deldate,@d2) & ' basedate='&format(basedate,@d2))
        end
      of 'P'
        !EndDate = RPQ:Deldate
        !not an error, just skip it
      else
        !error - it's final or unknow type
        if debugflag then Message('Hit an unknow or bad type during uint calc of: '&rpq:type).
      end
      
      !get the next record
      !THIS LOOP SHOULD WORK BUT IS CAUSING INTREST TO CALCULATE WIERD
      Util.GetNextReportQueueObligationType(UPPER(rtn:ObligationType), Pointer(ReportQueue), FALSE)
      if errorcode() 
        BREAK
      END 
      
      Debugcl.Send('19 UNIT Loop - Pointer(ReportQueue) : ' & Pointer(ReportQueue) & ', RPQ:ObligationType: ' & RPQ:ObligationType & ', rtn:ObligationType: ' & rtn:ObligationType )
    END !End of Loop 3
    !END !Nikita - End of 3 times loop
    
    !reget the current record for the last leg of the interest calc to this date
    !Start is where we have calculated interest up to
    !RTN:CurrentObligationTotals.DelBalBefore/after are the current delbalances
    Get(ReportQueue,QCounter)
    EndDate = BaseDate
    RTN:CurrentObligationTotals.Days=EndDate-Startdate
    IF COMMAND('/LOG')
      logcl.writeline(,'Finalleg Start='&format(Startdate,@d2) & ' enddate='&format(enddate,@d2) & ' days='&RTN:CurrentObligationTotals.Days)
    END
    Debugcl.Send('20 UInt - Finalleg Start='&format(Startdate,@d2) & ' enddate='&format(enddate,@d2) & ' days='&RTN:CurrentObligationTotals.Days)
    RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(rtn:ObligationType)))   

    if RTN:CurrentObligationTotals.Days > 0 then
      if RTN:CurrentObligationTotals.DelBalBefore > 0
        IntCalcClass.CalcInt(StartDate,EndDate,RTN:CurrentObligationTotals.DelBalBefore,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
        RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
      else
        clear(RTN:CurrentObligationTotals.CalcInterest)
      end
      IF COMMAND('/LOG')
        logcl.writeline(,'DelBalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
      END
      Debugcl.Send('21 UInt - DelBalbefore= '& RTN:CurrentObligationTotals.DelBalBefore & ' Interest= '& RTN:CurrentObligationTotals.NewInterest)
      
      if RTN:CurrentObligationTotals.DelBalAfter - MonthlyOblsub > 0
        Principle=RTN:CurrentObligationTotals.DelBalAfter-MonthlyOblSub
        IntCalcClass.CalcInt(StartDate,EndDate,Principle,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
        RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
      else
        clear(RTN:CurrentObligationTotals.CalcInterest)
      end
      IF COMMAND('/LOG')
        logcl.writeline(,'DelBalafter='&choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub>0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
      END
      Debugcl.Send('22 UInt DelBalafter= '&choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub>0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest= '& RTN:CurrentObligationTotals.NewInterest)
    end

    !if this calc ended at the delinquent date meaning we are now ready to add it to the balance then do it
    if RPQ:DelDate = EndDate then
      DebugCL.Send('Nikita 2 - 22.1 UINT inside the UInt issue fix RPQ:UnpaidBalance:' & RPQ:UnpaidBalance & ', DelBalAfter: ' & RTN:CurrentObligationTotals.DelBalAfter )
      !RPQ:REDUCEDAMOUNT = RPQ:UnpaidBalance
      if RPQ:Date < D010100 then
        RTN:CurrentObligationTotals.delBalBefore += RPQ:UnpaidBalance
      else
        RTN:CurrentObligationTotals.DelBalAfter  += RPQ:UnpaidBalance
      end
      DebugCL.Send('Nikita 3 - 22.1 UINT inside the UInt issue fix RPQ:UnpaidBalance:' & RPQ:UnpaidBalance & ', DelBalAfter: ' & RTN:CurrentObligationTotals.DelBalAfter )
      IF COMMAND('/LOG')
        logcl.writeline(,'updatebal DelBalbefore='&RTN:CurrentObligationTotals.DelBalbefore & ' DelBalAfter='& RTN:CurrentObligationTotals.DelBalAfter)
      END
      Debugcl.Send('23 UInt - updatebal DelBalbefore= '&RTN:CurrentObligationTotals.DelBalbefore & ' DelBalAfter= '& RTN:CurrentObligationTotals.DelBalAfter)
    END

    !final update of a few fields then saveit
    RPQ:DelBalBefore = RTN:CurrentObligationTotals.DelBalBefore
    RPQ:DelBalAfter  = RTN:CurrentObligationTotals.DelBalAfter
    
    RPQ:uint  = RTN:CurrentObligationTotals.UnconfirmedInterestBalance + RTN:CurrentObligationTotals.NewInterest
    !Nikita - End
    IF COMMAND('/LOG')
      logcl.writeline(,'Delbalbefore='&RTN:CurrentObligationTotals.DelBalBefore & '  delbalafter='&RTN:CurrentObligationTotals.DelBalAfter & '  newint='&RTN:CurrentObligationTotals.NewInterest & '  intbal='&rpq:uint)
    END
    Debugcl.Send('24 UInt - Delbalbefore= '& RTN:CurrentObligationTotals.DelBalBefore & '  delbalafter = ' & RTN:CurrentObligationTotals.DelBalAfter & '  newint= ' & RTN:CurrentObligationTotals.NewInterest & '  intbal='&rpq:uint)
    
!    IF PBalance
!      IF PBalance >= RPQ:Uint                     !If balance of pmt will
!        PBalance -= RPQ:Uint                      ! will pay off this int
!        RPQ:AplUint = RPQ:Uint                    ! save amount paid
!        RPQ:Uint = 0                              ! and set balance at 0
!      ELSE                                        !If won' pay off the interest
!        RPQ:Uint -= PBalance                      ! reduce the interest balance by the payment left
!        RPQ:AplUint = PBalance                    ! store the amount applied
!        PBalance = 0                              ! then set the payment left to 0
!      END
!    END
    DebugCL.Send('25 UInt Before final put POINTER(ReportQueue): ' & POINTER(ReportQueue) & ', PBalance : ' & PBalance )
    PUT(ReportQueue)                              !Save even if there is no
                                                ! new interest because this
                                                ! is what carries existing
                                                ! interest balance forward

    IF ERRORCODE()
      MESSAGE('ERROR saving interest calculation on unconfirmed interest.'|
        & ' The printout may not be correct.',,ICON:EXCLAMATION, |
        BUTTON:OK,BUTTON:OK)
    END
    
   
    GET(ReportQueue,QCounter)
    Exit


!-----------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
FirstCompound  ROUTINE
!------------------------------
                                                     !This routine handles compounded confirmed
                                                     ! interest from the date of judgement to
                                                     ! the anniversary date that is less than
                                                     ! 365 days from the date of the 1st record

!this updates
! CurrentObligationTotals.LastCompoundDate  = last date compounding was done
! CurrentObligationTotals.ConfirmedLastDate = date to start next interest calc from
! glo:confirmedInterestbalance = total interest charged so far
! CurrentObligationTotals.CompoundBalance  = interest compounded (added to principal for int calc)
   !@Parth - FB28903
  DATA
RTN:CurrentObligationTotals &GLO:TotalsGroupType
  CODE
!@Parth 
    GET(ReportQueue,QCOUNTER)
    RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    RTN:CurrentObligationTotals.LastCompoundDate = RTN:CurrentObligationTotals.ConfirmedLastDate       !Right now, this is the date of judgement

    LOOP                                               !Loop because on the first time
      IF RPQ:Date - RTN:CurrentObligationTotals.LastCompoundDate >= 365        ! there could be more than one year
                                                       ! of interest to compound
        RTN:CurrentObligationTotals.NewInterest = (RTN:CurrentObligationTotals.ConfirmedPrincipalBalance + RTN:CurrentObligationTotals.CompoundBalance) * RTN:CurrentObligationTotals.ConfIntRate 
        
        RTN:CurrentObligationTotals.CompoundBalance += RTN:CurrentObligationTotals.NewInterest
        RTN:CurrentObligationTotals.LastCompoundDate += 365
        CYCLE
      ELSE
        BREAK
      END
    END
    RTN:CurrentObligationTotals.ConfirmedLastDate = RTN:CurrentObligationTotals.LastCompoundDate
    RTN:CurrentObligationTotals.ConfirmedInterestBalance = RTN:CurrentObligationTotals.CompoundBalance
    GLO:Totals:ConfirmedInterestBalance = RTN:CurrentObligationTotals.CompoundBalance
    !Nikita - Added below
    GLO:Totals:ConfirmedLastDate = RTN:CurrentObligationTotals.LastCompoundDate
    !Nikita - End
    
!------------------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
CompoundInterest   ROUTINE
!------------------------------
  DATA
CurrentObligationTotals &GLO:TotalsGroupType
  CODE
                                                !This routine compounds interest on confirmed
                                                ! obligations (judgement).
                                                !If it has been more than a year, it compounds
                                                ! the interest and adds it to the CompoundBalance.
                                                ! Compound balance is a running total of interest
                                                ! which needs to be treated as principal when
                                                ! it comes to calculating interest.

!this updates
! CurrentObligationTotals.LastCompoundDate  = last date compounding was done
! CurrentObligationTotals.ConfirmedLastDate = date to start next interest calc from
! glo:confirmedInterestbalance = total interest charged so far
! loc:compoundBalance  = interest compounded (added to principal for int calc)
    GET(ReportQueue,QCounter)                     !Reactivate the current record
    !   @Parth - FB28903 
    CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
!   @Parth 
    IF RPQ:Date - CurrentObligationTotals.LastCompoundDate < 365
      EXIT
    END

    !calc interest from last records date to the aniversary of the last compounding
    CurrentObligationTotals.LastCompoundDate += 365                       !Increment CurrentObligationTotals.LastCompoundDate

    !get the date for the last record - start interest calc from here
    !GET(ReportQueue,QCOUNTER-1)                      !Calculate interest for the first part of
    !Nikita - Modified below parameters
    !Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType))
    Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), -1, FALSE)
    !Nikita - End
    CurrentObligationTotals.DailyRate = (CurrentObligationTotals.ConfirmedPrincipalBalance |      ! the period before compounding
        + CurrentObligationTotals.CompoundBalance) * CurrentObligationTotals.ConfIntRate / 365
    CurrentObligationTotals.Days = CurrentObligationTotals.LastCompoundDate - RPQ:DATE
    CurrentObligationTotals.NewInterest = CurrentObligationTotals.DailyRate * CurrentObligationTotals.Days
    IF CurrentObligationTotals.NewInterest < 0                                !This is just a precaution to prevent the
      CurrentObligationTotals.NewInterest = 0                                 ! use of a negative number
    END
    CurrentObligationTotals.ConfirmedLastDate = CurrentObligationTotals.LastCompoundDate
    CurrentObligationTotals.ConfirmedInterestBalance = RPQ:Cint + CurrentObligationTotals.NewInterest
    GLO:Totals:ConfirmedInterestBalance = RPQ:Cint + CurrentObligationTotals.NewInterest
    CurrentObligationTotals.CompoundBalance  = CurrentObligationTotals.ConfirmedInterestBalance
    
                                                      !This has now compounded the interest
                                                      ! up to the date of compounding and the
                                                      ! reset the date to that date so that
                                                      ! the regular CINT routine will pick up
                                                      ! from there

    !now see if we are within 1yr of date in the current record (not the last record)
    GET(ReportQueue, Qcounter)
    LOOP
      !if more than a year to current record then compound
      IF RPQ:Date - CurrentObligationTotals.LastCompoundDate >= 365
        !full year interest to compound
        CurrentObligationTotals.NewInterest = (CurrentObligationTotals.ConfirmedPrincipalBalance + CurrentObligationTotals.CompoundBalance) * CurrentObligationTotals.ConfIntRate
        !update my 4 variables
        CurrentObligationTotals.LastCompoundDate  += 365
        CurrentObligationTotals.ConfirmedLastDate += 365
        CurrentObligationTotals.ConfirmedInterestBalance += CurrentObligationTotals.NewInterest
        CurrentObligationTotals.CompoundBalance += CurrentObligationTotals.NewInterest
      ELSE
        BREAK
      END
    END 

!------------------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
FirstCompoundAtty     ROUTINE       !MA CREATED   6/25/01
  DATA
RTN:CurrentObligationTotals &GLO:TotalsGroupType
  CODE
!-----------------------------
                                                     !This routine handles compounded Attyfeescosts
                                                     ! interest from the date of judgement to
                                                     ! the anniversary date that is less than
                                                     ! 365 days from the date of the 1st record
    GET(ReportQueue,QCOUNTER)
    RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    RTN:CurrentObligationTotals.LastCompoundDateAtty = RTN:CurrentObligationTotals.ConfirmedLastDate   !Right now, this is the date of judgement
    LOOP                                               !Loop because on the first time
      IF RPQ:Date - RTN:CurrentObligationTotals.LastCompoundDateAtty >= 365    ! there could be more than one year
                                                       ! of interest to compound
        RTN:CurrentObligationTotals.NewInterest = (RTN:CurrentObligationTotals.AttyfeescostsBalance + RTN:CurrentObligationTotals.CompoundBalanceAtty) * ATT:InterestRate
        RTN:CurrentObligationTotals.CompoundBalanceAtty += RTN:CurrentObligationTotals.NewInterest
        RTN:CurrentObligationTotals.LastCompoundDateAtty += 365
        CYCLE
      ELSE
        BREAK
      END
    END
    
    RTN:CurrentObligationTotals.ConfirmedLastDate = RTN:CurrentObligationTotals.LastCompoundDateAtty
    RTN:CurrentObligationTotals.AttyfeescostsIntBalance = RTN:CurrentObligationTotals.CompoundBalanceAtty   !FIRST TIME IT'S 0
    GLO:Totals:AttyfeescostsIntBalance = RTN:CurrentObligationTotals.CompoundBalanceAtty   !FIRST TIME IT'S 0
    !Nikita - Added below
    GLO:Totals:ConfirmedLastDate =  RTN:CurrentObligationTotals.LastCompoundDateAtty
    !Nikita - End

!-----------------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ProcessLast         ROUTINE
!-----------------------------------------
  !@Parth - FB28903
DATA
RTN:CurrentObligationTotals   &GLO:TotalsGroupType
CurrentCount  LONG
CurrentObligation STRING(7)
oUOBL   DECIMAL(8,2)
oCOBL   DECIMAL(8,2)
oAttFee DECIMAL(8,2)
IsChildPProcess BYTE(0)
CODE
!@Parth 
  DEBUGCL.Send('1. Process Last started')
  !DO Uint
  Calculator.UIntNew(QCounter)
  !DO Cint
  Calculator.CIntNew(QCounter)
  DebugCL.Send('1. Nikita - From ProcessLast')
  Calculator.AttyfeescostsInt(UPPER(RPQ:ObligationType))      !MA ADDED TO CALC ATTYFEESCOSTS INTERESTS  6/25/01
      !MA ADDED TO CALC ATTYFEESCOSTS INTERESTS  6/25/01

  GET(ReportQueue,QCOUNTER)                 !Make sure we have the current
                                              ! record
!   @Parth - FB28903 
  !RTN:CurrentObligationTotals&= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
  CurrentObligation = UPPER(RPQ:ObligationType)
  !Nikita - Get previous obligation to fill below data
  LOOP
    !Get previous 'O' 
    Util.GetPreviousReportQueueObligationType(UPPER(CurrentObligation), POINTER(ReportQueue), FALSE)
    IF UPPER(RPQ:ObligationType) = CurrentObligation  
      oUOBL = RPQ:Uobl
      oCOBL = RPQ:Cobl
      oAttFee = RPQ:Attyfeescosts
      BREAK
    ELSIF POINTER(ReportQueue) <= 1 
      oUOBL = 0
      oCOBL = 0
      oAttFee = 0
      BREAK
    ELSE
      CYCLE
    END
  END
  !Nikita - END
  
  DEBUGCL.Send('2. Process Last Pointer: ' & POINTER(ReportQueue))
  
  GET(ReportQueue,QCOUNTER)
  !  RPQ:Uobl = GLO:UnconfirmedPrincipalBalance + RPQ:AmountO
  RPQ:Uobl = oUOBL + RPQ:AmountO
  !  RPQ:Cobl = GLO:ConfirmedPrincipalBalance
  RPQ:Cobl = oCOBL
  !  RPQ:Attyfeescosts = GLO:AttyfeescostsBalance  !MA ADDED  6/25/01
  RPQ:Attyfeescosts = oAttFee  
  ! @Parth 

  PUT(ReportQueue)                          !Save the changes


[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ProcessDebit        ROUTINE
!-----------------------------------------
  !DO Uint
  Calculator.UIntNew(QCounter)
  !DO Cint
  Calculator.CIntNew(QCOUNTER)

  GET(ReportQueue,QCOUNTER)

      !!!!!ALS on 1/29/97
  IF RPQ:Uobl < 0                            !If there is a credit balance
    IF RPQ:UnpaidBalance - ABS(RPQ:UOBL) <= 0!If credit is greater than
      RPQ:Unpaidbalance = 0                  ! balance, set to 0
    ELSE                                     !otherwise decrement unpaid
      RPQ:Unpaidbalance -= ABS(RPQ:UOBL)     ! balance by amount of credit
    END
  END
  
  
  RPQ:Uobl += RPQ:DebitUobl
    !update the delinquent balances if this obligation/debit been added
    !to the delinquent balances
  if RPQ:InterestFlag then !interestflag true when amt added to delbal
    IF RPQ:DATE<D010100
      RPQ:delbalBefore += RPQ:DebitUobl
    else
      RPQ:delBalafter += RPQ:DebitUobl
    END
  End
  RPQ:Uint += RPQ:DebitUint
  RPQ:Cobl += RPQ:DebitCobl
  DebugCL.Send('ProcessDebit RPQ:Cobl: '& RPQ:Cobl)
  RPQ:Cint += RPQ:DebitCint
  PUT(ReportQueue)

  DebugCL.Send('2. Nikita - From ProcessDebit')
  Calculator.AttyfeescostsInt(UPPER(RPQ:ObligationType))      !MA ADDED TO CALC ATTYFEESCOSTS INTERESTS  6/25/01
      !MA ADDED TO CALC ATTYFEESCOSTS INTERESTS  6/25/01


!-----------------------------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ProcessObligation   ROUTINE
!-----------------------------------------
  DebugCL.Send('0.1 ProcessObligation - QCounter: ' & QCOUNTER)
  !DO Uint
  Calculator.UIntNew(QCOUNTER)
  !DO Cint
  Calculator.CIntNew(QCOUNTER)
  

  GET(ReportQueue,QCOUNTER)

      !!!!!ALS on 1/29/97
  IF RPQ:Uobl < 0                            !If there is a credit balance
    IF RPQ:UnpaidBalance - ABS(RPQ:UOBL) <= 0!If credit is greater than
      RPQ:Unpaidbalance = 0                  ! balance, set to 0
    ELSE                                     !otherwise decrement unpaid
      RPQ:Unpaidbalance -= ABS(RPQ:UOBL)     ! balance by amount of credit
    END
  END
  
  DebugCL.Send('1. ProcessObligation - RPQ:Uobl: ' & RPQ:Uobl & ', RPQ:AmountO: ' & RPQ:AmountO & ', RPQ:REDUCEDAMOUNT: '  & RPQ:REDUCEDAMOUNT )
  RPQ:Uobl += RPQ:AmountO
  !Nikita - Added on 02/17/22 - Reverted on 21st feb 22
  RPQ:Uobl -= RPQ:REDUCEDAMOUNT      !MA ADDED  2/25/02
  !Nikita - End
  
  
  DebugCL.Send('2. ProcessObligation - After RPQ:Uobl: ' & RPQ:Uobl & ', QCOUNTER: ' & QCOUNTER)
  
  !update the delinquent balances if this obligation/debit been added
  !to the delinquent balances
  !if RPQ:InterestFlag then !interestflag true when amt added to delbal
  if RPQ:InterestFlag
    IF RPQ:DATE < D010100
      RPQ:delbalBefore += RPQ:AmountO
      RPQ:delbalBefore -= RPQ:REDUCEDAMOUNT
    else
      RPQ:delBalafter += RPQ:AmountO
      RPQ:DelBalAfter -= RPQ:ReducedAmount
    END
    DebugCL.Send('3. ProcessObligation RPQ:DelBalAfter: ' & RPQ:DelBalAfter)
  ELSE
    DebugCL.Send('4. ProcessObligation RPQ:DelBalAfter: ' & RPQ:DelBalAfter)
  End
  PUT(ReportQueue)

  DebugCL.Send('3. Nikita - From ProcessObligation')
  Calculator.AttyfeescostsInt(UPPER(RPQ:ObligationType))      !MA ADDED TO CALC ATTYFEESCOSTS INTERESTS  6/25/01

[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
LoadPayments        ROUTINE
DATA
IsChildPay      BYTE(1)
IsMedicalPay    BYTE(1)
IsDentalPay     BYTE(1)
CurrentOblType    STRING(7)
TotalRecords    LONG
!-------------------------------------
CODE
  !Nikita - added to solve dummy row
    QOB:Type = 'Child'
    GET(QOBLIGATE,QOB:Type)
    IF ERRORCODE() THEN 
      IsChildPay = 1
    ELSE
      IsChildPay = 0
    END
  
    QOB:Type = 'Medical'
    GET(QOBLIGATE,QOB:Type)
    IF ERRORCODE() THEN 
      IsMedicalPay = 1
    ELSE
      IsMedicalPay = 0
    END
    
    QOB:Type = 'Dental'
    GET(QOBLIGATE,QOB:Type)
    IF ERRORCODE() THEN 
      IsDentalPay = 1
    ELSE
      IsDentalPay = 0
    END
  !Nikita - End
  
  !DebugCL.Send('Load Payments Total Count: ' & RECORDS(QPAYMENTS))
  TotalRecords = 1
  GLO:TotalPayments = 0
  QCOUNTER = 0
  LOOP
    QCOUNTER += 1
    GET(QPAYMENTS,QCOUNTER)
    IF ERRORCODE() 
      BREAK
    END
    !-----STOP TO THE CUT OFF DATE  MA 3/5/02------
    IF QPA:PDate>GLO:CALCDATE
      BREAK
    END
    !----------------------------------------------
    
!!    GET(QOBLIGATE,QCOUNTER)
!!    IF ERRORCODE() 
!!      BREAK
!!    END
    !Nikita - END
    
    CLEAR(ReportQueue)
    RPQ:Date = QPA:PDate
    RPQ:DateFormatted = FORMAT(QPA:PDate, @d2)
    RPQ:Type = 'P'
    RPQ:AmountP = QPA:PAmount
    RPQ:AmountO = 0
    RPQ:UnpaidBalance = 0
    RPQ:REDUCEDAMOUNT=0
    RPQ:dummybyte = 0
    RPQ:IsDummyProcess = 0
    RPQ:TypeSort = 0
    RPQ:AddPossition = TotalRecords
    RPQ:IsJudgement = 0
    ADD(ReportQueue)
    TotalRecords += 1
    !Nikita - Added below
    GLO:TotalPayments += RPQ:AmountP
    
    !Nikita - End
    
    !RPQ:AmountP = 0
    RPQ:ObligationType = 'Child'
    RPQ:TypeSort = 4
    RPQ:AddPossition = TotalRecords
    RPQ:AmountP = 0 !QPA:PAmount ! Nikita - 0 replaced 0 with the QPA:PAmount
    RPQ:dummybyte = IsChildPay
    RPQ:IsDummyProcess = 0
    RPQ:IsJudgement = 0
    ADD(ReportQueue)
    TotalRecords += 1
    
    RPQ:ObligationType = 'Medical'
    RPQ:AmountP = 0
    RPQ:TypeSort = 5
    RPQ:AddPossition = TotalRecords
    RPQ:dummybyte = IsMedicalPay 
    RPQ:IsDummyProcess = 0
    RPQ:IsJudgement = 0
    ADD(ReportQueue)
    TotalRecords += 1
    
    RPQ:ObligationType = 'Dental'
    RPQ:AmountP = 0
    RPQ:TypeSort = 6
    RPQ:AddPossition = TotalRecords
    RPQ:dummybyte = IsDentalPay 
    RPQ:IsDummyProcess = 0
    ADD(ReportQueue) 
    TotalRecords += 1
  END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
LoadObligations   ROUTINE
!-------------------------------------
! @Parth - FB28903
  DATA
RTN:CurrentObligationTotals &GLO:TotalsGroupType
IsChildObl  BYTE(1)
IsMedicalObl    BYTE(1)
IsDentalObl BYTE(1)
PreviousDate    LONG
CurrentOblType  STRING(7)
IsChildDummy  BYTE(1)
IsMedicalDummy    BYTE(1)
IsDentalDummy BYTE(1)
  CODE
  !  GLO:TotalObligations = 0
    GLO:Totals:TotalObligations = 0
    GLO:TotalsChild:TotalObligations = 0
    GLO:TotalsMedical:TotalObligations = 0
    GLO:TotalsDental:TotalObligations = 0

    
    !Nikita - added to solve dummy row
    QOB:Type = 'Child'
    GET(QOBLIGATE,QOB:Type)
    IF ERRORCODE() THEN 
      IsChildDummy = 1
    ELSE
      IsChildDummy = 0
    END
  
    QOB:Type = 'Medical'
    GET(QOBLIGATE,QOB:Type)
    IF ERRORCODE() THEN 
      IsMedicalDummy = 1
    ELSE
      IsMedicalDummy = 0
    END
    
    QOB:Type = 'Dental'
    GET(QOBLIGATE,QOB:Type)
    IF ERRORCODE() THEN 
      IsDentalDummy = 1
    ELSE
      IsDentalDummy = 0
    END
    !Nikita - End
    
    QCOUNTER = 0
    LOOP
      QCOUNTER += 1

      GET(QOBLIGATE,QCOUNTER)
      IF ERRORCODE() 
        BREAK
      END
      RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(QOB:Type)))
      IF QOB:ODate > GLO:CALCDATE
        BREAK
      END
      
      CurrentOblType = QOB:Type
      !Nikita - to add missing obligation for the date
      IF PreviousDate <> QOB:ODate
        RPQ:Date = QOB:ODate
        RPQ:DateFormatted = FORMAT(QOB:ODate, @d2)
        QOB:Type = 'Child'
        GET(QOBLIGATE, QOB:ODate, QOB:Type)
        IF ERRORCODE() THEN 
!          STOP(ERROR()) 
          IsChildObl = 0
        ELSE
          IsChildObl = 1
        END
      
        QOB:Type = 'Medical'
        GET(QOBLIGATE,QOB:ODate, QOB:Type)
        IF ERRORCODE() THEN 
!          STOP(ERROR()) 
          IsMedicalObl = 0
        ELSE
          IsMedicalObl = 1
        END
        
        QOB:Type = 'Dental'
        GET(QOBLIGATE,QOB:ODate, QOB:Type)
        IF ERRORCODE() THEN 
!          STOP(ERROR()) 
          IsDentalObl = 0
        ELSE
          IsDentalObl = 1
        END
        
      ELSE
        IsChildObl = 1
        IsMedicalObl = 1
        IsDentalObl = 1
      END
      !DebugCL.Send('1. Obligation type IsChildObl: ' & IsChildObl & ', IsMedicalObl: ' & IsMedicalObl & ', IsDentalObl: ' & IsDentalObl & ', QOB:ODate: ' & format(QOB:ODate,@d2) )
      !Nikita - End
      GET(QOBLIGATE,QCOUNTER)
      IF ERRORCODE() 
        BREAK
      END
      
     !----------------------------------------------
      IF IsChildObl = 0 !AND (QOB:ODate <> NAMMedical:ConfirmedDate AND QOB:ODate <> NAMDental:ConfirmedDate) 
        Util.DummyRow(QOB:ODate,'Child', QOB:Frequency, IsChildDummy)
      END
      IF IsMedicalObl = 0 !AND (QOB:ODate <> NAMChild:ConfirmedDate AND QOB:ODate <> NAMMedical:ConfirmedDate)
        Util.DummyRow(QOB:ODate,'Medical', QOB:Frequency, IsMedicalDummy)      
      END
      IF IsDentalObl = 0 !AND (QOB:ODate <> NAMChild:ConfirmedDate AND QOB:ODate <> NAMDental:ConfirmedDate)
        Util.DummyRow(QOB:ODate,'Dental', QOB:Frequency, IsDentalDummy)
      END
      
      RPQ:Date = QOB:ODate
      RPQ:DateFormatted = FORMAT(QOB:ODate, @d2)
      RPQ:Type = 'O'
      RPQ:AmountO = QOB:OAmount
      RPQ:UnpaidBalance = QOB:OAmount
      RPQ:AmountP = 0
      RPQ:Frequency=QOB:Frequency       !MA ADDED  2/15/02
      RPQ:REDUCEDAMOUNT=0
      RPQ:ObligationType = QOB:Type
      rpq:deldate=0
      RPQ:DelBalBefore=0
      Rpq:DelBalAfter=0
      IF UPPER(QOB:Type) = 'CHILD'
        RPQ:TypeSort = 4
      ELSIF UPPER(QOB:Type) = 'MEDICAL'  
        RPQ:TypeSort = 5
      ELSIF UPPER(QOB:Type) = 'DENTAL'  
        RPQ:TypeSort = 6
      END
      RPQ:dummybyte=0
      RPQ:IsDummyProcess = 0
      RPQ:IsJudgement = 0
      ADD(ReportQueue)
      
      PreviousDate = QOB:ODate
      
!      DebugCL.Dump(ReportQueue, 'Insude LoadObligations')
      RTN:CurrentObligationTotals.TotalObligations += RPQ:AmountO
    END

[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
LoadDebit   ROUTINE
!-------------------------------

  !!!I've commented out reading the debit file record because its buffer
  !  is already current
!  EXT:CaseID = CAS:CaseID
!  SET(EXT:CaseKey,EXT:CaseKey)
!  NEXT(EXTRA)
!  IF ~ERRORCODE() AND EXT:CaseID = CAS:CaseID
  IF RPQ:DATE > 0 AND |
    (EXT:DebitUobl > 0 OR EXT:DebitUint > 0 OR EXT:DebitCobl > 0 OR EXT:DebitCint > 0)
    IF EXT:DebitDate<=GLO:CALCDATE   !USING CUT OFF DATE  MA 3/5/02
      RPQ:Date = EXT:DebitDate
      RPQ:DateFormatted = FORMAT(EXT:DebitDate, @d2)
      RPQ:Type = 'D'
      RPQ:AmountP = 0
      RPQ:AmountO = Ext:DebitUobl !0
      RPQ:UnpaidBalance = Ext:DebitUobl !0
      RPQ:DebitUobl = EXT:DebitUobl
      RPQ:DebitUint = EXT:DebitUint
      RPQ:DebitCobl = EXT:DebitCobl
      RPQ:DebitCint = EXT:DebitCint
      RPQ:DebitMessage = 'DEBIT'           !This is printed on the del report
      RPQ:REDUCEDAMOUNT=0
      RPQ:IsJudgement = 0
      ADD(ReportQueue)
    END
  END
  CLEAR(RPQ:DebitMessage) !this was still set as payments and final was processed


[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!!UintCal    ROUTINE         !Calculate interest on unconfirmed obligation
!!!***************************************************************************
!!!Ma - Fogbugz case 21376, if payment is On or After January 1, 2010 we call UintNew 
!!! instead of Uint. The UnitNew only calculates the interest not applying payment. 
!!! To apply payment on Uint call ApplyPaymentToUint. 8/6/09
!!!-----------------------
!!!input: ReportQ
!!!       QCounter = pointer into reportq of the record we are to calc interest to,assume it points to an obligations
!!!----------------------
!!  data
!!basedate long,auto    !date of record we are calc interest to - QCounter is its pointer
!!rtn:ptr  long,auto    !junk pointer variable - can be clear,reused - dont assume it has any particular value
!!StartDate long,auto   !date of the record to start int calc from
!!enddate long,auto   !intermediate date we calc with
!!!   @Parth - FB28903
!!RTN:CurrentObligationTotals &GLO:TotalsGroupType
!!!   @Parth
!!code
!!    IF QCOUNTER = 0
!!      RETURN
!!    END
!!    GET(ReportQueue,QCOUNTER)
!!    !   @Parth - FB28903 
!!    RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
!!!   @Parth 
!!  basedate=RPQ:Date
!!
!!  IF COMMAND('/LOG')
!!    logcl.writeline(,'') !blank separator line
!!    logcl.writeline(,'')
!!    Logcl.writeline(,'Call UInt for basedate='&format(RPQ:Date,@D2) & ' Pbalance='&pBalance & ' unpaidbal='&rpq:unpaidbalance)
!!  
!!  END
!!
!!  !Nikita - Pull out belo condition from the above code  
!!  if qcounter>1 then
!!    !get(ReportQueue,Qcounter-1)
!!    !Nikita - Modified below parameters
!!    !Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType))
!!    !Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), -1, FALSE)
!!    !Nikita - End
!!    logcl.writeline(,'delbalbefore='&RPQ:DelBalBefore & '  Delbalafter='&RPQ:DelBalAfter)
!!    get(ReportQueue,Qcounter)
!!  end
!!    
!!  !set the delinquent date = 1st day interest will be charged
!!  !if delinquency date is before 9/1 then set to 9/1
!!  case RPQ:Type
!!  of 'D'
!!  orof 'O'
!!  orOF 'F'
!!    RpQ:DelDate=RPQ:Date+30
!!    if RPQ:DelDate<69643 then RPQ:DelDate=69643.  !allow for 9/1/1991 as earliest
!!    put(ReportQueue)
!!  of 'P'
!!    RPQ:DelDate=RPQ:Date
!!  end
!!
!!  IF RPQ:Date< 69643 THEN
!!    IF COMMAND('/LOG')
!!    logcl.writeline(,'exit uint because before 9-1-91')
!!    END
!!    EXIT
!!  END           !No interest accrues on obls
!!                                          ! before Sept 1, 1991
!!                                          !also this will never become delinquent so delinquent date can stay 0
!!
!!
!!  IF RPQ:Uobl <= 0 THEN
!!    IF COMMAND('/LOG')
!!    logcl.writeline(,'exit uint because unconfirmed obligation=0')
!!    END
!!    EXIT                  !If no obligation due, can't be interest and delbalbefore/after must be 0 too
!!  END
!!
!!  IF QCOUNTER = 1                               !Can't be any unconfirmed
!!    IF COMMAND('/LOG')
!!    logcl.writeline(,'exit uint because on line 1')
!!    END
!!    EXIT                                        ! interest if this is the
!!  END                                            ! first record
!!
!!
!!
!!  !calc the monthly obligation amount
!!  get(ReportQueue,Qcounter)
!!  !get the obligation for the current record but will probably be overwritten below
!!  CASE CLIP(RPQ:Frequency)        !GET MONTHLY OBLIGATION OF CURRENT RECORD  MA 2/22/02
!!  OF 'Monthly'
!!    MonthlyOblSub=RPQ:AmountO
!!  OF 'Semi-monthly'
!!    MonthlyOblSub=RPQ:AmountO*2
!!  OF 'Weekly'
!!    MonthlyOblSub=(RPQ:AmountO*52)/12
!!  OF 'Bi-weekly'
!!    MonthlyOblSub=(RPQ:AmountO*26)/12
!!  ELSE
!!    MonthlyOblSub=0
!!  END
!!
!!!during 2003 revisions I was told to change to the prior month monthly obligation
!!!  for ALL cases NOT just for the final line or if Rpq:type<>'O'
!!
!!!  if MonthlyOblSub=0 or RPQ:Type<>'O' then
!!   !for the final line or other line without an amountO, get the monthly obligation by looping backward
!!    loop
!!      !get the previous record
!!      if Pointer(ReportQueue)=1 then break.
!!      !get(ReportQueue, pointer(ReportQueue)-1)
!!      !Nikita - Add last parmetner
!!      !Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), Pointer(ReportQueue))
!!      Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), Pointer(ReportQueue), FALSE)
!!      !Nikita - End
!!      IF ERRORCODE()
!!        BREAK
!!      END
!!      if RPQ:Type='O' then
!!        CASE CLIP(RPQ:Frequency)        !GET MONTHLY OBLIGATION OF CURRENT RECORD  MA 2/22/02
!!        OF 'Monthly'
!!          MonthlyOblSub=RPQ:AmountO
!!        OF 'Semi-monthly'
!!          MonthlyOblSub=RPQ:AmountO*2
!!        OF 'Weekly'
!!          MonthlyOblSub=(RPQ:AmountO*52)/12
!!        OF 'Bi-weekly'
!!          MonthlyOblSub=(RPQ:AmountO*26)/12
!!        ELSE
!!          MonthlyOblSub=0
!!        END
!!      end
!!      if MonthlyOblSub>0 and RPQ:Type='O' then break.
!!    end
!!!  end
!!  !Nikita - Pull below Get from below log if stateent
!!    Get(ReportQueue,Qcounter)
!!    IF COMMAND('/LOG')
!!      logcl.writeline(,'BaseDate='&format(RPQ:date,@d2)&' monthlyobl='&Monthlyoblsub)
!!    END
!!
!!  !get stuff from the previous record
!!  !GET(ReportQueue,QCOUNTER-1)
!!  !Nikita - pass last parameter
!!  !Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType))
!!  Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), -1, FALSE)
!!  !Nikita - End
!!  IF ERRORCODE()
!!    MESSAGE('ERROR calculating interest on unconfirmed interest.'|
!!          & ' The printout may not be correct.',,ICON:EXCLAMATION, |
!!          BUTTON:OK,BUTTON:OK)
!!    GET(ReportQueue,QCOUNTER)
!!    EXIT
!!  END
!!    !   @Parth - FB28903 
!!!   GLO:UnconfirmedPrincipalBalance = RPQ:Uobl
!!    RTN:CurrentObligationTotals.UnconfirmedPrincipalBalance = RPQ:Uobl
!!    GLO:Totals:UnconfirmedPrincipalBalance = RPQ:Uobl
!!!   @Parth 
!!  if BaseDate>=D010100 and FirstTimeIn2000=False
!!    !first time in 2000, look at the previous (last time in 1999) delbalbefore to see if its a credit
!!    ! if is a credit, copy it over to DelBalAfter
!!    ! this is like providing a starting balance for DelBalAfter and closing out DelBalBefore
!!    FirstTimeIn2000 = True
!!    if RPQ:DelBalBefore<0 then
!!      !credit balance at the end of 1999
!!      RTN:CurrentObligationTotals.DelBalBefore = 0
!!      RTN:CurrentObligationTotals.DelBalAfter=RPQ:DelBalAfter + RPQ:DelBalBefore
!!    end
!!  else
!!    !this is the normal case - just save the delinquent balances to the variable
!!    RTN:CurrentObligationTotals.delbalbefore = RPQ:DelBalBefore
!!    RTN:CurrentObligationTotals.DelBalAfter = RpQ:DelbalAFter
!!  end
!!    
!!    !   @Parth - FB28903 
!!!   GLO:UnconfirmedInterestBalance = RPQ:Uint
!!    RTN:CurrentObligationTotals.UnconfirmedInterestBalance = RPQ:Uint
!!    GLO:Totals:UnconfirmedInterestBalance = RPQ:Uint
!!!   @Parth
!!    RTN:CurrentObligationTotals.UnconfirmedLastDate = RPQ:DATE
!!    GLO:Totals:UnconfirmedLastDate = RPQ:DATE !Nikita Added
!!    
!!    StartDate = RPQ:Date
!!    IF RTN:CurrentObligationTotals.unconfirmedLastDate<69643 then !69643= 9/1/91 = earliest day to cal int from
!!      RTN:CurrentObligationTotals.unconfirmedLastDate = 69643
!!    end
!!
!!    IF COMMAND('/LOG')
!!    logcl.writeline(,'startDate='&format(startdate,@d2)& ' delbalbefore='&RTN:CurrentObligationTotals.delbalbefore & ' delbalafter='&RTN:CurrentObligationTotals.DelBalAfter)
!!    END
!!
!! 
!!    !1st find the first record not in the delinquent balance was calculated then get the next record
!!    !Nikita - Modified as per new code  
!!    !rtn:ptr=QCounter
!!    Get(ReportQueue,QCOUNTER) !Set teh current pointer to QCounter
!!    loop
!!      !push the pointer back one
!!      !Rtn:ptr-=1
!!     
!!      ! if rtn:ptr<1 then
!!!        !start with the 1st record if ran out of records
!!!        Get(ReportQueue,1)
!!!        break
!!!      end
!!      
!!      !Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), -1, FALSE)
!!      Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), POINTER(ReportQueue), FALSE)
!!      IF ERRORCODE()
!!        MESSAGE('ERROR calculating interest on unconfirmed interest.'|
!!              & ' The printout may not be correct.',,ICON:EXCLAMATION, |
!!              BUTTON:OK,BUTTON:OK)
!!        GET(ReportQueue,QCOUNTER)
!!        EXIT
!!      END
!!
!!      Get(ReportQueue,POINTER(ReportQueue))
!!      if RPQ:interestFlag then
!!        !go foward and get the 1st one with no interest flag
!!        !Get(ReportQueue,Rtn:ptr+1)
!!        Util.GetNextReportQueueObligationType(UPPER(RPQ:ObligationType),POINTER(ReportQueue), FALSE)
!!        break
!!      end
!!    end
!!
!!  IF COMMAND('/LOG')
!!  logcl.writeline(,'First record not in delinquent balance is: ' &format(RPQ:Date,@d2))
!!  END
!!
!!  !now come foward and calculate
!!  !startdate is already set to the date of the previous record
!!  RTN:CurrentObligationTotals.NewInterest=0
!!  loop
!!    !exit if we hit the base row we are calculating to
!!    !Enddate is where we have calculated interest up to
!!    !RTN:CurrentObligationTotals.DelBalBefore/after are the current delbalances
!!    if pointer(ReportQueue)=Qcounter then break.
!!
!!    Case RPQ:Type
!!    of 'D'
!!    orof 'F'
!!    orof 'O'
!!      !see if this record is delinquent
!!      if RPQ:DelDate < BaseDate then
!!        !its delinquent
!!        IF COMMAND('/LOG')
!!        logcl.writeline(,'Newly delinquent: ' & Format(RPQ:Date,@d2) & ' on: '& format(RPQ:DelDate,@d2) & ' unpaidbal='& RPQ:unpaidBalance)
!!        END
!!
!!        !process it
!!        enddate=RPQ:Deldate
!!        RTN:CurrentObligationTotals.Days=EndDate-Startdate !calc by class
!!        IF COMMAND('/LOG')
!!          logcl.writeline(,'Start='&format(Startdate,@d2) & ' enddate='&format(enddate,@d2) & ' days='&RTN:CurrentObligationTotals.Days)
!!        END
!!        if RTN:CurrentObligationTotals.Days > 0 then
!!          if RTN:CurrentObligationTotals.DelBalBefore>0
!!            IntCalcClass.CalcInt(StartDate,EndDate,RTN:CurrentObligationTotals.DelBalBefore,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
!!            !RTN:CurrentObligationTotals.DailyRate = (RTN:CurrentObligationTotals.DelBalBefore * .06) / 365
!!            RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
!!          else
!!            clear(RTN:CurrentObligationTotals.CalcInterest)
!!          end
!!          IF COMMAND('/LOG')
!!          logcl.writeline(,'DelBalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
!!          END
!!          if RTN:CurrentObligationTotals.DelBalAfter-MonthlyOblsub>0
!!            Principle=RTN:CurrentObligationTotals.DelBalAfter-MonthlyoblSub
!!            IntCalcClass.CalcInt(StartDate,EndDate,Principle,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
!!            !RTN:CurrentObligationTotals.DailyRate = ((RTN:CurrentObligationTotals.DelBalAfter-MonthlyoblSub) * .06) / 365
!!            RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
!!          else
!!            clear(RTN:CurrentObligationTotals.CalcInterest)
!!          end
!!          IF COMMAND('/LOG')
!!          logcl.writeline(,'DelBalafter='&choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub>0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
!!          END
!!        end
!!
!!        !if this calc ended at the delinquent date meaning we are now ready to add it to the balance then do it
!!        if RPQ:DelDate=EndDate then
!!          if RPQ:Date<D010100 then
!!            RTN:CurrentObligationTotals.DelBalBefore += RPQ:UnpaidBalance
!!          else
!!            RTN:CurrentObligationTotals.DelBalAfter  += RPQ:UnpaidBalance
!!          end
!!          IF COMMAND('/LOG')
!!          logcl.writeline(,'updatebal DelBalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' DelBalAfter='& RTN:CurrentObligationTotals.DelBalAfter &' unpaidbal='&RPQ:unpaidbalance)
!!          END
!!        end
!!        RPQ:interestFlag = True
!!        put(ReportQueue)
!!        StartDate=Enddate
!!      else
!!        IF COMMAND('/LOG')
!!        logcl.writeline(,'Not delinquent yet: ' & Format(RPQ:Date,@d2) & ' unpaidbal='& RPQ:unpaidBalance &' deldate='&format(RPQ:deldate,@d2) & ' basedate='&format(basedate,@d2))
!!        END
!!      end
!!
!!    of 'P'
!!      !not an error, just skip it
!!    else
!!      !error - it's final or unknow type
!!      if debugflag then Message('Hit an unknow or bad type during uint calc of: '&rpq:type).
!!    end
!!    !get the next record
!!    !Get(ReportQueue,Pointer(ReportQueue)+1)
!!    Util.GetNextReportQueueObligationType(UPPER(RPQ:ObligationType),POINTER(ReportQueue), FALSE) !Nikita - added to get next records
!!    if errorcode() then break.
!!  end
!!
!!  !reget the current record for the last leg of the interest calc to this date
!!  !Start is where we have calculated interest up to
!!  !CurrentObligationTotals.DelBalBefore/after are the current delbalances
!!  Get(ReportQueue,QCounter)
!!  EndDate=BaseDate
!!  RTN:CurrentObligationTotals.Days=EndDate-Startdate
!!  IF COMMAND('/LOG')
!!  logcl.writeline(,'Finalleg Start='&format(Startdate,@d2) & ' enddate='&format(enddate,@d2) & ' days='&RTN:CurrentObligationTotals.Days)
!!  END
!!
!!  if RTN:CurrentObligationTotals.Days>0 then
!!    if RTN:CurrentObligationTotals.DelBalBefore>0
!!      IntCalcClass.CalcInt(StartDate,EndDate,RTN:CurrentObligationTotals.DelBalBefore,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
!!      !RTN:CurrentObligationTotals.DailyRate = (RTN:CurrentObligationTotals.DelBalBefore * .06) / 365
!!      RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
!!    else
!!      clear(RTN:CurrentObligationTotals.CalcInterest)
!!    end
!!    IF COMMAND('/LOG')
!!    logcl.writeline(,'DelBalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
!!    END
!!    if RTN:CurrentObligationTotals.DelBalAfter-MonthlyOblsub>0
!!      Principle=RTN:CurrentObligationTotals.DelBalAfter-MonthlyOblSub
!!      IntCalcClass.CalcInt(StartDate,EndDate,Principle,RTN:CurrentObligationTotals.Days,RTN:CurrentObligationTotals.CalcInterest)
!!      !RTN:CurrentObligationTotals.DailyRate = ((RTN:CurrentObligationTotals.DelBalAfter-MonthlyoblSub) * .06) / 365
!!      RTN:CurrentObligationTotals.NewInterest += RTN:CurrentObligationTotals.CalcInterest
!!    else
!!      clear(RTN:CurrentObligationTotals.CalcInterest)
!!    end
!!    IF COMMAND('/LOG')
!!    logcl.writeline(,'DelBalafter='&choose(RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub>0,RTN:CurrentObligationTotals.DelBalAfter-monthlyoblsub,0) & ' Interest='& RTN:CurrentObligationTotals.CalcInterest)
!!    END
!!  end
!!
!!  !if this calc ended at the delinquent date meaning we are now ready to add it to the balance then do it
!!  !if RPQ:DelDate=EndDate then
!!    if RPQ:Date<D010100 then
!!      RTN:CurrentObligationTotals.DelBalBefore += RPQ:UnpaidBalance
!!    else
!!      RTN:CurrentObligationTotals.DelBalAfter  += RPQ:UnpaidBalance
!!    end
!!    IF COMMAND('/LOG')
!!    logcl.writeline(,'updatebal DelBalbefore='&RTN:CurrentObligationTotals.DelBalBefore & ' DelBalAfter='& RTN:CurrentObligationTotals.DelBalAfter)
!!    END
!!    
!!  !end
!!  DebugCL.Send('UINT End - RPQ:UnpaidBalance : ' & RPQ:UnpaidBalance & ', RTN:CurrentObligationTotals.DelBalBefore: ' & RTN:CurrentObligationTotals.DelBalBefore )
!!
!!  !final update of a few fields then saveit
!!  RPQ:DelBalBefore = RTN:CurrentObligationTotals.DelBalBefore
!!  RPQ:DelBalAfter  = RTN:CurrentObligationTotals.DelBalAfter
!!
!!    !   @Parth - FB28903 
!!!   RPQ:uint  = GLO:UnconfirmedInterestBalance + RTN:CurrentObligationTotals.NewInterest
!!    RPQ:uint  = RTN:CurrentObligationTotals.UnconfirmedInterestBalance + RTN:CurrentObligationTotals.NewInterest
!!!   @Parth
!!  DebugCL.Send('UINT END - RPQ:DelBalBefore: ' & RPQ:DelBalBefore)
!!  IF COMMAND('/LOG')
!!  logcl.writeline(,'Delbalbefore='&RTN:CurrentObligationTotals.DelBalBefore & '  delbalafter='&RTN:CurrentObligationTotals.DelBalAfter & '  newint='&RTN:CurrentObligationTotals.NewInterest & '  intbal='&rpq:uint)
!!  END
!!
!!  PUT(ReportQueue)                              !Save even if there is no
!!                                                ! new interest because this
!!                                                ! is what carries existing
!!                                                ! interest balance forward
!!
!!  IF ERRORCODE()
!!    MESSAGE('ERROR saving interest calculation on unconfirmed interest.'|
!!            & ' The printout may not be correct.',,ICON:EXCLAMATION, |
!!            BUTTON:OK,BUTTON:OK)
!!  END
!!  GET(ReportQueue,QCounter)


[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
UintPay     routine
    GET(ReportQueue,QCounter)
    IF ~PBalance then EXIT.                     !Exit if all of the pmt has
                                                ! been applied

    IF ~RPQ:UInt THEN EXIT.                     !If no interest due then
                                                ! nothing to pay

    IF PBalance
      IF PBalance >= RPQ:Uint                     !If balance of pmt will
        PBalance -= RPQ:Uint                      ! will pay off this int
        RPQ:AplUint = RPQ:Uint                    ! save amount paid
        RPQ:Uint = 0                              ! and set balance at 0
      ELSE                                        !If won' pay off the interest
        RPQ:Uint -= PBalance                      ! reduce the interest balance by the payment left
        RPQ:AplUint = PBalance                    ! store the amount applied
        PBalance = 0                              ! then set the payment left to 0
      END
   END 
    put(ReportQueue)


    
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
CintCal     routine
!--------------------------
  DATA
CurrentObligationTotals &GLO:TotalsGroupType
  CODE
    DebugCL.Send('CintCal Start')
    GET(ReportQueue,QCOUNTER)
    CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    
    IF CurrentObligationTotals.ConfirmedPrincipalBalance <= 0
      EXIT
    END
    
    IF RPQ:DATE <= CurrentObligationTotals.DateRendered                !Actually had a customer who called and had
      EXIT                                         ! a judgment that was later than the first
    END                                            ! obligation - this addresses that

    IF QCounter = 1                                !If this is the first record
      Util.GetNextReportQueueObligationType('CHILD',0, FALSE) !Nikita - Pass correct last parameter
      IF ~ERRORCODE()
        util.SetNamAndAttyObjects('CHILD')
        IF NAM:InterestType='COMPOUND'
          DO FirstCompound
        ELSE
          CurrentObligationTotals.ConfirmedInterestBalance=0
          GLO:Totals:ConfirmedInterestBalance=0
          CurrentObligationTotals.CompoundBalance = 0
        END
      END
      
      Util.GetNextReportQueueObligationType('MEDICAL',0, FALSE) !Nikita - Pass correct last parameter
      IF ~ERRORCODE()
        util.SetNamAndAttyObjects('MEDICAL')
        IF NAM:InterestType='COMPOUND'
          DO FirstCompound
        ELSE
          CurrentObligationTotals.ConfirmedInterestBalance=0
          GLO:Totals:ConfirmedInterestBalance=0
          CurrentObligationTotals.CompoundBalance = 0
        END
      END
      Util.GetNextReportQueueObligationType('DENTAL',0, FALSE) !Nikita - Pass correct last parameter
      IF ~ERRORCODE()
        util.SetNamAndAttyObjects('DENTAL')
        IF NAM:InterestType='COMPOUND'
          DO FirstCompound
        ELSE
          CurrentObligationTotals.ConfirmedInterestBalance=0
          GLO:Totals:ConfirmedInterestBalance=0
          CurrentObligationTotals.CompoundBalance = 0
        END
      END
    ELSE                                             !If not the first record
      DebugCL.Send('1 CintCal: RPQ:ObligationType: ' & UPPER(RPQ:ObligationType))
      util.SetNamAndAttyObjects(UPPER(RPQ:ObligationType))
      DebugCL.Send('2 CintCal: RPQ:Date: ' & RPQ:Date)
      IF NAM:InterestType='COMPOUND' and RPQ:Date |  !If it's been a year since compounding
        - CurrentObligationTotals.LastCompoundDate >= 365                ! and the user wants to compound, this
                                                     ! routine will calculate interest up to
        DO CompoundInterest                          ! the date where interest is compounded
                                                     ! and then set the following variables:
                                                     !  CurrentObligationTotals.ConfirmedLastDate
                                                     !  GLO:ConfirmedInterestBalance
  !this updates
  ! CurrentObligationTotals.LastCompoundDate  = last date compounding was done
  ! CurrentObligationTotals.ConfirmedLastDate = date to start next interest calc from
  ! glo:confirmedInterestbalance = total interest charged so far
  ! loc:compoundBalance  = interest compounded (added to principal for int calc)

        GET(ReportQueue,QCOUNTER)
        CurrentObligationTotals.ConfirmedPrincipalBalance = RPQ:Cobl
        GLO:Totals:ConfirmedPrincipalBalance = RPQ:Cobl
      ELSE
        !Nikita - Modified below parametenrs 
        !Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType))
        Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), -1, FALSE)
        !Nikita - End
        IF ERRORCODE()
          MESSAGE('ERROR calculating interest on confirmed interest.'|
                & ' The printout may not be correct.',,ICON:EXCLAMATION, |
                BUTTON:OK,BUTTON:OK)
          EXIT
        END
        CurrentObligationTotals.ConfirmedLastDate = RPQ:Date
        CurrentObligationTotals.ConfirmedPrincipalBalance = RPQ:Cobl
        GLO:Totals:ConfirmedPrincipalBalance = RPQ:Cobl
        
        CurrentObligationTotals.ConfirmedInterestBalance = RPQ:Cint
        GLO:Totals:ConfirmedInterestBalance = RPQ:Cint
        GLO:Totals:ConfirmedLastDate = RPQ:Date !Nikita - added the line
        
      END
    END
    
    GET(ReportQueue,QCounter)
    RPQ:Cint = CurrentObligationTotals.ConfirmedInterestBalance                      
    RPQ:Cobl = CurrentObligationTotals.ConfirmedPrincipalBalance                                                                  
    
    DebugCL.Send('CintCal RPQ:Cobl: ' & RPQ:Cobl)
    CurrentObligationTotals.DailyRate = ((CurrentObligationTotals.CompoundBalance +                        |
      CurrentObligationTotals.ConfirmedPrincipalBalance) * CurrentObligationTotals.ConfIntRate) / 365
    CurrentObligationTotals.Days = RPQ:Date - CurrentObligationTotals.ConfirmedLastDate
    CurrentObligationTotals.NewInterest = CurrentObligationTotals.DailyRate * CurrentObligationTotals.Days
    IF CurrentObligationTotals.NewInterest > 0
      RPQ:Cint += CurrentObligationTotals.NewInterest
    END

    PUT(ReportQueue)                              !Save the changes so far
    IF ERRORCODE()
      MESSAGE('ERROR saving interest calculation on unconfirmed interest.'|
              & ' The printout may not be correct.',,ICON:EXCLAMATION, |
              BUTTON:OK,BUTTON:OK)
    END
    GET(ReportQueue,QCounter)                     !Reactivate the current


!----------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
CintPay     routine
!----------------------
  DATA
CurrentObligationTotals &GLO:TotalsGroupType
  CODE
    GET(ReportQueue, QCounter)
    CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    
    DebugCL.Send('CintPay QCounter: ' & QCounter & ', PBalance: ' & PBalance & ', RPQ:CInt: ' & RPQ:CInt)
    
    IF ~PBalance then EXIT.                     !Exit if all of the pmt has
                                                ! been applied

    IF ~RPQ:CInt THEN 
      EXIT                     !If no interest due then  ! nothing to pay
    END
                                               
    IF PBalance
      IF PBalance >= RPQ:Cint                     !If balance of pmt will
        PBalance -= RPQ:Cint                      ! will pay off this int
        RPQ:AplCint = RPQ:Cint                    ! save amount paid
        RPQ:Cint = 0                              ! and set balance at 0
      ELSE                                        !If won' pay off the interest
        RPQ:Cint -= PBalance                      ! reduce the interest balance by the payment left
        RPQ:AplCint = PBalance                    ! store the amount applied
        PBalance = 0                              ! then set the payment left to 0
      END
    END
    
    IF RPQ:Cint < CurrentObligationTotals.CompoundBalance             !As obligor pays off interest, if he pays off
      CurrentObligationTotals.CompoundBalance = RPQ:Cint              ! all that has accrued this year, this makes sure
    END                                            ! that the compounded interest is paid off as he
                                                  ! makes further payments

    PUT(ReportQueue)                              !Save the changes so far

    
!--------------------------
Calculator.UIntPayNew          Procedure(long ObligationCount = -1)
!--------------------------
PCounter  LONG
  CODE
    IF ObligationCount = 0 
      RETURN
    END
    
    !Nikita - Added below code
    IF ObligationCount = -1
      PCounter = QCOUNTER
    ELSE
      PCounter = ObligationCount
    END
    !Nikita - End
    
    GET(ReportQueue,PCounter)
    
    DebugCL.Send('UIntPayNew Start -- ObligationCount: ' & ObligationCount & ', PBalance: ' & PBalance & ', RPQ:UInt: ' & RPQ:UInt)
    IF ~PBalance then RETURN.                     !Exit if all of the pmt has
                                                ! been applied

    IF ~RPQ:UInt THEN RETURN.                     !If no interest due then
                                                ! nothing to pay

    IF PBalance
      IF PBalance >= RPQ:Uint                     !If balance of pmt will
        PBalance -= RPQ:Uint                      ! will pay off this int
        RPQ:AplUint = RPQ:Uint                    ! save amount paid
        !Nikita - Added to fix Payment history 
        RPQ:AmountP += RPQ:Uint
        !Nikita - END
        RPQ:Uint = 0                              ! and set balance at 0
      ELSE                                        !If won' pay off the interest
        RPQ:Uint -= PBalance                      ! reduce the interest balance by the payment left
        RPQ:AplUint = PBalance                    ! store the amount applied
        !Nikita - Added to fix Payment history 
        RPQ:AmountP += PBalance
        !Nikita - END
        PBalance = 0                              ! then set the payment left to 0
      END
    END 
    put(ReportQueue)
    
!--------------------------

Calculator.CIntPayNew          Procedure(long ObligationCount = -1)
!--------------------------
CurrentObligationTotals &GLO:TotalsGroupType
PCounter                          LONG
  CODE
    IF ObligationCount = 0 
      RETURN
    END
    !Nikita - Added below code
    IF ObligationCount = -1
      PCounter = QCOUNTER
    ELSE
      PCounter = ObligationCount
    END
    !Nikita - End
    
    GET(ReportQueue,PCounter)
    CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    DebugCL.Send('CIntPayNew Start -- ObligationCount: ' & ObligationCount & ', PBalance: ' & PBalance & ', RPQ:UInt: ' & RPQ:UInt)
    IF ~PBalance then RETURN.                     !Exit if all of the pmt has
                                                ! been applied

    IF ~RPQ:CInt THEN RETURN.                     !If no interest due then
                                                ! nothing to pay
    IF PBalance
      IF PBalance >= RPQ:Cint                     !If balance of pmt will
        PBalance -= RPQ:Cint                      ! will pay off this int
        RPQ:AplCint = RPQ:Cint                    ! save amount paid
        !Nikita - TODO
        RPQ:AmountP += RPQ:Cint
        !Nikita - END
        RPQ:Cint = 0                              ! and set balance at 0
      ELSE                                        !If won' pay off the interest
        RPQ:Cint -= PBalance                      ! reduce the interest balance by the payment left
        RPQ:AplCint = PBalance                    ! store the amount applied
        !Nikita - TODO
        RPQ:AmountP += PBalance
        !Nikita - END
        PBalance = 0                              ! then set the payment left to 0
      END
    END
    
    IF RPQ:Cint < CurrentObligationTotals.CompoundBalance             !As obligor pays off interest, if he pays off
      CurrentObligationTotals.CompoundBalance = RPQ:Cint              ! all that has accrued this year, this makes sure
    END                                                   ! that the compounded interest is paid off as he
                                                          ! makes further payments
    put(ReportQueue)
[END]
[END]
