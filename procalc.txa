EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
  map
    InsertNumQ(REAL pHiNum, REAL pHiNumSS1, REAL pHiNumSS2, REAL pHiNumFed)
  end
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!EACH YEAR NUMBERS IN THIS PROCEDURE WILL BE UPDATED WITH NEW CHART
[END]
EMBED %LocalProcedures
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
InsertNumQ procedure(REAL pHiNum, REAL pHiNumSS1, REAL pHiNumSS2, REAL pHiNumFed)
  CODE
    NQ:ID = NQ:HiNum
    NQ:HiNum = round(pHiNum, .01)

    NQ:LoNumSS1 = NQ:HiNumSS1
    NQ:HiNumSS1 = round(pHiNumSS1, .01)

    NQ:LoNumSS2 = NQ:HiNumSS2
    NQ:HiNumSS2 = round(pHiNumSS2, .01)

    NQ:LoNumFed = NQ:HiNumFed
    NQ:HiNumFed = round(pHiNumFed, .01)

    add(NumQ)

    return

[END]
[END]
