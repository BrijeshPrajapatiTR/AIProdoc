[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!SetupExport      ROUTINE
!-------------------------------------
SetupExport      ROUTINE
!-------------------------------------
  FLUSH(ANSWERS)
  !?STRING3{PROP:TEXT} = '                     Saving data to ProDoc'
  STREAM(ANSWERS)
  MaxLoop = RECORDS(ReportQueue)
  QCOUNTER = 0
! @Parth - FB28903 
  QCOUNTERBig = 0
  QCOUNTERBigChild = 0
  QCOUNTERBigMedical = 0
  QCOUNTERBigDental = 0
  KCOUNTERChild = 0
  KCOUNTERMedical = 0
  KCOUNTERDental = 0
  
  KCOUNTERObligationsChild = 0
  KCOUNTERObligationsMedical = 0
  KCOUNTERObligationsDental = 0
  DebugCL.Send('SetupExport KCOUNTERObligationsChild: ' & KCOUNTERObligationsChild)
! @Parth 
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!DeleteExistingADOP   ROUTINE          !Delete existing data FOR ADOPTION AND SPECIFIED CASE
!----------------------------
DeleteExistingADOP   ROUTINE          !Delete existing data FOR ADOPTION AND SPECIFIED CASE
!----------------------------
  LOOP 10 TIMES
    GET(DeletedTokensQue,QCOUNTER)
    IF ERRORCODE() OR QCOUNTER>RECORDS(DeletedTokensQue)
      LOC:DelAdopDone = TRUE
      DeleteCompleted = TRUE          !COMPLETELY FINISH DELETION THEN PREPARE EXPORT
      DO SetupExport
      BREAK
    END
    ANS:CAS_ID = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:OBJ_ID = DTQ:OBJ_ID
    ANS:SCOPE = 'V'
    !ANS:INDEXSTRING = ''      !NOTE: THIS WON'T WORK
    CLEAR(ANS:INDEXSTRING,-1)
    SET(ANS:kScope,ANS:kScope)
    LOOP
      NEXT(ANSWERS)
      IF ERRORCODE() OR ANS:SCOPE <> 'V' OR ANS:CAS_ID<>GLO:CAS_ID |
                     OR ANS:VOLUME_ID<>LOC:VOLUME_ID OR ANS:OBJ_ID<>DTQ:OBJ_ID
        BREAK
      END
      DELETE(ANSWERS)
    END
    LOC:Progress = ((DeleteCOUNTER+QCOUNTER)/(DeleteCOUNTER*2)) * 100
    QCOUNTER += 1
    DISPLAY()
  END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!DeleteExistingFAM   ROUTINE          !Delete existing data FOR TXFAM AND SPECIFIED CASE
!----------------------------
DeleteExistingFAM   ROUTINE          !Delete existing data FOR TXFAM AND SPECIFIED CASE
!----------------------------
  LOOP 10 TIMES
    GET(DeletedTokensQue,QCOUNTER)
    IF ERRORCODE() OR QCOUNTER>RECORDS(DeletedTokensQue)
      LOC:DelFamilyDone = TRUE
      QCOUNTER=1       !WELL DONE FOR TXFAM BUT ALSO NEED TO BE DONE FOR TXADOPT SO RESET COUNTER
      BREAK
    END
    ANS:CAS_ID = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:OBJ_ID = DTQ:OBJ_ID
    ANS:SCOPE = 'V'
    CLEAR(ANS:INDEXSTRING,-1)
    SET(ANS:kScope,ANS:kScope)
    LOOP
      NEXT(ANSWERS)
      IF ERRORCODE() OR ANS:SCOPE <> 'V' OR ANS:CAS_ID<>GLO:CAS_ID |
                     OR ANS:VOLUME_ID<>LOC:VOLUME_ID OR ANS:OBJ_ID<>DTQ:OBJ_ID
        BREAK
      END
      DELETE(ANSWERS)
    END
    LOC:Progress = ((QCOUNTER)/(DeleteCOUNTER*2)) * 100
    QCOUNTER += 1
    DISPLAY()
  END
