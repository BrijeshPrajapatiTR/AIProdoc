[END]
EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!-----------------------------------
CalculateAmounts      ROUTINE
!-----------------------------------
  bCalculated = false
  IF ~FromDate
    SELECT(?FromDate)
    EXIT
  END

  IF ~TotalObligation
    SELECT(?TotalObligation)
    EXIT
  END


  IF ~PaymentAmount
    SELECT(?PaymentAmount)
    EXIT
  END

  CASE PaymentOption
  OF 'A'
  OROF 'B'
    IF ~FirstDay
      SELECT(?FirstDay)
      EXIT
    END
    if PaymentOption = 'B'
      if ~SecondDay and ~SemiMonthlyLastDay
        SELECT(?SecondDay)
        exit
      end
    end
  OF 'C'
  OROF 'D'
    IF ~DayOfWeek
      SELECT(?DayOfWeek)
      EXIT
    END
  END

  CLEAR(QAmortize)
  FREE(QAmortize)

  QAM:PaymentAmount = PaymentAmount
  QAM:PriorDate = FromDate
  QAM:PriorBalance = TotalObligation

  !Ma - Fogbugz case 12732, setup a flag for calculation if it's true then exit without printing report 12/5/07
  bCalErr = false
  CASE PaymentOption
  OF 'A'                        !Monthly
    DO Monthly
  OF 'B'                        !Semimonthly
    DO SemiMonthly
  OF 'C'                        !Weekly
    DO Weekly
  OF 'D'                        !Biweekly
    DO BiWeekly
  END
  !Ma - Fogbugz case 12732, setup a flag for calculation if it's true then clear results 12/5/07
  if bCalErr
    TotalPayments = 0
    DateLastPayment = 0
    AmountLastPayment = 0
    free(QAMORTIZE)
  else
    TotalPayments = RECORDS(QAMORTIZE)
    DateLastPayment = QAM:PaymentDate
    AmountLastPayment = QAM:PaymentAmount
    bCalculated = true
  end
  DISPLAY()

!-----------------------------------
Monthly      ROUTINE
!-----------------------------------

  IF MonthlyLastDay                         !If payment is to be made on last day of month
    FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                             ! subtract 1 day to get the
                                                             ! last day of month

  ELSIF DAY(FromDate) > FirstDay   !If from date is after the day of month for payment
    FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !set for next month
  ELSE                                        !otherwise set due date equal to the
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))  !day of month selected
  .
  LocalResponse = RequestCompleted

  QAM:PAYMENTDATE = FirstDate
  LOOP
    DO AddRecords
    !Ma - Fogbugz case 12732, setup a flag for calculation if it's true then exit  12/5/07
    if bCalErr
      break
    end
    IF QAM:NewBalance <= 0 THEN BREAK.
    IF MonthlyLastDay  !If payment on last day of month then set for 1st day of second
      QAM:PAYMENTDATE =  (DATE(MONTH(QAM:PAYMENTDATE)+2,1,YEAR(QAM:PAYMENTDATE)))-1   !month the subtract 1 to
                                                                    !get last day of next month
    ELSE
      QAM:PAYMENTDATE =  DATE(MONTH(QAM:PAYMENTDATE)+1,FirstDay,YEAR(QAM:PAYMENTDATE))
  . .


!-----------------------------------
SemiMonthly      ROUTINE
!-----------------------------------
  DATA
M      LONG
  CODE

  IF ~FirstDaY
    SELECT(?FirstDay)
    EXIT
  END

  IF ~SecondDay AND ~SemiMonthlyLastDay
    SELECT(?SecondDay)
    EXIT
  END

  IF DAY(FromDate) > FirstDay !If from date is greater than day of month for first obligation
    IF SemiMonthlyLastDay                         !If payment is to be made on last day of month
      FirstDate = DATE(MONTH(FromDate)+1,1,YEAR(FromDate))-1 !set for next month then
                                                               ! subtract 1 day to get the
                                                               ! last day of month
      DayFlag = 1           !DayFlag will be set to keep track of which obligation of the month we are doing
                            !  it's set in reverse from here because the addrecord is done in the loop below
                            !  and then the flag is reset.  This starts it out correctly

    ELSE   !If second obligation day is not the last day of month
      IF DAY(FromDate) > SecondDay !If past first and second obligation dates then start over with
        FirstDate = DATE(MONTH(FromDate)+1,FirstDay,YEAR(FromDate)) !the first obligation date next month
        DayFlag = 2
      ELSE                         !Otherwise set for the second obligation day
        !FirstDate = DATE(MONTH(FromDate)+1,SecondDay,YEAR(FromDate)) !Set first payment for day of
        FirstDate = DATE(MONTH(FromDate),SecondDay,YEAR(FromDate)) !Set first payment for day of
        DayFlag = 1                                                  !month for second obligation
      END!OF handling second day
    END!END OF SEMIMONTHLYLASTDAY IF STATEMENT

  ELSE                                        !If from date is less than set first obligation date
    FirstDate = DATE(MONTH(FromDate),FirstDay,YEAR(FromDate))!start obligation then
    DayFlag = 2
  .

  LocalResponse = RequestCompleted
  QAM:PaymentDate = FirstDate
  M = MONTH(QAM:PaymentDate)
  LOOP
    DO AddRecords
    !Ma - Fogbugz case 12732, setup a flag for calculation if it's true then exit  12/5/07
    if bCalErr
      break
    end
    IF QAM:NewBalance <= 0 THEN BREAK.
    IF DayFlag = 1
      QAM:PaymentDate =  DATE(MONTH(QAM:PaymentDate)+1,FirstDay,YEAR(QAM:PaymentDate))
      DayFlag = 2
      M = MONTH(QAM:PaymentDate)
    ELSE
      IF SemiMonthlyLastDay  !If payment on last day of month then set for 1st day of second
        QAM:PaymentDate =  (DATE(MONTH(QAM:PaymentDate)+1,1,YEAR(QAM:PaymentDate)))-1   !month the subtract 1 to
      ELSE                                                            !get last day of next month
        QAM:PaymentDate =  DATE(MONTH(QAM:PaymentDate),SecondDay,YEAR(QAM:PaymentDate))
        IF MONTH(QAM:PaymentDate) > M !FIX THE BUG WHEN SECOND DAY IS 30TH ON FEBRUARY THE MARCH 30TH WAS SKIPPED MA 12/21/05
          QAM:PaymentDate =  (DATE(M+1,1,YEAR(QAM:PaymentDate)))-1
        END
      END !OF IF MonthlyLastDay
      DayFlag = 1
  . .



!-----------------------------------
Weekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)       !THIS FORMULA GETS WRONG DATE
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE  3/8/02
 .

  LocalResponse = RequestCompleted

  QAM:PaymentDate = FirstDate
  LOOP
    DO AddRecords
    !Ma - Fogbugz case 12732, setup a flag for calculation if it's true then exit  12/5/07
    if bCalErr
      break
    end
    IF QAM:NewBalance <= 0 THEN BREAK.
    QAM:PaymentDate += 7
  .

!-----------------------------------
BiWeekly      ROUTINE
!-----------------------------------

 CASE DayOfWeek
 OF 'Sunday'
   DayNumber = 0
 OF 'Monday'
   DayNumber = 1
 OF 'Tuesday'
   DayNumber = 2
 OF 'Wednesday'
   DayNumber = 3
 OF 'Thursday'
   DayNumber = 4
 OF 'Friday'
   DayNumber = 5
 OF 'Saturday'
   DayNumber = 6
 END

 EnteredDay = FromDate % 7
 IF EnteredDay = DayNumber
     FirstDate = FromDate
 ELSIF EnteredDay < DayNumber
     FirstDate = FromDate + (DayNumber - EnteredDay)
 ELSE
    !FirstDate = FromDate + (EnteredDay - DayNumber)
    FirstDate = FromDate + 7 - (EnteredDay - DayNumber)    !MA CREATED NEW FORMULA INSTEAD OF OLD ONE  3/8/02
 .

  LocalResponse = RequestCompleted

  QAM:PaymentDate = FirstDate
  LOOP
    DO AddRecords
    !Ma - Fogbugz case 12732, setup a flag for calculation if it's true then exit  12/5/07
    if bCalErr
      break
    end
    IF QAM:NewBalance <= 0 THEN BREAK.
    QAM:PaymentDate += 14
  .


!-----------------------------------
AddRecords      ROUTINE
!-----------------------------------
  DATA
DailyInterest    Decimal(10,5)
DaysForInterest  LONG

  CODE
  !DailyInterest = (QAM:PriorBalance * .12)/365
  !DailyInterest = (QAM:PriorBalance * .06)/365   !Beth said interest rate changed from .12 to .06   MA 10/01/01
  DailyInterest = (QAM:PriorBalance *(GLO:IntRate/100))/365   !ALLOWING USER CHANGE INTEREST RATE  MA 9/6/02
  DaysForInterest = QAM:PaymentDate - QAM:PriorDate

  QAM:AppliedInterest = DailyInterest * DaysForInterest
  !Ma - Fogbugz case 12732, if payment amount is not >= interest then show error message and stop 12/5/07
  if QAM:PaymentAmount < QAM:AppliedInterest
    message('The payment amount you entered is insufficient to pay down the total obligation. You must adjust '|
          & 'the amount of the payment or the amount of the total obligation.')
    bCalErr = true
    exit
  end
  IF QAM:PriorBalance + QAM:AppliedInterest < QAM:PaymentAmount   !This handles the last payment
    QAM:AppliedPrincipal = QAM:PriorBalance
    QAM:NewBalance = 0
    QAM:PaymentAmount = QAM:AppliedInterest + QAM:AppliedPrincipal
  ELSE
    QAM:AppliedPrincipal = QAM:PaymentAmount - QAM:AppliedInterest
    QAM:NewBalance = QAM:PriorBalance - QAM:AppliedPrincipal
  END
  ADD(QAmortize,QAM:PaymentDate)
  IF ERRORCODE()
      MESSAGE('Unable to add an obligation for ' & FORMAT(QOB:ODATE,@D1) |
         & '!',,ICON:EXCLAMATION,BUTTON:OK,BUTTON:OK)
  .
  QAM:PriorDate = QAM:PaymentDate
  QAM:PriorBalance = QAM:NewBalance


[END]
