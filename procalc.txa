[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF ~GLO:CalcDate
  Select(?GLO:CalcDate)
  CYCLE
ELSE
  !warn if a data pasted the cut-off date has been entered
  !look at debits, confirmed judgement
  !unconfirmed obligations
  !payments
  warnflag=false
  if CheckDelinqencyDates then

!debugging to see if we are seeing the right values for these
!  global or threaded variables
!Message(format(Ext:debitdate,@d2),'debit')
!Message(format(Nam:ConfirmedDate,@d2),'confirmed')
!        Get(QObligate,Records(QObligate))
!Message(format(QObligate.ODate,@d2),'obligation')
!        Get(QPayments,Records(QPayments))
!Message(format(QPayments.pDate,@d2),'payments')



!            if ext:DebitDate>GLO:CalcDate or Nam:ConfirmedDate>GLO:CalcDate
    if EXTDebitChild:DebitDate > GLO:CalcDate OR NAMChild:ConfirmedDate > GLO:CalcDate OR EXTDebitMedical:DebitDate > GLO:CalcDate OR NAMMedical:ConfirmedDate > GLO:CalcDate OR EXTDebitDental:DebitDate > GLO:CalcDate OR NAMDental:ConfirmedDate > GLO:CalcDate
      WarnFlag=true
    else
      If ~warnflag and Records(QObligate)
        Sort(QObligate,QObligate.ODate)
        Get(QObligate,Records(QObligate))
        if ~errorcode() and QObligate.ODate>GLO:CalcDate then
          WarnFlag=True
        end
      end
      If ~warnflag and Records(QPayments)
        Sort(QPayments,QPayments.pDAte)
        Get(QPayments,Records(QPayments))
        if ~Errorcode() and QPayments.PDate>GLO:CalcDate then
          WarnFlag=true
        end
      end
    end
    if WarnFlag then
      if Message('You have entered information for obligations, payments, judgements, or debits occurring after the "Calculation Date".  This information will not be included.||Would you like to change the "Calculation Date"?','Some Data Excluded',icon:exclamation,Button:Yes+button:no,Button:no)=Button:Yes then
        Select(?GLO:CalcDate)
        cycle
      end
      LocalResponse = RequestCompleted
    else
      LocalResponse = RequestCompleted
    end
  end
end
[END]
[END]
