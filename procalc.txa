[INSTANCE]
INSTANCE 3
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[ADDITION]
NAME Clarion CloseCurrentWindow
[INSTANCE]
INSTANCE 1
[INSTANCE]
INSTANCE 2
[CALLS]
