WHEN '?NAM:InterestType'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
OMIT('***MCY***') !DEVELOPER SAID DON'T NEED TO HAVE WARNING AND LET USER CHOOSE EITHER TYPE OF INTEREST  7/23/01
IF NAM:ConfirmedDate<DATE(9,1,1987) AND GLO:CompoundFlag=1
  Message('Prior to 9/01/87 the interest calculations on confirmed child support ' |
        & 'balances should be Simple Interest.','Warning')
  GLO:CompoundFlag=0
  DISPLAY()
  CYCLE
END
IF NAM:ConfirmedDate>=DATE(9,1,1987) AND NAM:ConfirmedDate<=DATE(8,31,1993) AND GLO:CompoundFlag=0
  Message('From 9/01/87 - 8/31/93 the interest calculations on confirmed child support ' |
        & 'balances should be Annually Compound Interest.','Warning')
  GLO:CompoundFlag=1
  DISPLAY()
  CYCLE
END
IF NAM:ConfirmedDate>=DATE(9,1,1993) AND NAM:ConfirmedDate<DATE(1,1,2001) AND GLO:CompoundFlag=1
  Message('From 9/01/93 to present the interest calculations on confirmed child support ' |
        & 'balances should be Simply Interest.','Warning')
  GLO:CompoundFlag=0
  IF ~NAM:ConfirmedInterestRate
    NAM:ConfirmedInterestRate=0.12
  END
  DISPLAY()
  CYCLE
END
IF NAM:ConfirmedDate>=DATE(1,1,2001) AND GLO:CompoundFlag=1
  Message('From 9/01/93 to present the interest calculations on confirmed child support ' |
        & 'balances should be Simply Interest.','Warning')
  GLO:CompoundFlag=0
  IF ~NAM:ConfirmedInterestRate
    NAM:ConfirmedInterestRate=0.06
  END
  DISPLAY()
  CYCLE
END
!***MCY***
[END]
[END]
WHEN '?CurrentTab'
[INSTANCES]
WHEN 'NewSelection'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
CASE CHOICE(?CurrentTab)
OF 2
  ?OK{PROP:DEFAULT} = FALSE
  ?ChangePayment{PROP:DEFAULT} = FALSE
  ?ChangeObligation{PROP:DEFAULT} = TRUE
  IF ~CHOICE(?QOBLIGATE)
    SELECT(?QOBLIGATE,1)
  .
  do showfreqwarning
OF  3
  ?OK{PROP:DEFAULT} = FALSE
  ?ChangeObligation{PROP:DEFAULT} = FALSE
  ?ChangePayment{PROP:DEFAULT} = TRUE
  IF ~CHOICE(?QPAYMENT)
    SELECT(?QPAYMENT,1)
  END
OF 1
  ?ChangeObligation{PROP:DEFAULT} = FALSE
  ?ChangePayment{PROP:DEFAULT} = FALSE
  ?OK{PROP:DEFAULT} = TRUE
  SELECT(?OK)
  SELECT(?GLO:Obligor)
OF 4
  ?ChangeObligation{PROP:DEFAULT} = FALSE
  ?ChangePayment{PROP:DEFAULT} = FALSE
  ?OK{PROP:DEFAULT} = TRUE
  SELECT(?OK)
  SELECT(?NAM:ConfirmedDate)
OF 5
  ?ChangeObligation{PROP:DEFAULT} = FALSE
  ?ChangePayment{PROP:DEFAULT} = FALSE
  ?OK{PROP:DEFAULT} = TRUE
  SELECT(?OK)
  SELECT(?EXT:DebitDate)
END
DISPLAY()
[END]
