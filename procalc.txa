EMBED %ProcRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 3600
PROPERTY:END
!@Parth - FB28903 SaveJudgmentSupportTab Routine
SaveJudgmentSupportTab ROUTINE 
!    0{PROP:Text} = 0{PROP:Text} & JudgmentSupportTabSelected
  DebugCL.Send('Save Judgment called')
  !Message('1 Save Judgment called JudgmentSupportTabSelected: ' & JudgmentSupportTabSelected & ', NAM:ConfirmedInterestRate: '  & NAM:ConfirmedInterestRate)
    CASE (JudgmentSupportTabSelected)
    OF 1
      !MESSAGE('1 NAM ChildSupport: ' & NAMChild:ConfirmedInterestRate)
        NAMConfirmedObl = NAMConfirmedOblChildSupport
        ATTYFees = ATTYFeesChildSupport
    OF 2
     !MESSAGE('2 NAM MedicalSupport: ' & NAMMedical:ConfirmedInterestRate)
        NAMConfirmedObl = NAMConfirmedOblMedicalSupport
        ATTYFees = ATTYFeesMedicalSupport
    OF 3
      !MESSAGE('3 NAM DentalSupport: ' & NAMDental:ConfirmedInterestRate)
        NAMConfirmedObl = NAMConfirmedOblDentalSupport
        ATTYFees = ATTYFeesDentalSupport
    END
    !Message('2 Save Judgment called JudgmentSupportTabSelected: ' & JudgmentSupportTabSelected & ', NAM:ConfirmedInterestRate: '  & NAM:ConfirmedInterestRate)
    DISPLAY()
!@Parth
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!@Parth - FB28903 UpdateAfterSep1     ROUTINE
UpdateAfterSep1     ROUTINE
  
!    IF GLO:FiledAfterSep1Delinquency
!  ?QOBLIGATE{PROP:Format} = '45L|M~Date~L(4)@d2@42L|M~Amount~L(4)@n-10.2@48L|~Frequency~L(4)@s12@40L|~Type~L(4)@s10@'
  ?JudgmentSupportTabSelected{PROP:Hide} = FALSE
  ?DebitSupportTabSelected{PROP:Hide} = FALSE
  POST(EVENT:NewSelection, ?DebitSupportTabSelected)
  EXTDebitSave = EXTDebit
  POST(EVENT:NewSelection, ?JudgmentSupportTabSelected)
  NAMConfirmedOblSave = NAMConfirmedObl
  ATTYFeesSave = ATTYFees
!    ELSE
!        ?QOBLIGATE{PROP:Format} = '45L|M~Date~L(4)@d2@42L|M~Amount~L(4)@n-10.2@48L|~Frequency~L(4)@s12@'
!        ?JudgmentSupportTabSelected{PROP:Hide} = TRUE
!        ?DebitSupportTabSelected{PROP:Hide} = TRUE
!        Do RestoreDebitSupportTab
!        EXTDebit = EXTDebitSave
!        Do RestoreJudgmentSupportTab
!        NAMConfirmedObl = NAMConfirmedOblSave
!        ATTYFees = ATTYFeesSave
!    END
!@Parth
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!@Parth - FB28903 SaveDebitSupportTab Routine
SaveDebitSupportTab ROUTINE 
!    0{PROP:Text} = 0{PROP:Text} & DebitSupportTabSelected
    CASE (DebitSupportTabSelected)
    OF 1
        EXTDebit = EXTDebitChildSupport
    OF 2
        EXTDebit = EXTDebitMedicalSupport
    OF 3
        EXTDebit = EXTDebitDentalSupport
    END
    DISPLAY()
!@Parth
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!@Parth - FB28903 RestoreDebitSupportTab Routine
RestoreDebitSupportTab ROUTINE 
!    0{PROP:Text} = 0{PROP:Text} & DebitSupportTabSelected
    UPDATE()
    CASE (DebitSupportTabSelected)
    OF 1
        EXTDebitChildSupport = EXTDebit
    OF 2
        EXTDebitMedicalSupport = EXTDebit
    OF 3
        EXTDebitDentalSupport = EXTDebit
    END
!@Parth
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!@Parth - FB28903 RestoreJudgmentSupportTab Routine
RestoreJudgmentSupportTab ROUTINE 
!    0{PROP:Text} = 0{PROP:Text} & JudgmentSupportTabSelected
    !MESSAGE('1 Restore Judgment called Child: ' & NAMChild:ConfirmedInterestRate)
    UPDATE()
    CASE (JudgmentSupportTabSelected)
    OF 1
      DebugCL.Send('NAMConfirmedOblChildSupport = NAMConfirmedObl: ')
        NAMConfirmedOblChildSupport = NAMConfirmedObl
        ATTYFeesChildSupport = ATTYFees
    OF 2
      DebugCL.Send('NAMConfirmedOblMedicalSupport = NAMConfirmedObl: ')
        NAMConfirmedOblMedicalSupport = NAMConfirmedObl
        ATTYFeesMedicalSupport = ATTYFees
    OF 3
      DebugCL.Send('NAMConfirmedOblDentalSupport = NAMConfirmedObl: ')
        NAMConfirmedOblDentalSupport = NAMConfirmedObl
        ATTYFeesDentalSupport = ATTYFees
    END
    !MESSAGE('2 Restore Judgment called Child: ' & NAMChild:ConfirmedInterestRate)
!@Parth
[END]
