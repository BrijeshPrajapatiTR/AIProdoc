DESCRIPTION 'save original values in Judgment and Debit tabs'
FROM Clarion Source
MODIFIED '2007/12/11' '17:21:48'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  OriginalJudgGrp     :=: NAMConfirmedObl
  OriginalATTYFeesGrp :=: ATTYFees
  OriginalEXTDebitGrp :=: EXTDebit
