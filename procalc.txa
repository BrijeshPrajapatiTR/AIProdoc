EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
eTitle              EQUATE('Saving Data To ProDoc')
bCalcDateChanged    byte(false)
[END]
EMBED %BeforeWindowOpening
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  IF ~GLO:CalcDate
    !GetCalcDate(1) !1 means check the date to see if before payments, obligations, debitdate,confirmeddate
                   ! THE ProcessPayments PROCEDURE NEEDS THE GLO:CalcDate WHICH IS ASSIGNED IN GetCalcDate(1)
                   ! AND WE SHOULD CALL ProcessPayments BECAUSE SOME OF ANSWERS BEING SAVED ARE STATISTIC AMOUNTS
    !IF GlobalResponse <> RequestCompleted
    !  DO ProcedureReturn
    !.
    !Default to Today
    GLO:CalcDate=Today()
    bCalcDateChanged = true
  END

  !For SaveAndContinue and SaveAndClose we should popup the GetCalcDate window depending on if the dirty flags
  ! are true 12/11/07
  if bCalcDateChanged or GLO:UpdatePayments or GLO:UpdateObligate or ~AreValuesSame()
    GetCalcDate(1)
    IF GlobalResponse <> RequestCompleted
      bRetVal = true
      DO ProcedureReturn
    end
  end

  ProcessPayments
  !Ma - Fogbugz case 15992, after processPayments reset the dirty flags 12/11/07
  GLO:UpdatePayments = FALSE
  GLO:UpdateObligate = FALSE
  SaveOriginalValues()
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 1
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[WINDOW]
window  WINDOW('Saving Data To ProDoc'),AT(,,182,87),DOUBLE,CENTER,CURSOR(CURSOR:None),GRAY, |
          TIMER(1)
          SHEET,AT(8,4,164,61),USE(?Sheet1),WIZARD,#ORIG(?Sheet1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1)
              STRING('Please wait ...'),AT(15,18),USE(?String3),#ORIG(?String3)
              PROGRESS,AT(46,38,91,15),USE(LOC:Progress),RANGE(0,100),#ORIG(?Progress1)
            END
          END
          BUTTON('&Cancel'),AT(69,70,45,14),USE(?Cancel),LEFT,ICON('cancel.ico'),HIDE,#ORIG(?Button1)
        END

[END]
