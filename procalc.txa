[SOURCE]
PROPERTY:BEGIN
PRIORITY 3500
PROPERTY:END
LoadEverythingBUTPaymentsDental        ROUTINE
  COUNTER=0
  CLEAR(ANS:RECORD)
  LOOP
    COUNTER+=1      !INCREASE INDEXS[1] FOR OBLIGATIONS AND PAYMENTS DIMENSION CODE
    ANS:CAS_ID    = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:SCOPE='V'
    ANS:OBJ_ID= 'PX402'
    CLEAR(ANS:INDEXSTRING,-1)
    ANS:INDEXES[1]=SwapUshortBytes(COUNTER)
    GET(ANSWERS,ANS:kScope)
    IF ERRORCODE()
      BREAK     !IF DIDN'T FIND ANY OBLIGATTION OR PAYMENT THEN BREAK AND LOAD OTHER NON-DIMENSION CODES
    END
    CASE UPPER(CLIP(ANS:ANSWER))
    OF 'O'
      ANS:OBJ_ID='PX401'
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        CASE LEN(CLIP(LEFT(ANS:ANSWER)))
        OF 7
          QOB:ODate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D1)
        OF 8
          QOB:ODate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D01)
        OF 9
        OROF 10
          QOB:ODate=DEFORMAT(CLIP(LEFT(ANS:ANSWER)),@D2)
        END
      END
        
      ANS:OBJ_ID='PX403'
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        QOB:OAmount=DEFORMAT(CLIP(ANS:ANSWER))
      END
      ANS:OBJ_ID='AX400'
      GET(ANSWERS,ANS:kScope)
      IF ~ERRORCODE()
        QOB:Frequency=LEFT(ANS:ANSWER)
      ELSE
        QOB:Frequency=''
      END
      
      QOB:OCaseID=GLO:CAS_ID
      IF QOB:OAmount
        QOB:Type = 'Dental'
        QOB:TypeSort = SupportType:Dental
        QOB:ObligateTypeDisplayText = 'Dental Support'
        ADD(QObligate)
      END
    END
  END
