EMBED %BeforeOpeningWindow
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
GLO:CalcDate = TODAY()
IF SelfEmployed
  EmployedMessage = 'Obligor IS self-employed'
ELSE
  EmployedMessage = 'Obligor is NOT self-employed'
.

DO CalculateNet
[END]
EMBED %HandCodeEventTimer
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
IF ~LEN(CLIP(Explanation))
  ExplanationString{PROP:TEXT} = ''
ELSE
  ExplanationString = '*description of Sec. 154.123 deduction:'
.

PRINT(RPT:DETAIL)
 
IF ChildrenInCourt <= TotalChildren  !Message says can't calculate if TotalChildren >
  NumKids = ChildrenInCourt          ! ChildrenInCourt so there would be no sense in printing this
  Counter# = 1                       ! unless it meets that test
  LOOP
    GET(ExportQueue,Counter#)
    IF ERRORCODE() THEN BREAK.
    PRINT(RPT:SupportDetail)
    NumKids -=1
    Counter# += 1
    IF Counter# > RECORDS(ExportQueue) THEN BREAK.
  END !OF LOOP
END
PRINT(RPT:MessageDetail)

IF ChildrenInCourt > 1
  PRINT(RPT:AltBand)
.
!Ma - Fogbugz case 14024, print the new item #7 based on the Glo:IsOnAfter090107 value 6/18/07
!Ma - Fogbugz case 19568, removed the Glo:IsOnAfter090107 so only show RPT:ExplanationDetail7500 9/26/08
!if Glo:IsOnAfter090107
  !RGR - FBZ# 25153 As of 9/1/2013, Resouces calculated against $8550.00 rather than $7500.00
  !PRINT(RPT:ExplanationDetail7500)
  !FBZ# 25153 As of 9/1/2019, Resouces calculated against $9200.00 rather than $8550.00
  !PRINT(RPT:ExplanationDetail8550)
  PRINT(RPT:ExplanationDetail9200)
!else
!  PRINT(RPT:ExplanationDetail6000)
!end
LocalResponse = RequestCompleted
POST(EVENT:CloseWindow)
[END]
EMBED %ProcRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!------------------------
CalculateNet     ROUTINE
!------------------------
  IF TotalChildren < ChildrenInCourt
    ChildMonthly = ''
    ChildSemiMonthly = ''
    ChildWeekly = ''
    ChildBiWeekly = ''
    Message1 = 'CANNOT CALCULATE BECAUSE "Children before the court"'
    Message2 = 'is greater than "Obligor''s Total Children"'
    EXIT
  .

  IF ChildrenInCourt > 5
    Message1 = 'The above amounts are for 5 children.  Sec. 154.125 provides'
    Message2 = 'that support shall not be less than this.'
  END


  DO CalculateAlternatives


!------------------------------------
CalculateAlternatives   ROUTINE
!------------------------------------

  !!Note - AltNetResources is a global variable that is calculated
  ! in the CalculateSupport procedure !@Vedant FB28901
  !@ADO 1646468 Vedant ProCalc 2023
!!  IF GLO:FiledAfterSep1 |
!!  AND AltNetResources < 1000
  IF AltNetResources < 1000
  !Vedant - End
   ALT01 = AltNetResources * .15 - DisabilityIncome - SocialSecurityBenefits
