[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!ExportRecordsADOP     ROUTINE
!-------------------------------------
ExportRecordsADOP     ROUTINE
!-------------------------------------
  LOOP 10 TIMES
    QCOUNTER += 1
    IF QCOUNTER > MaxLoop
      DO ExportFinishOutADOP
      LOC:ExpAdopDone=TRUE
      ExportCompleted = TRUE
      CAS:CAS_ID=GLO:CAS_ID
      SET(CAS:kCAS_ID,CAS:kCAS_ID)
      NEXT(CASES)
      IF ~ERRORCODE() AND CAS:CAS_ID=GLO:CAS_ID AND ~CAS:VOLUME_ID
        CAS:VOLUME_ID=GLO:VOLUME_ID      !SAVE VOLUME_ID TO CASES.TPS BECAUSE IF IT'S NEW CASE
        PUT(CASES)                       ! THEN THE CAS:VOLUME_ID IS BLANK
      END
      BREAK
    .
    LOC:Progress = ((Maxloop+QCOUNTER)/(Maxloop*2)) * 100
    DISPLAY()

    GET(ReportQueue,QCounter)
    IF ERRORCODE() THEN BREAK.

    ANS:CAS_ID = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:SCOPE  = 'V'
    CLEAR(ANS:INDEXSTRING,-1)
    ANS:INDEXES[1]  = SwapUshortBytes(QCOUNTER)
    
    ANS:ANSWER      = LEFT(FORMAT(RPQ:DATE,@D01))
    ANS:OBJ_ID      = 'PX001'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
        
    ANS:ANSWER      = RPQ:Type
    ANS:OBJ_ID      = 'PX002'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    IF RPQ:TYPE = 'D'                                     !For DEBITS, the amount applied
      RPQ:AplUobl = RPQ:DebitUobl                         ! to each category is not stored in
      RPQ:AplCobl = RPQ:DebitCobl                         ! reportque so need to set it up here
      RPQ:AplUint = RPQ:DebitUint
      RPQ:AplCint = RPQ:DebitCint
      RPQ:AmountP = 0-(RPQ:DebitUobl+RPQ:DebitCobl+RPQ:DebitUint+RPQ:DebitCint)
      RPQ:AmountO = 0.00
    END

    !Ma - Fogbugz 18886, the pictures used to save decimal amount is too small which causes "######.##" so changed all
    ! "@N-_9.2" pictures to "@N-_10.2" and then changed the PX006V picture from "@N-_10.2" to "@N-11.2"  7/31/08
    ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountO,@N-_11.2))
    ANS:OBJ_ID      = 'PX003'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:UnpaidBalance,@N-_11.2))
    ANS:OBJ_ID      = 'PX004'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountP,@N-_11.2))
    IF RPQ:Type = 'D'
      ANS:Answer = 0.00
    END
    ANS:OBJ_ID      = 'PX005'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:Uobl,@N-_11.2))
    ANS:OBJ_ID      = 'PX006'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:Cobl,@N-_11.2))
    ANS:OBJ_ID      = 'PX007'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:Uint,@N-_11.2))
    ANS:OBJ_ID      = 'PX008'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:Cint,@N-_11.2))
    ANS:OBJ_ID      = 'PX009'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AplUobl,@N-_11.2))
    ANS:OBJ_ID      = 'PX010'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AplCobl,@N-_11.2))
    ANS:OBJ_ID      = 'PX011'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AplUint,@N-_11.2))
    ANS:OBJ_ID      = 'PX012'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AplCint,@N-_11.2))
    ANS:OBJ_ID      = 'PX013'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = RPQ:DebitMessage
    ANS:OBJ_ID      = 'PX014'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    !MA ADDED FOLLOWING CODE TO SAVE ATTORNEY'S FEES AND COSTS   7/05/01
    ANS:ANSWER      = LEFT(FORMAT(RPQ:Attyfeescosts,@N-_10.2))
    ANS:OBJ_ID      = 'PX049'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AttyfeescostsInt,@N-_10.2))
    ANS:OBJ_ID      = 'PX050'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    IF RPQ:TYPE = 'O'
      ANS:ANSWER      = LEFT(RPQ:Frequency)
      ANS:OBJ_ID      = 'AX100'
      ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
      ADD(ANSWERS)
    END

  END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!ExportRecordsFAM     ROUTINE
OMIT('*Parth-FB-28903-07-21-2021')
!-------------------------------------
ExportRecordsFAM     ROUTINE
!-------------------------------------
  LOOP 10 TIMES
    QCOUNTER += 1
    IF QCOUNTER > MaxLoop
      DO ExportFinishOutFAM
      LOC:ExpFamilyDone = TRUE
      QCOUNTER=0
      BREAK
    .
    LOC:Progress = (QCOUNTER/(Maxloop*2)) * 100    !SAVE SAME NUMBER OF RECORDS FOR BOTH TXFAM & TXADOPT
    DISPLAY()

    GET(ReportQueue,QCounter)
    IF ERRORCODE() THEN BREAK.

    ANS:CAS_ID = GLO:CAS_ID
    ANS:VOLUME_ID = LOC:VOLUME_ID
    ANS:SCOPE  = 'V'
    CLEAR(ANS:INDEXSTRING,-1)
    ANS:INDEXES[1]  = SwapUshortBytes(QCOUNTER)
    ANS:ANSWER      = LEFT(FORMAT(RPQ:DATE,@D01))
    ANS:OBJ_ID      = 'PX001'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
            
    ANS:ANSWER      = RPQ:Type
    ANS:OBJ_ID      = 'PX002'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    IF RPQ:TYPE = 'D'                                     !For DEBITS, the amount applied
      RPQ:AplUobl = RPQ:DebitUobl                         ! to each category is not stored in
      RPQ:AplCobl = RPQ:DebitCobl                         ! reportque so need to set it up here
      RPQ:AplUint = RPQ:DebitUint
      RPQ:AplCint = RPQ:DebitCint
      RPQ:AmountP = 0-(RPQ:DebitUobl+RPQ:DebitCobl+RPQ:DebitUint+RPQ:DebitCint)
      RPQ:AmountO = 0.00
    END

    !Ma - Fogbugz 18886, the pictures used to save decimal amount is too small which causes "######.##" so changed all
    ! "@N-_9.2" pictures to "@N-_10.2" and then changed the PX006V picture from "@N-_10.2" to "@N-11.2"  7/31/08
    ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountO,@N-_11.2))
    ANS:OBJ_ID      = 'PX003'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:UnpaidBalance,@N-_11.2))
    ANS:OBJ_ID      = 'PX004'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountP,@N-_11.2))
    ANS:OBJ_ID      = 'PX005'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:Uobl,@N-_11.2))
    ANS:OBJ_ID      = 'PX006'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:Cobl,@N-_11.2))
    ANS:OBJ_ID      = 'PX007'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:Uint,@N-_11.2))
    ANS:OBJ_ID      = 'PX008'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:Cint,@N-_11.2))
    ANS:OBJ_ID      = 'PX009'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AplUobl,@N-_11.2))
    ANS:OBJ_ID      = 'PX010'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AplCobl,@N-_11.2))
    ANS:OBJ_ID      = 'PX011'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AplUint,@N-_11.2))
    ANS:OBJ_ID      = 'PX012'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AplCint,@N-_11.2))
    ANS:OBJ_ID      = 'PX013'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = RPQ:DebitMessage
    ANS:OBJ_ID      = 'PX014'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    !MA ADDED FOLLOWING CODE TO SAVE ATTORNEY'S FEES AND COSTS   7/05/01
    ANS:ANSWER      = LEFT(FORMAT(RPQ:Attyfeescosts,@N-_10.2))
    ANS:OBJ_ID      = 'PX049'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    ANS:ANSWER      = LEFT(FORMAT(RPQ:AttyfeescostsInt,@N-_10.2))
    ANS:OBJ_ID      = 'PX050'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)

    IF RPQ:TYPE='O'            
      ANS:ANSWER      = LEFT(RPQ:Frequency)    !THIS IS NEW TOKEN FOR FREQUENCY ONLY SAVE FOR OBL
      ANS:OBJ_ID      = 'AX100'
      ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
      ADD(ANSWERS)
    END

    END
    
!END OMIT 
!*Parth-FB-28903-07-21-2021
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!@Parth - FB28903 - ExportRecordsFAMAfterSep1     ROUTINE
!-------------------------------------
ExportRecordsFAMAfterSep1   ROUTINE
!-------------------------------------
  LOOP 10 TIMES
    QCOUNTER += 1
    IF QCOUNTER > MaxLoop
      IF LOC:ExpFamilyDone = FALSE
        DO ExportFinishOutFAM
        LOC:ExpFamilyDone = TRUE
      ELSIF LOC:ExpAdopDone = FALSE
        DO ExportFinishOutFAM
        LOC:ExpAdopDone = TRUE
      END
!      QCOUNTER=0
!      QCOUNTERBig = 0
!      KCOUNTERChild = 0
!      KCOUNTERMedical = 0
!      KCOUNTERDental = 0
!!      DebugCL.Send('ExportRecordsFAMAfterSep1 (1) KCOUNTERObligationsChild: ' & KCOUNTERObligationsChild)
!      KCOUNTERObligationsChild = 0
!      KCOUNTERObligationsMedical = 0
!      KCOUNTERObligationsDental = 0
!      DebugCL.Send('ExportRecordsFAMAfterSep1 (2) KCOUNTERObligationsChild: ' & KCOUNTERObligationsChild)
      Do SetupExport
      BREAK
    .
    LOC:Progress = (QCOUNTER/(Maxloop*2)) * 100    !SAVE SAME NUMBER OF RECORDS FOR BOTH TXFAM & TXADOPT
    DISPLAY()
    
    GET(ReportQueue,QCounter)
    IF ERRORCODE() THEN BREAK.
!    DebugCL.Send('QCounter: ' & QCounter & ', RPQ:ObligationType: ' & RPQ:ObligationType & ', RPQ:Type: ' & RPQ:Type & ', RPQ:Date: ' & RPQ:DateFormatted)
    Do ExportRecordsFAMAfterSep1All
    Do ExportRecordsFAMAfterSep1AllChild
    Do ExportRecordsFAMAfterSep1AllMedical
    Do ExportRecordsFAMAfterSep1AllDental
    If RPQ:Type = 'P'
      Do ExportRecordsFAMAfterSep1Child
      Do ExportRecordsFAMAfterSep1Medical
      Do ExportRecordsFAMAfterSep1Dental
    ELSE
      CASE UPPER(RPQ:ObligationType)
      OF 'CHILD'
        Do ExportRecordsFAMAfterSep1Child
      OF 'MEDICAL'
        Do ExportRecordsFAMAfterSep1Medical
      OF 'DENTAL'
        Do ExportRecordsFAMAfterSep1Dental
      END
    END
  END
!@Parth
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!@Parth - FB28903 - ExportRecordsFAMAfterSep1All  ROUTINE
ExportRecordsFAMAfterSep1All    ROUTINE
  
  If (RPQ:Type = 'P' OR RPQ:Type = 'F') AND CLIP(RPQ:ObligationType) <> ''
    EXIT
  END
!  DebugCL.Send('Inner QCounter: ' & QCounter & ', RPQ:ObligationType: ' & RPQ:ObligationType & ', RPQ:Type: ' & RPQ:Type & ', RPQ:Date: ' & RPQ:DateFormatted)
  ANS:CAS_ID = GLO:CAS_ID
!  DebugCL.Send('Saving Volume: ' & LOC:VOLUME_ID)
  ANS:VOLUME_ID = LOC:VOLUME_ID
  ANS:SCOPE  = 'V'
  CLEAR(ANS:INDEXSTRING,-1)
! @Parth - FB28903 
  QCOUNTERBig += 1
   
  
  ANS:INDEXES[1]  = SwapUshortBytes(QCOUNTERBig)
! @Parth 
  DebugCL.Send('ExportRecordsFAMAfterSep1All,.....PX001: ' & FORMAT(RPQ:DATE,@D01))
  ANS:ANSWER      = LEFT(FORMAT(RPQ:DATE,@D01))
  ANS:OBJ_ID      = 'PX001'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)
            
  ANS:ANSWER      = RPQ:Type
  ANS:OBJ_ID      = 'PX002'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  IF RPQ:TYPE = 'D'                                     !For DEBITS, the amount applied
    RPQ:AplUobl = RPQ:DebitUobl                         ! to each category is not stored in
    RPQ:AplCobl = RPQ:DebitCobl                         ! reportque so need to set it up here
    RPQ:AplUint = RPQ:DebitUint
    RPQ:AplCint = RPQ:DebitCint
    RPQ:AmountP = 0-(RPQ:DebitUobl+RPQ:DebitCobl+RPQ:DebitUint+RPQ:DebitCint)
    RPQ:AmountO = 0.00
  END

    !Ma - Fogbugz 18886, the pictures used to save decimal amount is too small which causes "######.##" so changed all
    ! "@N-_9.2" pictures to "@N-_10.2" and then changed the PX006V picture from "@N-_10.2" to "@N-11.2"  7/31/08
  ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountO,@N-_11.2))
  ANS:OBJ_ID      = 'PX003'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:UnpaidBalance,@N-_11.2))
  ANS:OBJ_ID      = 'PX004'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AmountP,@N-_11.2))
  IF RPQ:Type = 'D'
      ANS:Answer = 0.00
  END
  ANS:OBJ_ID      = 'PX005'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)
  
  ANS:ANSWER      = LEFT(FORMAT(RPQ:Uobl,@N-_11.2))
  ANS:OBJ_ID      = 'PX006'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:Cobl,@N-_11.2))
  ANS:OBJ_ID      = 'PX007'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:Uint,@N-_11.2))
  ANS:OBJ_ID      = 'PX008'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:Cint,@N-_11.2))
  ANS:OBJ_ID      = 'PX009'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AplUobl,@N-_11.2))
  ANS:OBJ_ID      = 'PX010'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AplCobl,@N-_11.2))
  ANS:OBJ_ID      = 'PX011'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AplUint,@N-_11.2))
  ANS:OBJ_ID      = 'PX012'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AplCint,@N-_11.2))
  ANS:OBJ_ID      = 'PX013'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = RPQ:DebitMessage
  ANS:OBJ_ID      = 'PX014'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

    !MA ADDED FOLLOWING CODE TO SAVE ATTORNEY'S FEES AND COSTS   7/05/01
  ANS:ANSWER      = LEFT(FORMAT(RPQ:Attyfeescosts,@N-_10.2))
  ANS:OBJ_ID      = 'PX049'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  ANS:ANSWER      = LEFT(FORMAT(RPQ:AttyfeescostsInt,@N-_10.2))
  ANS:OBJ_ID      = 'PX050'
  ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
  ADD(ANSWERS)

  IF RPQ:TYPE='O'            
    ANS:ANSWER      = LEFT(RPQ:Frequency)    !THIS IS NEW TOKEN FOR FREQUENCY ONLY SAVE FOR OBL
    ANS:OBJ_ID      = 'AX100'
    ANS:LENGTH      = LEN(CLIP(ANS:ANSWER))
    ADD(ANSWERS)
  END
  
  
    
