OMIT('***MCY***')  !OMITED WHOLE THINGS BELOW BECAUSE IT SEEMS FUNY WHEN YOU CHANGE FIRST
                   ! BLOCK OF CODE THE GENERATOR AUTOMATICALLY CHANGES THE OTHER BLOCK ACCORDINGLY
                   ! SO THAT WE COULDN'T SET DIFFERENT PARAMETER FOR Preview AND Non-Preview OF SUMMARY
[END]
EMBED %ProcRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 3600
PROPERTY:END
  END
OMIT('***ALS***')   !moved to processpayments on 2/25/99

!------------------------------
Totals    ROUTINE
!-----------------------------
  TotalUnconfirmed = 0
  PayConfirmedO = 0
  PayUnconfirmedO = 0
  PayConfirmedI = 0
  PayUnconfirmedI = 0
  TotalPaymentsApplied = 0
  TotalPaymentsMade = 0
  TotalRemaining = 0

  GLO:UnconfirmedPrincipalBalance = 0
  GLO:UnconfirmedInterestBalance = 0
  GLO:ConfirmedPrincipalBalance = 0
  GLO:ConfirmedInterestBalance = 0

  QCOUNTER = 0
  LOOP QCOUNTER = 1 TO RECORDS(ReportQueue)
    GET(ReportQueue,QCOUNTER)
    IF ERRORCODE() THEN BREAK.
    TotalUnconfirmed += RPQ:AmountO
    PayConfirmedO += RPQ:AplCobl
    PayUnconfirmedO += RPQ:AplUobl
    PayConfirmedI += RPQ:AplCint
    PayUnconfirmedI += RPQ:AplUint
    TotalPaymentsMade += RPQ:AmountP

    IF RPQ:TYPE = 'D'              !set up to print debits
      IF EXT:DebitUobl             !This doesn't affect any calculations but
        RPQ:AmountO = EXT:DebitUobl! it causes the amount of the debit to be
      ELSIF EXT:DebitUint          ! shown in the first column after the date
        RPQ:AmountO = EXT:DebitUint
      ELSIF EXT:DebitCobl
        RPQ:AmountO = EXT:DebitCobl
      ELSIF EXT:DebitCint
        RPQ:AmountO = EXT:DebitCint
      .
      PUT(ReportQueue)
  . .

  TotalPaymentsApplied = RPQ:AplCobl + RPQ:AplUobl + RPQ:AplCint + RPQ:AplUint

  TotalObligations = NAM:ConfirmedPrincipal + TotalUnconfirmed

  GET(ReportQueue,RECORDS(ReportQueue))
  GLO:ConfirmedPrincipalBalance = RPQ:Cobl
  GLO:UnconfirmedPrincipalBalance = RPQ:Uobl
  GLO:ConfirmedInterestBalance = RPQ:Cint
  GLO:UnconfirmedInterestBalance = RPQ:Uint
  TotalRemaining = RPQ:Cobl + RPQ:Uobl + RPQ:Cint + RPQ:Uint

  IF TotalRemaining < 0                !Added on 5/12/97 by ALS
    PayUnconfirmedO -= ABS(TotalRemaining)  !If there's a credit balance at end
  .                                    ! need to deduct it from the amount
                                       ! we said was applied to unconfirmed
                                       ! obligations because in the calculation
                                       ! we had automaticallyl assumed that
                                       ! any amount of a payment that is left
                                       ! over will eventually be applied to
                                       ! an obligation.  If we wound up with
                                       ! a credit balance, this needs to be
                                       ! adjusted.
   ***ALS***

[SOURCE]
PROPERTY:BEGIN
PRIORITY 3600
PROPERTY:END
!@Parth - FB28903 - Update Report
UpdateReport        ROUTINE
DATA
Stringcl  StringClType
CODE
  
  ReplaceStringCL.ReplaceString(?string130,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?string72,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?string73,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?string137,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?string86,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?string87,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?string286,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?string287,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?string114,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?string125,report1,CurrentObligationType)
  ReplaceStringCL.ReplaceString(?String59,report,CurrentObligationType)
  DebugCL.Send('11 NAMChild:InterestType: ' & NAMChild:InterestType)
  
  InterestType = 'N/A'
  LOC:AttyInterestType = 'N/A'
  
  CASE UPPER(CurrentObligationType)
  OF 'CHILD'
    LOC:TotalUnconfirmed = GLO:TotalsChild:TotalUnconfirmed
    LOC:PayConfirmedO = GLO:TotalsChild:PayConfirmedO
    LOC:PayUnconfirmedO = GLO:TotalsChild:PayUnconfirmedO
    LOC:PayConfirmedI = GLO:TotalsChild:PayConfirmedI
    LOC:PayUnconfirmedI = GLO:TotalsChild:PayUnconfirmedI
    LOC:TotalPaymentsApplied = GLO:TotalsChild:TotalPaymentsApplied
    LOC:TotalPaymentsMade = GLO:TotalsChild:TotalPaymentsMade
    LOC:TotalRemaining = GLO:TotalsChild:TotalRemaining
    LOC:PayAttyfeescosts = GLO:TotalsChild:PayAttyfeescosts
    LOC:PayAttyfeescostsInt = GLO:TotalsChild:PayAttyfeescostsInt
    LOC:AttyfeescostsBalance = GLO:TotalsChild:AttyfeescostsBalance
    LOC:AttyfeescostsIntBalance = GLO:TotalsChild:AttyfeescostsIntBalance
    LOC:UnconfirmedPrincipalBalance = GLO:TotalsChild:UnconfirmedPrincipalBalance
    LOC:UnconfirmedPrincipalBalanceBefore = GLO:TotalsChild:UnconfirmedPrincipalBalanceBefore
    LOC:UnconfirmedInterestBalance = GLO:TotalsChild:UnconfirmedInterestBalance
    LOC:ConfirmedPrincipalBalance = GLO:TotalsChild:ConfirmedPrincipalBalance
    LOC:ConfirmedInterestBalance = GLO:TotalsChild:ConfirmedInterestBalance
    LOC:TotalObligations = GLO:TotalsChild:TotalObligations
    LOC:DelBalBefore = GLO:TotalsChild:DelBalBefore
    LOC:DelBalAfter = GLO:TotalsChild:DelBalAfter
    LOC:ConfirmedLastDate = GLO:TotalsChild:ConfirmedLastDate
    LOC:UnConfirmedLastDate = GLO:TotalsChild:UnConfirmedLastDate
    LOC:ConfIntRate = GLO:TotalsChild:ConfIntRate
    LOC:DateRendered = GLO:TotalsChild:DateRendered
    LOC:LastCompoundDate = GLO:TotalsChild:LastCompoundDate
    LOC:CompoundBalance = GLO:TotalsChild:CompoundBalance
    LOC:SaveCompoundBalance = GLO:TotalsChild:SaveCompoundBalance
    LOC:LastCompoundDateAtty = GLO:TotalsChild:LastCompoundDateAtty
    LOC:CompoundBalanceAtty = GLO:TotalsChild:CompoundBalanceAtty
