EMBED %ProcedureRoutines
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
!------------------------------
showfreqwarning routine
!------------------------------

          select(?Currenttab,2)
          IF RECORDS(QOBLIGATE) AND FIRSTOPEN AND MAKEGUESS
          !NOTE: this code is duplicated in OK and Cancel processing
          !
            FIRSTOPEN=FALSE
            MESSAGE('The column "Frequency" has been automatically filled out by Delinquent Calculator. '|
                  & 'Please ensure these values are correct.','Confirm',ICON:EXCLAMATION)
          END



!------------------------------
PaymentAlerts     ROUTINE
!------------------------------
 CASE KEYCODE()                                ! What keycode was hit
 OF MouseLeft2
 OROF ENTERKEY
   POST(Event:Accepted,?ChangePayment)
 OF InsertKey
   POST(Event:Accepted,?InsertPayment)
 OF DeleteKey
     POST(Event:Accepted,?DeletePayment)
 END

!--------------------------------
InsertPayment     ROUTINE
!--------------------------------
  GlobalRequest = InsertRecord
  UpdatePayments
  SORT(QPAYMENTS,QPA:PDATE)

!--------------------------------
ChangePayment     ROUTINE
!--------------------------------
  GET(QPAYMENTS,CHOICE(?QPAYMENT))
  GlobalRequest = ChangeRecord
  UpdatePayments
  SORT(QPAYMENTS,QPA:PDATE)

!--------------------------------
DeletePayment      ROUTINE
!--------------------------------
  GET(QPAYMENTS,CHOICE(?QPAYMENT))
  IF ~ERRORCODE()
    DELETE(QPAYMENTS)
    IF ~ERRORCODE()
       GLO:UpdatePayments = TRUE
    END
  END


!------------------------------
ObligateAlerts     ROUTINE
!------------------------------
 CASE KEYCODE()                                ! What keycode was hit
 OF MouseLeft2
 OROF ENTERKEY
   POST(Event:Accepted,?ChangeObligation)
 OF InsertKey
   POST(Event:Accepted,?InsertObligation)
 OF DeleteKey
     POST(Event:Accepted,?DeleteObligation)
 END

!--------------------------------
InsertObligation     ROUTINE
!--------------------------------
  GlobalRequest = InsertRecord
  UpdateObligate
  SORT(QObligate,+QOB:ODATE,+QOB:TypeSort)


!--------------------------------
ChangeObligation     ROUTINE
!--------------------------------
  GET(QOBLIGATE,CHOICE(?QOBLIGATE))
  GlobalRequest = ChangeRecord
  UpdateObligate
  SORT(QObligate,+QOB:ODATE,+QOB:TypeSort)

!--------------------------------
DeleteObligation     ROUTINE
!--------------------------------
  GET(QOBLIGATE,CHOICE(?QOBLIGATE))
  IF ~ERRORCODE()
    DELETE(QOBLIGATE)
    IF ~ERRORCODE()
       GLO:UpdateObligate = TRUE
    END
  END


!--------------------------
GetOblFrequency     ROUTINE     !MA CREATED THIS ROUTINE TO GET THE FREQUENCY OF OBLIGATION BY PARSING QOBLIGATE  2/15/02
!--------------------------
  IF ~RECORDS(QOBLIGATE)
    EXIT
  END
  IF RECORDS(QOBLIGATE)=1
    GET(QOBLIGATE,1)
    QOB:FREQUENCY='Monthly'     !IF ONLY 1 RECORD EXISTS THEN IT'S MONTHLY OBL
    PUT(QOBLIGATE)
    EXIT
  END
  FREE(ABSTRACTQ)
  CLEAR(ABSTRACTQ)
  MONTH#=0
  YEAR#=0
  GROUP#=0
  LOOP I#=1 TO RECORDS(QOBLIGATE)     !FIRST MARK UP GROUPS
    GET(QOBLIGATE,I#)
    IF ERRORCODE() THEN BREAK.
    IF I#=1
      MONTH#=MONTH(QOB:ODate)
      YEAR#=YEAR(QOB:ODate)
      GROUP#+=1
      QOB:GROUP=GROUP#
      PUT(QOBLIGATE)
      CYCLE
    END
    IF MONTH(QOB:ODATE)=MONTH# AND YEAR(QOB:ODATE)=YEAR#
      QOB:GROUP=GROUP#
    ELSE
      GROUP#+=1
      MONTH#=MONTH(QOB:ODate)
      YEAR#=YEAR(QOB:ODate)
      QOB:GROUP=GROUP#
    END
    PUT(QOBLIGATE)
  END
  I#=1
  GET(QOBLIGATE,1)
  LOOP                !THEN GENERATE THE ABSTRACTION OF THE OBLIGATION LIST INTO ABSTRACTQ
    GROUP#=QOB:GROUP
    C#=0
    FIRSTAMOUNT#=QOB:OAMOUNT
    LASTAMOUNT#=QOB:OAMOUNT
    FIRSTDATE#=QOB:ODATE
    LASTDATE#=QOB:ODATE
    LOOP J#=I# TO RECORDS(QOBLIGATE)
      GET(QOBLIGATE,J#)
      IF ERRORCODE() THEN BREAK.
      IF GROUP#=QOB:GROUP
        C#+=1
        LASTAMOUNT#=QOB:OAMOUNT
        LASTDATE#=QOB:ODATE
      ELSE
        BREAK
      END
    END
    CLEAR(ABSTRACTQ)
    AQ:ID=GROUP#
    AQ:FIRSTAMOUNT=FIRSTAMOUNT#
    AQ:LASTAMOUNT=LASTAMOUNT#
    AQ:FIRSTDATE=FIRSTDATE#
    AQ:LASTDATE=LASTDATE#
    AQ:NUMBEROFOBL=C#
    ADD(ABSTRACTQ)
    CASE C#
    OF 1        !IF IT'S 1 THEN THERE MAY BE 4 CHANCES OF 'WEEKLY','BI-WEEKLY','SEMI-MONTHLY' AND 'MONTHLY'
      IF J#+1>=RECORDS(QOBLIGATE)
        DATE#=QOB:ODATE
        GET(QOBLIGATE,J#+1)
        IF QOB:ODATE-DATE#=7 AND QOB:OAMOUNT=AQ:LASTAMOUNT     !WEEKLY
          AQ:TYPE='C'
          PUT(ABSTRACTQ)
        ELSIF QOB:ODATE-DATE#=14 AND QOB:OAMOUNT=AQ:LASTAMOUNT !BI-WEEKLY
          AQ:TYPE='D'
          PUT(ABSTRACTQ)
        END
        GET(QOBLIGATE,J#)
      END
    OF 2        !IF IT'S 2 THEN SEE IF IT'S WEEKLY OR BI-WEEKLY
      GET(QOBLIGATE,J#-1)
      DATE#=QOB:ODATE
      DAY1#=DAY(QOB:ODATE)
      GET(QOBLIGATE,J#-2)
      DAY2#=DAY(QOB:ODATE)
      IF DATE#-QOB:ODATE=7     !IT'S WEEKLY
        AQ:TYPE='C'
        PUT(ABSTRACTQ)
      ELSIF DATE#-QOB:ODATE=14
        IF J#+1<=RECORDS(QOBLIGATE)
          GET(QOBLIGATE,J#)
          DAY3#=DAY(QOB:ODATE)
          GET(QOBLIGATE,J#+1)
          IF DAY2#=DAY3# AND DAY1#=DAY(QOB:ODATE)
            AQ:TYPE=''
          ELSE
            AQ:TYPE='D'        !Bi-weekly
          END
          PUT(ABSTRACTQ)
        END
      END
      GET(QOBLIGATE,J#)
    OF 3
      !IF IT'S THREE THEN MAY BE BI-WEEKLY OR WEEKLY DEPENDING ON NEXT GROUP
    END
    IF J#>RECORDS(QOBLIGATE)
      BREAK
    END
    I#=J#
  END

  LOOP I#=1 TO RECORDS(ABSTRACTQ)    !THEN TRY TO GUESS THE FREQUENCY BASED ON THE ABSTRACTQ
    GET(ABSTRACTQ,I#)
    IF ERRORCODE() THEN BREAK.
    CASE AQ:NUMBEROFOBL
    OF 4                             !Weekly
    OROF 5
      AQ:FREQUENCY='Weekly'
      PUT(ABSTRACTQ)
    OF 3
      IF AQ:TYPE='C'
        AQ:FREQUENCY='Weekly'        !Weekly
        PUT(ABSTRACTQ)
      ELSIF AQ:TYPE='D'
        AQ:FREQUENCY='Bi-weekly'     !Bi-weekly
        PUT(ABSTRACTQ)
      ELSE
        LASTAMOUNT#=AQ:LASTAMOUNT
        FIRSTAMOUNT#=AQ:FIRSTAMOUNT
        IF I#+1<=RECORDS(ABSTRACTQ)
          GET(ABSTRACTQ,I#+1)
          IF AQ:NUMBEROFOBL=4 AND LASTAMOUNT#=AQ:FIRSTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Weekly'    !Weekly
          ELSE
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Bi-weekly' !Bi-weekly
          END
        ELSE
          GET(ABSTRACTQ,I#-1)
          IF AQ:NUMBEROFOBL=4 AND FIRSTAMOUNT#=AQ:LASTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Weekly'    !Weekly
          ELSE
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Bi-weekly' !Bi-weekly
          END
        END
        PUT(ABSTRACTQ)
      END
    OF 2
      IF AQ:TYPE='C'
        AQ:Frequency='Weekly'        !Weekly
      ELSIF AQ:TYPE='D'
        AQ:Frequency='Bi-weekly'     !Bi-weekly
      ELSE
        AQ:Frequency='Semi-monthly'  !Semi-monthly
      END
      PUT(ABSTRACTQ)
    OF 1
      LASTAMOUNT#=AQ:LASTAMOUNT
      FIRSTAMOUNT#=AQ:FIRSTAMOUNT
      LASTDATE#=AQ:LASTDATE
      FIRSTDATE#=AQ:FIRSTDATE
      IF AQ:TYPE='C'
        AQ:Frequency='Weekly'
        PUT(ABSTRACTQ)
      ELSIF AQ:TYPE='D'
        AQ:Frequency='Bi-weekly'
        PUT(ABSTRACTQ)
      ELSE
        IF I#+1<=RECORDS(ABSTRACTQ)
          GET(ABSTRACTQ,I#+1)
          IF AQ:NUMBEROFOBL=2 AND LASTAMOUNT#=AQ:FIRSTAMOUNT AND AQ:FIRSTDATE-LASTDATE#<30
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Semi-monthly' !Semi-monthly
          ELSE
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Monthly'      !Monthly
          END
        ELSE       !IF IT'S LAST ONE THEN SEE BACKWARD
          GET(ABSTRACTQ,I#-1)
          IF AQ:NUMBEROFOBL=4 AND FIRSTAMOUNT#=AQ:LASTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Weekly'       !Weekly
          ELSIF AQ:NUMBEROFOBL=3 AND FIRSTAMOUNT#=AQ:LASTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Bi-weekly'    !Bi-weekly
          ELSIF AQ:NUMBEROFOBL=2 AND FIRSTAMOUNT#=AQ:LASTAMOUNT
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Semi-monthly' !Semi-monthly
          ELSE
            GET(ABSTRACTQ,I#)
            AQ:Frequency='Monthly'      !Monthly
          END
        END
        PUT(ABSTRACTQ)
      END
    END
  END
  LOOP I#=1 TO RECORDS(QOBLIGATE)     !NOW WRITE BACK FREQUENCY TO QOBLIGATE
    GET(QOBLIGATE,I#)
    IF ERRORCODE() THEN BREAK.
    AQ:ID=QOB:GROUP
    GET(ABSTRACTQ,AQ:ID)
    IF ~ERRORCODE()
      QOB:FREQUENCY=AQ:FREQUENCY
    ELSE
      QOB:FREQUENCY=''
    END
    PUT(QOBLIGATE)
  END


[END]
