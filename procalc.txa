[WINDOW]
window  WINDOW('Child Support Calculator'),AT(,,424,290),FONT('MS Sans Serif',8,,FONT:regular), |
          DOUBLE,ALRT(AltShiftF11),ALRT(AltShiftF12),CENTER,ICON('prowin.ico'),GRAY,MDI,HLP('~Obligatio' & |
          'n_Calculator_Form'),SYSTEM
          SHEET,AT(5,1,414,262),USE(?Sheet1),#ORIG(?Sheet1),#ORDINAL(1)
            TAB('&General'),USE(?Tab1),#ORIG(?Tab1),#ORDINAL(2)
              PROMPT('Obligo&r:'),AT(14,29),USE(?Prompt1),#ORIG(?Prompt1),#ORDINAL(3)
              ENTRY(@s80),AT(43,28,114,12),USE(GLO:Obligor),#ORIG(GLO:Obligor),#ORDINAL(4)
              PROMPT('Describe Obligor:'),AT(162,26,30,18),USE(?Prompt15),#ORIG(?Prompt15), |
                #ORDINAL(5)
              OPTION,AT(193,23,67,25),USE(GLO:ObligorParty),#ORIG(?Option1),#ORDINAL(6)
                RADIO('Petitioner'),AT(197,26),USE(?Option1:Radio1),VALUE('1'),#ORIG(?Option1:Radio1), |
                  #ORDINAL(7)
                RADIO('Respondent'),AT(197,35),USE(?Option1:Radio2),VALUE('2'),#ORIG(?Option1:Radio2), |
                  #ORDINAL(8)
              END
              PROMPT('Oblig&ee:'),AT(265,29),USE(?Prompt12),#ORIG(?Prompt12),#ORDINAL(9)
              ENTRY(@s80),AT(294,28,114,12),USE(GLO:Obligee),#ORIG(GLO:Obligee),#ORDINAL(10)
              GROUP('Children'),AT(14,48,396,25),USE(?Group1),BOXED,#ORIG(?Group1),#ORDINAL(11)
                PROMPT('Obligor''s tota&l children:'),AT(19,58),USE(?Prompt3),#ORIG(?Prompt3), |
                  #ORDINAL(12)
                SPIN(@n3),AT(93,56,26,12),USE(TotalChildren),RANGE(1,255),STEP(1),#ORIG(?Spin1), |
                  #ORDINAL(13)
                PROMPT('N&umber of children before the court:'),AT(128,58),USE(?Prompt4),#ORIG(?Prompt4), |
                  #ORDINAL(14)
                SPIN(@n3),AT(245,56,26,12),USE(ChildrenInCourt),RANGE(1,255),STEP(1),#ORIG(?Spin2), |
                  #ORDINAL(15)
                PROMPT('("Number of children before the court" is higher than "Total children")'), |
                  AT(281,54,125,17),USE(?Message4),FONT(,,COLOR:Red,,CHARSET:ANSI),HIDE,#ORIG(?Prompt15), |
                  #ORDINAL(16)
              END
              GROUP('Sec. 154.062 Deductions'),AT(13,75,397,27),USE(?Group2),BOXED,#ORIG(?Group2), |
                #ORDINAL(17)
                PROMPT('&Monthly health ins. for children:'),AT(19,86),USE(?Prompt5),#ORIG(?Prompt5), |
                  #ORDINAL(18)
                ENTRY(@n-9.2),AT(123,85,34,12),USE(HealthInsurance),#ORIG(HealthInsurance), |
                  #ORDINAL(19)
                PROMPT('Monthl&y union dues:'),AT(165,86),USE(?Prompt6),#ORIG(?Prompt6),#ORDINAL(20)
                ENTRY(@n-7.2),AT(234,85,,12),USE(UnionDues),#ORIG(UnionDues),#ORDINAL(21)
                PROMPT('St&ate inc. tax:'),AT(274,86),USE(?Prompt10),#ORIG(?Prompt10),#ORDINAL(22)
                ENTRY(@n-11.2),AT(323,85,46,12),USE(StateIncomeTax),#ORIG(StateIncomeTax), |
                  #ORDINAL(23)
              END
              GROUP('&Income'),AT(13,103,398,41),USE(?Group3),BOXED,#ORIG(?Group3),#ORDINAL(24)
                PROMPT('&Obligor''s average (taxable) gross monthly income:'),AT(19,114),USE(?Prompt7), |
                  #ORIG(?Prompt7),#ORDINAL(25)
                ENTRY(@n-13.2),AT(180,112,77,12),USE(GrossMonthlyIncome),#ORIG(NetMonthlyIncome), |
                  #ORDINAL(26)
                CHECK('Obligor is sel&f-employed'),AT(265,112,,11),USE(SelfEmployed),VALUE('1', |
                  '0'),#ORIG(SelfEmployed),#ORDINAL(27)
                PROMPT('Additional nonta&xable monthly income (such as military allowances):'), |
                  AT(19,130),USE(?Prompt13),#ORIG(?Prompt13),#ORDINAL(28)
                ENTRY(@n-13.2),AT(237,128,59,12),USE(NontaxableMonthly),#ORIG(NontaxableMonthly), |
                  #ORDINAL(29)
              END
              GROUP('Income Going To Children Because Of Obligor''s Disablity'),AT(13,147, |
                398,28),USE(?Group5),BOXED,#ORIG(?Group5),#ORDINAL(30)
                PROMPT('Amoun&t of any monthly benefits received by child(ren) because ' & |
                  'of obligor''s disability:'),AT(19,160),USE(?Prompt14),#ORIG(?Prompt14), |
                  #ORDINAL(31)
                ENTRY(@n-13.2),AT(286,158,60,12),USE(DisabilityIncome),IMM,#ORIG(DisabilityIncome), |
                  #ORDINAL(32)
              END
              GROUP('Income Going To Children Because Of Obligor''s Social Security Old' & |
                ' Age Benefits'),AT(13,178,399,28),USE(?Group6),BOXED,#ORIG(?Group6),#ORDINAL(33)
                PROMPT('Amount of any monthly benefits received by child(ren) because o' & |
                  'f obligor''s social security ol&d age benefits:'),AT(17,191),USE(?Prompt11), |
                  #ORIG(?Prompt11),#ORDINAL(34)
                ENTRY(@n-13.2),AT(352,189,56,12),USE(SocialSecurityBenefits),#ORIG(SocialSecurityBenefits), |
                  #ORDINAL(35)
              END
              GROUP('Support Obligation For Children Before The Court 1'),AT(13,208,399,52), |
                USE(?Group4),BOXED,#ORIG(?Group4),#ORDINAL(36)
                STRING('Monthly'),AT(110,218),USE(?String7),FONT(,,,FONT:underline),#ORIG(?String7), |
                  #ORDINAL(37)
                STRING('Semi-monthly'),AT(158,218),USE(?String8),FONT(,,,FONT:underline),#ORIG(?String8), |
                  #ORDINAL(38)
                STRING('Weekly'),AT(292,218),USE(?String9),FONT(,,,FONT:underline),#ORIG(?String9), |
                  #ORDINAL(39)
                STRING('Bi-weekly'),AT(229,218),USE(?String10),FONT(,,,FONT:underline),#ORIG(?String10), |
                  #ORDINAL(40)
                STRING(@n$-11.2),AT(216,230),USE(ChildBiWeekly),RIGHT,#ORIG(?String11),#ORDINAL(41)
                STRING(@n$-11.2),AT(155,230),USE(ChildSemiMonthly),RIGHT,#ORIG(?String11), |
                  #ORDINAL(42)
                STRING(@n$-11.2),AT(274,230),USE(ChildWeekly),RIGHT,#ORIG(?String11),#ORDINAL(43)
                STRING(@n$-11.2),AT(94,230,39,10),USE(ChildMonthly),RIGHT,#ORIG(?String11), |
                  #ORDINAL(44)
                STRING('(The above amounts are for 5 children.  Sec. 154.125 provides t' & |
                  'hat support'),AT(87,240),USE(?Message5),HIDE,#ORIG(?String6),#ORDINAL(45)
                STRING('for more than 5 children shall not be less than the amount for ' & |
                  '5 children)'),AT(89,249),USE(?Message6),HIDE,#ORIG(?String11),#ORDINAL(46)
              END
            END
            TAB('Ad&justments'),USE(?Tab2),#ORIG(?Tab2),#ORDINAL(47)
              STRING('Section 154.123 of the Family Code gives the court discretion to ' & |
                'deviate from the child support'),AT(25,27,302,10),USE(?String13),#ORIG(?String13), |
                #ORDINAL(48)
              STRING('guidelines.  That section lists many factors which may be conside' & |
                'red and it lists examples of'),AT(25,36),USE(?String14),#ORIG(?String14), |
                #ORDINAL(49)
              STRING('expenses which might be deducted from net resources in determinin' & |
                'g the support obligation.'),AT(25,44),USE(?String15),#ORIG(?String15),#ORDINAL(50)
              STRING('Some examples of expenses include child care expenses incurred in' & |
                ' order to maintain gainful'),AT(25,60),USE(?String16),#ORIG(?String16),#ORDINAL(51)
              STRING('employment; expenses of education beyond secondary school; cost o' & |
                'f travel in order to exercise'),AT(25,68),USE(?String17),#ORIG(?String17), |
                #ORDINAL(52)
              STRING('possession of or access to a child; debts assumed by a party; etc.'), |
                AT(25,76),USE(?String18),#ORIG(?String18),#ORDINAL(53)
              STRING('Any amount you enter here will be deducted from net resources bef' & |
                'ore the amount of obligor''s'),AT(25,92),USE(?String19),#ORIG(?String19), |
                #ORDINAL(54)
              STRING('child support obligation is determined.  You will have to convinc' & |
                'e the judge that circumstances'),AT(25,100),USE(?String20),#ORIG(?String20), |
                #ORDINAL(55)
              STRING('justify this deviation from the guidelines.  See Section 154.123 ' & |
                'for more details.'),AT(25,108),USE(?String21),#ORIG(?String21),#ORDINAL(56)
              PROMPT('A&mount:'),AT(27,131),USE(?Prompt8),#ORIG(?Prompt8),#ORDINAL(57)
              ENTRY(@n-11.2),AT(57,129,,12),USE(Adjustment),#ORIG(Adjustment),#ORDINAL(58)
              PROMPT('&Description:'),AT(123,131),USE(?Prompt9),#ORIG(?Prompt9),#ORDINAL(59)
              TEXT,AT(167,130,150,47),USE(Explanation),VSCROLL,#ORIG(Explanation),#ORDINAL(60)
            END
          END
          BUTTON('&Save and Close'),AT(293,267,62,19),USE(?OKButton),LEFT,ICON('ok.ico'),DEFAULT, |
            TIP('save all information and quit this program'),#ORIG(?Button4),#ORDINAL(61)
          BUTTON('&Cancel'),AT(359,267,60,19),USE(?CancelButton),LEFT,ICON('cancel.ico'),TIP('quit this ' & |
            'program without saving information'),#ORDINAL(62)
          BUTTON('&Help'),AT(5,268,60,19),USE(?Help),LEFT,ICON(ICON:Help),STD(STD:Help),TIP('display help'), |
            #ORIG(?Button4),#ORDINAL(63)
          BUTTON('&Print'),AT(165,267,60,19),USE(?PrintButton),LEFT,ICON('5printme.ico'),TIP('print report'), |
            #ORIG(?Button3),#ORDINAL(64)
          BUTTON('Sa&ve and Continue'),AT(228,267,62,19),USE(?SaveAndContinueButton),LEFT, |
            ICON('save.ico'),TIP('save all information and continue with this program'),#ORIG(?Button5), |
            #ORDINAL(65)
        END

[PROCEDURE]
NAME GetAverageNum
GLOBAL
NOEXPORT
[COMMON]
DESCRIPTION 'Ma created to calculate average of two numbers'
FROM Clarion Source
MODIFIED '2021/06/17' '17:37:56'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  IF NQ:HINUM-NQ:ID<=0
    PERCENTAGE=0
  ELSE
    PERCENTAGE=(GrossMonthlyIncome-NQ:ID)/(NQ:HINUM-NQ:ID)
  END
  GLO:FICASSTAX1=NQ:LONUMSS1+(NQ:HINUMSS1-NQ:LONUMSS1)*PERCENTAGE
  GLO:FICASSTAX2=NQ:LONUMSS2+(NQ:HINUMSS2-NQ:LONUMSS2)*PERCENTAGE
  GLO:FICASSTAX=GLO:FICASSTAX1+GLO:FICASSTAX2
  GLO:FEDERALTAX=NQ:LONUMFED+(NQ:HINUMFED-NQ:LONUMFED)*PERCENTAGE
  NetResources=GrossMonthlyIncome-GLO:FICASSTAX-GLO:FEDERALTAX
[END]
EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
PERCENTAGE    REAL
[END]
[END]
