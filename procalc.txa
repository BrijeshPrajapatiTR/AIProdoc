%Parameters DEFAULT  ('')
[EMBED]
EMBED %ProcedureInitialize
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
!Fogbugz case 10793, call SetGlobals() before checking license and if caller is cscjs then force to use ProCalc.chm as help
! file since the CSCJS does not have it's own help file (The registration PowerPack window has a help button) MA 12/11/06
SetGlobals(cmdline)
IF GLO:CALLER = eCallerIsCSCJS
  HELP('PROCALC.HLP')
  IF Licensecl.init('TX', 0, , eProCalcHelp)   !THE SECOND PARAMETER 1 MEANS SHOWING TREE AND 0 MEANS NO TREE
    DO PROCEDURERETURN
  END
ELSE
  IF Licensecl.init('TX',0)   !THE SECOND PARAMETER 1 MEANS SHOWING TREE AND 0 MEANS NO TREE
    DO PROCEDURERETURN
  END
END
IF Licensecl.CheckLicense('Procalc.dll')  !CHECK THE LICENSE FOR ADDIN BEING STARTED
  Licensecl.Kill()
  DO PROCEDURERETURN
END
Licensecl.Kill()

HELP('PROCALC.HLP')
!SetGlobals(cmdline)    !FOR EXE VERSION DON'T NEED TO CALL SETGLOBALS PROCEDURE  6/27/01
PaymentOption = 'A'
FirstDay = 1
CLEAR(QAmortize)
FREE(QAmortize)
GLO:IntRate=6.00
FromDate = TODAY()
[END]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?FromDate'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
?FromDate{PROP:TOUCHED} = TRUE
[END]
[END]
WHEN '?Option1:Monthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptFirstDay,?MonthlyLastDay)
DISABLE(?PromptSecondDay,?DayOfWeek)
DISPLAY()
[END]
[END]
WHEN '?Option1:semimonthly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?MonthlyLastDay)
DISPLAY()
[END]
[END]
WHEN '?Option1:weekly'
[INSTANCES]
WHEN 'Selected'
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ENABLE(?PromptDayOfWeek,?DayOfWeek)
DISABLE(?PromptFirstDay,?SemiMonthlyLastDay)
DISPLAY()
[END]
[END]
