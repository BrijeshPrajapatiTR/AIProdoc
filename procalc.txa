[WINDOW]
QuickWindow WINDOW('Payments'),AT(,,230,97),FONT('MS Sans Serif',8,,FONT:regular),DOUBLE,CENTER, |
          GRAY,IMM,HLP('~Payments_Form'),SYSTEM
          SHEET,AT(5,7,218,65),USE(?CurrentTab),SPREAD,#ORIG(CurrentTab)
            TAB('Payment'),FONT(,,,FONT:bold,CHARSET:ANSI)
              PROMPT('Date:'),AT(18,26),USE(?PAY:DATE:Prompt),#LINK(?QPA:PDate),#ORIG(?PAY:DATE:Prompt)
              ENTRY(@D2<50B),AT(54,24,51,12),USE(QPA:PDate),REQ,#LINK(?PAY:DATE:Prompt),#ORIG(PAY:DATE)
              BUTTON,AT(109,22,15,14),USE(?Calendar),LEFT,ICON('smcal.ico'),FLAT,SKIP,#ORIG(?Calendar), |
                #SEQ(2)
              STRING('(mm/dd/yyyy)'),AT(126,26),USE(?String2),#ORIG(?String2)
              PROMPT('Amount:'),AT(18,45),USE(?PAY:AMOUNT:Prompt),#LINK(?QPA:PAmount),#ORIG(?PAY:AMOUNT:Prompt)
              ENTRY(@n-10.2),AT(54,43,51,12),USE(QPA:PAmount),REQ,#LINK(?PAY:AMOUNT:Prompt), |
                #ORIG(PAY:AMOUNT)
            END
          END
          BUTTON('&OK'),AT(120,78,50,15),USE(?Ok),LEFT,ICON('ok.ico'),DEFAULT,#ORIG(?Button5)
          BUTTON('&Cancel'),AT(173,78,50,15),USE(?Cancel),LEFT,ICON('cancel.ico'),#ORIG(?Cancel), |
            #SEQ(3)
          BUTTON('&Help'),AT(5,78,50,15),USE(?Help),LEFT,ICON(ICON:Help),STD(STD:Help)
          BUTTON('&Repeat'),AT(67,78,50,15),USE(?MultiAddButton),LEFT,ICON('RETRY.ICO'),DEFAULT, |
            #ORIG(?Button4)
        END

[END]
