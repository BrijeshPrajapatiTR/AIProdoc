%Parameters DEFAULT  ('')
[EMBED]
EMBED %ControlPreEventHandling
[INSTANCES]
WHEN '?OkButton'
[INSTANCES]
WHEN 'Accepted'
[DEFINITION]
[GROUP]
PRIORITY 4000
INSTANCE 1
[END]
[END]
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 2
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[ADDITION]
NAME Clarion CloseCurrentWindow
[INSTANCE]
INSTANCE 1
[WINDOW]
window  WINDOW('Completed'),AT(,,258,146),FONT('MS Sans Serif',10,,FONT:regular),DOUBLE,CENTER, |
          GRAY
          SHEET,AT(6,5,245,121),USE(?Sheet1),WIZARD,#ORIG(?Sheet1)
            TAB('Tab 1'),USE(?Tab1),#ORIG(?Tab1)
              STRING('The table of obligations owed and payments made by the obligor have been'), |
                AT(13,11),USE(?String1),#ORIG(?String1)
              STRING('saved in your Windows clipboard.  To paste this informaton into y' & |
                'our pleading,'),AT(13,20),USE(?String2),#ORIG(?String2)
              STRING('do the following:'),AT(13,29),USE(?String3),#ORIG(?String3)
              STRING('1.  Switch to your word processor (WordPerfect, Microsoft  Word, etc.)'), |
                AT(31,42),USE(?String4),#ORIG(?String4)
              STRING('2.  Place the cursor at the place in the pleading where you want'),AT(31, |
                54),USE(?String5),#ORIG(?String5)
              STRING('the table placed.'),AT(39,63),USE(?String6),#ORIG(?String6)
              STRING('3.  Paste the table from the clipboard by pressing CTRL-V keys'),AT(31, |
                74),USE(?String7),#ORIG(?String7)
              STRING('or by selecting Edit/Paste on the word processor''s menu.'),AT(39,83), |
                USE(?String8),#ORIG(?String8)
              STRING('NOTE - depending on your margin, font, and tab settings, the information'), |
                AT(13,99),USE(?String9),#ORIG(?String9)
              STRING('may require some formatting after it is pasted into your word processor.'), |
                AT(13,108),USE(?String10),#ORIG(?String10)
            END
          END
          BUTTON('&OK'),AT(99,129,48,15),USE(?OkButton),LEFT,ICON('ok.ico'),#ORIG(?Button1)
        END

[END]
