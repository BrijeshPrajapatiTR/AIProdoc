[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 1
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[PROCEDURE]
NAME AreValuesSame
PROTOTYPE '(),byte'
PARAMETERS '()'
GLOBAL
NOEXPORT
[COMMON]
DESCRIPTION 'compare values for Judgment and Debit tabs'
FROM Clarion Source
MODIFIED '2007/12/11' '17:21:52'
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %DataSection
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
bRetVal     byte(false)
[END]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 5000
PROPERTY:END
  !Judgment
  if ORIJUDG:ConfirmedDate <> NAM:ConfirmedDate
    return bRetVal
  end
  if ORIJUDG:ConfirmedPrincipal <> NAM:ConfirmedPrincipal
    return bRetVal
  end
  if ORIJUDG:ConfirmedInterestRate <> NAM:ConfirmedInterestRate
    return bRetVal
  end
  if ORIJUDG:InterestType <> NAM:InterestType
    return bRetVal
  end

  !Attorney fees
  if ORIATT:AttyFeescosts <> ATT:AttyFeescosts
    return bRetVal
  end
  if ORIATT:InterestRate <> ATT:InterestRate
    return bRetVal
  end
  if ORIATT:InterestType <> ATT:InterestType
    return bRetVal
  end

  !Debits
  if ORIEXT:DebitDate <> EXT:DebitDate
    return bRetVal
  end
  if ORIEXT:DebitUobl <> EXT:DebitUobl
    return bRetVal
  end
  if ORIEXT:DebitUint <> EXT:DebitUint
    return bRetVal
  end
  if ORIEXT:DebitCobl <> EXT:DebitCobl
    return bRetVal
  end
  if ORIEXT:DebitCint <> EXT:DebitCint
    return bRetVal
  end

  bRetVal = true
  return bRetVal
[END]
[END]
