[EMBED]
EMBED %GlobalData
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
ConfirmedObligation     EQUATE(1)
UnconfirmedObligation   EQUATE(2)
ConfirmedInterest       EQUATE(3)
UnconfirmedInterest     EQUATE(4)

FullReport              EQUATE(1)
SummaryReport           EQUATE(2)

glo:Calculatesupportthread      long
