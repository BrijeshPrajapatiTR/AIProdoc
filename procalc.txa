[MODULE]
[COMMON]
FROM Clarion GENERATED
MODIFIED '2021/06/17' '17:37:56'
[PROCEDURE]
NAME SendToClipboard
NOEXPORT
[COMMON]
DESCRIPTION 'send report to clipboard'
FROM Clarion Source
MODIFIED '2021/07/27' '18:35:18'
[DATA]
[SCREENCONTROLS]
! PROMPT('Clip Data:'),USE(?ClipData:Prompt)
! TEXT,USE(ClipData),BOXED
[REPORTCONTROLS]
! TEXT,USE(ClipData),BOXED
ClipData                 STRING(64000)
!!> GUID('a0661e17-579f-4f98-b588-60a39d400285'),PROMPT('Clip Data:'),HEADER('Clip Data'),PICTURE(@s255)
[PROMPTS]
%GenerateOpenClose LONG  (0)
%Parameters DEFAULT  ('')
[EMBED]
EMBED %ProcessedCode
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  !For sending to clip board we do same as printing report i.e. always popup the GetCalcDate window to allow
  ! user to setup date for different calculations 12/11/07
  GetCalcDate(1) !1 means check QObligate, Qpayments, debitdate, confirmeddate to see if any are after the cut off date
  IF GlobalResponse <> RequestCompleted
    RETURN
  .

    ProcessPayments
    DebugCL.Send('ReportQueue dump')
    DebugCL.DumpQ(ReportQueue,'Report Queue')
    DebugCL.DumpQ(QObligate,'Obligation Queue')
    DebugCL.DumpQ(QPayments, 'Payments Queue')
    
    DebugCL.Dump(GLO:TotalsGroup,'GLO - Totals Group')
    DebugCL.Dump(GLO:TotalsGroupChild,'GLO - Totals Group Child')
    DebugCL.Dump(GLO:TotalsGroupMedical,'GLO - Totals Group Medical')
    DebugCL.Dump(GLO:TotalsGroupDental,'GLO - Totals Group Dental Confirmed')
    
    DebugCL.Dump(NAMConfirmedOblSave,'NAM Confirmed OblSave')
    DebugCL.Dump(NAMConfirmedOblChildSupport,'NAM Confirmed Obl Child Support')
    DebugCL.Dump(NAMConfirmedOblMedicalSupport,'NAM Confirmed Obl Medical Support')
    DebugCL.Dump(NAMConfirmedOblDentalSupport,'NAM Confirmed Obl Dental Support')
    
    DebugCL.Dump(ATTYFeesSave,'Atty Support')
    DebugCL.Dump(ATTYFeesChildSupport,'Atty Child Support')
    DebugCL.Dump(ATTYFeesMedicalSupport,'Atty Medical Support')
    DebugCL.Dump(ATTYFeesDentalSupport,'Atty Dental Support')
    
    DebugCL.Dump(EXTDebitSave,'EXT Debit Save')
    DebugCL.Dump(EXTDebitChildSupport,'EXT Debit Child Support')
    DebugCL.Dump(EXTDebitMedicalSupport,'EXT Debit Medical Support')
    DebugCL.Dump(EXTDebitDentalSupport,'EXT Debit Dental Support')
    
    
  !Ma - Fogbugz case 15992, after processPayments reset the dirty flags 12/11/07
  GLO:UpdatePayments = FALSE
  GLO:UpdateObligate = FALSE
  SaveOriginalValues()

  ClipData = 'DATE' & '<9>' & '<9>' & 'DATE'& '<9>'& '<9>' & 'AMOUNT' & '<9>' & 'AMOUNT' & '<9>' & 'BALANCE' & '<13,10>'
  ClipData = CLIP(ClipData) |
           & 'DUE' & '<9>' & '<9>' & 'PAID' & '<9>' & '<9>' &'DUE' & '<9>' & '<9>' & 'PAID' & '<9>' & '<9>' & 'REMAINING DUE'|
           & '<13,10>' & '<13,10>'

  LOOP I# = 1 TO RECORDS(ReportQueue)
    GET(ReportQueue,I#)
    IF ERRORCODE() THEN BREAK.
    IF RPQ:Type = 'O'
      ClipData = CLIP(ClipData) & FORMAT(ReportQueue:Date,@D1)|
                                & '<9>'& '<9>' & '<9>' & FORMAT(ReportQueue:AmountO,@N13.2)|
                                & '<9>' & '<9>' & '<9>'& FORMAT(ReportQueue:UnpaidBalance,@N13.2) & '<13,10>'
    ELSE
      ClipData = CLIP(ClipData) & '<9>' & '<9>' & FORMAT(ReportQueue:Date,@D1)|
                                & '<9>' & '<9>'  & '<9>' & FORMAT(ReportQueue:AmountP,@N13.2) & '<13,10>'
  . .

  SETCLIPBOARD(CLIP(ClipData))

  FinishedWindow
!  TotalUnconfirmed = 0
!  PayConfirmedO = 0
!  PayUnconfirmedO = 0
!  PayConfirmedI = 0
!  PayUnconfirmedI = 0
!  TotalPaymentsApplied = 0
!  TotalPaymentsMade = 0
!  GLO:UnconfirmedPrincipalBalance = 0
!  GLO:UnconfirmedInterestBalance = 0
!  TotalRemaining = 0

!  DO TOTALS
!  LOC:ACTION = PrintObligations
!  ObligateCounter = 0
!  PayCounter = 0
!  ApplyCounter = 0

!  IF GLO:ConfirmedPrincipalBalance
!    CASE GLO:CompoundFlag
!    OF 0
!      InterestType = 'SIMPLE'
!    OF 1
!      InterestType = 'COMPOUND'
!    ELSE
!      InterestType = 'N/A'
!  . .


    OMIT('****')

!------------------------------
Totals    ROUTINE
!-----------------------------

  TotalUnconfirmed = 0
  PayConfirmedO = 0
  PayUnconfirmedO = 0
  PayConfirmedI = 0
  PayUnconfirmedI = 0
  TotalPaymentsApplied = 0
  TotalPaymentsMade = 0
  TotalRemaining = 0

  GLO:UnconfirmedPrincipalBalance = 0
  GLO:UnconfirmedInterestBalance = 0
  GLO:ConfirmedPrincipalBalance = 0
  GLO:ConfirmedInterestBalance = 0

  LOOP I# = 1 TO RECORDS(ReportQueue)
    GET(ReportQueue,I#)
    IF ERRORCODE() THEN BREAK.
    TotalUnconfirmed += RPQ:AmountO
    PayConfirmedO += RPQ:AplCobl
    PayUnconfirmedO += RPQ:AplUobl
    PayConfirmedI += RPQ:AplCint
    PayUnconfirmedI += RPQ:AplUint
    TotalPaymentsMade += RPQ:AmountP
  .

  TotalPaymentsApplied = RPQ:AplCobl + RPQ:AplUobl + RPQ:AplCint + RPQ:AplUint

  TotalObligations = CAS:ConfirmedPrincipal + TotalUnconfirmed

  GET(ReportQueue,RECORDS(ReportQueue))
  GLO:ConfirmedPrincipalBalance = RPQ:Cobl
  GLO:UnconfirmedPrincipalBalance = RPQ:Uobl
  GLO:ConfirmedInterestBalance = RPQ:Cint
  GLO:UnconfirmedInterestBalance = RPQ:Uint
  TotalRemaining = RPQ:Cobl + RPQ:Uobl + RPQ:Cint + RPQ:Uint

    ****
[END]
[END]
[ADDITION]
NAME BBHHABC BBHHProc
[INSTANCE]
INSTANCE 1
OWNER 5
[PROMPTS]
%verDerivedClass LONG  (0)
[CALLS]
GetCalcDate
[END]
