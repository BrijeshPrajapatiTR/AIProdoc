EMBED %LocalProcedures
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 8500
PROPERTY:END
LOCALCL.GetCaseDesc     PROCEDURE()!,STRING
  CODE
  sCaseDesc = ''
  CAS:CAS_ID = GLO:CAS_ID
  SET(CAS:kCAS_ID, CAS:kCAS_ID )
  NEXT(Cases)
  IF ~ERRORCODE() AND CAS:CAS_ID = GLO:CAS_ID
    IF GLO:CON_ID = 0
      GLO:CON_ID = CAS:CON_ID
    END
    sCaseDesc = CAS:Description
  END
  RETURN


LOCALCL.GetContactName   PROCEDURE()!,STRING
  CODE
  sFullName = ''
  IF GLO:CON_ID > 0
    clear(contacts)
    CON:CON_ID = GLO:CON_ID
    SET(CON:kCON_ID,CON:kCON_ID)
    NEXT(Contacts)
    IF ~ERRORCODE() AND CON:CON_ID = GLO:CON_ID
      sFullName = CON:L_NAME
      IF ~CON:IsBusiness
        IF CON:L_NAME AND (CON:F_NAME OR CON:M_NAME)
          sFullName = CLIP(sFullName) & ','
        END
        IF CON:F_NAME
          sFullName = CLIP(sFullName) & CHOOSE(sFullName = '', '', ' ') & CON:F_NAME
        END
        IF CON:M_NAME
          sFullName = CLIP(sFullName) & CHOOSE(sFullName = '', '', ' ') & CON:M_NAME
        END
        IF LEN(CLIP(CON:M_NAME)) = 1
          sFullName = CLIP(sFullName) & '.'
        END
      END
    END
  END
  RETURN

[END]
