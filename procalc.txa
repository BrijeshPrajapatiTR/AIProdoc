[WINDOW]
AppFrame APPLICATION('ProCalc - Child Support Calculator ( Version 2002.3)'),AT(,,400,247), |
          FONT('MS Sans Serif',8,,FONT:regular),RESIZE,MAXIMIZE,CENTER,ICON('PROCALC.ICO'), |
          MAX,STATUS(-1,80,120,45),SYSTEM
          MENUBAR,USE(?MENUBAR1),#ORDINAL(1)
            MENU('&File'),USE(?MENU1),#ORDINAL(2)
              ITEM('&Obligation calculator'),USE(?FileChildsupportcalculator),MSG('calculate ' & |
                'monthly,semi-monthly, weekly or bi-weekly obligation'),#ORDINAL(3)
              ITEM('&Delinquent support calculator'),USE(?FileDelinquentsupportcalculator), |
                MSG('calculate amounts remaining due on previous obligations'),#ORDINAL(4)
              ITEM,USE(?SEPARATOR1),SEPARATOR,#ORDINAL(5)
              ITEM('&Semi-monthly, weekly, biweekly'),USE(?FileSemimonthlyweeklybiweekly), |
                MSG('calculate semi-monthly- weekly and biweekly amounts for a known mn' & |
                'thly obligation'),#ORDINAL(6)
              ITEM('A&mortize'),USE(?FileAmortize),MSG('Calculate time to payout a lump' & |
                ' sum obligaton (ie. arrearage amount paid monthly)'),#ORDINAL(7)
              ITEM,USE(?SEPARATOR2),SEPARATOR,#ORDINAL(8)
              ITEM('E&xit'),USE(?Exit),MSG('Exit this application'),STD(STD:Close),#ORDINAL(9)
            END
            MENU('&Help'),USE(?MENU2),MSG('Windows Help'),#ORDINAL(10)
              ITEM('&Contents'),USE(?Helpindex),MSG('View the contents of the help file'), |
                STD(STD:HelpIndex),#ORDINAL(11)
              ITEM('&Search for Help On...'),USE(?HelpSearch),MSG('Search for help on a subject'), |
                STD(STD:HelpSearch),#ORDINAL(12)
              ITEM('&How to Use Help'),USE(?HelpOnHelp),MSG('How to use Windows Help'),STD(STD:HelpOnHelp), |
                #ORDINAL(13)
              ITEM('&About'),USE(?HelpAbout),#ORDINAL(14)
            END
          END
        END

[END]
