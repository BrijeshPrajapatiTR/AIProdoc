[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 4000
PROPERTY:END
  !  Message('size of rpq: ' & size(ReportQueue))! this should be odd to avoid qbug
  IF COMMAND('/LOG')
    logcl.init(clogfile,1) !create a new logfile
    logcl.SuppressDateStamp=true 
  END

  FREE(ReportQueue)
  CLEAR(ReportQueue)

  GLO:Totals:ConfIntRate = NAM:ConfirmedInterestRate
  GLO:TotalsChild:ConfIntRate = NAMChild:ConfirmedInterestRate
  GLO:TotalsMedical:ConfIntRate = NAMMedical:ConfirmedInterestRate
  GLO:TotalsDental:ConfIntRate = NAMDental:ConfirmedInterestRate
        
  GLO:Totals:ConfirmedLastDate = NAM:ConfirmedDate
  GLO:TotalsChild:ConfirmedLastDate = NAMChild:ConfirmedDate
  GLO:TotalsMedical:ConfirmedLastDate = NAMMedical:ConfirmedDate
  GLO:TotalsDental:ConfirmedLastDate = NAMDental:ConfirmedDate

  GLO:Totals:DateRendered = NAM:ConfirmedDate
  GLO:TotalsChild:DateRendered = NAMChild:ConfirmedDate
  GLO:TotalsMedical:DateRendered = NAMMedical:ConfirmedDate
  GLO:TotalsDental:DateRendered = NAMDental:ConfirmedDate

  GLO:Totals:ConfirmedPrincipalBalance = NAM:ConfirmedPrincipal
  GLO:TotalsChild:ConfirmedPrincipalBalance = NAMChild:ConfirmedPrincipal
  GLO:TotalsMedical:ConfirmedPrincipalBalance = NAMMedical:ConfirmedPrincipal
  GLO:TotalsDental:ConfirmedPrincipalBalance = NAMDental:ConfirmedPrincipal
  
  
    
   !Nikita - Commented as duplicate initiallization
!  GLO:Totals:ConfirmedLastDate = NAM:ConfirmedDate
!  GLO:TotalsChild:ConfirmedLastDate = NAMChild:ConfirmedDate
!  GLO:TotalsMedical:ConfirmedLastDate = NAMMedical:ConfirmedDate
!  GLO:TotalsDental:ConfirmedLastDate = NAMDental:ConfirmedDate
    !Nikita - End
   
  DebugCL.Send('Load 1 - NAM:ConfirmedPrincipal: ' & NAM:ConfirmedPrincipal & ', NAMChild:ConfirmedPrincipal: ' & NAMChild:ConfirmedPrincipal)
  DebugCL.Send('Load 2 - NAMMedical:ConfirmedPrincipal: ' & NAMMedical:ConfirmedPrincipal & ', NAMDental:ConfirmedPrincipal: ' & NAMDental:ConfirmedPrincipal)
  DebugCL.Send('Load 3 -  ATTMedical:Attyfeescosts: ' & ATTMedical:Attyfeescosts & ', ATTDental:Attyfeescosts: ' & ATTDental:Attyfeescosts)

  !Nikita - Comment below as GLO Total is not exists
!  IF GLO:Totals:ConfirmedLastDate < DATE(9,1,01)
!    GLO:Totals:AttyfeescostsBalance=0
!    GLO:TotalsChild:AttyfeescostsBalance=0
!    GLO:TotalsMedical:AttyfeescostsBalance=0
!    GLO:TotalsDental:AttyfeescostsBalance=0
!  ELSE
!    GLO:Totals:AttyfeescostsBalance=ATT:Attyfeescosts
!    GLO:TotalsChild:AttyfeescostsBalance=ATTChild:Attyfeescosts
!    GLO:TotalsMedical:AttyfeescostsBalance=ATTMedical:Attyfeescosts
!    GLO:TotalsDental:AttyfeescostsBalance=ATTDental:Attyfeescosts
!    DebugCL.Send('1 Set AttyfeescostsBalance: ' & GLO:TotalsMedical:AttyfeescostsBalance)
!  END
  
  IF GLO:TotalsChild:ConfirmedLastDate < DATE(9,1,01)
    GLO:TotalsChild:AttyfeescostsBalance=0
  ELSE
    GLO:TotalsChild:AttyfeescostsBalance=ATTChild:Attyfeescosts
  END
    
  IF GLO:TotalsMedical:ConfirmedLastDate < DATE(9,1,01)
    GLO:TotalsMedical:AttyfeescostsBalance=0
  ELSE
    GLO:TotalsMedical:AttyfeescostsBalance=ATTMedical:Attyfeescosts
  END
    
  IF GLO:TotalsDental:ConfirmedLastDate < DATE(9,1,01)
    GLO:TotalsDental:AttyfeescostsBalance=0
  ELSE
    GLO:TotalsDental:AttyfeescostsBalance=ATTDental:Attyfeescosts
  END
  !Nkikita - END  
  
  
  GLO:Totals:AttyfeescostsIntBalance=0
  GLO:TotalsChild:AttyfeescostsIntBalance=0
  GLO:TotalsMedical:AttyfeescostsIntBalance=0
  GLO:TotalsDental:AttyfeescostsIntBalance=0
    
  !Nikita - to rest  CompoundBalanceAtty value
  GLO:Totals:CompoundBalanceAtty = 0
  GLO:TotalsChild:CompoundBalanceAtty=0
  GLO:TotalsMedical:CompoundBalanceAtty=0
  GLO:TotalsDental:CompoundBalanceAtty=0
  !Nikita - END
  
  !Nikita - Added on 17 Feb to solve Bug # 131
  GLO:Totals:CompoundBalance = 0
  GLO:TotalsChild:CompoundBalance=0
  GLO:TotalsMedical:CompoundBalance=0
  GLO:TotalsDental:CompoundBalance=0
  !Nikita - End
    
  !----------------------------------------------
  GLO:Totals:UnconfirmedPrincipalBalance=0
  GLO:TotalsChild:UnconfirmedPrincipalBalance=0
  GLO:TotalsMedical:UnconfirmedPrincipalBalance=0
  GLO:TotalsDental:UnconfirmedPrincipalBalance=0

  GLO:Totals:UnconfirmedPrincipalBalanceBefore=0
  GLO:TotalsChild:UnconfirmedPrincipalBalanceBefore=0
  GLO:TotalsMedical:UnconfirmedPrincipalBalanceBefore=0
  GLO:TotalsDental:UnconfirmedPrincipalBalanceBefore=0
        
  GLO:Totals:ConfirmedInterestBalance=0
  GLO:TotalsChild:ConfirmedInterestBalance=0
  GLO:TotalsMedical:ConfirmedInterestBalance=0
  GLO:TotalsDental:ConfirmedInterestBalance=0
        
  GLO:Totals:UnconfirmedInterestBalance=0
  GLO:TotalsChild:UnconfirmedInterestBalance=0
  GLO:TotalsMedical:UnconfirmedInterestBalance=0
  GLO:TotalsDental:UnconfirmedInterestBalance=0

  GLO:Totals:delbalbefore=0 !unconfirmed and delinquent but was due before 1/1/00   added 9 mar 02 for jan 02 uint changes
  GLO:TotalsChild:delbalbefore=0
  GLO:TotalsMedical:delbalbefore=0
  GLO:TotalsDental:delbalbefore=0
        
  GLO:Totals:delbalafter=0  !unconfirmed and delinquent but was due after or on 1.1.00
  GLO:TotalsChild:delbalafter=0
  GLO:TotalsMedical:delbalafter=0
  GLO:TotalsDental:delbalafter=0

  !Nikita - Added below just to make it sync  
  GLO:Totals:UnconfirmedLastDate = 0 
  !Nikita - End
  GLO:TotalsChild:UnconfirmedLastDate = 0
  GLO:TotalsMedical:UnconfirmedLastDate = 0
  GLO:TotalsDental:UnconfirmedLastDate = 0

  GLO:TotalsChild:LastCompoundDate = GLO:TotalsChild:ConfirmedLastDate
  GLO:TotalsMedical:LastCompoundDate = GLO:TotalsMedical:ConfirmedLastDate
  GLO:TotalsDental:LastCompoundDate = GLO:TotalsDental:ConfirmedLastDate
  GLO:TotalsChild:LastCompoundDateAtty = GLO:TotalsChild:ConfirmedLastDate   !MA ADDED   7/17/01
  GLO:TotalsMedical:LastCompoundDateAtty = GLO:TotalsMedical:ConfirmedLastDate   !MA ADDED   7/17/01
  GLO:TotalsDental:LastCompoundDateAtty = GLO:TotalsDental:ConfirmedLastDate   !MA ADDED   7/17/01

  DO LoadObligations
  DO LoadPayments

  Do LoadDebitChild
  Do LoadDebitMedical
  Do LoadDebitDental

  
  !MA ADDED THE JUDGEMENT DATE  7/23/01

    
  !CHILD------
  DebugCL.Send('Report Start - Records(ReportQueue): ' & Records(ReportQueue))  
  Util.DumpCurrentTotals('At START')
  Loop tmp:obligationType# = 1 to 3
    CASE tmp:obligationType#
    Of 1
      tmp:obligationType" = 'Child'
    OF 2
      tmp:obligationType" = 'Medical'
    OF 3
      tmp:obligationType" = 'Dental'
    END
    TMP:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(tmp:obligationType")))
    !Nikita - Commented to fix if no obligation for the tmp:obligationType", then add it
    !Util.GetPreviousReportQueueObligationType(UPPER(tmp:obligationType"), Records(ReportQueue), FALSE)
    !Nikita - End

    
    !DebugCL.Send('1 After GetPreviousReportQueueObligationType: RPQ:ObligationType: '& RPQ:ObligationType & ', tmp:obligationType": ' & tmp:obligationType" & ', RPQ:Type: ' & RPQ:Type)
    DebugCL.Send('1 ConfirmedLastDate: ' & Format(TMP:CurrentObligationTotals:ConfirmedLastDate,@d2) & ' , GLO:CALCDATE: ' & format(GLO:CALCDATE,@d2))
    !If UPPER(RPQ:ObligationType) = UPPER(tmp:obligationType")! AND RPQ:Type = 'O' !Nkita - this condition not require
      DebugCL.Send('1.2 Judgement add start for : ' & UPPER(RPQ:ObligationType))
      !Nikita - TODO set blank for Judgement and Final rows
      !LOC:FREQUENCY=RPQ:FREQUENCY
      LOC:FREQUENCY=''
      !Nikita  - END
      DebugCL.Send('1.3 Judgement ConfirmedLastDate : ' & format(TMP:CurrentObligationTotals.ConfirmedLastDate,@d2) & ', GLO:CALCDATE: ' & Format(GLO:CALCDATE, @d2))
      IF TMP:CurrentObligationTotals.ConfirmedLastDate AND TMP:CurrentObligationTotals:ConfirmedLastDate <= GLO:CALCDATE  !USING CUT OFF DATE  MA 3/5/02
        RPQ:Date=TMP:CurrentObligationTotals.ConfirmedLastDate
        RPQ:DateFormatted = FORMAT(TMP:CurrentObligationTotals.ConfirmedLastDate,@d2)
        RPQ:ObligationType = UPPER(tmp:obligationType")
        GET(ReportQueue,RPQ:Date,RPQ:ObligationType)
        IF ERRORCODE()
!          MESSAGE('Error in TMP:CurrentObligationTotals:ConfirmedLastDate: ' & TMP:CurrentObligationTotals:ConfirmedLastDate)
          RPQ:Date = TMP:CurrentObligationTotals.ConfirmedLastDate
          RPQ:DateFormatted = FORMAT(TMP:CurrentObligationTotals.ConfirmedLastDate, @d2)
          RPQ:Type = 'O'
          RPQ:ObligationType = tmp:obligationType"
          RPQ:AmountP = 0
          RPQ:AmountO = 0
          RPQ:FREQUENCY=LOC:FREQUENCY
          RPQ:REDUCEDAMOUNT=0
          RPQ:UnpaidBalance=0
          RPQ:TypeSort = tmp:obligationType# !Nikita - Added to be on sync and sort
          RPQ:dummybyte = 0
          RPQ:IsDummyProcess = 0
          RPQ:AddPossition = 0 !RECORDS(ReportQueue) + 1
          RPQ:IsJudgement = 1
          CLEAR(RPQ:DebitMessage)
          ADD(ReportQueue)
          DebugCL.Send('Report - new record added with RPQ:Date: ' & RPQ:Date)
          
          !Nikita - Added below code to add dummy rows if same date judgement is not present for the other obligations
          IF UPPER(tmp:obligationType") = 'CHILD' 
            IF NAMChild:ConfirmedDate <> NAMMedical:ConfirmedDate
              !Add medical dummy judgement for the date
              Util.DummyRow(NAMChild:ConfirmedDate, 'Medical', LOC:FREQUENCY, TRUE, TRUE)
            END
            IF NAMChild:ConfirmedDate <> NAMDental:ConfirmedDate
              !Add dental dummy judgement for the date
              Util.DummyRow(NAMChild:ConfirmedDate, 'Dental', LOC:FREQUENCY,  TRUE, TRUE)
            END
          ELSIF UPPER(tmp:obligationType") = 'MEDICAL' 
            IF NAMMedical:ConfirmedDate <> NAMChild:ConfirmedDate
              !Add child dummy judgement for the date
              Util.DummyRow(NAMMedical:ConfirmedDate, 'Child', LOC:FREQUENCY, TRUE, TRUE)
            END
            IF NAMMedical:ConfirmedDate <> NAMDental:ConfirmedDate AND NAMChild:ConfirmedDate <> NAMMedical:ConfirmedDate
              !Add dental dummy judgement for the date
              Util.DummyRow(NAMMedical:ConfirmedDate, 'Dental', LOC:FREQUENCY, TRUE, TRUE)
            END
          ELSIF UPPER(tmp:obligationType") = 'DENTAL' 
            IF NAMDental:ConfirmedDate <> NAMChild:ConfirmedDate AND NAMDental:ConfirmedDate <> NAMMedical:ConfirmedDate
              !Add child dummy judgement for the date
              Util.DummyRow(NAMDental:ConfirmedDate, 'Child', LOC:FREQUENCY, TRUE, TRUE)
            END
            IF NAMDental:ConfirmedDate <> NAMMedical:ConfirmedDate AND NAMDental:ConfirmedDate <> NAMChild:ConfirmedDate
              !Add medical dummy judgement for the date
              Util.DummyRow(NAMDental:ConfirmedDate, 'Medical', LOC:FREQUENCY, TRUE, TRUE)
            END
          END
          !Nikita - END
        END
      END
    !END      
    
    !Nikita - added sort as per old code
    !SORT(ReportQueue, +RPQ:Date, +RPQ:Type, +RPQ:TypeSort, +RPQ:AddPossition)
    !SORT(ReportQueue, +RPQ:Date, +RPQ:Type, -RPQ:TypeSort)
    SORT(ReportQueue, +RPQ:Date, +RPQ:Type, +RPQ:AddPossition,  +RPQ:TypeSort)
    
    !Nikita - End
    
    Util.GetPreviousReportQueueObligationType(UPPER(tmp:obligationType"), Records(ReportQueue), false)
    DebugCL.Send('2 After GetPreviousReportQueueObligationType')
    LOC:LASTOBLDATE=RPQ:Date
    IF GLO:CalcDate > RPQ:Date                   ! end of the queue which is
      RPQ:Date = GLO:CalcDate                    ! used to calculate interest
      RPQ:DateFormatted = FORMAT(GLO:CalcDate, @d2)
      RPQ:Type = 'F'                         ! accruing from the last activity
      RPQ:AmountP = 0                        ! up until the calculation date
      RPQ:AmountO = 0
      RPQ:FREQUENCY=LOC:FREQUENCY
      RPQ:REDUCEDAMOUNT=0
      RPQ:UnpaidBalance=0
      RPQ:ObligationType = tmp:obligationType"
      RPQ:dummybyte = Util.IsDummyRow(tmp:obligationType")
      RPQ:IsDummyProcess = Util.IsDummyRow(tmp:obligationType")
      RPQ:IsJudgement = 0
      RPQ:AddPossition = 0
      RPQ:TypeSort = tmp:obligationType# !Nikita - Added to be on sync and sort
      CLEAR(RPQ:DebitMessage)
      ADD(ReportQueue)
    END
  END
    !SORT(ReportQueue, +RPQ:Date, +RPQ:Type, +RPQ:TypeSort, +RPQ:AddPossition)
    !SORT(ReportQueue, +RPQ:Date, +RPQ:Type, -RPQ:TypeSort)
    SORT(ReportQueue, +RPQ:Date, +RPQ:Type,+RPQ:AddPossition, +RPQ:TypeSort)
    
    
    DebugCL.Send('Queue after Sort')
    DebugCL.Dump(ReportQueue,'CGM====')
    
  LocalRequest = GlobalRequest
  LocalResponse = RequestCancelled
  CLEAR(GlobalRequest)
  CLEAR(GlobalResponse)
  RecordsToProcess = RECORDS(QPAYMENTS)
  RecordsPerCycle = 1000
  RecordsProcessed = 0
  PercentProgress = 0
  OPEN(ProgressWindow)
  !ProgressWindow{PROP:HIDE} = TRUE
  ProgressWindow{Prop:Text} = 'Processing Payments'
  ?Progress:PctText{Prop:Text} = '0% Completed'
  ?Progress:UserString{Prop:Text}=''
  PaymentCounter = 0
  ObligateCounter = 0
  CurrentRecord = 0
  !   @Parth - FB28903 
  !    GLO:ConfirmedInterestBalance = 0
  GLO:Totals:ConfirmedInterestBalance=0
  GLO:TotalsChild:ConfirmedInterestBalance=0
  GLO:TotalsMedical:ConfirmedInterestBalance=0
  GLO:TotalsDental:ConfirmedInterestBalance=0
  !   @Parth 
  QCounter = 0
  PBalance = 0
  ACCEPT
    CASE EVENT()
    OF Event:Timer
      RecordsThisCycle = 0
      DebugCL.Send('RecordsThisCycle: ' & RecordsThisCycle & ', RecordsPerCycle: ' & RecordsPerCycle)
      
      PBalForPaymentOnly = 0
      LOOP WHILE RecordsThisCycle < RecordsPerCycle
        QCounter += 1
        LOC:DoApplyPayment = FALSE !Nikita - Added this to manage payment sequence
        IF PercentProgress < 100
          PercentProgress = (RecordsProcessed / RecordsToProcess)*100
          IF PercentProgress > 100
            PercentProgress = 100
          END
          IF PercentProgress <> Progress:Thermometer THEN
            Progress:Thermometer = PercentProgress
            ?Progress:PctText{Prop:Text} = FORMAT(PercentProgress,@N3) & '% Completed'
            DISPLAY()
          END
        END
        DebugCL.Send('Loop 1')

        GET(ReportQueue,QCOUNTER)  
!       @Parth - FB28903 -  
        iF ERRORCODE()
          0{prop:timer} = 0
          ?Progress:PctText{Prop:Text} = 'Process Completed'
          DISPLAY(?Progress:PctText)
          POST(Event:CloseWindow)
          LocalResponse = RequestCompleted
          DebugCL.Send('Loop 1.1: QCOUNTER: ' & QCOUNTER & ', RPQ:Type: ' & RPQ:Type & ', Clip(RPQ:ObligationType)): ' & Clip(RPQ:ObligationType))
          BREAK
        END
!       @Parth 
        !Nikita Modified the condition to enable calculation for obligation types
        IF RPQ:Type = 'P' AND Clip(RPQ:ObligationType) = ''
          DebugCL.Send('Loop 2: QCOUNTER: ' & QCOUNTER & ', RPQ:Type: ' & RPQ:Type & ', Clip(RPQ:ObligationType)): ' & Clip(RPQ:ObligationType))
          !Nikita - added below to get PBalance
          PBalance = RPQ:AmountP
          !Nikita - End
          !Nikita - Reset the array so that can hold only the current payment context values
          CLEAR(CurrContextPaidAmount)
          CYCLE
        END
        !IF RPQ:dummybyte = 1 AND RPQ:Type <> 'P'
        IF RPQ:dummybyte = 1 AND (RPQ:Type = 'O' OR RPQ:Type = 'D')
          CYCLE
        END
        DebugCL.Send('Loop 3')

          
        !This next section carries
        ! the confirmed and unconf|
        ! unconfirmed obligation
        ! balances forward from the
        ! previous record
        !If on the first record,
        ! these balances are set
        ! before calling this
        ! procedure
        Util.DumpCurrentTotals('CgM==== TOP OF LOOP')
        DebugCL.Send('Loop 4')
!        debugcl.dump(ReportQueue, 'CGM==== TOP OF LOOP ::' & QCOUNTER)
                
        GLO:Totals:UnconfirmedInterestBalance  = 0 
        GLO:Totals:UnconfirmedPrincipalBalance = 0
        GLO:Totals:DelBalBefore = 0
        GLO:Totals:delBalAfter  = 0 
        GLO:Totals:ConfirmedPrincipalBalance  = 0 
        GLO:Totals:ConfirmedInterestBalance  = 0 
        GLO:Totals:AttyfeescostsBalance  = 0 
        GLO:Totals:AttyfeescostsIntBalance  = 0 
        DebugCL.Send('2 Set GLO:Totals:AttyfeescostsBalance ' & GLO:Totals:AttyfeescostsBalance)
        ProcessedPayment = false
        DebugCL.Send('Loop 5')
        Loop tmpCounter# = 1 to 3 by 1
          GET(ReportQueue,QCOUNTER)
          tmpObligationName" = ''
          tmpReportQueueObligationName" = RPQ:ObligationType !Nikita saved the QCounter's Obligation type
          case tmpCounter#
          OF 1
            tmpObligationName" = 'CHILD'
          OF 2
            tmpObligationName" = 'MEDICAL'
          OF 3
            tmpObligationName" = 'DENTAL'
!          OF 4
!            tmpObligationName" = ''
          END
          
          !Nikita Added below condition
          DebugCL.Send('Loop 6 - tmpReportQueueObligationName: ' & tmpReportQueueObligationName" & ', RPQ:ObligationType: ' & RPQ:ObligationType)
          IF UPPER(tmpReportQueueObligationName") <> UPPER(tmpObligationName")
            DebugCL.Send('break insite loop 6')
            CYCLE
          END
          !Nikita End
          
          DebugCL.Send('3 before GetPreviousReportQueueObligationType')
          
          Util.GetPreviousReportQueueObligationType(tmpObligationName",-1, FALSE) !@Parth change False to true
          
          IF ERRORCODE()
            ! DO NOTHING
!           @PArth - FB28903 - 
            0{prop:timer} = 0
            DebugCL.Send('Error on 3 after GetPreviousReportQueueObligationType' & ERRORCODE())
            ?Progress:PctText{Prop:Text} = 'Process Completed'
            DISPLAY(?Progress:PctText)
            POST(Event:CloseWindow)
            LocalResponse = RequestCompleted
            BREAK
!           @Parth 
          ELSE
            DebugCL.Send('3.0 POINTER: ' & POINTER(ReportQueue) & ', RPQ:ObligationType: ' & RPQ:ObligationType)
            IF UPPER(tmpObligationName") = UPPER(RPQ:ObligationType) !Nikita Added the condition
                DebugCL.Send('3.1 - QCOUNTER: ' & QCOUNTER & ', ProcessedPayment: ' & ProcessedPayment & ', tmpReportQueueObligationName: ' & tmpReportQueueObligationName")
                TMP:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(tmpObligationName")))
                
                IF CLIP(tmpObligationName") <> '' AND ProcessedPayment = false
                  DebugCL.Send('3.2')
                  ProcessedPayment = true
                  GLO:Totals:UnconfirmedInterestBalance += RPQ:Uint
                  GLO:Totals:UnconfirmedPrincipalBalance += RPQ:Uobl
                  GLO:Totals:DelBalBefore += RPQ:DelBalBefore !unconfimed delinquent balance on obligations due before 1/1/00
                  GLO:Totals:delBalAfter  += RPQ:DelBalAfter  !unconfimed delinquent balance on obligations due on or after 1/1/00
                  DebugCL.Send('3.2.1 QCunter: ' & QCOUNTER & ', RPQ:Date: ' & format(RPQ:Date,@d2) & ', TMP:CurrentObligationTotals.DateRendered : ' & format(TMP:CurrentObligationTotals.DateRendered,@d2) ) 
                  IF RPQ:Date >= TMP:CurrentObligationTotals.DateRendered              !ALS 2/19/99
                    DebugCL.Send('3.3')
                    
                    GLO:Totals:ConfirmedPrincipalBalance += RPQ:Cobl
                    GLO:Totals:ConfirmedInterestBalance += RPQ:Cint
                    GLO:Totals:AttyfeescostsBalance += RPQ:Attyfeescosts
                    GLO:Totals:AttyfeescostsIntBalance += RPQ:AttyfeescostsInt
                    
                    !Nikita - added below from outer loop
                    TMP:CurrentObligationTotals.ConfirmedPrincipalBalance = RPQ:Cobl
                    TMP:CurrentObligationTotals.ConfirmedInterestBalance = RPQ:Cint
                    TMP:CurrentObligationTotals.AttyfeescostsBalance = RPQ:Attyfeescosts
                    TMP:CurrentObligationTotals.AttyfeescostsIntBalance = RPQ:AttyfeescostsInt
                    !Nikita - End
                    
                    DebugCL.Send('3.3')
                    DebugCL.Send('333 RPQ:Cint' & RPQ:Cint)
                    DebugCL.Send('3. Set here GLO:Totals:AttyfeescostsBalance: ' & GLO:Totals:AttyfeescostsBalance & ', TMP:CurrentObligationTotals.AttyfeescostsBalance: ' & TMP:CurrentObligationTotals.AttyfeescostsBalance )
                    DebugCL.Send('333 TMP:CurrentObligationTotals.AttyfeescostsBalance: ' & TMP:CurrentObligationTotals.AttyfeescostsBalance)
                    
                  END              
                  DebugCL.Send('3.4')
                END
                
                DebugCL.Send('3.5 RPQ:Uobl: ' & RPQ:Uobl & ', RPQ:Uint: ' & RPQ:Uint)
                TMP:CurrentObligationTotals.UnconfirmedPrincipalBalance=RPQ:Uobl
                TMP:CurrentObligationTotals.UnconfirmedInterestBalance = RPQ:Uint
                TMP:CurrentObligationTotals.DelBalBefore =RPQ:DelBalBefore !unconfimed delinquent balance on obligations due before 1/1/00
                TMP:CurrentObligationTotals.delBalAfter  =RPQ:DelBalAfter  !unconfimed delinquent balance on obligations due on or after 1/1/00
                !Nikita - Moved below to up
!!!                IF RPQ:Date >= TMP:CurrentObligationTotals.DateRendered              !ALS 2/19/99
!!!                  DebugCL.Send('3.6 RPQ:Cobl: ' & RPQ:Cobl & ', RPQ:Cint: ' & RPQ:Cint)
!!!                  TMP:CurrentObligationTotals.ConfirmedPrincipalBalance = RPQ:Cobl
!!!                  TMP:CurrentObligationTotals.ConfirmedInterestBalance = RPQ:Cint
!!!                  TMP:CurrentObligationTotals.AttyfeescostsBalance = RPQ:Attyfeescosts
!!!                  TMP:CurrentObligationTotals.AttyfeescostsIntBalance = RPQ:AttyfeescostsInt
!!!                END        
                DebugCL.Send('3.7')
            END !Nikita End of if
          END !End of Else
          DebugCL.Send('3.8')
          !Nikita Added below condition to exit loop if already processed current obligation
          IF ProcessedPayment = true
            BREAK
          END
          !Nikita End
        END !End of loop           
        DebugCL.Send('3.9 TMP:CurrentObligationTotals.ConfirmedPrincipalBalance: ' & TMP:CurrentObligationTotals.ConfirmedPrincipalBalance)
        Util.DumpCurrentTotals('AfterSetup')
        DebugCL.Send('3.10')        
        GET(ReportQueue,QCOUNTER)                 !Make sure we have the
        ! current record
        IF ERRORCODE()
          0{prop:timer} = 0
          DebugCL.Send('3.11')
          ?Progress:PctText{Prop:Text} = 'Process Completed'
          DISPLAY(?Progress:PctText)
          POST(Event:CloseWindow)
          LocalResponse = RequestCompleted
          BREAK
        ELSE 
         DebugCL.Send('3.12: RPQ:ObligationType: ' & RPQ:ObligationType & ', QCounter: ' & QCOUNTER & ', GLO:Totals:ConfirmedPrincipalBalance: ' & GLO:Totals:ConfirmedPrincipalBalance)

          TMP:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 

          Util.DumpCurrentTotals('PRE-PRocessing')
          DebugCL.Send('3.13 TMP:UnconfirmedPrincipalBalance: ' & TMP:CurrentObligationTotals.UnconfirmedPrincipalBalance & ', TMP:ConfirmedPrincipalBalance: ' & TMP:CurrentObligationTotals.ConfirmedPrincipalBalance )
          RPQ:Uobl = TMP:CurrentObligationTotals.UnconfirmedPrincipalBalance
          DebugCL.Send('3.13 - 2 RPQ:Date: ' & Format(RPQ:Date,@d2) & ', TMP:CurrentObligationTotals.DateRendered: ' & Format(TMP:CurrentObligationTotals.DateRendered,@d2) )
          RPQ:Uint = TMP:CurrentObligationTotals.UnconfirmedInterestBalance
          IF RPQ:Date < TMP:CurrentObligationTotals.DateRendered  
            RPQ:Cobl = 0                           
            RPQ:Cint = 0                 
            RPQ:Attyfeescosts=0    
            RPQ:AttyfeescostsInt=0
          ELSE
            !Nikita - Added below if condition 
            DebugCL.Send('RPQ:Type: ' & RPQ:Type & ', GLO:Totals:ConfirmedPrincipalBalance: ' & GLO:Totals:ConfirmedPrincipalBalance & |
              ', GLO:Totals:ConfirmedInterestBalance: ' & GLO:Totals:ConfirmedInterestBalance & |
              ', GLO:Totals:AttyfeescostsBalance: ' & GLO:Totals:AttyfeescostsBalance & |
              ', GLO:Totals:AttyfeescostsIntBalance: ' & GLO:Totals:AttyfeescostsIntBalance)

            IF CLIP(RPQ:Type) = 'P'
              !sett from glogal
              RPQ:Cobl = GLO:Totals:ConfirmedPrincipalBalance
              RPQ:Cint = GLO:Totals:ConfirmedInterestBalance
              RPQ:Attyfeescosts = GLO:Totals:AttyfeescostsBalance
              RPQ:AttyfeescostsInt = GLO:Totals:AttyfeescostsIntBalance
            ELSE
              DebugCL.Send('Accept RPQ:Cobl: ' & TMP:CurrentObligationTotals.ConfirmedPrincipalBalance)
              RPQ:Cobl = TMP:CurrentObligationTotals.ConfirmedPrincipalBalance
              DebugCL.Send('Accept RPQ:Cint: ' & TMP:CurrentObligationTotals.ConfirmedInterestBalance)
              RPQ:Cint = TMP:CurrentObligationTotals.ConfirmedInterestBalance
              RPQ:Attyfeescosts = TMP:CurrentObligationTotals.AttyfeescostsBalance
              DebugCL.Send('Accept RPQ:Attyfeescosts: ' & TMP:CurrentObligationTotals.AttyfeescostsBalance)
              DebugCL.Send('Accept RPQ:AttyfeescostsInt: ' & TMP:CurrentObligationTotals.AttyfeescostsIntBalance)
              RPQ:AttyfeescostsInt = TMP:CurrentObligationTotals.AttyfeescostsIntBalance
            END
            !Nikita - End
          END
          DebugCL.Send('3.14')
          PUT(ReportQueue)
          DebugCL.Send('3.15')
!          debugcl.dump(DebugReportQueue, 'END Pre-Processing ::' & QCOUNTER)
          !Util.DumpCurrentTotals('END Pre-Processing')
          DebugCL.Send('3.16')
          GET(ReportQueue,QCOUNTER)               !Make sure we have the
          DebugCL.Send('3.17')
          ! current record
        END          
        DebugCL.Send('3.18')
        
        !Nikita - to test
        DebugCL.Dump(ReportQueue,'CGM====')
        !Nikita - End
        
        RecordsProcessed += 1
        LOC:SaveDate = RPQ:Date
        CASE RPQ:Type
        OF 'D'
          DO ProcessDebit
        OF 'O'
          CASE UPPER(RPQ:ObligationType)
          Of 'CHILD'
            ProcessedObligations = bor(ProcessedObligations, OT:Child)
          OF 'MEDICAL'
            ProcessedObligations = bor(ProcessedObligations, OT:Medical)
          OF 'DENTAL'
            ProcessedObligations = bor(ProcessedObligations, OT:Dental)
          END
          !DebugCL.Send('3.19')
          DO ProcessObligation
          !DebugCL.Send('3.20')
        OF 'P'
          DebugCL.Send('3.21')
          IF UPPER(RPQ:ObligationType) = 'CHILD'
            IsContinueToPayment = FALSE
          ELSE
            IsContinueToPayment = TRUE
          END
          IF RPQ:Date =< date(1, 1, 2010)
            DebugCL.Send('3.22')
            LOC:DoApplyPayment = TRUE !Nikita - Added this to manage payment sequence
            Calculator.ProcessPayment(TRUE)
            !DebugCL.Send('3.23')
          ELSE
            DebugCL.Send('3.24')
            LOC:DoApplyPayment = FALSE !Nikita - Added this to manage payment sequence
            Calculator.ProcessPayment(FALSE)
            !DebugCL.Send('3.25')
          END
        OF 'F'
          DebugCL.Send('3.25.1 - Processing Last - PBALANCE: ' & PBalance)
          DO ProcessLast
        END
        DebugCL.Send('3.26')
!        debugcl.dump(ReportQueue, 'CGM==== BOTTOM OF LOOP ::' & QCOUNTER)
        !Util.DumpCurrentTotals('CGM==== BOTTOM OF LOOP ::')
        !Nikita - to test
        DebugCL.Dump(ReportQueue,'CGM====')
        !Nikita - End
        DebugCL.Send('3.27')
      END !LOOP
      DebugCL.Send('3.28')
      
    END  !CASE EVENT()
    DebugCL.Send('3.28.1 - Remaining PBALANCE: ' & PBalance)
    CASE FIELD()
    OF ?Progress:Cancel
      CASE Event()
      OF Event:Accepted
        DebugCL.Send('3.29')
        LocalResponse = RequestCancelled
        POST(Event:CloseWindow)
      END
      DebugCL.Send('3.30')
    END !CASE FIELD()
    DebugCL.Send('3.31')
  END
    DebugCL.Send('3.32')
    CLOSE(ProgressWindow)
    
  DebugCL.Send('3.33')
    Calculator.CalculateTotals('CHILD', GLO:TotalsGroupChild, EXTDebitChildSupport)
    DebugCL.Send('3.34')
    Calculator.CalculateTotals('MEDICAL', GLO:TotalsGroupMedical, EXTDebitMedicalSupport)
    DebugCL.Send('3.35')
    Calculator.CalculateTotals('DENTAL', GLO:TotalsGroupDental, EXTDebitDentalSupport)
    DebugCL.Send('3.36')
    DebugCL.Dump(ReportQueue,'CGM====')
  IF COMMAND('/LOG')
    logcl.kill()
  END


  !-----------------------------------------
[END]
EMBED %LocalProcedures
[DEFINITION]
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
IntCalcClass.CalcInt procedure(long pStartDate, long pEndDate, *decimal pPrinciple, *long pDays, *decimal pInt)
!Input: pStartDate, pEndDate - must be valid dates. If not, pInt set to zero as is days
!       pPrinciple - principle to calc interest on
!Output: pDays - days between start and end date
!        pInt - calculated interest
! earliest date: 69643
! 1/1/2002 = 73418
d01012002 equate(73418)
Dr        DECIMAL(10,5)  !daily rate
  code
  !initialize output variables
  clear(pDays)
  clear(pInt)

  DebugCL.Send('1. Calulate Int - pStartDate: ' & Format(pStartDate,@d2) & ', pEndDate: ' & Format(pEndDate,@d2) & ' , pPrinciple: ' & pPrinciple  & ', pDays: ' & pDays & ', pInt: ' & pInt )  
  !validate input variables
  IF ~pStartDate OR ~pEndDate OR ~pPrinciple OR pEndDate <= pStartDate then return. !no days or no priciple
  if pStartDate<69643 then pStartDate=69643.

  !calc days
  pDays=pEndDate-pStartDate
  if pDays<=0 then return. !no days, no interest

  IF COMMAND('/LOG')
  logcl.writeline(,'Start='&format(pStartdate,@d2) & ' enddate='&format(penddate,@d2) & ' days='&pdays)
  END

  DebugCL.Send('2. Calulate Int Start= ' & format(pStartdate,@d2) & ', enddate= ' & format(penddate,@d2) & ', days= ' & pdays)

  !calc interest for each period
  if pEndDate =< d01012002 then
    !use 12% for the entire period
    DR=(pPrinciple*0.12)/365.0
    pInt=dr*pDays
    IF COMMAND('/LOG')
    logcl.writeline(,'Rate=12%' & ' principle=' & pPrinciple & ' days='&pDays & '  interest='&pInt)
    END

    DebugCL.Send('3. Calulate Int Rate=12% ' & ' principle= ' & pPrinciple & ' days= ' & pDays & ' interest= ' & pInt)
    !pInt=(pPrinciple*days*0.12)/365.0
  elsif pStartDate>=d01012002 then
    !use 6% for the entire period
    DR = (pPrinciple * 0.06)/365.0
    pInt=dr*pDays
    IF COMMAND('/LOG')
    logcl.writeline(,'Rate=6%' & ' principle=' & pPrinciple & ' days='&pDays & '  interest='&pInt)
    END
    DebugCL.Send('4. Calulate Int Rate=6% ' & ' principle= ' & pPrinciple & ' days= ' & pDays & ' interest= ' & pInt)
    !pInt=(pPrinciple*days*0.06)/365.0
  else
    !split - 12% for the 1st part ; then 6%
    DR=(pPrinciple *0.12)/365.0
    pInt=dr*(d01012002-pStartDate)
    IF COMMAND('/LOG')
    logcl.writeline(,'Rate=12%' & ' principle=' & pPrinciple & ' days='&(d01012002-pStartDate))
    END

    DR=(pPrinciple * 0.06)/365.0
    pInt+=(dr*(pEndDate-d01012002))
    IF COMMAND('/LOG')
    logcl.writeline(,'Rate=6%' & ' principle=' & pPrinciple & ' days='&(pEndDate-d01012002) & '  6+12 interest='&pInt)
    END
    DebugCL.Send('5. Calulate Int Rate=6% ' & ' principle= ' & pPrinciple & ' days= ' & pDays & ' interest= ' & pInt)
    !pInt = (pPrinciple * (d01012002-pStartDate) * 0.12)/365.0
    !pInt += (pPrinciple * (pEndDate - d01012002) * .06)/365.0
  end
  return
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
LABEL
PROPERTY:END
Util.GetObligationTotals  PROCEDURE(STRING ObligationType)
  CODE
    dbg:CurrentObligationGroup = ObligationType
    CASE UPPER(ObligationType)
    OF 'CHILD'
      !DebugCL.Send('Total return for child')
      RETURN ADDRESS(GLO:TotalsGroupChild)
    OF 'MEDICAL'
      !DebugCL.Send('Total return for medical')
      RETURN ADDRESS(GLO:TotalsGroupMedical)
    OF 'DENTAL'
      !DebugCL.Send('Total return for dental')
      RETURN ADDRESS(GLO:TotalsGroupDental)
    ELSE      
      RETURN ADDRESS(GLO:TotalsGroup)
    END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
LABEL
PROPERTY:END
Util.GetPreviousReportQueueObligationType   PROCEDURE(STRING ObligationType, LONG ForceRow = -1, BYTE includePayments = true, BYTE excludeDummy = True)
loc:QCounterL long
  CODE
    DebugCL.Send('Previous - ObligationType: ' & ObligationType & ', ForceRow: ' & ForceRow & ', includePayments: ' & includePayments)
    IF ForceRow = -1
      loc:QCounterL = QCOUNTER - 1
    ELSE
      loc:QCounterL = ForceRow - 1
    END
 
    LOOP
      !DebugCL.Send('Before GET loc:QCounterL: ' & loc:QCounterL)
!     @Parth - FB28903 0 PaymentIssue 
   
      Get(ReportQueue, loc:QCounterL)
      IF ERRORCODE()
        !DebugCL.Dump(ReportQueue,'CGM==== TOP OF LOOP ::' & loc:QCounterL & ', QCOUNTER: ' & QCOUNTER & ', ForceRow: ' & ForceRow)
        BREAK
      END
          
      !DebugCL.Send('Previous - RPQ:ObligationType: ' & RPQ:ObligationType & ', RPQ:Type: ' & RPQ:Type)
       
!     @Parth - FB28903 - PaymentIssue 
!      IF CLIP(RPQ:ObligationType) <> '' AND RPQ:Type = 'P'
!        CYCLE
!      END
      loc:QCounterL -= 1 
      If loc:QCounterL = 0 
        BREAK
      END
      
      !Nikita - To fix calculation issue
!      IF (UPPER(RPQ:ObligationType) = UPPER(ObligationType) AND CLIP(RPQ:Type) <> 'P') OR (includePayments = true AND CLIP(RPQ:ObligationType) = '')
!        DebugCL.Send('Break inside break')
!        BREAK
!      END
      
      !Nikita - TODO added to not process for dummy byte
      IF excludeDummy AND RPQ:dummybyte = 1 !Skip dummy row as well
       CYCLE
      END  
      !Nikita - END
      
      IF (UPPER(RPQ:ObligationType) = UPPER(ObligationType) AND includePayments = false ) OR (includePayments = true AND CLIP(RPQ:ObligationType) = '')
        DebugCL.Send('Break inside break loc:QCounterL : ' & loc:QCounterL)
        BREAK
      END
      !Nikita - End
      
      IF CLIP(RPQ:ObligationType) <> '' ! AND RPQ:Type = 'P'  !AND loc:QCounterL > 1 !@Parth - FB28903 - PaymentIssue
        CYCLE
      END  
      
      
!     @Parth 
      
    END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
LABEL
PROPERTY:END
Util.GetNextReportQueueObligationType   PROCEDURE(STRING ObligationType, LONG ForceRow = -1, BYTE includePayments = true , BYTE SkipQCount = FALSE, BYTE excludeDummy = True)
loc:QCounter                              long
loc:RPQRecordCount                        LONG
loc:PreCounterOfSame                      LONG
  CODE
    IF SkipQCount
      loc:RPQRecordCount = Records(ReportQueue)
    ELSE
      loc:RPQRecordCount = QCOUNTER
    END
      
    loc:PreCounterOfSame = 0
    
    DebugCL.Send('1 NextReportQueueObligationType ForceRow: ' & ForceRow & ', QCOUNTER: ' & QCOUNTER & ', loc:QCounter: ' & loc:QCounter)
    DebugCL.Send('1.1 includePayments: ' & includePayments)
    IF ForceRow = -1
      loc:QCounter = QCOUNTER + 1
    ELSE
      loc:QCounter = ForceRow + 1
    END
      
    LOOP
      Get(ReportQueue, loc:QCounter)
      IF ERRORCODE()
        DebugCL.Send('2 NextReportQueueObligationType ERRORCODE: ' & ERRORCODE())
        BREAK
      END
      
      IF UPPER(RPQ:ObligationType) = UPPER(ObligationType)
        loc:PreCounterOfSame = loc:QCounter
      END
      
      !DebugCL.Send('8 NextReportQueueObligationType loc:QCounter: ' & loc:QCounter & ', CLIP(RPQ:ObligationType): ' & CLIP(RPQ:ObligationType) &', RPQ:Type: ' & RPQ:Type)
      !Nikita pull out below condition outside
      loc:QCounter += 1
      If loc:QCounter > loc:RPQRecordCount
        !Nikita - Get previous same obligation type counter
        IF UPPER(RPQ:ObligationType) <> UPPER(ObligationType)
          Get(ReportQueue, loc:PreCounterOfSame)
          loc:QCounter = loc:PreCounterOfSame
        ELSE
          loc:QCounter = POINTER(ReportQueue)
        END
        DebugCL.Send('3 NextReportQueueObligationType - Back to same obligation loc:QCounter: ' & loc:QCounter)
        BREAK
      END
      !Nikita
     
      !Nikita - TODO added to not process for dummy byte
      IF excludeDummy AND RPQ:dummybyte = 1 !Skip dummy row as well
        CYCLE
      END  
      !Nikita - END
      
      IF (UPPER(RPQ:ObligationType) = UPPER(ObligationType) AND includePayments = false )  or (includePayments = true AND CLIP(RPQ:ObligationType) = '')
        DebugCL.Send('4 NextReportQueueObligationType RPQ:ObligationType: ' & UPPER(RPQ:ObligationType) & ', UPPER(ObligationType): ' & UPPER(ObligationType) & ', includePayments: ' & includePayments)
        DebugCL.Send('4.1 loc:QCounter: ' & loc:QCounter - 1) 
        BREAK
      END 
      
!      IF CLIP(RPQ:ObligationType) = '' AND RPQ:Type = 'P'
      IF CLIP(RPQ:ObligationType) <> '' !@Parth - FB28903 - PaymentIssue AND RPQ:Type = 'P'
        !DebugCL.Send('10 NextReportQueueObligationType - cycle')
        CYCLE
      END
      
      DebugCL.Send('11 NextReportQueueObligationType - END')
    END
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
LABEL
PROPERTY:END
Util.SetNamAndAttyObjects   PROCEDURE(STRING ObligationType)
loc:QCounter long
  CODE
    CASE (ObligationType)
    OF 'CHILD'
        NAMConfirmedObl = NAMConfirmedOblChildSupport
        ATTYFees = ATTYFeesChildSupport
    OF 'MEDICAL'
        NAMConfirmedObl = NAMConfirmedOblMedicalSupport
        ATTYFees = ATTYFeesMedicalSupport
    OF 'DENTAL'
        NAMConfirmedObl = NAMConfirmedOblDentalSupport
        ATTYFees = ATTYFeesDentalSupport
    END
     
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Util.DumpCurrentTotals  PROCEDURE(string TitleText)
  CODE
!    DebugCL.Dump(GLO:TotalsGroup, Clip(TitleText) &' Loop ::' & QCOUNTER & ' Type=GLOBAL')
!    DebugCL.Dump(GLO:TotalsGroupChild, Clip(TitleText) &' Loop ::' & QCOUNTER & ' Type=CHILD')
!    DebugCL.Dump(GLO:TotalsGroupMedical, Clip(TitleText) &' Loop ::' & QCOUNTER & ' Type=MEDICAL-')
!    DebugCL.Dump(GLO:TotalsGroupDental, Clip(TitleText) &' Loop ::' & QCOUNTER & ' Type=DENTAL')

[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Util.SyncPayments   PROCEDURE(long ObligationCount = -1)
IsChildObl            BYTE(1)
IsMedicalObl          BYTE(1)
IsDentalObl           BYTE(1)
  CODE
    DebugCL.Send('Sync Start - ObligationCount: ' & ObligationCount)
    If ObligationCount = -1 
      ObligationCount = QCOUNTER
    END
  
    IF PBalance > 0                              !If there's any left unapplied, set
      GET(ReportQueue,ObligationCount)               ! uobl to show a negative (credit)
      DebugCL.Send('52 PP ObligationCount: ' & ObligationCount & ', PBalance: ' & PBalance & ', RPQ:UOBL: ' & RPQ:UOBL)
    
      !Nikita - added to manage remaining balance amount
      IF PBalance 
        RPQ:AplUobl += PBalance
        RPQ:AmountP += PBalance
        RPQ:Uobl -= PBalance
        IF RPQ:DATE < D010100
          RPQ:delbalBefore -= PBalance
        else
          RPQ:delBalafter -= PBalance
        END
        PBalance = 0
        PUT(ReportQueue)
      END
      !Nikita - End

      DebugCL.Send('53 PP After calculation ' & ObligationCount & ', PBalance: ' & PBalance & ', RPQ:UOBL: ' & RPQ:UOBL & ', ApplyTotal: ' & ApplyTotal & ', RPQ:AplUobl: ' & RPQ:AplUobl)
      
    END  
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Util.DummyRow             PROCEDURE(Date oDate, string ObligationType, string Frequency , BYTE IsDummy = TRUE, BYTE IsJudgement = FALSE)
  code
    RPQ:Date = oDate
    RPQ:DateFormatted = FORMAT(oDate, @d2)
    RPQ:Type = 'O'
    RPQ:AmountO = 0
    RPQ:UnpaidBalance = 0
    RPQ:AmountP = 0
    RPQ:Frequency= Frequency       !MA ADDED  2/15/02
    RPQ:REDUCEDAMOUNT=0
    RPQ:ObligationType = ObligationType
    rpq:deldate=0
    RPQ:DelBalBefore=0
    Rpq:DelBalAfter=0
    RPQ:dummybyte = IsDummy
    RPQ:IsDummyProcess = 1
    CASE UPPER(ObligationType)
    OF 'CHILD'
      IF IsJudgement 
        RPQ:TypeSort = 1
      ELSE
        RPQ:TypeSort = 4
      END
    OF 'MEDICAL'
      IF IsJudgement 
        RPQ:TypeSort = 2
      ELSE
        RPQ:TypeSort = 5
      END
    OF 'DENTAL'
      IF IsJudgement 
        RPQ:TypeSort = 3
      ELSE
        RPQ:TypeSort = 6
      END
    END
    !RPQ:IsJudgement = 0
    
    
    ADD(ReportQueue)
    RETURN
