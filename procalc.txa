[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
LABEL
PROPERTY:END
Calculator.CalculateTotals  PROCEDURE(STRING ObligationType, GLO:TotalsGroupType TotalsGroup, EXTDebit EXTDebitGroup)
IsMatchFound BYTE(1)
  CODE
  
  TotalsGroup.TotalUnconfirmed = 0
  TotalsGroup.PayConfirmedO = 0
  TotalsGroup.PayUnconfirmedO = 0
  TotalsGroup.PayConfirmedI = 0
  TotalsGroup.PayUnConfirmedI = 0
  TotalsGroup.TotalPaymentsApplied = 0
  TotalsGroup.TotalPaymentsMade = 0
  TotalsGroup.TotalRemaining = 0

  !-----MA ADDED  6/25/01--------
  TotalsGroup.PayAttyfeescosts=0
  TotalsGroup.PayAttyfeescostsInt=0
  TotalsGroup.AttyfeescostsBalance=0
  TotalsGroup.AttyfeescostsIntBalance=0
  !------------------------------

  TotalsGroup.UnconfirmedPrincipalBalance = 0
  TotalsGroup.UnconfirmedPrincipalBalanceBefore = 0   !MA ADDED  3/6/02
  TotalsGroup.UnconfirmedInterestBalance = 0
  TotalsGroup.ConfirmedPrincipalBalance = 0
  TotalsGroup.ConfirmedInterestBalance = 0

  QCOUNTER = 0
  LOOP QCOUNTER = 1 TO RECORDS(ReportQueue)
    GET(ReportQueue,QCOUNTER)
    IF ERRORCODE() THEN BREAK.
    
    !DebugCL.Send('1 Calculate Total QCOUNTER: ' & QCOUNTER & ', RPQ:ObligationType: ' & RPQ:ObligationType )
    IF CLIP(UPPER(RPQ:ObligationType)) <> CLIP(UPPER(ObligationType)) OR Clip(RPQ:ObligationType) = '' OR CLIP(RPQ:Type) = 'F' OR RPQ:dummybyte = 1
      CYCLE
    END
    !DebugCL.Send('2 Calculate Total inside to caculate RPQ:ObligationType: ' & RPQ:ObligationType & ', RPQ:Type: ' & RPQ:Type & ', Pointer: ' & POINTER(ReportQueue) )
    DebugCL.Send('2.1 Calculate Total inside dummybyte: ' & RPQ:dummybyte & ', RPQ:AplUobl: ' & RPQ:AplUobl )
    
    TotalsGroup.TotalUnconfirmed += RPQ:AmountO
    TotalsGroup.PayConfirmedO += RPQ:AplCobl
    TotalsGroup.PayUnconfirmedO += RPQ:AplUobl
    TotalsGroup.PayConfirmedI += RPQ:AplCint
    TotalsGroup.PayUnConfirmedI += RPQ:AplUint
    TotalsGroup.TotalPaymentsMade += RPQ:AmountP
    TotalsGroup.PayAttyfeescosts += RPQ:AplAtty         !MA ADDED  6/25/01
    TotalsGroup.PayAttyfeescostsInt += RPQ:AplAttyInt   !MA ADDED  6/25/01

    IF RPQ:TYPE = 'D'              !set up to print debits
      IF EXTDebitGroup.DebitUobl             !This doesn't affect any calculations but
        RPQ:AmountO = EXTDebitGroup.DebitUobl! it causes the amount of the debit to be
      ELSIF EXTDebitGroup.DebitUint          ! shown in the first column after the date
        RPQ:AmountO = EXTDebitGroup.DebitUint
      ELSIF EXTDebitGroup.DebitCobl
        RPQ:AmountO = EXTDebitGroup.DebitCobl
      ELSIF EXTDebitGroup.DebitCint
        RPQ:AmountO = EXTDebitGroup.DebitCint
      END
      PUT(ReportQueue)
    END
  END
  
  DebugCL.Send('2.1 Calculate Total: - POINTER: ' & POINTER(ReportQueue))
    
  !Nikita - TODO
  !TotalsGroup.TotalPaymentsApplied = RPQ:AplCobl + RPQ:AplUobl + RPQ:AplCint + RPQ:AplUint +RPQ:AplAtty + RPQ:AplAttyInt    !MA CHANGED  6/25/01
  TotalsGroup.TotalPaymentsApplied = TotalsGroup.PayConfirmedO + TotalsGroup.PayUnconfirmedO |
    + TotalsGroup.PayConfirmedI + TotalsGroup.PayUnConfirmedI |
    + TotalsGroup.PayAttyfeescosts + TotalsGroup.PayAttyfeescostsInt    !MA CHANGED  6/25/01
  !Nikita - END
  
  DebugCL.Send('3 Calculate Total: TotalsGroup.PayUnconfirmedO: ' & TotalsGroup.PayUnconfirmedO)
  DebugCL.Send('4 Calculate Total: TotalsGroup.TotalPaymentsApplied: ' & TotalsGroup.TotalPaymentsApplied)
    
  util.SetNamAndAttyObjects(UPPER(ObligationType))
  TotalsGroup.TotalObligations = NAM:ConfirmedPrincipal + TotalsGroup.TotalUnconfirmed
  
  !Nikita - Get last obligation row
  GET(ReportQueue,RECORDS(ReportQueue))
  IF UPPER(RPQ:ObligationType) <> UPPER(ObligationType)
      LOOP  
        !GET(ReportQueue,RECORDS(ReportQueue))
        Util.GetPreviousReportQueueObligationType(UPPER(ObligationType), POINTER(ReportQueue), FALSE, FALSE)
        !IF (RPQ:Type = 'F' OR RPQ:Type = 'O')  AND UPPER(RPQ:ObligationType) = UPPER(ObligationType)
        DebugCL.Send('4.1 Pointer: ' & POINTER(ReportQueue) )
        IF ERRORCODE()
          IsMatchFound = 0
          BREAK
        END
        IF UPPER(RPQ:ObligationType) = UPPER(ObligationType) 
          IsMatchFound = 1
          BREAK
        ELSIF UPPER(RPQ:ObligationType) <> UPPER(ObligationType) AND POINTER(ReportQueue) <=1
          IsMatchFound = 0
          BREAK
        ELSE
          CYCLE
        END
      END
  !ELSIF UPPER(RPQ:ObligationType) = UPPER(ObligationType) AND RPQ:dummybyte !Nikita - TODO 3 Feb 22
  ELSIF UPPER(RPQ:ObligationType) = UPPER(ObligationType) AND RPQ:dummybyte AND RPQ:Type <> 'F'
      LOOP  
        Util.GetPreviousReportQueueObligationType(UPPER(ObligationType), POINTER(ReportQueue), FALSE, FALSE)
        DebugCL.Send('4.2 Pointer: ' & POINTER(ReportQueue) )
        IF ERRORCODE()
          IsMatchFound = 0
          BREAK
        END
        !IF UPPER(RPQ:ObligationType) = UPPER(ObligationType) AND RPQ:Type = 'O' !Nikita - TODO 3 Feb 22
        IF UPPER(RPQ:ObligationType) = UPPER(ObligationType) AND RPQ:Type = 'O' 
          IsMatchFound = 1
          BREAK
        ELSIF UPPER(RPQ:ObligationType) <> UPPER(ObligationType) AND POINTER(ReportQueue) <=1
          IsMatchFound = 0
          BREAK
        ELSE
          CYCLE
        END
      END
  END
  DebugCL.Send('4.3 Calculate Total: - POINTER: ' & POINTER(ReportQueue) & ', TotalsGroup.PayUnconfirmedO: ' & TotalsGroup.PayUnconfirmedO )
  !Nikita - END
  
  IF IsMatchFound
    TotalsGroup.ConfirmedPrincipalBalance = RPQ:Cobl
    TotalsGroup.UnconfirmedPrincipalBalance = RPQ:Uobl
    TotalsGroup.ConfirmedInterestBalance = RPQ:Cint
    TotalsGroup.UnconfirmedInterestBalance = RPQ:Uint
    TotalsGroup.AttyfeescostsBalance = RPQ:Attyfeescosts         !MA ADDED  6/25/01
    TotalsGroup.AttyfeescostsIntBalance = RPQ:AttyfeescostsInt   !MA ADDED  6/25/01
    
    TotalsGroup.TotalRemaining = RPQ:Cobl + RPQ:Uobl + RPQ:Cint + RPQ:Uint + RPQ:Attyfeescosts + RPQ:AttyfeescostsInt !MA CHANGED 6/25/01
  ELSE
    TotalsGroup.ConfirmedPrincipalBalance = 0
    TotalsGroup.UnconfirmedPrincipalBalance = 0
    TotalsGroup.ConfirmedInterestBalance = 0
    TotalsGroup.UnconfirmedInterestBalance = 0
    TotalsGroup.AttyfeescostsBalance = 0
    TotalsGroup.AttyfeescostsIntBalance = 0
    
    TotalsGroup.TotalRemaining = 0
  END
  DebugCL.Send('5 Set TotalsGroup.AttyfeescostsBalance: ' & TotalsGroup.AttyfeescostsBalance)
    
  !TotalsGroup.TotalPaymentsMade += RPQ:AplUobl  
  
  DebugCL.Send('5.1 Calculate Total: AttyfeescostsIntBalance ' & TotalsGroup.AttyfeescostsIntBalance)
  
  !Nikita - TODO
  TotalsGroup.DateRendered = NAM:ConfirmedDate
  !Nikita - END

  DebugCL.Send('6. Calculate total - TotalsGroup.TotalRemaining: ' & TotalsGroup.TotalRemaining & ', TotalPaymentsMade: ' & TotalsGroup.TotalPaymentsMade )
  IF TotalsGroup.TotalRemaining < 0                !Added on 5/12/97 by ALS
    TotalsGroup.PayUnconfirmedO -= ABS(TotalsGroup.TotalRemaining)  !If there's a credit balance at end
  END                                   ! need to deduct it from the amount
                                       ! we said was applied to unconfirmed
                                       ! obligations because in the calculation
                                       ! we had automaticallyl assumed that
                                       ! any amount of a payment that is left
                                       ! over will eventually be applied to
                                       ! an obligation.  If we wound up with
                                       ! a credit balance, this needs to be
                                       ! adjusted.
  DebugCL.Send('7. Calculate total - TotalsGroup.PayUnconfirmed: ' & TotalsGroup.PayUnconfirmedO)

!@Parth
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.CompoundInterestAtty  PROCEDURE(long ObligationCount = -1)
CurrentObligationTotals             &GLO:TotalsGroupType
PCounter  Long
  CODE
    IF ObligationCount = -1
      PCounter = QCOUNTER
    ELSE
      PCounter = ObligationCount
    END
    
    DebugCL.Send('1. Compound intereset for PCounter: ' & PCounter)
    
    GET(ReportQueue,PCounter)                     !Reactivate the current record
    CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 

    IF RPQ:Date - CurrentObligationTotals.LastCompoundDateAtty < 365
      DebugCL.Send('2. Compound intereset return.. ' )
      RETURN
    END
    CurrentObligationTotals.LastCompoundDateAtty += 365                  !Increment CurrentObligationTotals.LastCompoundDate
    !Nikita - Modified below parameters
    !Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType))
    Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), PCounter, FALSE)
    !Nikita - End
    CurrentObligationTotals.DailyRate = (CurrentObligationTotals.AttyfeescostsBalance |          ! the period before compounding
      + CurrentObligationTotals.CompoundBalanceAtty) * ATT:InterestRate / 365
    CurrentObligationTotals.Days = CurrentObligationTotals.LastCompoundDateAtty - RPQ:DATE
    CurrentObligationTotals.NewInterest = CurrentObligationTotals.DailyRate * CurrentObligationTotals.Days
    IF CurrentObligationTotals.NewInterest < 0                                !This is just a precaution to prevent the
      CurrentObligationTotals.NewInterest = 0                                 ! use of a negative number
    END

    CurrentObligationTotals.ConfirmedLastDate = CurrentObligationTotals.LastCompoundDateAtty
    CurrentObligationTotals.AttyfeescostsIntBalance = RPQ:AttyfeescostsInt + CurrentObligationTotals.NewInterest
    CurrentObligationTotals.CompoundBalanceAtty = CurrentObligationTotals.AttyfeescostsIntBalance
    
    GLO:Totals:AttyfeescostsIntBalance = RPQ:AttyfeescostsInt + CurrentObligationTotals.NewInterest
    GLO:Totals:ConfirmedLastDate = CurrentObligationTotals.LastCompoundDateAtty !Nikita Added
   
    GET(ReportQueue, PCounter)
    LOOP
      IF RPQ:Date - CurrentObligationTotals.LastCompoundDateAtty >= 365
        CurrentObligationTotals.NewInterest = (CurrentObligationTotals.AttyfeescostsBalance + CurrentObligationTotals.CompoundBalanceAtty) * ATT:InterestRate
        CurrentObligationTotals.LastCompoundDateAtty  += 365
        CurrentObligationTotals.ConfirmedLastDate += 365
        CurrentObligationTotals.AttyfeescostsIntBalance += CurrentObligationTotals.NewInterest
        GLO:Totals:AttyfeescostsIntBalance += CurrentObligationTotals.NewInterest
        CurrentObligationTotals.CompoundBalanceAtty += CurrentObligationTotals.NewInterest
      ELSE
        BREAK
      END
    END
    DebugCL.Send('3. Compond interest CurrentObligationTotals.CompoundBalanceAtty: ' & CurrentObligationTotals.CompoundBalanceAtty)

!------------------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.AttyfeescostsInt     Procedure(string ObliatationType, long ObligationCount = -1)
CurrentObligationTotals           &GLO:TotalsGroupType
PCounter                        LONG
  CODE

    IF ObligationCount = 0 
      RETURN
    END
    
    !Nikita - Added below code
    IF ObligationCount = -1
      PCounter = QCOUNTER
    ELSE
      PCounter = ObligationCount
    END
    !Nikita - End

    DebugCL.Send('1. Atty feescosts Int - PCounter: ' & PCounter)
    
    
!    IF GLO:Totals:AttyfeescostsBalance <= 0    !IF THERE IS NO ATTY FEES AND COSTS THEN RETURN
!      RETURN
!    END
    
    GET(ReportQueue,PCounter)
    DebugCL.Dump(GLO:TotalsGroupDental, 'GLO:TotalsGroupDental: ' & 'ObliatationType: ' & ObliatationType)
    CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    DebugCL.Send('2. Atty feescosts Int - CurrentObligationTotals.AttyfeescostsBalance: ' & CurrentObligationTotals.AttyfeescostsBalance)
    IF CurrentObligationTotals.AttyfeescostsBalance <= 0
      RETURN
    END
  
    DebugCL.Send('3. Atty feescosts Int - RPQ:DATE: ' & format(RPQ:DATE, @d2) & ', CurrentObligationTotals.DateRendered: ' & Format(CurrentObligationTotals.DateRendered,@d2))
    IF RPQ:DATE <= CurrentObligationTotals.DateRendered                !Actually had a customer who called and had
      RETURN                                         ! a judgment that was later than the first
    END                                            ! obligation - this addresses that

    !Nikita - Set Att Interest rate to use
    IF UPPER(ObliatationType) = 'CHILD'
      ATT:InterestRate = ATTChild:InterestRate
    ELSIF UPPER(ObliatationType) = 'MEDICAL'
      ATT:InterestRate = ATTMedical:InterestRate
    ELSIF UPPER(ObliatationType) = 'DENTAL'
      ATT:InterestRate = ATTDental:InterestRate
    END
    !Nikita - End
    
    !IF PCounter = 1                                !If this is the first record
    IF (UPPER(ObliatationType) = 'CHILD' AND PCounter = 1) OR (UPPER(ObliatationType) = 'MEDICAL' AND PCounter = 2) OR (UPPER(ObliatationType) = 'DENTAL' AND PCounter = 3) 
      DebugCL.Send('3.1. Atty feescosts Int RESET')
      CurrentObligationTotals.CompoundBalanceAtty = 0
      CurrentObligationTotals.AttyfeescostsIntBalance=0
      GLO:Totals:AttyfeescostsIntBalance=0
      IF CLIP(ATT:InterestType)='COMPOUND'
        DO FirstCompoundAtty                       !If want to compound, this handles all
                                                   ! confirmed interest from the date of
                                                   ! judgement to the date of the first rec
                                                   ! CurrentObligationTotals.ConfirmedLastDate and LOC:CompoundBalanceAtty
                                                   ! are set in the FirstCompound routine
      END
    ELSE  
      DebugCL.Send('1. Att Interest ATT:InterestType: ' & ATT:InterestType & ', CurrentObligationTotals.LastCompoundDateAtty: ' & Format(CurrentObligationTotals.LastCompoundDateAtty, @d2))                                              !If not the first record
      IF CLIP(ATT:InterestType)='COMPOUND' and RPQ:Date |            !If it's been a year since compounding
        - CurrentObligationTotals.LastCompoundDateAtty >= 365                      ! and the user wants to compound, this
                                                               ! routine will calculate interest up to
        Self.CompoundInterestAtty(PCounter)                                ! the date where interest is compounded
                                                               ! and then set the following variables:
                                                               !  CurrentObligationTotals.ConfirmedLastDate
                                                               !  GLO:ConfirmedInterestBalance
        GET(ReportQueue,PCounter)
  !     @Parth - FB28903 
  !      GLO:AttyfeescostsBalance = RPQ:Attyfeescosts
        CurrentObligationTotals.AttyfeescostsBalance = RPQ:Attyfeescosts
        GLO:Totals:AttyfeescostsBalance = RPQ:Attyfeescosts
  !     @Parth 

        !GLO:AttyfeescostsBalance+=LOC:CompoundBalanceAtty     !MA ADDED   7/16/01
        !LOC:CompoundBalanceAtty=0                             !MA ADDED   7/16/01

      ELSE
        DebugCL.Send('2. Att Interest ATT:InterestType: ' & ATT:InterestType)  
        !GET(ReportQueue,QCounter-1)
        !Nikita - pass IncludePayment as FALSE
        Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), PCounter, FALSE)
        !Nikita - End
        IF ERRORCODE()
          MESSAGE('ERROR calculating interest on attorney''s fees and costs interest.'|
                & ' The printout may not be correct',,ICON:EXCLAMATION, |
                BUTTON:OK,BUTTON:OK)
          RETURN
        END
        
        DebugCL.Send('AttyfeescostsInt - POINTER(ReportQueue): ' & POINTER(ReportQueue))
        CurrentObligationTotals.ConfirmedLastDate = RPQ:Date
        CurrentObligationTotals.AttyfeescostsBalance = RPQ:Attyfeescosts
        CurrentObligationTotals.AttyfeescostsIntBalance = RPQ:AttyfeescostsInt
        
        GLO:Totals:AttyfeescostsIntBalance = RPQ:AttyfeescostsInt
        GLO:Totals:ConfirmedLastDate = RPQ:Date !Nikita Added
        GLO:Totals:AttyfeescostsBalance = RPQ:Attyfeescosts
        
        DebugCL.Send('6. Set CurrentObligationTotals.AttyfeescostsBalance: ' & CurrentObligationTotals.AttyfeescostsBalance & ', GLO:Totals:AttyfeescostsBalance: ' & GLO:Totals:AttyfeescostsBalance)
      END
    END
    
    !Nikita - TODO
    !GET(ReportQueue,QCounter)
    GET(ReportQueue,PCounter)
    !Nikita - End
    RPQ:AttyfeescostsInt = CurrentObligationTotals.AttyfeescostsIntBalance 
         
                                                                ! is the balance from the last
                                                                ! record
    RPQ:Attyfeescosts = CurrentObligationTotals.AttyfeescostsBalance
    CurrentObligationTotals.DailyRate = ((CurrentObligationTotals.CompoundBalanceAtty +                        |
      CurrentObligationTotals.AttyfeescostsBalance) * ATT:InterestRate) / 365
    
    CurrentObligationTotals.Days = RPQ:Date - CurrentObligationTotals.ConfirmedLastDate

    DebugCL.Send('2 Atty fees costs int CurrentObligationTotals.CompoundBalanceAtty :' & CurrentObligationTotals.CompoundBalanceAtty & ', CurrentObligationTotals.AttyfeescostsBalance: ' & CurrentObligationTotals.AttyfeescostsBalance & ', ATT:InterestRate: ' & ATT:InterestRate )
  
    DebugCL.Send('3 Atty fees costs int - Days: ' & CurrentObligationTotals.Days & ', DailyRate: ' &  CurrentObligationTotals.DailyRate & ', RPQ:Attyfeescosts: ' & RPQ:Attyfeescosts)
    CurrentObligationTotals.NewInterest = CurrentObligationTotals.DailyRate * CurrentObligationTotals.Days

    IF CurrentObligationTotals.NewInterest > 0
      RPQ:AttyfeescostsInt += CurrentObligationTotals.NewInterest
    END
    DebugCL.Send('After RPQ:AttyfeescostsInt: ' & RPQ:AttyfeescostsInt)
    
    !Nikita - Enable below line for before 2010 case
    IF LOC:DoApplyPayment AND PBalance
      IF PBalance >= RPQ:AttyfeescostsInt         !If balance of pmt will
        PBalance -= RPQ:AttyfeescostsInt          ! will pay off this int
        RPQ:AplAttyInt = RPQ:AttyfeescostsInt     ! save amount paid
        RPQ:AmountP += RPQ:AttyfeescostsInt
        RPQ:AttyfeescostsInt = 0                  ! and set balance at 0
      ELSE                                        !If won' pay off the interest
        RPQ:AttyfeescostsInt -= PBalance          ! reduce the interest balance by the payment left
        RPQ:AplAttyInt = PBalance                 ! store the amount applied
        RPQ:AmountP += PBalance
        PBalance = 0                              ! then set the payment left to 0
      END
    END
    !Nikita - END
    
    DebugCL.Send('AttyfeescostsInt - RPQ:AttyfeescostsInt: ' & RPQ:AttyfeescostsInt & ', CurrentObligationTotals.CompoundBalanceAtty: ' & CurrentObligationTotals.CompoundBalanceAtty)
    IF RPQ:AttyfeescostsInt < CurrentObligationTotals.CompoundBalanceAtty  !As obligor pays off interest, if he pays off
      CurrentObligationTotals.CompoundBalanceAtty = RPQ:AttyfeescostsInt   ! all that has accrued this year, this makes sure
      DebugCL.Send('5 Atty fees costs int: CompoundBalanceAtty: ' & CurrentObligationTotals.CompoundBalanceAtty)
    END                                                 ! that the compounded interest is paid off as he
                                                       ! makes further payments

    DebugCL.Send('AttyfeescostsInt - Save above details PCounter:  ' & PCounter)
    PUT(ReportQueue)                              !Save the changes so far
    IF ERRORCODE()
      MESSAGE('ERROR saving interest calculation on attorney''s fees and costs interest.'|
              & ' The printout may not be correct',,ICON:EXCLAMATION, |
              BUTTON:OK,BUTTON:OK)
    END
    GET(ReportQueue,QCounter)                     !Reactivate the current
                                                  ! record

!-----------------------------
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.PayAttyfeescosts   PROCEDURE(string ObligationType, long ObligationCount = -1)
!--------------------------
RTN:CurrentObligationTotals     &GLO:TotalsGroupType
PCounter                        LONG
  CODE
    
    IF ObligationCount = 0 
      RETURN
    END
    
    !Nikita - Added below code
    IF ObligationCount = -1
      PCounter = QCOUNTER
    ELSE
      PCounter = ObligationCount
    END
    !Nikita - End
    
    DebugCL.Send('1. PayAttyfeescosts - Start ObligationType: ' & ObligationType & ', PCounter: ' & PCounter)
    
    IF ~PBalance then RETURN.                     !Exit if all of the pmt has
    
    GET(ReportQueue,PCounter)                   ! been applied
    RTN:CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    IF ~RPQ:Attyfeescosts 
      DebugCL.Send('2. PayAttyfeescosts - return ~RPQ:Attyfeescosts')
      RETURN
    END 
    
    IF RPQ:Date < RTN:CurrentObligationTotals.DateRendered 
      DebugCL.Send('3. PayAttyfeescosts - return RPQ:Date')
      RETURN
    END
    
    IF PBalance >= RPQ:Attyfeescosts              !If balance of pmt will
      RPQ:AplAtty = RPQ:Attyfeescosts             ! will pay off confirmed obligation
      PBalance -= RPQ:Attyfeescosts               ! reduce pmt balance
      !Nikita - Added to fix Payment history 
      RPQ:AmountP += RPQ:Attyfeescosts
      !Nikita - END
      RPQ:Attyfeescosts = 0                       ! and set confirmed obligation to 0
    ELSE                                          !If balance won't pay int
      RPQ:AplAtty = PBalance                      ! reduce bal of interest
      RPQ:Attyfeescosts -= PBalance               ! set balance to 0
      !Nikita - Added to fix Payment history 
      RPQ:AmountP += PBalance
      !Nikita - END
      PBalance = 0                                !
    END 
    DebugCL.Send('4. PayAttyfeescosts - RPQ:AplAtty: ' & RPQ:AplAtty & ', RPQ:Attyfeescosts: ' & RPQ:Attyfeescosts & ', PBalance: ' & PBalance)
                                           !In both of the above, we
                                                  ! stored how much applied was
                                                  ! applied to unconfirmed obl
                                                  ! in AplUobl
    PUT(ReportQueue)
    GET(ReportQueue,QCounter)                     !Reactivate the current
                                                  ! record
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.AttyfeesIntCalc    PROCEDURE(STRING ObligationType, long ObligationCount = -1)
CurrentObligationTotals         &GLO:TotalsGroupType
PCounter                        LONG
  CODE
    IF ObligationCount = 0 
      RETURN
    END
    
    !Nikita - Added below code
    IF ObligationCount = -1
      PCounter = QCOUNTER
    ELSE
      PCounter = ObligationCount
    END
    !Nikita - End
    DebugCL.Send('1. Atty feesIntCalc START' )
    GET(ReportQueue,PCounter)
    CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    
    DebugCL.Send('2. Atty feesIntCalc START AttyfeescostsBalance: ' & CurrentObligationTotals.AttyfeescostsBalance & ', DateRendered: ' & Format(CurrentObligationTotals.DateRendered,@d2)  )
    DebugCL.Send('3. Atty feesIntCalc RPQ:DATE: ' & format(RPQ:DATE,@d2))
    IF CurrentObligationTotals.AttyfeescostsBalance <= 0
      RETURN
    END
    
    IF RPQ:DATE <= CurrentObligationTotals.DateRendered                !Actually had a customer who called and had
      RETURN                                         ! a judgment that was later than the first
    END                                            ! obligation - this addresses that

    IF PCounter = 1                                !If this is the first record
      DebugCL.Send('4. Atty feesIntCalc inside PCounter = 1 ')
      CurrentObligationTotals.CompoundBalanceAtty = 0
      CurrentObligationTotals.AttyfeescostsIntBalance=0
      GLO:Totals:AttyfeescostsIntBalance=0
      IF CLIP(ATT:InterestType)='COMPOUND'
        DO FirstCompoundAtty                       !If want to compound, this handles all
                                                   ! confirmed interest from the date of
                                                   ! judgement to the date of the first rec
                                                   ! CurrentObligationTotals.ConfirmedLastDate and LOC:CompoundBalanceAtty
                                                   ! are set in the FirstCompound routine
      END
    ELSE                                                       !If not the first record
      DebugCL.Send('5. Atty feesIntCalc inside PCounter = 1 ')
      IF CLIP(ATT:InterestType)='COMPOUND' and RPQ:Date |            !If it's been a year since compounding
        - CurrentObligationTotals.LastCompoundDateAtty >= 365                      ! and the user wants to compound, this
        DebugCL.Send('6. Atty feesIntCalc - Calculate Compound')
                                                               ! routine will calculate interest up to
        SELF.CompoundInterestAtty(PCounter)                                ! the date where interest is compounded
                                                               ! and then set the following variables:
                                                               !  CurrentObligationTotals.ConfirmedLastDate
                                                               !  GLO:ConfirmedInterestBalance
        GET(ReportQueue,PCounter)
        CurrentObligationTotals.AttyfeescostsBalance = RPQ:Attyfeescosts
        GLO:Totals:AttyfeescostsBalance = RPQ:Attyfeescosts
      ELSE
        DebugCL.Send('7. Atty feesIntCalc - Calculate simple')
        !GET(ReportQueue,QCounter-1)
        !Nikita - Modified below parameters
        !Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType))
        Util.GetPreviousReportQueueObligationType(UPPER(RPQ:ObligationType), PCounter, FALSE)
        !Nikita - End
        IF ERRORCODE()
          MESSAGE('ERROR calculating interest on attorney''s fees and costs interest.'|
            & ' The printout may not be correct',,ICON:EXCLAMATION, |
            BUTTON:OK,BUTTON:OK)
          RETURN
        END
        DebugCL.Send('7. Atty feesIntCalc - RPQ:Date: ' & format(RPQ:Date,@d2) & ', RPQ:Attyfeescosts: ' & RPQ:Attyfeescosts )
        CurrentObligationTotals.ConfirmedLastDate = RPQ:Date
        CurrentObligationTotals.AttyfeescostsBalance = RPQ:Attyfeescosts
        CurrentObligationTotals.AttyfeescostsIntBalance = RPQ:AttyfeescostsInt
        
        GLO:Totals:ConfirmedLastDate = RPQ:Date
        GLO:Totals:AttyfeescostsBalance = RPQ:Attyfeescosts
        GLO:Totals:AttyfeescostsIntBalance = RPQ:AttyfeescostsInt
      END
    END

    GET(ReportQueue,PCounter)
    RPQ:AttyfeescostsInt = CurrentObligationTotals.AttyfeescostsIntBalance          
                                                                ! is the balance from the last
                                                                ! record
    RPQ:Attyfeescosts = CurrentObligationTotals.AttyfeescostsBalance   !MA CHANGED TO WRITE BACK TO RECORD'S FIELD BECAUSE WE UPDATE BANLANCE  7/16/01
    
    CurrentObligationTotals.DailyRate = ((CurrentObligationTotals.CompoundBalanceAtty +                        |
    CurrentObligationTotals.AttyfeescostsBalance) * ATT:InterestRate) / 365
    CurrentObligationTotals.Days = RPQ:Date - CurrentObligationTotals.ConfirmedLastDate
    CurrentObligationTotals.NewInterest = CurrentObligationTotals.DailyRate * CurrentObligationTotals.Days

    IF CurrentObligationTotals.NewInterest > 0
      RPQ:AttyfeescostsInt += CurrentObligationTotals.NewInterest
    END
    PUT(ReportQueue)                              !Save the changes so far
    IF ERRORCODE()
      MESSAGE('ERROR saving interest calculation on unconfirmed interest.'|
        & ' The printout may not be correct.',,ICON:EXCLAMATION, |
        BUTTON:OK,BUTTON:OK)
    END
    GET(ReportQueue,QCounter)                     !Reactivate the current
    
Calculator.AttyfeesIntPay    PROCEDURE(STRING ObligationType, long ObligationCount = -1)
CurrentObligationTotals         &GLO:TotalsGroupType
PQCount     LONG
  CODE
    IF ObligationCount = 0 
      RETURN
    END
    
    IF ObligationCount = -1
      PQCount = QCOUNTER
    ELSE
      PQCount = ObligationCount
    END
    DebugCL.Send('Attyfees Int Pay for  PQCount: ' & PQCount)
    
    GET(ReportQueue, PQCount)
    CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    IF ~PBalance 
        RETURN                     !Exit if all of the pmt has
    END                          !been applied
    
    IF RPQ:AttyfeescostsInt = 0  !If no interest due then nothing to pay
       RETURN
    END  
                                              
    IF PBalance  
     DebugCL.Send('Nikita - Attyfees Int Pay for  PBalance ' & PBalance & ', RPQ:AttyfeescostsInt: ' & RPQ:AttyfeescostsInt )
      IF PBalance >= RPQ:AttyfeescostsInt         !If balance of pmt will
        PBalance -= RPQ:AttyfeescostsInt          ! will pay off this int
        
        !Nikita - TODO
        !RPQ:AplAttyInt = RPQ:AttyfeescostsInt     ! save amount paid
        RPQ:AplAttyInt += RPQ:AttyfeescostsInt  
        !Nikita - END
        
        !Nikita - Added to fix Payment history 
        RPQ:AmountP += RPQ:AttyfeescostsInt
        !Nikita - END
        RPQ:AttyfeescostsInt = 0                  ! and set balance at 0
      ELSE                                        !If won' pay off the interest
        RPQ:AttyfeescostsInt -= PBalance          ! reduce the interest balance by the payment left
        
        !Nikita - TODO
        !RPQ:AplAttyInt = PBalance                 ! store the amount applied
        RPQ:AplAttyInt += PBalance                 
        !Nikita - END
        
        !Nikita - Added to fix Payment history 
        RPQ:AmountP += PBalance
        !Nikita - END
        PBalance = 0                              ! then set the payment left to 0
      END
    END  

    IF RPQ:AttyfeescostsInt < CurrentObligationTotals.CompoundBalanceAtty  !As obligor pays off interest, if he pays off
      CurrentObligationTotals.CompoundBalanceAtty = RPQ:AttyfeescostsInt   ! all that has accrued this year, this makes sure
    END                                                ! that the compounded interest is paid off as he
                                                       ! makes further payments
    PUT(ReportQueue)                              !Save the changes so far
    IF ERRORCODE()
      MESSAGE('ERROR saving interest calculation on attorney''s fees and costs interest.'|
              & ' The printout may not be correct',,ICON:EXCLAMATION, |
              BUTTON:OK,BUTTON:OK)
    END    
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.PayConfirmedObl    PROCEDURE(string ObligationType, long ObligationCount = -1)
CurrentObligationTotals         &GLO:TotalsGroupType
PCounter                    LONG
  CODE
    !Nikita - Added below code
    IF ObligationCount = -1
      PCounter = QCOUNTER
    ELSE
      PCounter = ObligationCount
    END
    !Nikita - End
    
    DebugCL.Send('1 PCON PBalance: ' & PBalance)
    IF ~PBalance then RETURN.                     !Exit if all of the pmt has

    DebugCL.Send('2 PCON PCounter ' & PCounter)
    GET(ReportQueue,PCounter)                   ! been applied
    CurrentObligationTotals &= (Util.GetObligationTotals(UPPER(RPQ:ObligationType))) 
    DebugCL.Send('3 PCON RPQ:Cobl: ' & RPQ:Cobl)
    IF ~RPQ:Cobl THEN RETURN.                         !Exit if no confirmed obl
    DebugCL.Send('4 PCON RPQ:Date: ' & RPQ:Date & ', CurrentObligationTotals.DateRendered: ' & CurrentObligationTotals.DateRendered)
    IF RPQ:Date < CurrentObligationTotals.DateRendered THEN RETURN.    !If judgment was after first obligation or pmt

    DebugCL.Send('5 PCON')
    IF PBalance >= RPQ:Cobl                       !If balance of pmt will
      DebugCL.Send('6 PCON RPQ:Cobl: ' & RPQ:Cobl)
      RPQ:AplCobl = RPQ:Cobl                      ! will pay off confirmed obligation
      PBalance -= RPQ:Cobl                        ! reduce pmt balance
      !Nikita - Added to fix Payment history 
      RPQ:AmountP += RPQ:Cobl
      !Nikita - End
      RPQ:Cobl = 0                                ! and set confirmed obligation to 0
      DebugCL.Send('7 PCON: RPQ:AplCobl: ' & RPQ:AplCobl & ', PBalance: ' & PBalance & ', RPQ:Cobl: ' & RPQ:Cobl)
    ELSE                                          !If balance won't pay int
      DebugCL.Send('8 PCON RPQ:Cobl: ' & RPQ:Cobl)
      RPQ:AplCobl = PBalance                      ! reduce bal of interest
      RPQ:Cobl -= PBalance                        ! set balance to 0
      !Nikita - Added to fix Payment history 
      RPQ:AmountP += PBalance
      !Nikita - End
      PBalance = 0                                !
      DebugCL.Send('9 PCON: RPQ:AplCobl: ' & RPQ:AplCobl & ', PBalance: ' & PBalance & ', RPQ:Cobl: ' & RPQ:Cobl)
    END                                            !In both of the above, we
                                                  ! stored how much applied was
                                                  ! applied to unconfirmed obl
                                                  ! in AplUobl
    DebugCL.Send('10 PCON RPQ:AplCobl: ' & RPQ:AplCobl & ', RPQ:AplUobl: ' & RPQ:AplUobl & ', Pointer: ' & POINTER(ReportQueue) )
    PUT(ReportQueue)
    GET(ReportQueue,QCounter)                     !Reactivate the current
                                                  ! record
[SOURCE]
PROPERTY:BEGIN
PRIORITY 50
PROPERTY:END
Calculator.ProcessPayment   PROCEDURE(BYTE After2010)
loc:CurrentObligationType     String(7)
LOC:SaveDate                  LONG
Loc:IsProcessBack30           BYTE 
LOC:ChildPointer              LONG
LOC:MedicalPointer            LONG
LOC:DentalPointer             LONG
LOC:ProcessForChild           BYTE
LOC:ProcessForMed             BYTE
LOC:ProcessForDen             BYTE

!----------------------------------------- 
  CODE
    !Nikita - reset local variables
    Loc:IsProcessBack30 = FALSE
    LOC:ProcessForChild = FALSE
    LOC:ProcessForMed = FALSE
    LOC:ProcessForDen = FALSE
    
    LOC:ChildPointer = 0
    LOC:MedicalPointer = 0
    LOC:DentalPointer = 0
    !Nikita - End
    
    
  !This is the new payment applying priority
    DebugCL.Send('1 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance & ', IsContinueToPayment: ' & IsContinueToPayment & ', After2010: ' & After2010  )
    GET(ReportQueue,QCOUNTER)
    DebugCL.Send('2 PP')
    loc:CurrentObligationType = RPQ:ObligationType
    DebugCL.Send('3 PP loc:CurrentObligationType: ' & loc:CurrentObligationType)
    PBalance += RPQ:AmountP                            !This holds a running
                                                       ! total of how much
                                                       ! of the payment has
                                                        ! not been applied

    DebugCL.Send('4 PP PBalance: ' & PBalance & ', RPQ:AmountP: ' & RPQ:AmountP & ', QCOUNTER: ' & QCOUNTER)
  
    !Nikita - TO stop processing for dummy row
    IF RPQ:dummybyte = 1
      !Nikita - Added to manage Pbalance
      IF PBalance AND Util.IsDummyRow('Child') = TRUE AND Util.IsDummyRow('Medical') = TRUE AND Util.IsDummyRow('Dental') = TRUE
        RPQ:AmountP = PBalance
        PBalForPaymentOnly += PBalance !Added on 27 Jan 22
        RPQ:Uobl = 0 - PBalForPaymentOnly 
        RPQ:AplUobl = 0 - PBalance 
        PUT(ReportQueue)
        PBalance = 0 
      END
      !Nikita - End
      RETURN
    END
    !Nikita - END
    
    DebugCL.Send('5 PP Process Start')
    !IF IsContinueToPayment = FALSE
    IF UPPER(loc:CurrentObligationType) = 'CHILD'
      self.PayCurrentOblBefore('CHILD', QCOUNTER, FALSE)  !First, pay current obligations
      self.PayCurrentOblAfter('CHILD', loc:month, loc:year, Glo:Calcdate, QCOUNTER)
      
      !Nikita - Added below condition to check if Medical and dental rows are dummy
      DebugCL.Send('5.1 PP Check for dummy row')
      IF Util.IsDummyRow('Medical') AND Util.IsDummyRow('Dental') THEN
        DebugCL.Send('5.2 PP Inside for dummy row')
        Loc:IsProcessBack30 = TRUE
        LOC:ChildPointer = QCOUNTER
      END
      !Nikita - End
    END
    
    !IF IsContinueToPayment = TRUE AND UPPER(loc:CurrentObligationType) = 'MEDICAL'
    IF UPPER(loc:CurrentObligationType) = 'MEDICAL'
      DebugCL.Send('6 PP QCOUNTER: ' & QCOUNTER  & ', PBalance: ' & PBalance)
      self.PayCurrentOblBefore('MEDICAL', QCOUNTER, FALSE)  !First, pay current obligations
      self.PayCurrentOblAfter('MEDICAL', loc:month, loc:year, Glo:Calcdate, QCOUNTER)
!      self.PayCurrentOblBack30('MEDICAL', QCOUNTER)
      DebugCL.Send('6.1 PP END PBalance: ' & PBalance)
 
     !Nikita - Added below condition to check if Medical and dental rows are dummy
      IF Util.IsDummyRow('Dental') THEN
        Loc:IsProcessBack30 = TRUE
        LOC:MedicalPointer = QCOUNTER
        IF Util.IsDummyRow('Child') THEN
          LOC:ChildPointer = 0
        ELSE
          LOC:ChildPointer = QCOUNTER - 1
        END
      END
      !Nikita - End
    END
    
    !IF IsContinueToPayment = TRUE AND UPPER(loc:CurrentObligationType) = 'DENTAL'
    IF UPPER(loc:CurrentObligationType) = 'DENTAL'
      DebugCL.Send('7 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
      self.PayCurrentOblBefore('DENTAL', QCOUNTER, FALSE)  !First, pay current obligations
      self.PayCurrentOblAfter('DENTAL', loc:month, loc:year, Glo:Calcdate, QCOUNTER )
!      self.PayCurrentOblBack30('DENTAL', QCOUNTER )
      DebugCL.Send('8.1 PP END PBalance: ' & PBalance)
      Loc:IsProcessBack30 = TRUE
      
      IF Util.IsDummyRow('Child') THEN
        LOC:ChildPointer = 0
      ELSE
        LOC:ChildPointer = QCOUNTER - 2
      END
      IF Util.IsDummyRow('Medical') THEN
        LOC:MedicalPointer = 0
      ELSE
        LOC:MedicalPointer = QCOUNTER - 1
      END
      
      LOC:DentalPointer = QCOUNTER
    END
    !Nikita Added additional condition - FOR BACK30
   
!    LOC:ChildPointer = QCOUNTER - 2
!    LOC:MedicalPointer = QCOUNTER - 1
!    LOC:DentalPointer = QCOUNTER
    
    IF Loc:IsProcessBack30 = TRUE  AND LOC:ChildPointer > 0
      DebugCL.Send('10 PP lookback 30 for CHILD QCOUNTER: ' & LOC:ChildPointer)
      self.PayCurrentOblBack30('CHILD', LOC:ChildPointer)
      DebugCL.Send('10.1 PP END PBalance: ' & PBalance)
      DebugCL.Send('10.2 PP END PBalance: ' & PBalance)
      LOC:ProcessForChild = TRUE !Nikita added to manage UINTNew calculation
    END
    
    IF Loc:IsProcessBack30 = TRUE AND LOC:MedicalPointer > 0
      DebugCL.Send('11 PP lookback 30 for MEDICAL QCOUNTER: ' & LOC:MedicalPointer)
      self.PayCurrentOblBack30('MEDICAL', LOC:MedicalPointer)
      DebugCL.Send('11.1 PP END PBalance: ' & PBalance)
      DebugCL.Send('11.2 PP END PBalance: ' & PBalance)
      LOC:ProcessForMed = TRUE !Nikita added to manage UINTNew calculation
    END
    
    IF Loc:IsProcessBack30 = TRUE AND LOC:DentalPointer > 0
      DebugCL.Send('12 PP lookback 30 for DENTAL QCOUNTER: ' & LOC:DentalPointer)
      self.PayCurrentOblBack30('DENTAL', LOC:DentalPointer )
      DebugCL.Send('12.1 PP END PBalance: ' & PBalance)

      DebugCL.Send('12.2 PP END PBalance: ' & PBalance)
      LOC:ProcessForDen = TRUE !Nikita added to manage UINTNew calculation
    END
    !Nikita - End
    
    DebugCL.Send('16 PP QCOUNTER: ' & QCOUNTER & ', After2010: ' & After2010)
    IF After2010 
      !Calculate unconfirmed and confirmed interest before paying delinquent
      DebugCL.Send('17 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
      !DO UintCal     !Calc unconfirmed interest
      IF LOC:ProcessForChild = TRUE
        SELF.UIntNew(LOC:ChildPointer)
        SELF.CIntNew(LOC:ChildPointer)
      END
      IF LOC:ProcessForMed = TRUE
        SELF.UIntNew(LOC:MedicalPointer)
        SELF.CIntNew(LOC:MedicalPointer)
      END
      IF LOC:ProcessForDen = TRUE
        SELF.UIntNew(LOC:DentalPointer)
        SELF.CIntNew(LOC:DentalPointer)
      END
      DebugCL.Send('18 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
      !DO CintCal     !Calc confirmed interest
      !DO Cint
    ELSE
      DebugCL.Send('19 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
      !DO Uint                                   !Calc and Pay Unconfirmed interest
      IF LOC:ProcessForChild = TRUE
        SELF.UIntNew(LOC:ChildPointer)
        SELF.CIntNew(LOC:ChildPointer)
      END
      IF LOC:ProcessForMed = TRUE
        SELF.UIntNew(LOC:MedicalPointer)
        SELF.CIntNew(LOC:MedicalPointer)
      END
      IF LOC:ProcessForDen = TRUE
        SELF.UIntNew(LOC:DentalPointer)
        SELF.CIntNew(LOC:DentalPointer)
      END
      DebugCL.Send('20 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
      !DO Cint                                   !Calc and Pay Confirmed interest
    END
    DebugCL.Send('21 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
    
    !Pay delinquent (unconfirmed) obl
    IF Loc:IsProcessBack30 = TRUE AND PBalance AND LOC:ChildPointer > 0                              !If there's a credit balance
      DebugCL.Send('22 PP QCOUNTER: ' & LOC:ChildPointer & ', PBalance: ' & PBalance)
      self.PayDelinquentObl('CHILD', LOC:ChildPointer)
      Loc:IsProcessBack30 = TRUE
    END
    
    IF Loc:IsProcessBack30 = TRUE AND PBalance AND LOC:MedicalPointer > 0                              !If there's a credit balance
      DebugCL.Send('24 PP QCOUNTER: ' & LOC:MedicalPointer & ', PBalance: ' & PBalance)
      self.PayDelinquentObl('MEDICAL', LOC:MedicalPointer)
      Loc:IsProcessBack30 = TRUE
    END
    
    IF Loc:IsProcessBack30 = TRUE AND PBalance AND LOC:DentalPointer > 0                             !If there's a credit balance
      DebugCL.Send('26 PP QCOUNTER: ' & QCOUNTER  & ', PBalance: ' & PBalance)
      self.PayDelinquentObl('DENTAL', LOC:DentalPointer)
      Loc:IsProcessBack30 = TRUE
    END
    DebugCL.Send('27 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)

    !Pay confirmed obl
    DebugCL.Send('28 PBalance before PayConfirmedObl: ' & PBalance & ', QCOUNTER: ' & QCOUNTER)
    IF Loc:IsProcessBack30 = TRUE AND PBalance                               !If there's a credit balance
      DebugCL.Send('29 PP QCOUNTER: ' & LOC:ChildPointer & ', PBalance: ' & PBalance)
      IF LOC:ChildPointer > 0  
        SELF.PayConfirmedObl('CHILD', LOC:ChildPointer )
      END
      
      DebugCL.Send('30 PP QCOUNTER: ' & LOC:MedicalPointer & ', PBalance: ' & PBalance)
      IF LOC:MedicalPointer > 0
        SELF.PayConfirmedObl('MEDICAL', LOC:MedicalPointer)
      END
      
      DebugCL.Send('31 PP QCOUNTER: ' & LOC:DentalPointer  & ', PBalance: ' & PBalance)
      IF LOC:DentalPointer > 0 
        SELF.PayConfirmedObl('DENTAL', LOC:DentalPointer)
      END
      
      Loc:IsProcessBack30 = TRUE
    END
    DebugCL.Send('32 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
    !Nikita - Removed PBALANCE condition as need to calculate attFee etc in all the conditions
    !IF Loc:IsProcessBack30 = TRUE AND PBalance
    IF Loc:IsProcessBack30 = TRUE
      IF After2010 
          
          !Calculate Attorney fees interest before paying Attorney fees
          SELF.AttyfeescostsInt('CHILD', LOC:ChildPointer)
          DebugCL.Send('36 PP QCOUNTER: ' & LOC:ChildPointer & ', PBalance: ' & PBalance)
          
          self.AttyfeescostsInt('MEDICAL', LOC:MedicalPointer)
          DebugCL.Send('37 PP QCOUNTER: ' & LOC:MedicalPointer & ', PBalance: ' & PBalance)
          
          self.AttyfeescostsInt('DENTAL', LOC:DentalPointer  )
          DebugCL.Send('38 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
          !Pay Attorney fees
          self.PayAttyfeescosts('CHILD', LOC:ChildPointer)
          DebugCL.Send('39 PP QCOUNTER: ' & LOC:ChildPointer & ', PBalance: ' & PBalance)
          
          self.PayAttyfeescosts('MEDICAL', LOC:MedicalPointer)
          DebugCL.Send('40 PP QCOUNTER: ' & LOC:MedicalPointer & ', PBalance: ' & PBalance)
          
          self.PayAttyfeescosts('DENTAL', LOC:DentalPointer )
          DebugCL.Send('41 PP QCOUNTER: ' & LOC:DentalPointer & ', PBalance: ' & PBalance)
          
!!          !Pay interest
!!          self.AttyfeesIntPay('CHILD', LOC:ChildPointer)
!!          DebugCL.Send('42 PP QCOUNTER: ' & LOC:ChildPointer & ', PBalance: ' & PBalance)
!!          
!!          self.AttyfeesIntPay('MEDICAL', LOC:MedicalPointer)
!!          DebugCL.Send('43 PP QCOUNTER: ' & LOC:MedicalPointer & ', PBalance: ' & PBalance)
!!          self.AttyfeesIntPay('DENTAL', LOC:DentalPointer )
          
        ELSE
          !Pay interest of unconfirmed and confirmed
          !Nikita -Need to pay first for child and medical and then dental
          DebugCL.Send('33 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
!          DO UintPay                                !Pay Unconfirmed interest
          self.UIntPayNew(LOC:ChildPointer)                                !Pay Unconfirmed interest
          self.UIntPayNew(LOC:MedicalPointer)                                !Pay Unconfirmed interest
          self.UIntPayNew(LOC:DentalPointer)                                !Pay Unconfirmed interest
          DebugCL.Send('34 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
!          DO CintPay                                !Pay Confirmed interest
          self.CIntPayNew(LOC:ChildPointer)
          self.CIntPayNew(LOC:MedicalPointer)
          self.CIntPayNew(LOC:DentalPointer)
          DebugCL.Send('35 PP QCOUNTER: ' & QCOUNTER & ', PBalance: ' & PBalance)
          !Nikita - END
          DebugCL.Send('4. Nikita - From ProcessPayment')
          DebugCL.Send('44 PP QCOUNTER: ' & LOC:ChildPointer & ', PBalance: ' & PBalance)
          SELF.AttyfeescostsInt('CHILD', LOC:ChildPointer)
          IF PBalance               !MA ADDED TO PAY ATTORNEY'S FEES AND COSTS  6/25/01
            DebugCL.Send('45 PP QCOUNTER: ' & LOC:ChildPointer & ', PBalance: ' & PBalance)
            SELF.PayAttyfeescosts('CHILD', LOC:ChildPointer)
          END
          
          DebugCL.Send('46 PP QCOUNTER: ' & LOC:MedicalPointer & ', PBalance: ' & PBalance)
          SELF.AttyfeescostsInt('MEDICAL', LOC:MedicalPointer)
          IF PBalance               !MA ADDED TO PAY ATTORNEY'S FEES AND COSTS  6/25/01
            DebugCL.Send('47 PP QCOUNTER: ' & LOC:MedicalPointer & ', PBalance: ' & PBalance)
            SELF.PayAttyfeescosts('MEDICAL', LOC:MedicalPointer)
          END
          
          DebugCL.Send('48 PP QCOUNTER: ' & LOC:DentalPointer  & ', PBalance: ' & PBalance)
          SELF.AttyfeescostsInt('DENTAL', LOC:DentalPointer)
          IF PBalance               !MA ADDED TO PAY ATTORNEY'S FEES AND COSTS  6/25/01
            DebugCL.Send('49 PP QCOUNTER: ' & LOC:DentalPointer  & ', PBalance: ' & PBalance)
            SELF.PayAttyfeescosts('DENTAL', LOC:DentalPointer )
          END
          
          DebugCL.Send('50 PP QCOUNTER: ' & LOC:DentalPointer & ', PBalance: ' & PBalance)
          
          !Nkikita - Added condition TODO
          !Pay interest
          self.AttyfeesIntPay('CHILD', LOC:ChildPointer)
          
          self.AttyfeesIntPay('MEDICAL', LOC:MedicalPointer)
                   
          self.AttyfeesIntPay('DENTAL', LOC:DentalPointer )
          !Nikita -End
        END
      
      DebugCL.Send('51 PP LOC:ChildPointer: ' & LOC:ChildPointer & ', LOC:MedicalPointer: ' & LOC:MedicalPointer & ', LOC:DentalPointer: ' & LOC:DentalPointer )
      
      IF Util.IsDummyRow('Child') = FALSE THEN 
        DebugCL.Send('52 PP Child is not dummy')
        util.SyncPayments(LOC:ChildPointer)
      ELSIF Util.IsDummyRow('Child') = TRUE AND Util.IsDummyRow('Medical') = FALSE
        DebugCL.Send('52 PP Child is dummy but Medical is not dummy')
        util.SyncPayments(LOC:MedicalPointer)
      ELSIF Util.IsDummyRow('Child') = TRUE AND Util.IsDummyRow('Medical') = TRUE AND Util.IsDummyRow('Dental') = FALSE
        DebugCL.Send('52 PP Child is dummy, Medical is dummy but Dental is not dummy')
        util.SyncPayments(LOC:DentalPointer)
      END 
  END
    
    
