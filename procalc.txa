ExplanationDetail6000 DETAIL,AT(10,10,7490,5313),USE(?DETAIL3),PAGEBEFORE(-1),#ORDINAL(168)
              STRING('HOW CHILD SUPPORT CALCULATOR CALCULATES CHILD SUPPORT OBLIGATIONS'), |
                AT(1052,104),USE(?String124),FONT(,,,FONT:bold),CENTER,#ORIG(?String124),#ORDINAL(169)
              STRING('Child Support Calculator applies the guidelines found in Chapter ' & |
                '154, Subchapter C (Sec 154.121 et seq)'),AT(604,563),USE(?String125),#ORIG(?String125), |
                #ORDINAL(170)
              STRING('of the Texas Family Code. It performs the following steps:'),AT(604, |
                740),USE(?String126),#ORIG(?String126),#ORDINAL(171)
              STRING('1.  Calculate net monthly income by multiplying the gross monthly' & |
                ' income by the appropriate'),AT(615,990,6240,208),USE(?String127),#ORIG(?String127), |
                #ORDINAL(172)
              STRING('percentage found in the Attorney General''s promulgated tax chart' & |
                '. This chart is authorized in'),AT(823,1156),USE(?String128),#ORIG(?String128), |
                #ORDINAL(173)
              STRING('Section 154.061 and is used to deduct a standard amount for socia' & |
                'l security and income taxes.'),AT(823,1323),USE(?String129),TRN,#ORIG(?String129), |
                #ORDINAL(174)
              STRING('2.  Net resources are calculated by the following steps (Sec. 154.062):'), |
                AT(615,1542),USE(?String130),#ORIG(?String130),#ORDINAL(175)
              STRING('a.  add non-taxable income;'),AT(823,1719),USE(?String131),#ORIG(?String131), |
                #ORDINAL(176)
              STRING('b.  deduct monthly expenses for health insurance coverage for obl' & |
                'igor''s children;'),AT(823,1875),USE(?String132),TRN,#ORIG(?String132),#ORDINAL(177)
              STRING('c.  deduct any monthly amount for union dues;'),AT(823,2042),USE(?String133), |
                #ORIG(?String133),#ORDINAL(178)
              STRING('d.  deduct any amounts for state income tax; and'),AT(823,2198),USE(?String134), |
                #ORIG(?String134),#ORDINAL(179)
              STRING('e.  deduct any amounts you want to argue to the judge that should' & |
                ' be considered under Section 154.123.'),AT(823,2344),USE(?String135),TRN, |
                #ORIG(?String135),#ORDINAL(180)
              STRING('4.  Calculate obligor''s support obligation by multiplying adjust' & |
                'ed net resources by the percentages found'),AT(615,3021),USE(?String136), |
                TRN,#ORIG(?String136),#ORDINAL(181)
              STRING('in Sec.154.125.  This section provides different percentages for ' & |
                'different numbers of children.'),AT(823,3198),USE(?String137),#ORIG(?String137), |
                #ORDINAL(182)
              STRING('3.  If obligor is obligated  to support children in more than one' & |
                ' household, then the adjustments'),AT(615,2604,6292,208),USE(?String138), |
                #ORIG(?String138),#ORDINAL(183)
              STRING('provided in Section 154.128 are applied to calculate adjusted net' & |
                ' resources.'),AT(823,2771,5792,208),USE(?String139),#ORIG(?String139),#ORDINAL(184)
              STRING('5.  If the child(ren) are receiving disability income, then, as p' & |
                'rovided in Section 154.132, the amount of that'),AT(625,3469),USE(?String158), |
                TRN,#ORIG(?String158),#ORDINAL(185)
              STRING('disability income is deducted from the monthly support obligation.'), |
                AT(813,3656),USE(?String159),TRN,#ORIG(?String159),#ORDINAL(186)
              STRING('6.  If the child(ren) are receiving Social Security Old Age benef' & |
                'its, then, as provided in Section 154.133, the'),AT(625,3938),USE(?String166), |
                TRN,#ORIG(?String166),#ORDINAL(187)
              STRING('amount of those benefits is deducted from the monthly support obligation.'), |
                AT(813,4125),USE(?String167),TRN,#ORIG(?String167),#ORDINAL(188)
              STRING('NOTE - Section 154.125 provides that the child support guidelines' & |
                ' apply only if the obligor''s monthly net'),AT(604,4646),USE(?String140), |
                #ORIG(?String140),#ORDINAL(189)
              STRING('resources are $6,000.00 or less.  Section 154.126 contains instru' & |
                'ctions for situations where resources'),AT(604,4813),USE(?String141),#ORIG(?String141), |
                #ORDINAL(190)
              STRING('exceed $6,000.00.'),AT(604,4990),USE(?String142),#ORIG(?String142),#ORDINAL(191)
            END
