@page
@using ProCalc.Core.Domain
@model ProCalc.Web.Pages.Customers.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}
<h2>Customers</h2>
<p><a class="btn btn-primary" asp-page="Create">New Customer</a></p>
<table class="table table-striped">
<thead><tr><th>Code</th><th>Name</th><th>Email</th><th>Phone</th><th></th></tr></thead>
<tbody>
@foreach (var c in Model.Customers)
{
    <tr>
        <td>@c.Code</td>
        <td>@c.Name</td>
        <td>@c.Email</td>
        <td>@c.Phone</td>
        <td>
            <a class="btn btn-sm btn-secondary" asp-page="Edit" asp-route-id="@c.Id">Edit</a>
            <a class="btn btn-sm btn-danger" asp-page="Delete" asp-route-id="@c.Id">Delete</a>
        </td>
    </tr>
}
</tbody>
</table>
