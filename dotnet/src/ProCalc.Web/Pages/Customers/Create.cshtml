@page
@model ProCalc.Web.Pages.Customers.CreateModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}
<h2>New Customer</h2>
<form method="post">
    <div class="mb-3"><label class="form-label">Code</label><input asp-for="Customer.Code" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Name</label><input asp-for="Customer.Name" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Email</label><input asp-for="Customer.Email" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Phone</label><input asp-for="Customer.Phone" class="form-control" /></div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-page="Index">Cancel</a>
</form>
